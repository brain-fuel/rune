-- Chapter 273 — a constant-folding optimizer, proven correct (proven tier, metatheory).
--
-- The canonical verified-compiler-pass theorem: an optimizer `fold` that collapses
-- constant subexpressions preserves the evaluation result for EVERY expression. It is
-- built from "smart constructors" (addSmart/mulSmart) that fold two literals into one, each
-- proven to preserve the value; `fold` recurses with them and its correctness follows by
-- structural induction. Proof-only.
--
--   foldCorrect : (e : Expr) -> Eq Nat (eval (fold e)) (eval e)

data Nat : U is
  zero : Nat
| succ : Nat -> Nat
end
builtin nat Nat zero succ

-- (Eq / refl / subst are ambient, as in ch03.)

cong : (A : U) -> (B : U) -> (f : A -> B) -> (x : A) -> (y : A) -> Eq A x y -> Eq B (f x) (f y) is
  fn (A : U) (B : U) (f : A -> B) (x : A) (y : A) (p : Eq A x y) is
    subst A x y p (fn (z : A) is Eq B (f x) (f z) end) refl
  end
end

transEq : (A : U) -> (x : A) -> (y : A) -> (z : A) -> Eq A x y -> Eq A y z -> Eq A x z is
  fn (A : U) (x : A) (y : A) (z : A) (p : Eq A x y) (q : Eq A y z) is
    subst A y z q (fn (w : A) is Eq A x w end) p
  end
end

cong2 : (A : U) -> (B : U) -> (C : U) -> (f : A -> B -> C) ->
        (a : A) -> (a2 : A) -> (b : B) -> (b2 : B) ->
        Eq A a a2 -> Eq B b b2 -> Eq C (f a b) (f a2 b2) is
  fn (A : U) (B : U) (C : U) (f : A -> B -> C)
     (a : A) (a2 : A) (b : B) (b2 : B) (pa : Eq A a a2) (pb : Eq B b b2) is
    transEq C (f a b) (f a2 b) (f a2 b2)
      (cong A C (fn (x : A) is f x b end) a a2 pa)
      (cong B C (fn (y : B) is f a2 y end) b b2 pb)
  end
end

natAdd : Nat -> Nat -> Nat is
  fn (a : Nat) (b : Nat) is
    NatElim (fn (x : Nat) is Nat end) b (fn (k : Nat) (ih : Nat) is succ ih end) a
  end
end

natMul : Nat -> Nat -> Nat is
  fn (a : Nat) (b : Nat) is
    NatElim (fn (x : Nat) is Nat end) zero (fn (k : Nat) (ih : Nat) is natAdd b ih end) a
  end
end

data Expr : U is
  lit : Nat -> Expr
| add : Expr -> Expr -> Expr
| mul : Expr -> Expr -> Expr
end

eval : Expr -> Nat is
  fn (e : Expr) is
    ExprElim (fn (x : Expr) is Nat end)
      (fn (n : Nat) is n end)
      (fn (l : Expr) (r : Expr) (ihl : Nat) (ihr : Nat) is natAdd ihl ihr end)
      (fn (l : Expr) (r : Expr) (ihl : Nat) (ihr : Nat) is natMul ihl ihr end)
      e
  end
end

-- smart add: if both operands are literals, fold to one literal; else rebuild an add node.
addSmart : Expr -> Expr -> Expr is
  fn (a : Expr) (b : Expr) is
    ExprElim (fn (x : Expr) is Expr end)
      (fn (m : Nat) is
         ExprElim (fn (y : Expr) is Expr end)
           (fn (n : Nat) is lit (natAdd m n) end)
           (fn (bl : Expr) (br : Expr) (il : Expr) (ir : Expr) is add (lit m) (add bl br) end)
           (fn (bl : Expr) (br : Expr) (il : Expr) (ir : Expr) is add (lit m) (mul bl br) end)
           b end)
      (fn (al : Expr) (ar : Expr) (il : Expr) (ir : Expr) is add (add al ar) b end)
      (fn (al : Expr) (ar : Expr) (il : Expr) (ir : Expr) is add (mul al ar) b end)
      a
  end
end

mulSmart : Expr -> Expr -> Expr is
  fn (a : Expr) (b : Expr) is
    ExprElim (fn (x : Expr) is Expr end)
      (fn (m : Nat) is
         ExprElim (fn (y : Expr) is Expr end)
           (fn (n : Nat) is lit (natMul m n) end)
           (fn (bl : Expr) (br : Expr) (il : Expr) (ir : Expr) is mul (lit m) (add bl br) end)
           (fn (bl : Expr) (br : Expr) (il : Expr) (ir : Expr) is mul (lit m) (mul bl br) end)
           b end)
      (fn (al : Expr) (ar : Expr) (il : Expr) (ir : Expr) is mul (add al ar) b end)
      (fn (al : Expr) (ar : Expr) (il : Expr) (ir : Expr) is mul (mul al ar) b end)
      a
  end
end

-- each smart constructor preserves the value: by case on a (and on b in the lit case),
-- every branch's eval is exactly natAdd/natMul of the operand values (refl).
addSmartCorrect : (a : Expr) -> (b : Expr) -> Eq Nat (eval (addSmart a b)) (natAdd (eval a) (eval b)) is
  fn (a : Expr) (b : Expr) is
    ExprElim (fn (x : Expr) is Eq Nat (eval (addSmart x b)) (natAdd (eval x) (eval b)) end)
      (fn (m : Nat) is
         ExprElim (fn (y : Expr) is Eq Nat (eval (addSmart (lit m) y)) (natAdd m (eval y)) end)
           (fn (n : Nat) is refl end)
           (fn (bl : Expr) (br : Expr) (il : Eq Nat (eval (addSmart (lit m) bl)) (natAdd m (eval bl))) (ir : Eq Nat (eval (addSmart (lit m) br)) (natAdd m (eval br))) is refl end)
           (fn (bl : Expr) (br : Expr) (il : Eq Nat (eval (addSmart (lit m) bl)) (natAdd m (eval bl))) (ir : Eq Nat (eval (addSmart (lit m) br)) (natAdd m (eval br))) is refl end)
           b end)
      (fn (al : Expr) (ar : Expr) (il : Eq Nat (eval (addSmart al b)) (natAdd (eval al) (eval b))) (ir : Eq Nat (eval (addSmart ar b)) (natAdd (eval ar) (eval b))) is refl end)
      (fn (al : Expr) (ar : Expr) (il : Eq Nat (eval (addSmart al b)) (natAdd (eval al) (eval b))) (ir : Eq Nat (eval (addSmart ar b)) (natAdd (eval ar) (eval b))) is refl end)
      a
  end
end

mulSmartCorrect : (a : Expr) -> (b : Expr) -> Eq Nat (eval (mulSmart a b)) (natMul (eval a) (eval b)) is
  fn (a : Expr) (b : Expr) is
    ExprElim (fn (x : Expr) is Eq Nat (eval (mulSmart x b)) (natMul (eval x) (eval b)) end)
      (fn (m : Nat) is
         ExprElim (fn (y : Expr) is Eq Nat (eval (mulSmart (lit m) y)) (natMul m (eval y)) end)
           (fn (n : Nat) is refl end)
           (fn (bl : Expr) (br : Expr) (il : Eq Nat (eval (mulSmart (lit m) bl)) (natMul m (eval bl))) (ir : Eq Nat (eval (mulSmart (lit m) br)) (natMul m (eval br))) is refl end)
           (fn (bl : Expr) (br : Expr) (il : Eq Nat (eval (mulSmart (lit m) bl)) (natMul m (eval bl))) (ir : Eq Nat (eval (mulSmart (lit m) br)) (natMul m (eval br))) is refl end)
           b end)
      (fn (al : Expr) (ar : Expr) (il : Eq Nat (eval (mulSmart al b)) (natMul (eval al) (eval b))) (ir : Eq Nat (eval (mulSmart ar b)) (natMul (eval ar) (eval b))) is refl end)
      (fn (al : Expr) (ar : Expr) (il : Eq Nat (eval (mulSmart al b)) (natMul (eval al) (eval b))) (ir : Eq Nat (eval (mulSmart ar b)) (natMul (eval ar) (eval b))) is refl end)
      a
  end
end

-- the optimizer: recurse, combining with the smart constructors.
fold : Expr -> Expr is
  fn (e : Expr) is
    ExprElim (fn (x : Expr) is Expr end)
      (fn (n : Nat) is lit n end)
      (fn (l : Expr) (r : Expr) (ihl : Expr) (ihr : Expr) is addSmart ihl ihr end)
      (fn (l : Expr) (r : Expr) (ihl : Expr) (ihr : Expr) is mulSmart ihl ihr end)
      e
  end
end

-- THE CORRECTNESS THEOREM, by structural induction:
--   lit:  eval (fold (lit n)) = n = eval (lit n)                                 -> refl
--   add:  eval (fold (add l r)) = eval (addSmart (fold l) (fold r))
--         addSmartCorrect : = natAdd (eval (fold l)) (eval (fold r))
--         cong2 natAdd ihl ihr : = natAdd (eval l) (eval r) = eval (add l r)
--   mul:  symmetric with mulSmartCorrect.
foldCorrect : (e : Expr) -> Eq Nat (eval (fold e)) (eval e) is
  fn (e : Expr) is
    ExprElim (fn (x : Expr) is Eq Nat (eval (fold x)) (eval x) end)
      (fn (n : Nat) is refl end)
      (fn (l : Expr) (r : Expr) (ihl : Eq Nat (eval (fold l)) (eval l)) (ihr : Eq Nat (eval (fold r)) (eval r)) is
         transEq Nat
           (eval (addSmart (fold l) (fold r)))
           (natAdd (eval (fold l)) (eval (fold r)))
           (natAdd (eval l) (eval r))
           (addSmartCorrect (fold l) (fold r))
           (cong2 Nat Nat Nat natAdd (eval (fold l)) (eval l) (eval (fold r)) (eval r) ihl ihr) end)
      (fn (l : Expr) (r : Expr) (ihl : Eq Nat (eval (fold l)) (eval l)) (ihr : Eq Nat (eval (fold r)) (eval r)) is
         transEq Nat
           (eval (mulSmart (fold l) (fold r)))
           (natMul (eval (fold l)) (eval (fold r)))
           (natMul (eval l) (eval r))
           (mulSmartCorrect (fold l) (fold r))
           (cong2 Nat Nat Nat natMul (eval (fold l)) (eval l) (eval (fold r)) (eval r) ihl ihr) end)
      e
  end
end
