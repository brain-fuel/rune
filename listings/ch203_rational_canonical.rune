-- Chapter 203 — the canonical rational Q (QPair) with field, order, AND the integer-division engine, merged base for floorQ/to_radix. Self-contained.
data Nat : U is
  zero : Nat
| succ : Nat -> Nat
end

add : Nat -> Nat -> Nat is
  fn (m : Nat) (n : Nat) is
    NatElim (fn (x : Nat) is Nat end) n (fn (k : Nat) (ih : Nat) is succ ih end) m
  end
end

mul : Nat -> Nat -> Nat is
  fn (m : Nat) (n : Nat) is
    NatElim (fn (x : Nat) is Nat end) zero (fn (k : Nat) (ih : Nat) is add n ih end) m
  end
end

-- The equality toolkit (ch07), with implicit arguments doing the bookkeeping.

cong : {A : U} -> {B : U} -> (f : A -> B) -> {x : A} -> {y : A} -> Eq A x y -> Eq B (f x) (f y) is
  fn {A : U} {B : U} (f : A -> B) {x : A} {y : A} (p : Eq A x y) is
    subst A x y p (fn (z : A) is Eq B (f x) (f z) end) refl
  end
end

sym : {A : U} -> {x : A} -> {y : A} -> Eq A x y -> Eq A y x is
  fn {A : U} {x : A} {y : A} (p : Eq A x y) is
    subst A x y p (fn (z : A) is Eq A z x end) refl
  end
end

trans : {A : U} -> {x : A} -> {y : A} -> {z : A} -> Eq A x y -> Eq A y z -> Eq A x z is
  fn {A : U} {x : A} {y : A} {z : A} (p : Eq A x y) (q : Eq A y z) is
    subst A y z q (fn (w : A) is Eq A x w end) p
  end
end

-- ============================================================================
-- The Nat SEMIRING lemmas (ch63 / ch81), redeclared verbatim.
-- ============================================================================

addZeroR : (n : Nat) -> Eq Nat (add n zero) n is
  fn (n : Nat) is
    NatElim (fn (x : Nat) is Eq Nat (add x zero) x end)
      (refl zero)
      (fn (k : Nat) (ih : Eq Nat (add k zero) k) is
         subst Nat (add k zero) k ih
           (fn (z : Nat) is Eq Nat (add (succ k) zero) (succ z) end)
           (refl (add (succ k) zero))
       end)
      n
  end
end

addSuccR : (n : Nat) -> (m : Nat) -> Eq Nat (add n (succ m)) (succ (add n m)) is
  fn (n : Nat) (m : Nat) is
    NatElim (fn (x : Nat) is Eq Nat (add x (succ m)) (succ (add x m)) end)
      (refl (succ m))
      (fn (k : Nat) (ih : Eq Nat (add k (succ m)) (succ (add k m))) is
         subst Nat (add k (succ m)) (succ (add k m)) ih
           (fn (z : Nat) is Eq Nat (add (succ k) (succ m)) (succ z) end)
           (refl (add (succ k) (succ m)))
       end)
      n
  end
end

addAssoc : (a : Nat) -> (b : Nat) -> (c : Nat)
   -> Eq Nat (add (add a b) c) (add a (add b c)) is
  fn (a : Nat) (b : Nat) (c : Nat) is
    NatElim (fn (x : Nat) is Eq Nat (add (add x b) c) (add x (add b c)) end)
      (refl (add b c))
      (fn (k : Nat) (ih : Eq Nat (add (add k b) c) (add k (add b c))) is
         subst Nat (add (add k b) c) (add k (add b c)) ih
           (fn (z : Nat) is Eq Nat (succ (add (add k b) c)) (succ z) end)
           (refl (succ (add (add k b) c)))
       end)
      a
  end
end

addComm : (n : Nat) -> (m : Nat) -> Eq Nat (add n m) (add m n) is
  fn (n : Nat) (m : Nat) is
    NatElim (fn (x : Nat) is Eq Nat (add x m) (add m x) end)
      (subst Nat (add m zero) m (addZeroR m)
         (fn (z : Nat) is Eq Nat z (add m zero) end)
         (refl (add m zero)))
      (fn (k : Nat) (ih : Eq Nat (add k m) (add m k)) is
         subst Nat (succ (add m k)) (add m (succ k))
           (subst Nat (add m (succ k)) (succ (add m k)) (addSuccR m k)
              (fn (z : Nat) is Eq Nat z (add m (succ k)) end)
              (refl (add m (succ k))))
           (fn (z : Nat) is Eq Nat (succ (add k m)) z end)
           (subst Nat (add k m) (add m k) ih
              (fn (z : Nat) is Eq Nat (succ (add k m)) (succ z) end)
              (refl (succ (add k m))))
       end)
      n
  end
end

mulZeroR : (n : Nat) -> Eq Nat (mul n zero) zero is
  fn (n : Nat) is
    NatElim (fn (x : Nat) is Eq Nat (mul x zero) zero end)
      (refl zero)
      (fn (k : Nat) (ih : Eq Nat (mul k zero) zero) is ih end)
      n
  end
end

-- RIGHT DISTRIBUTIVITY: (a + b) * c = a*c + b*c (ch63).
mulDistR : (a : Nat) -> (b : Nat) -> (c : Nat)
   -> Eq Nat (mul (add a b) c) (add (mul a c) (mul b c)) is
  fn (a : Nat) (b : Nat) (c : Nat) is
    NatElim (fn (x : Nat) is Eq Nat (mul (add x b) c) (add (mul x c) (mul b c)) end)
      (refl (mul b c))
      (fn (k : Nat) (ih : Eq Nat (mul (add k b) c) (add (mul k c) (mul b c))) is
         subst Nat
           (add c (add (mul k c) (mul b c)))
           (add (add c (mul k c)) (mul b c))
           (subst Nat
              (add (add c (mul k c)) (mul b c))
              (add c (add (mul k c) (mul b c)))
              (addAssoc c (mul k c) (mul b c))
              (fn (z : Nat) is Eq Nat z (add (add c (mul k c)) (mul b c)) end)
              (refl (add (add c (mul k c)) (mul b c))))
           (fn (z : Nat) is Eq Nat (add c (mul (add k b) c)) z end)
           (subst Nat (mul (add k b) c) (add (mul k c) (mul b c)) ih
              (fn (z : Nat) is Eq Nat (add c (mul (add k b) c)) (add c z) end)
              (refl (add c (mul (add k b) c))))
       end)
      a
  end
end

-- MULTIPLICATIVE SUCCESSOR-SHIFT: mul n (succ m) = add (mul n m) n (ch81).
mulSuccR : (n : Nat) -> (m : Nat) -> Eq Nat (mul n (succ m)) (add (mul n m) n) is
  fn (n : Nat) (m : Nat) is
    NatElim
      (fn (x : Nat) is Eq Nat (mul x (succ m)) (add (mul x m) x) end)
      (refl zero)
      (fn (k : Nat) (ih : Eq Nat (mul k (succ m)) (add (mul k m) k)) is
         subst Nat
           (succ (add (add m (mul k m)) k))
           (add (add m (mul k m)) (succ k))
           (subst Nat
              (add (add m (mul k m)) (succ k))
              (succ (add (add m (mul k m)) k))
              (addSuccR (add m (mul k m)) k)
              (fn (z : Nat) is Eq Nat z (add (add m (mul k m)) (succ k)) end)
              (refl (add (add m (mul k m)) (succ k))))
           (fn (z : Nat) is Eq Nat (mul (succ k) (succ m)) z end)
           (subst Nat
              (add m (add (mul k m) k))
              (add (add m (mul k m)) k)
              (subst Nat
                 (add (add m (mul k m)) k)
                 (add m (add (mul k m) k))
                 (addAssoc m (mul k m) k)
                 (fn (z : Nat) is Eq Nat z (add (add m (mul k m)) k) end)
                 (refl (add (add m (mul k m)) k)))
              (fn (z : Nat) is Eq Nat (mul (succ k) (succ m)) (succ z) end)
              (subst Nat
                 (mul k (succ m))
                 (add (mul k m) k)
                 ih
                 (fn (z : Nat) is Eq Nat (mul (succ k) (succ m)) (succ (add m z)) end)
                 (refl (mul (succ k) (succ m)))))
       end)
      n
  end
end

-- COMMUTATIVITY of Nat mul (ch81), by induction on m.
mulComm : (m : Nat) -> (n : Nat) -> Eq Nat (mul m n) (mul n m) is
  fn (m : Nat) (n : Nat) is
    NatElim
      (fn (x : Nat) is Eq Nat (mul x n) (mul n x) end)
      (subst Nat (mul n zero) zero (mulZeroR n)
         (fn (z : Nat) is Eq Nat z (mul n zero) end)
         (refl (mul n zero)))
      (fn (k : Nat) (ih : Eq Nat (mul k n) (mul n k)) is
         subst Nat
           (add (mul n k) n)
           (mul n (succ k))
           (subst Nat
              (mul n (succ k))
              (add (mul n k) n)
              (mulSuccR n k)
              (fn (z : Nat) is Eq Nat z (mul n (succ k)) end)
              (refl (mul n (succ k))))
           (fn (z : Nat) is Eq Nat (mul (succ k) n) z end)
           (subst Nat
              (mul n k)
              (mul k n)
              (subst Nat (mul k n) (mul n k) ih
                 (fn (z : Nat) is Eq Nat z (mul k n) end)
                 (refl (mul k n)))
              (fn (z : Nat) is Eq Nat (add n z) (add (mul n k) n) end)
              (addComm n (mul n k)))
       end)
      m
  end
end

-- LEFT DISTRIBUTIVITY: a * (b + c) = a*b + a*c, derived from mulComm + mulDistR.
mulDistL : (a : Nat) -> (b : Nat) -> (c : Nat)
   -> Eq Nat (mul a (add b c)) (add (mul a b) (mul a c)) is
  fn (a : Nat) (b : Nat) (c : Nat) is
    trans (mulComm a (add b c))
      (trans (mulDistR b c a)
        (trans (cong (fn (s : Nat) is add s (mul c a) end) (mulComm b a))
          (cong (fn (s : Nat) is add (mul a b) s end) (mulComm c a))))
  end
end

-- x + (y + z) = y + (x + z) and the interchange law (ch07), the workhorses of the
-- respect proofs.
swapLeft : (x : Nat) -> (y : Nat) -> (z : Nat) ->
    Eq Nat (add x (add y z)) (add y (add x z)) is
  fn (x : Nat) (y : Nat) (z : Nat) is
    trans (sym (addAssoc x y z))
      (trans (cong (fn (s : Nat) is add s z end) (addComm x y))
        (addAssoc y x z))
  end
end

interchange : (w : Nat) -> (x : Nat) -> (y : Nat) -> (z : Nat) ->
    Eq Nat (add (add w x) (add y z)) (add (add w y) (add x z)) is
  fn (w : Nat) (x : Nat) (y : Nat) (z : Nat) is
    trans (addAssoc w x (add y z))
      (trans (cong (fn (s : Nat) is add w s end) (swapLeft x y z))
        (sym (addAssoc w y (add x z))))
  end
end

-- ============================================================================
-- NEW NAT LEMMAS this chapter needs beyond ch105's set.
-- ============================================================================

-- MULTIPLICATIVE RIGHT IDENTITY: mul n 1 = n. One-line induction:
--   mul (succ k) 1 = add 1 (mul k 1) = succ (mul k 1) = succ k by IH.
mulOneR : (n : Nat) -> Eq Nat (mul n (succ zero)) n is
  fn (n : Nat) is
    NatElim (fn (x : Nat) is Eq Nat (mul x (succ zero)) x end)
      (refl zero)
      (fn (k : Nat) (ih : Eq Nat (mul k (succ zero)) k) is
         cong succ ih
       end)
      n
  end
end

-- MUL ASSOCIATIVITY: (a * b) * c = a * (b * c) (ch81 sibling), by induction on a.
--   (succ k * b) * c = (b + k*b) * c           [def]
--                    = b*c + (k*b)*c           [mulDistR]
--                    = b*c + k*(b*c)           [IH]
--                    = (succ k) * (b*c)         [def]
mulAssoc : (a : Nat) -> (b : Nat) -> (c : Nat)
   -> Eq Nat (mul (mul a b) c) (mul a (mul b c)) is
  fn (a : Nat) (b : Nat) (c : Nat) is
    NatElim (fn (x : Nat) is Eq Nat (mul (mul x b) c) (mul x (mul b c)) end)
      (refl zero)
      (fn (k : Nat) (ih : Eq Nat (mul (mul k b) c) (mul k (mul b c))) is
         trans (mulDistR b (mul k b) c)
           (cong (fn (s : Nat) is add (mul b c) s end) ih)
       end)
      a
  end
end

-- ============================================================================
-- ch07/ch103/ch105 ℤ infrastructure, redeclared verbatim.
-- ============================================================================

cong2 : {A : U} -> {B : U} -> {C : U} -> (f : A -> B -> C)
     -> {x : A} -> {y : A} -> {u : B} -> {v : B}
     -> Eq A x y -> Eq B u v -> Eq C (f x u) (f y v) is
  fn {A : U} {B : U} {C : U} (f : A -> B -> C)
     {x : A} {y : A} {u : B} {v : B} (p : Eq A x y) (q : Eq B u v) is
    trans (cong (fn (z : A) is f z u end) p) (cong (fn (z : B) is f y z end) q)
  end
end

data NatPair : U is
  npair : Nat -> Nat -> NatPair
end

fst : NatPair -> Nat is
  fn (p : NatPair) is
    NatPairElim (fn (x : NatPair) is Nat end) (fn (a : Nat) (b : Nat) is a end) p
  end
end

snd : NatPair -> Nat is
  fn (p : NatPair) is
    NatPairElim (fn (x : NatPair) is Nat end) (fn (a : Nat) (b : Nat) is b end) p
  end
end

ZRel : NatPair -> NatPair -> Prop is
  fn (p : NatPair) (q : NatPair) is
    Eq Nat (add (fst p) (snd q)) (add (fst q) (snd p))
  end
end

Z : U is Quot NatPair ZRel end

zfrom : Nat -> Z is fn (n : Nat) is qin NatPair ZRel (npair n zero) end end
zzero : Z is zfrom zero end
zone : Z is zfrom (succ zero) end
zminusOne : Z is qin NatPair ZRel (npair zero (succ zero)) end

psucc : NatPair -> NatPair is
  fn (p : NatPair) is npair (succ (fst p)) (snd p) end
end
pneg : NatPair -> NatPair is
  fn (p : NatPair) is npair (snd p) (fst p) end
end
padd : NatPair -> NatPair -> NatPair is
  fn (p : NatPair) (q : NatPair) is
    npair (add (fst p) (fst q)) (add (snd p) (snd q))
  end
end

-- Integer addition, by lifting twice (ch103).
paddRespL : (p : NatPair) -> (p' : NatPair) -> (q : NatPair) ->
    ZRel p p' -> ZRel (padd p q) (padd p' q) is
  fn (p : NatPair) (p' : NatPair) (q : NatPair) (r : ZRel p p') is
    trans (interchange (fst p) (fst q) (snd p') (snd q))
      (trans (cong (fn (s : Nat) is add s (add (fst q) (snd q)) end) r)
        (sym (interchange (fst p') (fst q) (snd p) (snd q))))
  end
end

paddRespR : (p : NatPair) -> (q : NatPair) -> (q' : NatPair) ->
    ZRel q q' -> ZRel (padd p q) (padd p q') is
  fn (p : NatPair) (q : NatPair) (q' : NatPair) (r : ZRel q q') is
    trans (interchange (fst p) (fst q) (snd p) (snd q'))
      (trans (cong (fn (s : Nat) is add (add (fst p) (snd p)) s end) r)
        (sym (interchange (fst p) (fst q') (snd p) (snd q))))
  end
end

zaddR : NatPair -> Z -> Z is
  fn (p : NatPair) is
    qlift NatPair ZRel Z
      (fn (q : NatPair) is qin NatPair ZRel (padd p q) end)
      (fn (q : NatPair) (q' : NatPair) (r : ZRel q q') is
        qsound NatPair ZRel (padd p q) (padd p q') (paddRespR p q q' r)
      end)
  end
end

zadd : Z -> Z -> Z is
  qlift NatPair ZRel (Z -> Z) zaddR
    (fn (p : NatPair) (p' : NatPair) (r : ZRel p p') is
      fn (z : Z) is
        qind NatPair ZRel (fn (w : Z) is Eq Z (zaddR p w) (zaddR p' w) end)
          (fn (q : NatPair) is
            qsound NatPair ZRel (padd p q) (padd p' q) (paddRespL p p' q r)
          end)
          z
      end
    end)
end

-- Integer multiplication, by lifting twice (ch105).
pmul : NatPair -> NatPair -> NatPair is
  fn (p : NatPair) (q : NatPair) is
    npair
      (add (mul (fst p) (fst q)) (mul (snd p) (snd q)))
      (add (mul (fst p) (snd q)) (mul (snd p) (fst q)))
  end
end

pmulRespR : (p : NatPair) -> (q : NatPair) -> (q' : NatPair) ->
    ZRel q q' -> ZRel (pmul p q) (pmul p q') is
  fn (p : NatPair) (q : NatPair) (q' : NatPair) (r : ZRel q q') is
    trans
      (interchange
        (mul (fst p) (fst q)) (mul (snd p) (snd q))
        (mul (fst p) (snd q')) (mul (snd p) (fst q')))
      (trans
        (cong2 (fn (u : Nat) (v : Nat) is add u v end)
          (trans (sym (mulDistL (fst p) (fst q) (snd q')))
            (trans (cong (fn (s : Nat) is mul (fst p) s end) r)
              (mulDistL (fst p) (fst q') (snd q))))
          (trans (addComm (mul (snd p) (snd q)) (mul (snd p) (fst q')))
            (trans
              (sym
                (trans (sym (mulDistL (snd p) (fst q) (snd q')))
                  (trans (cong (fn (s : Nat) is mul (snd p) s end) r)
                    (mulDistL (snd p) (fst q') (snd q)))))
              (addComm (mul (snd p) (fst q)) (mul (snd p) (snd q'))))))
        (interchange
          (mul (fst p) (fst q')) (mul (fst p) (snd q))
          (mul (snd p) (snd q')) (mul (snd p) (fst q))))
  end
end

pmulRespL : (p : NatPair) -> (p' : NatPair) -> (q : NatPair) ->
    ZRel p p' -> ZRel (pmul p q) (pmul p' q) is
  fn (p : NatPair) (p' : NatPair) (q : NatPair) (r : ZRel p p') is
    trans
      (trans
        (cong (fn (s : Nat) is add (add (mul (fst p) (fst q)) (mul (snd p) (snd q))) s end)
          (addComm (mul (fst p') (snd q)) (mul (snd p') (fst q))))
        (interchange
          (mul (fst p) (fst q)) (mul (snd p) (snd q))
          (mul (snd p') (fst q)) (mul (fst p') (snd q))))
      (trans
        (cong2 (fn (u : Nat) (v : Nat) is add u v end)
          (trans (sym (mulDistR (fst p) (snd p') (fst q)))
            (trans (cong (fn (s : Nat) is mul s (fst q) end) r)
              (mulDistR (fst p') (snd p) (fst q))))
          (trans (addComm (mul (snd p) (snd q)) (mul (fst p') (snd q)))
            (trans (sym (mulDistR (fst p') (snd p) (snd q)))
              (trans (cong (fn (s : Nat) is mul s (snd q) end) (sym r))
                (trans (mulDistR (fst p) (snd p') (snd q))
                  (addComm (mul (fst p) (snd q)) (mul (snd p') (snd q))))))))
        (trans
          (interchange
            (mul (fst p') (fst q)) (mul (snd p) (fst q))
            (mul (snd p') (snd q)) (mul (fst p) (snd q)))
          (cong (fn (s : Nat) is add (add (mul (fst p') (fst q)) (mul (snd p') (snd q))) s end)
            (addComm (mul (snd p) (fst q)) (mul (fst p) (snd q))))))
  end
end

zmulR : NatPair -> Z -> Z is
  fn (p : NatPair) is
    qlift NatPair ZRel Z
      (fn (q : NatPair) is qin NatPair ZRel (pmul p q) end)
      (fn (q : NatPair) (q' : NatPair) (r : ZRel q q') is
        qsound NatPair ZRel (pmul p q) (pmul p q') (pmulRespR p q q' r)
      end)
  end
end

zmul : Z -> Z -> Z is
  qlift NatPair ZRel (Z -> Z) zmulR
    (fn (p : NatPair) (p' : NatPair) (r : ZRel p p') is
      fn (z : Z) is
        qind NatPair ZRel (fn (w : Z) is Eq Z (zmulR p w) (zmulR p' w) end)
          (fn (q : NatPair) is
            qsound NatPair ZRel (pmul p q) (pmul p' q) (pmulRespL p p' q r)
          end)
          z
      end
    end)
end

-- pmul p q ~ pmul q p on representatives (ch105).
pmulComm : (p : NatPair) -> (q : NatPair) -> ZRel (pmul p q) (pmul q p) is
  fn (p : NatPair) (q : NatPair) is
    cong2 (fn (u : Nat) (v : Nat) is add u v end)
      (cong2 (fn (u : Nat) (v : Nat) is add u v end)
        (mulComm (fst p) (fst q))
        (mulComm (snd p) (snd q)))
      (trans
        (cong2 (fn (u : Nat) (v : Nat) is add u v end)
          (mulComm (fst q) (snd p))
          (mulComm (snd q) (fst p)))
        (addComm (mul (snd p) (fst q)) (mul (fst p) (snd q))))
  end
end

zmulComm : (x : Z) -> (y : Z) -> Eq Z (zmul x y) (zmul y x) is
  fn (x : Z) is
    qind NatPair ZRel (fn (w : Z) is (y : Z) -> Eq Z (zmul w y) (zmul y w) end)
      (fn (p : NatPair) is
        fn (y : Z) is
          qind NatPair ZRel
            (fn (w : Z) is Eq Z (zmul (qin NatPair ZRel p) w) (zmul w (qin NatPair ZRel p)) end)
            (fn (q : NatPair) is
              qsound NatPair ZRel (pmul p q) (pmul q p) (pmulComm p q)
            end)
            y
        end
      end)
      x
  end
end

-- ============================================================================
-- NEW IN CH107 — the remaining commutative-ring laws.
-- ============================================================================

-- ----------------------------------------------------------------------------
-- MULTIPLICATIVE RIGHT IDENTITY: x * 1 = x.
-- zone = qin (1, 0). On a representative (a, b):
--   pmul (a,b) (1,0) = (a*1 + b*0, a*0 + b*1).
-- The ZRel obligation relating it back to (a, b) is
--   (a*1 + b*0) + b  =  a + (a*0 + b*1).
-- LHS: a*1 = a (mulOneR), b*0 = 0 (mulZeroR), so a*1 + b*0 = a + 0 = a, hence LHS = a + b.
-- RHS: a*0 = 0 (mulZeroR), b*1 = b (mulOneR), so a*0 + b*1 = 0 + b = b, hence RHS = a + b.
-- Both reduce to a + b; the obligation is the composite of these two simplifications.
-- ----------------------------------------------------------------------------
pmulOneR : (p : NatPair) -> ZRel (pmul p (npair (succ zero) zero)) p is
  fn (p : NatPair) is
    -- Goal: add (add (mul (fst p) 1) (mul (snd p) 0)) (snd p)
    --     = add (fst p) (add (mul (fst p) 0) (mul (snd p) 1)).
    -- LHS  -> add (add (fst p) zero) (snd p)  [mulOneR, mulZeroR]
    --      -> add (fst p) (snd p)             [addZeroR]
    -- RHS  <- add (fst p) (add zero (snd p))  [mulZeroR, mulOneR]
    --      <- add (fst p) (snd p)             [add zero (snd p) is snd p by def]
    trans
      (cong (fn (s : Nat) is add s (snd p) end)
        (trans
          (cong2 (fn (u : Nat) (v : Nat) is add u v end)
            (mulOneR (fst p))
            (mulZeroR (snd p)))
          (addZeroR (fst p))))
      (cong (fn (s : Nat) is add (fst p) s end)
        (sym
          (cong2 (fn (u : Nat) (v : Nat) is add u v end)
            (mulZeroR (fst p))
            (mulOneR (snd p)))))
  end
end

zmulOneR : (x : Z) -> Eq Z (zmul x zone) x is
  fn (x : Z) is
    qind NatPair ZRel (fn (w : Z) is Eq Z (zmul w zone) w end)
      (fn (p : NatPair) is
        qsound NatPair ZRel (pmul p (npair (succ zero) zero)) p (pmulOneR p)
      end)
      x
  end
end

-- LEFT IDENTITY: 1 * x = x, from commutativity + right identity.
zmulOneL : (x : Z) -> Eq Z (zmul zone x) x is
  fn (x : Z) is
    trans (zmulComm zone x) (zmulOneR x)
  end
end

-- ----------------------------------------------------------------------------
-- ANNIHILATION: x * 0 = 0.
-- zzero = qin (0, 0). On a representative (a, b):
--   pmul (a,b) (0,0) = (a*0 + b*0, a*0 + b*0).
-- The ZRel obligation relating it to (0, 0) is
--   (a*0 + b*0) + 0  =  0 + (a*0 + b*0),
-- which after a*0 = b*0 = 0 (mulZeroR) is 0 + 0 = 0 + 0 — but we discharge it directly
-- by addComm on the two (equal) components.
-- ----------------------------------------------------------------------------
pmulZeroR : (p : NatPair) -> ZRel (pmul p (npair zero zero)) (npair zero zero) is
  fn (p : NatPair) is
    -- Goal: add (add (mul (fst p) 0) (mul (snd p) 0)) 0
    --     = add 0 (add (mul (fst p) 0) (mul (snd p) 0)).
    addComm (add (mul (fst p) zero) (mul (snd p) zero)) zero
  end
end

zmulZeroR : (x : Z) -> Eq Z (zmul x zzero) zzero is
  fn (x : Z) is
    qind NatPair ZRel (fn (w : Z) is Eq Z (zmul w zzero) zzero end)
      (fn (p : NatPair) is
        qsound NatPair ZRel (pmul p (npair zero zero)) (npair zero zero) (pmulZeroR p)
      end)
      x
  end
end

-- ----------------------------------------------------------------------------
-- LEFT-DISTRIBUTIVITY — THE RING AXIOM: x * (y + z) = x*y + x*z.
-- On representatives p=(a,b), q=(c,d), r=(e,f):
--   zadd q r = (c+e, d+f).
--   fst (pmul p (q+r)) = a*(c+e) + b*(d+f)
--   fst (padd (pmul p q) (pmul p r)) = (a*c + b*d) + (a*e + b*f)
-- a*(c+e) = a*c + a*e and b*(d+f) = b*d + b*f (mulDistL), so the LHS first component is
--   (a*c + a*e) + (b*d + b*f), which interchanges to (a*c + b*d) + (a*e + b*f) = RHS first.
-- The SECOND components are identical:
--   snd (pmul p (q+r)) = a*(d+f) + b*(c+e)
--   snd (padd …)       = (a*d + b*c) + (a*f + b*e)
-- a*(d+f) = a*d + a*f and b*(c+e) = b*c + b*e (mulDistL), interchange to
--   (a*d + b*c) + (a*f + b*e) = RHS second.
-- Both pairs of components are LITERALLY EQUAL as Nats, so the ZRel obligation is
-- discharged by cong2 into both components (each a mulDistL-then-interchange equality).
-- ----------------------------------------------------------------------------

-- The first-component identity: a*(c+e) + b*(d+f) = (a*c + b*d) + (a*e + b*f).
pmulDistFst : (a : Nat) -> (b : Nat) -> (c : Nat) -> (d : Nat) -> (e : Nat) -> (f : Nat)
   -> Eq Nat
        (add (mul a (add c e)) (mul b (add d f)))
        (add (add (mul a c) (mul b d)) (add (mul a e) (mul b f))) is
  fn (a : Nat) (b : Nat) (c : Nat) (d : Nat) (e : Nat) (f : Nat) is
    trans
      (cong2 (fn (u : Nat) (v : Nat) is add u v end)
        (mulDistL a c e)
        (mulDistL b d f))
      (interchange (mul a c) (mul a e) (mul b d) (mul b f))
  end
end

-- pmul p (padd q r) ~ padd (pmul p q) (pmul p r): components are equal, lift to ZRel.
-- The ZRel obligation is
--   fst (pmul p (q+r)) + snd (padd (pmul p q) (pmul p r))
--     = fst (padd …) + snd (pmul p (q+r)).
-- We prove the stronger fact that fst's are equal and snd's are equal, then assemble
-- the obligation by cong2: the LHS rewrites to RHS-fst + LHS-snd, and addComm-free.
pmulDistR : (p : NatPair) -> (q : NatPair) -> (r : NatPair)
   -> ZRel (pmul p (padd q r)) (padd (pmul p q) (pmul p r)) is
  fn (p : NatPair) (q : NatPair) (r : NatPair) is
    -- Goal: add (fst (pmul p (padd q r))) (snd (padd (pmul p q) (pmul p r)))
    --     = add (fst (padd (pmul p q) (pmul p r))) (snd (pmul p (padd q r))).
    -- fst (pmul p (padd q r)) = a*(c+e) + b*(d+f)
    -- fst (padd (pmul p q) (pmul p r)) = (a*c+b*d) + (a*e+b*f)
    -- snd (pmul p (padd q r)) = a*(d+f) + b*(c+e)
    -- snd (padd (pmul p q) (pmul p r)) = (a*d+b*c) + (a*f+b*e)
    cong2 (fn (u : Nat) (v : Nat) is add u v end)
      -- fst-eq : a*(c+e) + b*(d+f) = (a*c+b*d) + (a*e+b*f)
      (pmulDistFst (fst p) (snd p) (fst q) (snd q) (fst r) (snd r))
      -- snd-eq, reversed (we need snd(padd) = snd(pmul …)):
      --   (a*d+b*c) + (a*f+b*e) = a*(d+f) + b*(c+e)
      (sym (pmulDistFst (fst p) (snd p) (snd q) (fst q) (snd r) (fst r)))
  end
end

zmulDistR : (x : Z) -> (y : Z) -> (z : Z)
   -> Eq Z (zmul x (zadd y z)) (zadd (zmul x y) (zmul x z)) is
  fn (x : Z) is
    qind NatPair ZRel
      (fn (wx : Z) is (y : Z) -> (z : Z) -> Eq Z (zmul wx (zadd y z)) (zadd (zmul wx y) (zmul wx z)) end)
      (fn (p : NatPair) is
        fn (y : Z) is
          qind NatPair ZRel
            (fn (wy : Z) is (z : Z) -> Eq Z (zmul (qin NatPair ZRel p) (zadd wy z)) (zadd (zmul (qin NatPair ZRel p) wy) (zmul (qin NatPair ZRel p) z)) end)
            (fn (q : NatPair) is
              fn (z : Z) is
                qind NatPair ZRel
                  (fn (wz : Z) is Eq Z (zmul (qin NatPair ZRel p) (zadd (qin NatPair ZRel q) wz)) (zadd (zmul (qin NatPair ZRel p) (qin NatPair ZRel q)) (zmul (qin NatPair ZRel p) wz)) end)
                  (fn (r : NatPair) is
                    qsound NatPair ZRel
                      (pmul p (padd q r)) (padd (pmul p q) (pmul p r))
                      (pmulDistR p q r)
                  end)
                  z
              end
            end)
            y
        end
      end)
      x
  end
end

-- RIGHT-DISTRIBUTIVITY: (x + y) * z = x*z + y*z, from zmulComm + zmulDistR.
--   (x+y)*z = z*(x+y)        (zmulComm)
--           = z*x + z*y      (zmulDistR)
--           = x*z + y*z      (zmulComm on each summand).
zmulDistL : (x : Z) -> (y : Z) -> (z : Z)
   -> Eq Z (zmul (zadd x y) z) (zadd (zmul x z) (zmul y z)) is
  fn (x : Z) (y : Z) (z : Z) is
    trans (zmulComm (zadd x y) z)
      (trans (zmulDistR z x y)
        (trans (cong (fn (s : Z) is zadd s (zmul z y) end) (zmulComm z x))
          (cong (fn (s : Z) is zadd (zmul x z) s end) (zmulComm z y))))
  end
end

-- ----------------------------------------------------------------------------
-- ASSOCIATIVITY: (x * y) * z = x * (y * z).
-- On representatives p=(a,b), q=(c,d), r=(e,f):
--   pmul p q = (ac+bd, ad+bc).
--   pmul (pmul p q) r = ((ac+bd)*e + (ad+bc)*f, (ac+bd)*f + (ad+bc)*e).
--   pmul q r = (ce+df, cf+de).
--   pmul p (pmul q r) = (a*(ce+df) + b*(cf+de), a*(cf+de) + b*(ce+df)).
-- Both components are equal Nat semiring expressions: expand with mulDistR (left side,
-- (x+y)*z) and mulDistL (right side, x*(y+z)), reassociate each product with mulAssoc,
-- and regroup the FOUR triple-products with the interchange law. We prove each component
-- as a literal Nat equality and lift by cong2 into ZRel.
-- ----------------------------------------------------------------------------

-- FIRST component: (ac+bd)*e + (ad+bc)*f = a*(ce+df) + b*(cf+de).
--   LHS = (ace + bde) + (adf + bcf)        [mulDistR ×2, mulAssoc ×4]
--   reorder to (ace + adf) + (bde + bcf)   [interchange]
--   RHS = (ace + adf) + (bcf + bde)        [mulDistL ×2, mulAssoc ×4]
-- so we need (bde + bcf) = (bcf + bde), an addComm, sitting in the second summand.
pmulAssocFst : (a : Nat) -> (b : Nat) -> (c : Nat) -> (d : Nat) -> (e : Nat) -> (f : Nat)
   -> Eq Nat
        (add (mul (add (mul a c) (mul b d)) e) (mul (add (mul a d) (mul b c)) f))
        (add (mul a (add (mul c e) (mul d f))) (mul b (add (mul c f) (mul d e)))) is
  fn (a : Nat) (b : Nat) (c : Nat) (d : Nat) (e : Nat) (f : Nat) is
    trans
      -- expand both products on the LHS by mulDistR:
      --   (ac+bd)*e = ac*e + bd*e ;  (ad+bc)*f = ad*f + bc*f
      (cong2 (fn (u : Nat) (v : Nat) is add u v end)
        (mulDistR (mul a c) (mul b d) e)
        (mulDistR (mul a d) (mul b c) f))
      (trans
        -- reassociate every triple product: (ac)e = a(ce), (bd)e = b(de),
        --   (ad)f = a(df), (bc)f = b(cf).
        (cong2 (fn (u : Nat) (v : Nat) is add u v end)
          (cong2 (fn (u : Nat) (v : Nat) is add u v end)
            (mulAssoc a c e)
            (mulAssoc b d e))
          (cong2 (fn (u : Nat) (v : Nat) is add u v end)
            (mulAssoc a d f)
            (mulAssoc b c f)))
        (trans
          -- now LHS = (a(ce) + b(de)) + (a(df) + b(cf));
          -- interchange to (a(ce) + a(df)) + (b(de) + b(cf)).
          (interchange (mul a (mul c e)) (mul b (mul d e)) (mul a (mul d f)) (mul b (mul c f)))
          (trans
            -- contract each summand by mulDistL (reverse):
            --   a(ce) + a(df) = a*(ce+df) ;  b(de) + b(cf) = b*(de+cf).
            (cong2 (fn (u : Nat) (v : Nat) is add u v end)
              (sym (mulDistL a (mul c e) (mul d f)))
              (sym (mulDistL b (mul d e) (mul c f))))
            -- fix the second factor of the b-term: b*(de+cf) = b*(cf+de) by addComm.
            (cong (fn (s : Nat) is add (mul a (add (mul c e) (mul d f))) (mul b s) end)
              (addComm (mul d e) (mul c f))))))
  end
end

-- pmul (pmul p q) r ~ pmul p (pmul q r): both components equal. The SECOND component
-- of (pq)r is (ac+bd)*f + (ad+bc)*e and of p(qr) is a*(cf+de) + b*(ce+df) — the SAME
-- shape as pmulAssocFst with e and f swapped, so it reuses pmulAssocFst at swapped args.
pmulAssoc : (p : NatPair) -> (q : NatPair) -> (r : NatPair)
   -> ZRel (pmul (pmul p q) r) (pmul p (pmul q r)) is
  fn (p : NatPair) (q : NatPair) (r : NatPair) is
    -- ZRel obligation:
    --   fst (pmul (pmul p q) r) + snd (pmul p (pmul q r))
    --     = fst (pmul p (pmul q r)) + snd (pmul (pmul p q) r).
    -- fst-eq : fst (pmul (pmul p q) r) = fst (pmul p (pmul q r))  [pmulAssocFst]
    -- snd-eq : snd (pmul (pmul p q) r) = snd (pmul p (pmul q r))  [pmulAssocFst, e/f swapped]
    -- assemble: cong2 add (fst-eq) (sym snd-eq).
    cong2 (fn (u : Nat) (v : Nat) is add u v end)
      (pmulAssocFst (fst p) (snd p) (fst q) (snd q) (fst r) (snd r))
      (sym (pmulAssocFst (fst p) (snd p) (fst q) (snd q) (snd r) (fst r)))
  end
end

zmulAssoc : (x : Z) -> (y : Z) -> (z : Z)
   -> Eq Z (zmul (zmul x y) z) (zmul x (zmul y z)) is
  fn (x : Z) is
    qind NatPair ZRel
      (fn (wx : Z) is (y : Z) -> (z : Z) -> Eq Z (zmul (zmul wx y) z) (zmul wx (zmul y z)) end)
      (fn (p : NatPair) is
        fn (y : Z) is
          qind NatPair ZRel
            (fn (wy : Z) is (z : Z) -> Eq Z (zmul (zmul (qin NatPair ZRel p) wy) z) (zmul (qin NatPair ZRel p) (zmul wy z)) end)
            (fn (q : NatPair) is
              fn (z : Z) is
                qind NatPair ZRel
                  (fn (wz : Z) is Eq Z (zmul (zmul (qin NatPair ZRel p) (qin NatPair ZRel q)) wz) (zmul (qin NatPair ZRel p) (zmul (qin NatPair ZRel q) wz)) end)
                  (fn (r : NatPair) is
                    qsound NatPair ZRel
                      (pmul (pmul p q) r) (pmul p (pmul q r))
                      (pmulAssoc p q r)
                  end)
                  z
              end
            end)
            y
        end
      end)
      x
  end
end

-- ============================================================================
-- Sanity: the ring laws COMPUTE through the quotient on concrete integers.
-- ============================================================================

-- (2 − 0) and (0 − 3) as explicit representatives.
zexLeft : Z is qin NatPair ZRel (npair (succ (succ zero)) zero) end
zexRight : Z is qin NatPair ZRel (npair zero (succ (succ (succ zero)))) end

-- x * 1 = x on a concrete integer, by zmulOneR.
zexOneR : Eq Z (zmul zexLeft zone) zexLeft is zmulOneR zexLeft end

-- Distributivity on concrete integers: zexLeft * (zexLeft + zexRight)
--   = zexLeft*zexLeft + zexLeft*zexRight, by zmulDistR.
zexDist : Eq Z
    (zmul zexLeft (zadd zexLeft zexRight))
    (zadd (zmul zexLeft zexLeft) (zmul zexLeft zexRight)) is
  zmulDistR zexLeft zexLeft zexRight
end

-- Associativity on concrete integers.
zexAssoc : Eq Z
    (zmul (zmul zexLeft zexRight) zexLeft)
    (zmul zexLeft (zmul zexRight zexLeft)) is
  zmulAssoc zexLeft zexRight zexLeft
end

-- ============================================================================
-- CHAPTER 108 — ℚ, THE FIELD OF FRACTIONS OVER ℤ.
-- Everything above is the ch107 ℤ-ring development, redeclared verbatim. Below is
-- the NEW rational layer: the localization of ℤ at the nonzero denominators.
-- ============================================================================

-- ----------------------------------------------------------------------------
-- Two ℤ-ring lemmas the ℚ well-definedness needs, derived from ch107's axioms.
-- ----------------------------------------------------------------------------

-- The 4-FACTOR REGROUPING in a commutative ring: (a·b)·(c·d) = (a·c)·(b·d).
-- This is the multiplicative analog of ch07/ch107's additive `interchange`, and it
-- is the workhorse of the cross-multiplication respect proofs. Pure assoc+comm:
--   (a·b)·(c·d) = a·(b·(c·d))      [zmulAssoc]
--              = a·((b·c)·d)       [sym zmulAssoc, inside]
--              = a·((c·b)·d)       [zmulComm b c, inside]
--              = a·(c·(b·d))       [zmulAssoc, inside]
--              = (a·c)·(b·d)       [sym zmulAssoc]
zmulInterchange : (a : Z) -> (b : Z) -> (c : Z) -> (d : Z)
   -> Eq Z (zmul (zmul a b) (zmul c d)) (zmul (zmul a c) (zmul b d)) is
  fn (a : Z) (b : Z) (c : Z) (d : Z) is
    trans (zmulAssoc a b (zmul c d))
      (trans
        (cong (fn (s : Z) is zmul a s end) (sym (zmulAssoc b c d)))
        (trans
          (cong (fn (s : Z) is zmul a (zmul s d) end) (zmulComm b c))
          (trans
            (cong (fn (s : Z) is zmul a s end) (zmulAssoc c b d))
            (sym (zmulAssoc a c (zmul b d))))))
  end
end

-- The Nat→ℤ embedding `zfrom` is a MULTIPLICATIVE homomorphism:
--   zfrom (m · n) = zmul (zfrom m) (zfrom n).
-- zfrom n = qin (n, 0); zmul (zfrom m) (zfrom n) computes (by the qlift ι-rules) to
-- qin (pmul (m,0) (n,0)) = qin (mul m n + mul 0 0, mul m 0 + mul 0 n). The ZRel
-- obligation relating (mul m n, 0) to that is discharged by addZeroR / mulZeroR
-- (mul 0 _ reduces to 0 definitionally; mul m 0 needs mulZeroR).
zmulHom : (m : Nat) -> (n : Nat)
   -> Eq Z (zfrom (mul m n)) (zmul (zfrom m) (zfrom n)) is
  fn (m : Nat) (n : Nat) is
    qsound NatPair ZRel
      (npair (mul m n) zero)
      (pmul (npair m zero) (npair n zero))
      -- Goal: add (mul m n) (add (mul m zero) zero) = add (add (mul m n) zero) zero.
      (trans
        -- LHS -> mul m n
        (trans
          (cong (fn (s : Nat) is add (mul m n) s end)
            (trans (addZeroR (mul m zero)) (mulZeroR m)))
          (addZeroR (mul m n)))
        -- mul m n -> RHS
        (sym
          (trans (addZeroR (add (mul m n) zero)) (addZeroR (mul m n)))))
  end
end

-- ----------------------------------------------------------------------------
-- THE REPRESENTATION.  A QPair (a, b) denotes the fraction  a / succ(b),  so the
-- denominator is structurally nonzero with no carried proof (the +1 trick). The
-- numerator is a genuine ℤ (ch107's quotient integer); the denominator is a Nat.
-- ----------------------------------------------------------------------------

data QPair : U is
  qpair : Z -> Nat -> QPair
end

qnum : QPair -> Z is
  fn (p : QPair) is
    QPairElim (fn (x : QPair) is Z end) (fn (a : Z) (b : Nat) is a end) p
  end
end

qdenN : QPair -> Nat is
  fn (p : QPair) is
    QPairElim (fn (x : QPair) is Nat end) (fn (a : Z) (b : Nat) is b end) p
  end
end

-- The denominator as a (nonzero, positive) ℤ:  zden p = zfrom (succ (qdenN p)).
zden : QPair -> Z is
  fn (p : QPair) is zfrom (succ (qdenN p)) end
end

-- CROSS-MULTIPLICATION, in ℤ:  (a / sb) ~ (c / sd)  ⟺  a · sd = c · sb.
-- Eq Z lands in Prop (proof-irrelevant strict equality), so QRel : QPair -> QPair -> Prop.
QRel : QPair -> QPair -> Prop is
  fn (p : QPair) (q : QPair) is
    Eq Z (zmul (qnum p) (zden q)) (zmul (qnum q) (zden p))
  end
end

Q : U is Quot QPair QRel end

-- The embedding ℤ ↪ ℚ:  n ↦ n / 1.
qfromZ : Z -> Q is fn (z : Z) is qin QPair QRel (qpair z zero) end end
qzero : Q is qfromZ zzero end
qone : Q is qfromZ zone end

-- ----------------------------------------------------------------------------
-- MULTIPLICATION ON REPRESENTATIVES.  (a/sb) · (c/sd) = (a·c) / (sb·sd).
-- The denominator index is chosen so that  succ (qmulDen b d) = mul (succ b) (succ d)
-- DEFINITIONALLY:  mul (succ b) (succ d) = add (succ d) (mul b (succ d))
--                                        = succ (add d (mul b (succ d))),
-- so qmulDen b d = add d (mul b (succ d)). Hence zden (qmulP p q) = zfrom (sb·sd),
-- which zmulHom turns into zmul (zden p) (zden q).
-- ----------------------------------------------------------------------------
qmulDen : Nat -> Nat -> Nat is
  fn (b : Nat) (d : Nat) is add d (mul b (succ d)) end
end

qmulP : QPair -> QPair -> QPair is
  fn (p : QPair) (q : QPair) is
    qpair (zmul (qnum p) (qnum q)) (qmulDen (qdenN p) (qdenN q))
  end
end

-- zden (qmulP p q) = zmul (zden p) (zden q).  By construction the denominator index
-- gives  succ (qmulDen (qdenN p) (qdenN q)) = mul (succ (qdenN p)) (succ (qdenN q))
-- definitionally, so zden (qmulP p q) = zfrom (mul (succ b) (succ d)) and zmulHom closes it.
qmulDenZ : (p : QPair) -> (q : QPair)
   -> Eq Z (zden (qmulP p q)) (zmul (zden p) (zden q)) is
  fn (p : QPair) (q : QPair) is
    zmulHom (succ (qdenN p)) (succ (qdenN q))
  end
end

-- ----------------------------------------------------------------------------
-- WELL-DEFINEDNESS — the cross-multiplication respect proof (the analog of ch105's
-- pmulRespL/R one level up).  We must show qmulP respects QRel in each argument.
--
-- RIGHT respect: given QRel q q'  (i.e.  nq · zden q' = nq' · zden q),
--   QRel (qmulP p q) (qmulP p q'),  i.e.
--   (np·nq) · zden(qmulP p q')  =  (np·nq') · zden(qmulP p q).
-- Rewrite both denominators by qmulDenZ to zmul (zden p) (zden _), regroup the four
-- ℤ-factors with zmulInterchange so the q-vs-q' data line up, apply the hypothesis,
-- and regroup back.
-- ----------------------------------------------------------------------------
qmulRespR : (p : QPair) -> (q : QPair) -> (q' : QPair) ->
    QRel q q' -> QRel (qmulP p q) (qmulP p q') is
  fn (p : QPair) (q : QPair) (q' : QPair) (h : QRel q q') is
    -- Goal: zmul (zmul (qnum p) (qnum q)) (zden (qmulP p q'))
    --     = zmul (zmul (qnum p) (qnum q')) (zden (qmulP p q)).
    trans
      -- rewrite the right denominator: zden (qmulP p q') = zmul (zden p) (zden q')
      (cong (fn (s : Z) is zmul (zmul (qnum p) (qnum q)) s end) (qmulDenZ p q'))
      (trans
        -- ((np·nq)·(zb·zd')) = ((np·zb)·(nq·zd'))   [zmulInterchange]
        (zmulInterchange (qnum p) (qnum q) (zden p) (zden q'))
        (trans
          -- apply the hypothesis inside the second factor: nq·zd' = nq'·zd
          (cong (fn (s : Z) is zmul (zmul (qnum p) (zden p)) s end) h)
          (trans
            -- ((np·zb)·(nq'·zd)) = ((np·nq')·(zb·zd))   [sym zmulInterchange]
            (sym (zmulInterchange (qnum p) (qnum q') (zden p) (zden q)))
            -- fold the denominator back: zmul (zden p) (zden q) = zden (qmulP p q)
            (cong (fn (s : Z) is zmul (zmul (qnum p) (qnum q')) s end)
              (sym (qmulDenZ p q))))))
  end
end

-- LEFT respect: given QRel p p'  (np · zden p' = np' · zden p),
--   QRel (qmulP p q) (qmulP p' q). Same algebra with the p-data crossing.
qmulRespL : (p : QPair) -> (p' : QPair) -> (q : QPair) ->
    QRel p p' -> QRel (qmulP p q) (qmulP p' q) is
  fn (p : QPair) (p' : QPair) (q : QPair) (h : QRel p p') is
    -- Goal: zmul (zmul (qnum p) (qnum q)) (zden (qmulP p' q))
    --     = zmul (zmul (qnum p') (qnum q)) (zden (qmulP p q)).
    trans
      (cong (fn (s : Z) is zmul (zmul (qnum p) (qnum q)) s end) (qmulDenZ p' q))
      (trans
        -- ((np·nq)·(zb'·zd)) = ((np·zb')·(nq·zd))   [zmulInterchange]
        (zmulInterchange (qnum p) (qnum q) (zden p') (zden q))
        (trans
          -- apply hypothesis in the FIRST factor: np·zb' = np'·zb
          (cong (fn (s : Z) is zmul s (zmul (qnum q) (zden q)) end) h)
          (trans
            -- ((np'·zb)·(nq·zd)) = ((np'·nq)·(zb·zd))   [sym zmulInterchange]
            (sym (zmulInterchange (qnum p') (qnum q) (zden p) (zden q)))
            (cong (fn (s : Z) is zmul (zmul (qnum p') (qnum q)) s end)
              (sym (qmulDenZ p q))))))
  end
end

-- Lift qmulP through QRel, twice (the ch105/ch107 double-qind pattern).
qmulR : QPair -> Q -> Q is
  fn (p : QPair) is
    qlift QPair QRel Q
      (fn (q : QPair) is qin QPair QRel (qmulP p q) end)
      (fn (q : QPair) (q' : QPair) (r : QRel q q') is
        qsound QPair QRel (qmulP p q) (qmulP p q') (qmulRespR p q q' r)
      end)
  end
end

qmul : Q -> Q -> Q is
  qlift QPair QRel (Q -> Q) qmulR
    (fn (p : QPair) (p' : QPair) (r : QRel p p') is
      fn (z : Q) is
        qind QPair QRel (fn (w : Q) is Eq Q (qmulR p w) (qmulR p' w) end)
          (fn (q : QPair) is
            qsound QPair QRel (qmulP p q) (qmulP p' q) (qmulRespL p p' q r)
          end)
          z
      end
    end)
end

-- ----------------------------------------------------------------------------
-- THE FIELD LAW: COMMUTATIVITY OF ℚ MULTIPLICATION.  x · y = y · x.
-- On representatives, qmulP p q and qmulP q p relate by QRel because the numerators
-- commute (zmulComm) and the denominators commute, lined up by zmulInterchange.
--   QRel (qmulP p q) (qmulP q p)  needs
--     (np·nq) · zden(qmulP q p) = (nq·np) · zden(qmulP p q).
-- Rewrite both denominators (qmulDenZ); the obligation is then a pure ℤ identity:
--   (np·nq)·(zd·zb) = (nq·np)·(zb·zd), from zmulComm (numerators), zmulComm
--   (denominators), assembled by cong2.
-- ----------------------------------------------------------------------------
cong2Z : (f : Z -> Z -> Z) -> {x : Z} -> {y : Z} -> {u : Z} -> {v : Z}
     -> Eq Z x y -> Eq Z u v -> Eq Z (f x u) (f y v) is
  fn (f : Z -> Z -> Z) {x : Z} {y : Z} {u : Z} {v : Z} (p : Eq Z x y) (q : Eq Z u v) is
    trans (cong (fn (z : Z) is f z u end) p) (cong (fn (z : Z) is f y z end) q)
  end
end

qmulCommP : (p : QPair) -> (q : QPair) -> QRel (qmulP p q) (qmulP q p) is
  fn (p : QPair) (q : QPair) is
    -- Goal: zmul (zmul (qnum p) (qnum q)) (zden (qmulP q p))
    --     = zmul (zmul (qnum q) (qnum p)) (zden (qmulP p q)).
    trans
      (cong (fn (s : Z) is zmul (zmul (qnum p) (qnum q)) s end) (qmulDenZ q p))
      (trans
        -- (np·nq)·(zd·zb) = (nq·np)·(zb·zd) by commuting both factors of each product
        (cong2Z (fn (u : Z) (v : Z) is zmul u v end)
          (zmulComm (qnum p) (qnum q))
          (zmulComm (zden q) (zden p)))
        (cong (fn (s : Z) is zmul (zmul (qnum q) (qnum p)) s end)
          (sym (qmulDenZ p q))))
  end
end

qmulComm : (x : Q) -> (y : Q) -> Eq Q (qmul x y) (qmul y x) is
  fn (x : Q) is
    qind QPair QRel (fn (w : Q) is (y : Q) -> Eq Q (qmul w y) (qmul y w) end)
      (fn (p : QPair) is
        fn (y : Q) is
          qind QPair QRel
            (fn (w : Q) is Eq Q (qmul (qin QPair QRel p) w) (qmul w (qin QPair QRel p)) end)
            (fn (q : QPair) is
              qsound QPair QRel (qmulP p q) (qmulP q p) (qmulCommP p q)
            end)
            y
        end
      end)
      x
  end
end

-- ----------------------------------------------------------------------------
-- Sanity: ℚ multiplication COMPUTES through the quotient on concrete rationals.
-- ----------------------------------------------------------------------------

-- 1/2 (numerator 1, denominator succ 1 = 2) and 2/1 (numerator 2, denominator succ 0 = 1).
qHalf : Q is qin QPair QRel (qpair zone (succ zero)) end
qTwoOverOne : Q is qin QPair QRel (qpair (zfrom (succ (succ zero))) zero) end

-- 1/2 · 2/1 = (1·2)/(2·1) = 2/2, which qsound identifies with 1/1 = qone:
--   (1·2)/2 ~ 1/1  ⟺  (1·2)·1 = 1·2   (cross-multiply in ℤ), true by refl after the
-- numerators/denominators compute. We state the well-definedness witness as a QRel and
-- feed it to qsound to obtain the propositional identity 2/2 ~ 1/1.
qHalfTimesTwo : Q is qmul qHalf qTwoOverOne end

-- 2/2 ~ 1/1: the QRel obligation is  (1·2) · succ 0  =  1 · succ (succ 0)  in ℤ,
-- i.e.  zmul (zmul zone (zfrom 2)) (zfrom 1)  =  zmul zone (zfrom 2)  — both sides reduce
-- to the integer 2; discharge by the ℤ ring identity (zmulOneL on the right, after
-- zmulOneR on the spurious unit denominator on the left).
qTwoHalves : Q is qin QPair QRel (qpair (zmul zone (zfrom (succ (succ zero)))) (succ zero)) end

-- The computing example, fully proven: qmul qHalf qTwoOverOne IS the rational 2/2.
qMulComputes : Eq Q (qmul qHalf qTwoOverOne) qTwoHalves is
  refl (qmul qHalf qTwoOverOne)
end

-- Commutativity on these concrete rationals, by qmulComm.
qExComm : Eq Q (qmul qHalf qTwoOverOne) (qmul qTwoOverOne qHalf) is
  qmulComm qHalf qTwoOverOne
end

-- ============================================================================
-- CH108, PART II — ℚ ADDITION, and the field law qaddComm.
-- (a/sb) + (c/sd) = (a·sd + c·sb) / (sb·sd).  Well-definedness is the cross-
-- multiplication argument using zmulDistL (distributivity) + zmulInterchange + the
-- ℤ ring commutativity, mirroring qmulRespL/R with an extra distributivity step.
-- ============================================================================

-- ℤ addition is commutative — lift padd's componentwise addComm through ZRel.
-- padd p q ~ padd q p on representatives: both components commute by addComm.
paddComm : (p : NatPair) -> (q : NatPair) -> ZRel (padd p q) (padd q p) is
  fn (p : NatPair) (q : NatPair) is
    -- Goal: add (add (fst p) (fst q)) (add (snd q) (snd p))
    --     = add (add (fst q) (fst p)) (add (snd p) (snd q)).
    cong2 (fn (u : Nat) (v : Nat) is add u v end)
      (addComm (fst p) (fst q))
      (addComm (snd q) (snd p))
  end
end

zaddComm : (x : Z) -> (y : Z) -> Eq Z (zadd x y) (zadd y x) is
  fn (x : Z) is
    qind NatPair ZRel (fn (w : Z) is (y : Z) -> Eq Z (zadd w y) (zadd y w) end)
      (fn (p : NatPair) is
        fn (y : Z) is
          qind NatPair ZRel
            (fn (w : Z) is Eq Z (zadd (qin NatPair ZRel p) w) (zadd w (qin NatPair ZRel p)) end)
            (fn (q : NatPair) is
              qsound NatPair ZRel (padd p q) (padd q p) (paddComm p q)
            end)
            y
        end
      end)
      x
  end
end

-- ADDITION ON REPRESENTATIVES.  Numerator a·sd + c·sb; denominator the SAME product
-- index as multiplication, so zden (qaddP p q) = zmul (zden p) (zden q) by qmulDenZ.
qaddP : QPair -> QPair -> QPair is
  fn (p : QPair) (q : QPair) is
    qpair
      (zadd (zmul (qnum p) (zden q)) (zmul (qnum q) (zden p)))
      (qmulDen (qdenN p) (qdenN q))
  end
end

-- zden (qaddP p q) = zmul (zden p) (zden q) — same denominator index as qmulP.
qaddDenZ : (p : QPair) -> (q : QPair)
   -> Eq Z (zden (qaddP p q)) (zmul (zden p) (zden q)) is
  fn (p : QPair) (q : QPair) is
    zmulHom (succ (qdenN p)) (succ (qdenN q))
  end
end

-- RIGHT respect.  Given QRel q q' (nq·zd' = nq'·zd), show QRel (qaddP p q) (qaddP p q').
-- The numerator is a SUM, so distribute (zmulDistL) over the denominator product, then
-- handle the two terms:
--   term1 (np·zd)·(zb·zd') = (np·zd')·(zb·zd)   — pure regrouping, no hypothesis
--   term2 (nq·zb)·(zb·zd') = (nq'·zb)·(zb·zd)   — uses the hypothesis nq·zd' = nq'·zd
-- and reassemble with cong2Z.
qaddRespR : (p : QPair) -> (q : QPair) -> (q' : QPair) ->
    QRel q q' -> QRel (qaddP p q) (qaddP p q') is
  fn (p : QPair) (q : QPair) (q' : QPair) (h : QRel q q') is
    -- Goal: zmul (zadd (np·zd) (nq·zb)) (zden (qaddP p q'))
    --     = zmul (zadd (np·zd') (nq'·zb)) (zden (qaddP p q)).
    trans
      (cong (fn (s : Z) is zmul (zadd (zmul (qnum p) (zden q)) (zmul (qnum q) (zden p))) s end)
        (qaddDenZ p q'))
      (trans
        -- distribute the LHS over (zb·zd')
        (zmulDistL (zmul (qnum p) (zden q)) (zmul (qnum q) (zden p)) (zmul (zden p) (zden q')))
        (trans
          (cong2Z (fn (u : Z) (v : Z) is zadd u v end)
            -- term1: (np·zd)·(zb·zd') = (np·zd')·(zb·zd)
            (trans (zmulInterchange (qnum p) (zden q) (zden p) (zden q'))
              (trans (cong (fn (s : Z) is zmul (zmul (qnum p) (zden p)) s end)
                       (zmulComm (zden q) (zden q')))
                (sym (zmulInterchange (qnum p) (zden q') (zden p) (zden q)))))
            -- term2: (nq·zb)·(zb·zd') = (nq'·zb)·(zb·zd), via the hypothesis
            (trans (cong (fn (s : Z) is zmul (zmul (qnum q) (zden p)) s end)
                     (zmulComm (zden p) (zden q')))
              (trans (zmulInterchange (qnum q) (zden p) (zden q') (zden p))
                (trans (cong (fn (s : Z) is zmul s (zmul (zden p) (zden p)) end) h)
                  (trans (sym (zmulInterchange (qnum q') (zden p) (zden q) (zden p)))
                    (cong (fn (s : Z) is zmul (zmul (qnum q') (zden p)) s end)
                      (zmulComm (zden q) (zden p))))))))
          -- reassemble: zadd (…) (…) = zmul (zadd (np·zd') (nq'·zb)) (zden (qaddP p q))
          (trans
            (sym (zmulDistL (zmul (qnum p) (zden q')) (zmul (qnum q') (zden p)) (zmul (zden p) (zden q))))
            (cong (fn (s : Z) is zmul (zadd (zmul (qnum p) (zden q')) (zmul (qnum q') (zden p))) s end)
              (sym (qaddDenZ p q))))))
  end
end

-- LEFT respect.  Given QRel p p' (np·zb' = np'·zb), show QRel (qaddP p q) (qaddP p' q).
qaddRespL : (p : QPair) -> (p' : QPair) -> (q : QPair) ->
    QRel p p' -> QRel (qaddP p q) (qaddP p' q) is
  fn (p : QPair) (p' : QPair) (q : QPair) (h : QRel p p') is
    -- Goal: zmul (zadd (np·zd) (nq·zb)) (zden (qaddP p' q))
    --     = zmul (zadd (np'·zd) (nq·zb')) (zden (qaddP p q)).
    trans
      (cong (fn (s : Z) is zmul (zadd (zmul (qnum p) (zden q)) (zmul (qnum q) (zden p))) s end)
        (qaddDenZ p' q))
      (trans
        (zmulDistL (zmul (qnum p) (zden q)) (zmul (qnum q) (zden p)) (zmul (zden p') (zden q)))
        (trans
          (cong2Z (fn (u : Z) (v : Z) is zadd u v end)
            -- term1: (np·zd)·(zb'·zd) = (np'·zd)·(zb·zd), via hypothesis np·zb' = np'·zb
            (trans (zmulInterchange (qnum p) (zden q) (zden p') (zden q))
              (trans (cong (fn (s : Z) is zmul s (zmul (zden q) (zden q)) end) h)
                (sym (zmulInterchange (qnum p') (zden q) (zden p) (zden q)))))
            -- term2: (nq·zb)·(zb'·zd) = (nq·zb')·(zb·zd), pure regrouping (one interchange)
            (zmulInterchange (qnum q) (zden p) (zden p') (zden q)))
          (trans
            (sym (zmulDistL (zmul (qnum p') (zden q)) (zmul (qnum q) (zden p')) (zmul (zden p) (zden q))))
            (cong (fn (s : Z) is zmul (zadd (zmul (qnum p') (zden q)) (zmul (qnum q) (zden p'))) s end)
              (sym (qaddDenZ p q))))))
  end
end

qaddR : QPair -> Q -> Q is
  fn (p : QPair) is
    qlift QPair QRel Q
      (fn (q : QPair) is qin QPair QRel (qaddP p q) end)
      (fn (q : QPair) (q' : QPair) (r : QRel q q') is
        qsound QPair QRel (qaddP p q) (qaddP p q') (qaddRespR p q q' r)
      end)
  end
end

qadd : Q -> Q -> Q is
  qlift QPair QRel (Q -> Q) qaddR
    (fn (p : QPair) (p' : QPair) (r : QRel p p') is
      fn (z : Q) is
        qind QPair QRel (fn (w : Q) is Eq Q (qaddR p w) (qaddR p' w) end)
          (fn (q : QPair) is
            qsound QPair QRel (qaddP p q) (qaddP p' q) (qaddRespL p p' q r)
          end)
          z
      end
    end)
end

-- THE FIELD LAW: COMMUTATIVITY OF ℚ ADDITION.  x + y = y + x.
-- On representatives, qaddP p q ~ qaddP q p: the numerators commute (the two summands
-- swap, zaddComm) and the denominators commute (zmulComm), lined up via the same
-- denominator-rewrite + cong2 assembly as qmulCommP.
qaddCommP : (p : QPair) -> (q : QPair) -> QRel (qaddP p q) (qaddP q p) is
  fn (p : QPair) (q : QPair) is
    -- Goal: zmul (zadd (np·zd) (nq·zb)) (zden (qaddP q p))
    --     = zmul (zadd (nq·zb) (np·zd)) (zden (qaddP p q)).
    trans
      (cong (fn (s : Z) is zmul (zadd (zmul (qnum p) (zden q)) (zmul (qnum q) (zden p))) s end)
        (qaddDenZ q p))
      (trans
        (cong2Z (fn (u : Z) (v : Z) is zmul u v end)
          (zaddComm (zmul (qnum p) (zden q)) (zmul (qnum q) (zden p)))
          (zmulComm (zden q) (zden p)))
        (cong (fn (s : Z) is zmul (zadd (zmul (qnum q) (zden p)) (zmul (qnum p) (zden q))) s end)
          (sym (qaddDenZ p q))))
  end
end

qaddComm : (x : Q) -> (y : Q) -> Eq Q (qadd x y) (qadd y x) is
  fn (x : Q) is
    qind QPair QRel (fn (w : Q) is (y : Q) -> Eq Q (qadd w y) (qadd y w) end)
      (fn (p : QPair) is
        fn (y : Q) is
          qind QPair QRel
            (fn (w : Q) is Eq Q (qadd (qin QPair QRel p) w) (qadd w (qin QPair QRel p)) end)
            (fn (q : QPair) is
              qsound QPair QRel (qaddP p q) (qaddP q p) (qaddCommP p q)
            end)
            y
        end
      end)
      x
  end
end

-- Sanity: 1/2 + 1/2 = 1.  On representatives (1, succ 0) + (1, succ 0):
--   numerator = 1·2 + 1·2,  denominator index succ (qmulDen 1 1) = 2·2 = 4, i.e. 4/4-style;
-- it qsound-relates to 1/1 = qone. We pin the COMPUTED representative and prove it commutes.
qHalfPlusHalf : Q is qadd qHalf qHalf end

-- qadd qHalf qHalf computes to the explicit representative below (refl through the quotient).
qHalfSumRep : Q is
  qin QPair QRel
    (qpair (zadd (zmul zone (zden (qpair zone (succ zero))))
                 (zmul zone (zden (qpair zone (succ zero)))))
           (qmulDen (succ zero) (succ zero)))
end

qAddComputes : Eq Q (qadd qHalf qHalf) qHalfSumRep is
  refl (qadd qHalf qHalf)
end

-- Addition commutes on concrete rationals, by qaddComm.
qExAddComm : Eq Q (qadd qHalf qTwoOverOne) (qadd qTwoOverOne qHalf) is
  qaddComm qHalf qTwoOverOne
end

-- ============================================================================
-- CHAPTER 113 — CLOSING THE RING + FIELD STRUCTURE OF ℚ.
-- Everything above is the ch108 ℚ development (itself over the ch107 ℤ ring),
-- redeclared verbatim. Below: the remaining ring identities/axioms and the field
-- inverse. We first add the two ℤ lemmas ch108 omitted (zaddZeroR, zaddAssoc) and
-- a left-zero (zmulZeroL), then lift the ℚ ring laws through qind.
-- ============================================================================

-- ----------------------------------------------------------------------------
-- ℤ lemmas needed below (proven exactly as ch103/ch107, using ch108's Nat lemmas).
-- ----------------------------------------------------------------------------

-- LEFT ZERO: 0 · x = 0, from commutativity + zmulZeroR.
zmulZeroL : (x : Z) -> Eq Z (zmul zzero x) zzero is
  fn (x : Z) is
    trans (zmulComm zzero x) (zmulZeroR x)
  end
end

-- ADDITIVE RIGHT IDENTITY: z + 0 = z (ch103, restated with ch108's addZeroR).
zaddZeroR : (z : Z) -> Eq Z (zadd z zzero) z is
  fn (z : Z) is
    qind NatPair ZRel (fn (w : Z) is Eq Z (zadd w zzero) w end)
      (fn (p : NatPair) is
        qsound NatPair ZRel (padd p (npair zero zero)) p
          (trans (cong (fn (s : Nat) is add s (snd p) end) (addZeroR (fst p)))
            (cong (fn (s : Nat) is add (fst p) s end) (sym (addZeroR (snd p)))))
      end)
      z
  end
end

-- ADDITIVE ASSOCIATIVITY: (x + y) + z = x + (y + z) (ch103, verbatim).
zaddAssoc : (x : Z) -> (y : Z) -> (z : Z) ->
    Eq Z (zadd (zadd x y) z) (zadd x (zadd y z)) is
  fn (x : Z) is
    qind NatPair ZRel
      (fn (wx : Z) is (y : Z) -> (z : Z) -> Eq Z (zadd (zadd wx y) z) (zadd wx (zadd y z)) end)
      (fn (p : NatPair) is
        fn (y : Z) is
          qind NatPair ZRel
            (fn (wy : Z) is (z : Z) -> Eq Z (zadd (zadd (qin NatPair ZRel p) wy) z) (zadd (qin NatPair ZRel p) (zadd wy z)) end)
            (fn (q : NatPair) is
              fn (z : Z) is
                qind NatPair ZRel
                  (fn (wz : Z) is Eq Z (zadd (zadd (qin NatPair ZRel p) (qin NatPair ZRel q)) wz) (zadd (qin NatPair ZRel p) (zadd (qin NatPair ZRel q) wz)) end)
                  (fn (r : NatPair) is
                    qsound NatPair ZRel
                      (padd (padd p q) r) (padd p (padd q r))
                      (trans (cong (fn (s : Nat) is add s (add (snd p) (add (snd q) (snd r))) end)
                                (addAssoc (fst p) (fst q) (fst r)))
                        (cong (fn (s : Nat) is add (add (fst p) (add (fst q) (fst r))) s end)
                                (sym (addAssoc (snd p) (snd q) (snd r)))))
                  end)
                  z
              end
            end)
            y
        end
      end)
      x
  end
end

-- ----------------------------------------------------------------------------
-- RING IDENTITY (×):  x · 1 = x.   qone = qin (1/1).
-- On a representative p: qmulP p (1,0) = ((np·1) / (zb·1)), and the QRel obligation
--   (np·1)·zb = np·(zb·1)  reduces — both sides to np·zb — by zmulOneR twice + qmulDenZ.
-- ----------------------------------------------------------------------------
qmulOneRP : (p : QPair) -> QRel (qmulP p (qpair zone zero)) p is
  fn (p : QPair) is
    -- Goal: zmul (zmul (qnum p) zone) (zden p) = zmul (qnum p) (zden (qmulP p (qpair zone zero)))
    trans
      (cong (fn (s : Z) is zmul s (zden p) end) (zmulOneR (qnum p)))
      (sym
        (trans
          (cong (fn (s : Z) is zmul (qnum p) s end) (qmulDenZ p (qpair zone zero)))
          (cong (fn (s : Z) is zmul (qnum p) s end) (zmulOneR (zden p)))))
  end
end

qmulOneR : (x : Q) -> Eq Q (qmul x qone) x is
  fn (x : Q) is
    qind QPair QRel (fn (w : Q) is Eq Q (qmul w qone) w end)
      (fn (p : QPair) is
        qsound QPair QRel (qmulP p (qpair zone zero)) p (qmulOneRP p)
      end)
      x
  end
end

-- ----------------------------------------------------------------------------
-- RING IDENTITY (+):  x + 0 = x.   qzero = qin (0/1).
-- On p: qaddP p (0,0) numerator = (np·1) + (0·zb) = np; denominator = zb·1 = zb.
-- The QRel obligation np·zb = np·zb after the numerator collapses (zmulOneR + zmulZeroL
-- + zaddZeroR) and the denominator collapses (qaddDenZ + zmulOneR).
-- ----------------------------------------------------------------------------
qaddZeroP : (p : QPair) -> QRel (qaddP p (qpair zzero zero)) p is
  fn (p : QPair) is
    -- Goal: zmul (zadd (zmul (qnum p) zone) (zmul zzero (zden p))) (zden p)
    --     = zmul (qnum p) (zden (qaddP p (qpair zzero zero)))
    trans
      (cong (fn (s : Z) is zmul s (zden p) end)
        (trans
          (cong2Z (fn (u : Z) (v : Z) is zadd u v end)
            (zmulOneR (qnum p))
            (zmulZeroL (zden p)))
          (zaddZeroR (qnum p))))
      (sym
        (trans
          (cong (fn (s : Z) is zmul (qnum p) s end) (qaddDenZ p (qpair zzero zero)))
          (cong (fn (s : Z) is zmul (qnum p) s end) (zmulOneR (zden p)))))
  end
end

qaddZero : (x : Q) -> Eq Q (qadd x qzero) x is
  fn (x : Q) is
    qind QPair QRel (fn (w : Q) is Eq Q (qadd w qzero) w end)
      (fn (p : QPair) is
        qsound QPair QRel (qaddP p (qpair zzero zero)) p (qaddZeroP p)
      end)
      x
  end
end

-- ----------------------------------------------------------------------------
-- RING AXIOM (× ASSOCIATIVITY):  (x · y) · z = x · (y · z).
-- Triple qind. On representatives the numerators are zmulAssoc-equal and the
-- denominators (after qmulDenZ unfolds each product) are zmulAssoc-equal, so the
-- cross-multiplied QRel obligation is cong2Z (numerator-assoc) (denominator-assoc).
-- ----------------------------------------------------------------------------
qmulAssocP : (p : QPair) -> (q : QPair) -> (r : QPair)
   -> QRel (qmulP (qmulP p q) r) (qmulP p (qmulP q r)) is
  fn (p : QPair) (q : QPair) (r : QPair) is
    -- Goal: zmul (zmul (zmul (qnum p) (qnum q)) (qnum r)) (zden (qmulP p (qmulP q r)))
    --     = zmul (zmul (qnum p) (zmul (qnum q) (qnum r))) (zden (qmulP (qmulP p q) r))
    trans
      -- rewrite RHS denominator -> zmul (zden p) (zmul (zden q) (zden r))
      (cong (fn (s : Z) is zmul (zmul (zmul (qnum p) (qnum q)) (qnum r)) s end)
        (trans (qmulDenZ p (qmulP q r))
          (cong (fn (s : Z) is zmul (zden p) s end) (qmulDenZ q r))))
      (trans
        -- numerator-assoc + denominator (right-grouped -> left-grouped)
        (cong2Z (fn (u : Z) (v : Z) is zmul u v end)
          (zmulAssoc (qnum p) (qnum q) (qnum r))
          (sym (zmulAssoc (zden p) (zden q) (zden r))))
        -- fold the (now left-grouped) denominator back to zden (qmulP (qmulP p q) r)
        (cong (fn (s : Z) is zmul (zmul (qnum p) (zmul (qnum q) (qnum r))) s end)
          (sym (trans (qmulDenZ (qmulP p q) r)
            (cong (fn (s : Z) is zmul s (zden r) end) (qmulDenZ p q))))))
  end
end

qmulAssoc : (x : Q) -> (y : Q) -> (z : Q)
   -> Eq Q (qmul (qmul x y) z) (qmul x (qmul y z)) is
  fn (x : Q) is
    qind QPair QRel
      (fn (wx : Q) is (y : Q) -> (z : Q) -> Eq Q (qmul (qmul wx y) z) (qmul wx (qmul y z)) end)
      (fn (p : QPair) is
        fn (y : Q) is
          qind QPair QRel
            (fn (wy : Q) is (z : Q) -> Eq Q (qmul (qmul (qin QPair QRel p) wy) z) (qmul (qin QPair QRel p) (qmul wy z)) end)
            (fn (q : QPair) is
              fn (z : Q) is
                qind QPair QRel
                  (fn (wz : Q) is Eq Q (qmul (qmul (qin QPair QRel p) (qin QPair QRel q)) wz) (qmul (qin QPair QRel p) (qmul (qin QPair QRel q) wz)) end)
                  (fn (r : QPair) is
                    qsound QPair QRel
                      (qmulP (qmulP p q) r) (qmulP p (qmulP q r))
                      (qmulAssocP p q r)
                  end)
                  z
              end
            end)
            y
        end
      end)
      x
  end
end

-- ----------------------------------------------------------------------------
-- RING AXIOM (+ ASSOCIATIVITY):  (x + y) + z = x + (y + z).
-- The cross-multiplication obligation, with all denominators rewritten to products
-- by qaddDenZ, is the pure ℤ identity below in the six values a,b,c (numerators)
-- and x,y,z (denominators). Both numerators equal  a·y·z + b·x·z + c·x·y  (modulo
-- ℤ assoc/comm), and the two outer denominators are zmulAssoc-equal; assemble by cong2Z.
-- ----------------------------------------------------------------------------

-- numerator identity:  ((a·y + b·x)·z + c·(x·y))  =  (a·(y·z) + (b·z + c·y)·x).
qaddAssocNum : (a : Z) -> (b : Z) -> (c : Z) -> (x : Z) -> (y : Z) -> (z : Z)
   -> Eq Z
        (zadd (zmul (zadd (zmul a y) (zmul b x)) z) (zmul c (zmul x y)))
        (zadd (zmul a (zmul y z)) (zmul (zadd (zmul b z) (zmul c y)) x)) is
  fn (a : Z) (b : Z) (c : Z) (x : Z) (y : Z) (z : Z) is
    trans
      -- distribute the first product:  (a·y + b·x)·z = (a·y)·z + (b·x)·z
      (cong (fn (s : Z) is zadd s (zmul c (zmul x y)) end)
        (zmulDistL (zmul a y) (zmul b x) z))
      (trans
        -- reassociate the outer sum to the right
        (zaddAssoc (zmul (zmul a y) z) (zmul (zmul b x) z) (zmul c (zmul x y)))
        (trans
          -- term-by-term match against the RHS (after distributing its second product)
          (cong2Z (fn (u : Z) (v : Z) is zadd u v end)
            -- T1: (a·y)·z = a·(y·z)
            (zmulAssoc a y z)
            (cong2Z (fn (u : Z) (v : Z) is zadd u v end)
              -- T2: (b·x)·z = (b·z)·x
              (trans (zmulAssoc b x z)
                (trans (cong (fn (s : Z) is zmul b s end) (zmulComm x z))
                  (sym (zmulAssoc b z x))))
              -- T3: c·(x·y) = (c·y)·x
              (trans (cong (fn (s : Z) is zmul c s end) (zmulComm x y))
                (sym (zmulAssoc c y x)))))
          -- fold RHS second product back:  (b·z)·x + (c·y)·x = (b·z + c·y)·x
          (cong (fn (s : Z) is zadd (zmul a (zmul y z)) s end)
            (sym (zmulDistL (zmul b z) (zmul c y) x)))))
  end
end

-- The full QRel obligation, threading qaddDenZ on each of the four denominator
-- occurrences and dispatching the resulting pure-ℤ identity by qaddAssocNum.
qaddAssocP : (p : QPair) -> (q : QPair) -> (r : QPair)
   -> QRel (qaddP (qaddP p q) r) (qaddP p (qaddP q r)) is
  fn (p : QPair) (q : QPair) (r : QPair) is
    trans
      -- (1a) rewrite the inner denominator zden (qaddP p q) -> zmul (zden p) (zden q)
      (cong (fn (s : Z) is
               zmul (zadd (zmul (zadd (zmul (qnum p) (zden q)) (zmul (qnum q) (zden p))) (zden r))
                          (zmul (qnum r) s))
                    (zden (qaddP p (qaddP q r))) end)
        (qaddDenZ p q))
      (trans
        -- (1b) rewrite the outer right denominator -> zmul (zden p) (zmul (zden q) (zden r))
        (cong (fn (s : Z) is
                 zmul (zadd (zmul (zadd (zmul (qnum p) (zden q)) (zmul (qnum q) (zden p))) (zden r))
                            (zmul (qnum r) (zmul (zden p) (zden q))))
                      s end)
          (trans (qaddDenZ p (qaddP q r))
            (cong (fn (s : Z) is zmul (zden p) s end) (qaddDenZ q r))))
        (trans
          -- (2) the pure ℤ identity: numerator by qaddAssocNum, denominator by zmulAssoc
          (cong2Z (fn (u : Z) (v : Z) is zmul u v end)
            (qaddAssocNum (qnum p) (qnum q) (qnum r) (zden p) (zden q) (zden r))
            (sym (zmulAssoc (zden p) (zden q) (zden r))))
          (trans
            -- (3a) fold zmul (zden q) (zden r) back to zden (qaddP q r) in the numerator
            (cong (fn (s : Z) is
                     zmul (zadd (zmul (qnum p) s)
                                (zmul (zadd (zmul (qnum q) (zden r)) (zmul (qnum r) (zden q))) (zden p)))
                          (zmul (zmul (zden p) (zden q)) (zden r)) end)
              (sym (qaddDenZ q r)))
            -- (3b) fold the outer left denominator back to zden (qaddP (qaddP p q) r)
            (cong (fn (s : Z) is
                     zmul (zadd (zmul (qnum p) (zden (qaddP q r)))
                                (zmul (zadd (zmul (qnum q) (zden r)) (zmul (qnum r) (zden q))) (zden p)))
                          s end)
              (sym (trans (qaddDenZ (qaddP p q) r)
                (cong (fn (s : Z) is zmul s (zden r) end) (qaddDenZ p q))))))))
  end
end

qaddAssoc : (x : Q) -> (y : Q) -> (z : Q)
   -> Eq Q (qadd (qadd x y) z) (qadd x (qadd y z)) is
  fn (x : Q) is
    qind QPair QRel
      (fn (wx : Q) is (y : Q) -> (z : Q) -> Eq Q (qadd (qadd wx y) z) (qadd wx (qadd y z)) end)
      (fn (p : QPair) is
        fn (y : Q) is
          qind QPair QRel
            (fn (wy : Q) is (z : Q) -> Eq Q (qadd (qadd (qin QPair QRel p) wy) z) (qadd (qin QPair QRel p) (qadd wy z)) end)
            (fn (q : QPair) is
              fn (z : Q) is
                qind QPair QRel
                  (fn (wz : Q) is Eq Q (qadd (qadd (qin QPair QRel p) (qin QPair QRel q)) wz) (qadd (qin QPair QRel p) (qadd (qin QPair QRel q) wz)) end)
                  (fn (r : QPair) is
                    qsound QPair QRel
                      (qaddP (qaddP p q) r) (qaddP p (qaddP q r))
                      (qaddAssocP p q r)
                  end)
                  z
              end
            end)
            y
        end
      end)
      x
  end
end

-- ----------------------------------------------------------------------------
-- RING AXIOM (LEFT DISTRIBUTIVITY):  x · (y + z) = x·y + x·z.   The heaviest law.
-- After rewriting every denominator to a product, the cross-multiplication obligation
-- is the pure ℤ identity  numL · denR = numR · denL  where, crucially,
--   numR = zp · numL   and   denR = zp · denL
-- (the RHS carries an extra factor zp from the duplicated denominator), so the identity
-- collapses to a pure assoc/comm rearrangement once those two factorings are supplied.
-- ----------------------------------------------------------------------------

-- denominator factoring:  (zp·zq)·(zp·zr) = zp·(zp·(zq·zr)).
qmulDistDen : (zp : Z) -> (zq : Z) -> (zr : Z)
   -> Eq Z (zmul (zmul zp zq) (zmul zp zr)) (zmul zp (zmul zp (zmul zq zr))) is
  fn (zp : Z) (zq : Z) (zr : Z) is
    trans (zmulInterchange zp zq zp zr) (zmulAssoc zp zp (zmul zq zr))
  end
end

-- numerator factoring:
--   (np·nq)·(zp·zr) + (np·nr)·(zp·zq)  =  zp·(np·(nq·zr + nr·zq)).
qmulDistNum : (np : Z) -> (nq : Z) -> (nr : Z) -> (zp : Z) -> (zq : Z) -> (zr : Z)
   -> Eq Z
        (zadd (zmul (zmul np nq) (zmul zp zr)) (zmul (zmul np nr) (zmul zp zq)))
        (zmul zp (zmul np (zadd (zmul nq zr) (zmul nr zq)))) is
  fn (np : Z) (nq : Z) (nr : Z) (zp : Z) (zq : Z) (zr : Z) is
    trans
      (cong2Z (fn (u : Z) (v : Z) is zadd u v end)
        -- (np·nq)·(zp·zr) = zp·(np·(nq·zr))
        (trans (zmulInterchange np nq zp zr)
          (trans (cong (fn (s : Z) is zmul s (zmul nq zr) end) (zmulComm np zp))
            (zmulAssoc zp np (zmul nq zr))))
        -- (np·nr)·(zp·zq) = zp·(np·(nr·zq))
        (trans (zmulInterchange np nr zp zq)
          (trans (cong (fn (s : Z) is zmul s (zmul nr zq) end) (zmulComm np zp))
            (zmulAssoc zp np (zmul nr zq)))))
      -- fold:  zp·(np·(nq·zr)) + zp·(np·(nr·zq)) = zp·(np·(nq·zr + nr·zq))
      (sym
        (trans (cong (fn (s : Z) is zmul zp s end)
                 (zmulDistR np (zmul nq zr) (zmul nr zq)))
          (zmulDistR zp (zmul np (zmul nq zr)) (zmul np (zmul nr zq)))))
  end
end

-- the pure-ℤ cross identity (everything in product-denominator form).
qmulDistCross : (np : Z) -> (nq : Z) -> (nr : Z) -> (zp : Z) -> (zq : Z) -> (zr : Z)
   -> Eq Z
        (zmul (zmul np (zadd (zmul nq zr) (zmul nr zq)))
              (zmul (zmul zp zq) (zmul zp zr)))
        (zmul (zadd (zmul (zmul np nq) (zmul zp zr)) (zmul (zmul np nr) (zmul zp zq)))
              (zmul zp (zmul zq zr))) is
  fn (np : Z) (nq : Z) (nr : Z) (zp : Z) (zq : Z) (zr : Z) is
    trans
      -- denR = zp·denL
      (cong (fn (s : Z) is zmul (zmul np (zadd (zmul nq zr) (zmul nr zq))) s end)
        (qmulDistDen zp zq zr))
      (trans
        -- numL·(zp·denL) = (numL·zp)·denL
        (sym (zmulAssoc (zmul np (zadd (zmul nq zr) (zmul nr zq))) zp (zmul zp (zmul zq zr))))
        (trans
          -- (numL·zp)·denL = (zp·numL)·denL
          (cong (fn (s : Z) is zmul s (zmul zp (zmul zq zr)) end)
            (zmulComm (zmul np (zadd (zmul nq zr) (zmul nr zq))) zp))
          -- (zp·numL)·denL = numR·denL    (numR = zp·numL, reversed)
          (cong (fn (s : Z) is zmul s (zmul zp (zmul zq zr)) end)
            (sym (qmulDistNum np nq nr zp zq zr)))))
  end
end

-- The full QRel obligation for distributivity, threading qaddDenZ/qmulDenZ on the four
-- denominator occurrences and dispatching the pure-ℤ identity by qmulDistCross.
qmulDistRP : (p : QPair) -> (q : QPair) -> (r : QPair)
   -> QRel (qmulP p (qaddP q r)) (qaddP (qmulP p q) (qmulP p r)) is
  fn (p : QPair) (q : QPair) (r : QPair) is
    trans
      -- rewrite the LHS denominator  zden (qaddP (qmulP p q) (qmulP p r))
      --   -> zmul (zmul (zden p) (zden q)) (zmul (zden p) (zden r))
      (cong (fn (s : Z) is
               zmul (zmul (qnum p) (zadd (zmul (qnum q) (zden r)) (zmul (qnum r) (zden q)))) s end)
        (trans (qaddDenZ (qmulP p q) (qmulP p r))
          (cong2Z (fn (u : Z) (v : Z) is zmul u v end) (qmulDenZ p q) (qmulDenZ p r))))
      (trans
        -- the pure ℤ cross identity
        (qmulDistCross (qnum p) (qnum q) (qnum r) (zden p) (zden q) (zden r))
        (trans
          -- fold the numerator denominators back:  zmul (zden p) (zden r) -> zden (qmulP p r)
          --   and zmul (zden p) (zden q) -> zden (qmulP p q)
          (cong (fn (s : Z) is zmul s (zmul (zden p) (zmul (zden q) (zden r))) end)
            (cong2Z (fn (u : Z) (v : Z) is zadd u v end)
              (cong (fn (s : Z) is zmul (zmul (qnum p) (qnum q)) s end) (sym (qmulDenZ p r)))
              (cong (fn (s : Z) is zmul (zmul (qnum p) (qnum r)) s end) (sym (qmulDenZ p q)))))
          -- fold the RHS (LHS-rep) denominator back to  zden (qmulP p (qaddP q r))
          (cong (fn (s : Z) is
                   zmul (zadd (zmul (zmul (qnum p) (qnum q)) (zden (qmulP p r)))
                              (zmul (zmul (qnum p) (qnum r)) (zden (qmulP p q)))) s end)
            (sym (trans (qmulDenZ p (qaddP q r))
              (cong (fn (s : Z) is zmul (zden p) s end) (qaddDenZ q r)))))))
  end
end

qmulDistR : (x : Q) -> (y : Q) -> (z : Q)
   -> Eq Q (qmul x (qadd y z)) (qadd (qmul x y) (qmul x z)) is
  fn (x : Q) is
    qind QPair QRel
      (fn (wx : Q) is (y : Q) -> (z : Q) -> Eq Q (qmul wx (qadd y z)) (qadd (qmul wx y) (qmul wx z)) end)
      (fn (p : QPair) is
        fn (y : Q) is
          qind QPair QRel
            (fn (wy : Q) is (z : Q) -> Eq Q (qmul (qin QPair QRel p) (qadd wy z)) (qadd (qmul (qin QPair QRel p) wy) (qmul (qin QPair QRel p) z)) end)
            (fn (q : QPair) is
              fn (z : Q) is
                qind QPair QRel
                  (fn (wz : Q) is Eq Q (qmul (qin QPair QRel p) (qadd (qin QPair QRel q) wz)) (qadd (qmul (qin QPair QRel p) (qin QPair QRel q)) (qmul (qin QPair QRel p) wz)) end)
                  (fn (r : QPair) is
                    qsound QPair QRel
                      (qmulP p (qaddP q r)) (qaddP (qmulP p q) (qmulP p r))
                      (qmulDistRP p q r)
                  end)
                  z
              end
            end)
            y
        end
      end)
      x
  end
end

-- ============================================================================
-- CHAPTER 119 — ℚ AS AN ORDERED FIELD.
-- Everything above is the ch117 ℚ-field development (over the ch107 ℤ ring),
-- redeclared verbatim. Below is the NEW order layer.
-- ============================================================================

-- ----------------------------------------------------------------------------
-- The Boolean order toolkit (ch65/ch80/ch82/ch83), redeclared verbatim.
-- ----------------------------------------------------------------------------

data Bool : U is
  true  : Bool
| false : Bool
end

-- lte a b = (a <= b): zero is below everything; succ k <= zero is false; succ k <=
-- succ m recurses to k <= m. Recurses on its FIRST argument.
lte : Nat -> Nat -> Bool is
  fn (a : Nat) is
    NatElim (fn (x : Nat) is Nat -> Bool end)
      (fn (n : Nat) is true end)
      (fn (k : Nat) (ih : Nat -> Bool) is
         fn (n : Nat) is
           NatElim (fn (y : Nat) is Bool end)
             false
             (fn (m : Nat) (ih2 : Bool) is ih m end)
             n
         end
       end)
      a
  end
end

-- or a b = Boolean disjunction by BoolElim on the first argument (ch83).
or : Bool -> Bool -> Bool is
  fn (a : Bool) (b : Bool) is
    BoolElim (fn (x : Bool) is Bool end) true b a
  end
end

-- REFLEXIVITY of lte (ch65).
lteRefl : (n : Nat) -> Eq Bool (lte n n) true is
  fn (n : Nat) is
    NatElim (fn (x : Nat) is Eq Bool (lte x x) true end)
      (refl true)
      (fn (k : Nat) (ih : Eq Bool (lte k k) true) is ih end)
      n
  end
end

-- ABSURDITY from `false = true`: any lte equation (ch80 idiom).
lteAbsurd : (a : Nat) -> (c : Nat) -> Eq Bool false true -> Eq Bool (lte a c) true is
  fn (a : Nat) (c : Nat) (h : Eq Bool false true) is
    subst Bool false true h
      (fn (z : Bool) is
         case z of
         | true  -> Eq Bool (lte a c) true
         | false -> Eq Bool true true
         end
       end)
      (refl true)
  end
end

-- ABSURDITY from `false = true`: any Nat equation (ch82 idiom).
lteAbsurdNat : (a : Nat) -> (b : Nat) -> Eq Bool false true -> Eq Nat a b is
  fn (a : Nat) (b : Nat) (h : Eq Bool false true) is
    subst Bool false true h
      (fn (z : Bool) is
         case z of
         | true  -> Eq Nat a b
         | false -> Eq Nat a a
         end
       end)
      (refl a)
  end
end

-- TRANSITIVITY of lte (ch80, verbatim).
lteTrans : (a : Nat) -> (b : Nat) -> (c : Nat)
   -> Eq Bool (lte a b) true -> Eq Bool (lte b c) true -> Eq Bool (lte a c) true is
  fn (a : Nat) is
    NatElim
      (fn (x : Nat) is
         (b : Nat) -> (c : Nat)
           -> Eq Bool (lte x b) true -> Eq Bool (lte b c) true
           -> Eq Bool (lte x c) true end)
      (fn (b : Nat) (c : Nat)
          (hab : Eq Bool (lte zero b) true) (hbc : Eq Bool (lte b c) true) is
         refl true end)
      (fn (a' : Nat)
          (ih : (b : Nat) -> (c : Nat)
                  -> Eq Bool (lte a' b) true -> Eq Bool (lte b c) true
                  -> Eq Bool (lte a' c) true) is
         fn (b : Nat) is
           NatElim
             (fn (y : Nat) is
                (c : Nat)
                  -> Eq Bool (lte (succ a') y) true -> Eq Bool (lte y c) true
                  -> Eq Bool (lte (succ a') c) true end)
             (fn (c : Nat)
                 (hab : Eq Bool false true) (hbc : Eq Bool (lte zero c) true) is
                lteAbsurd (succ a') c hab end)
             (fn (b' : Nat)
                 (ihb : (c : Nat)
                          -> Eq Bool (lte (succ a') b') true
                          -> Eq Bool (lte b' c) true
                          -> Eq Bool (lte (succ a') c) true) is
                fn (c : Nat) is
                  NatElim
                    (fn (z : Nat) is
                       Eq Bool (lte (succ a') (succ b')) true
                         -> Eq Bool (lte (succ b') z) true
                         -> Eq Bool (lte (succ a') z) true end)
                    (fn (hab : Eq Bool (lte a' b') true)
                        (hbc : Eq Bool false true) is
                       lteAbsurd (succ a') zero hbc end)
                    (fn (c' : Nat)
                        (ihc : Eq Bool (lte (succ a') (succ b')) true
                                 -> Eq Bool (lte (succ b') c') true
                                 -> Eq Bool (lte (succ a') c') true) is
                       fn (hab : Eq Bool (lte a' b') true)
                          (hbc : Eq Bool (lte b' c') true) is
                         ih b' c' hab hbc end
                     end)
                    c
                end
              end)
             b
         end
       end)
      a
  end
end

-- ANTISYMMETRY of lte (ch82, verbatim).
lteAntisym : (a : Nat) -> (b : Nat)
   -> Eq Bool (lte a b) true -> Eq Bool (lte b a) true -> Eq Nat a b is
  fn (a : Nat) is
    NatElim
      (fn (x : Nat) is
         (b : Nat)
           -> Eq Bool (lte x b) true -> Eq Bool (lte b x) true
           -> Eq Nat x b end)
      (fn (b : Nat) is
         NatElim
           (fn (y : Nat) is
              Eq Bool (lte zero y) true -> Eq Bool (lte y zero) true
                -> Eq Nat zero y end)
           (fn (hab : Eq Bool (lte zero zero) true)
               (hba : Eq Bool (lte zero zero) true) is
              refl zero end)
           (fn (b' : Nat)
               (ihb : Eq Bool (lte zero b') true -> Eq Bool (lte b' zero) true
                        -> Eq Nat zero b') is
              fn (hab : Eq Bool (lte zero (succ b')) true)
                 (hba : Eq Bool false true) is
                lteAbsurdNat zero (succ b') hba end
            end)
           b
       end)
      (fn (a' : Nat)
          (ih : (b : Nat)
                  -> Eq Bool (lte a' b) true -> Eq Bool (lte b a') true
                  -> Eq Nat a' b) is
         fn (b : Nat) is
           NatElim
             (fn (y : Nat) is
                Eq Bool (lte (succ a') y) true -> Eq Bool (lte y (succ a')) true
                  -> Eq Nat (succ a') y end)
             (fn (hab : Eq Bool false true)
                 (hba : Eq Bool (lte zero (succ a')) true) is
                lteAbsurdNat (succ a') zero hab end)
             (fn (b' : Nat)
                 (ihb : Eq Bool (lte (succ a') b') true
                          -> Eq Bool (lte b' (succ a')) true
                          -> Eq Nat (succ a') b') is
                fn (hab : Eq Bool (lte a' b') true)
                   (hba : Eq Bool (lte b' a') true) is
                  subst Nat a' b' (ih b' hab hba)
                    (fn (z : Nat) is Eq Nat (succ a') (succ z) end)
                    (refl (succ a'))
                end
              end)
             b
         end
       end)
      a
  end
end

-- TOTALITY of lte (ch83, verbatim).
lteTotal : (a : Nat) -> (b : Nat)
   -> Eq Bool (or (lte a b) (lte b a)) true is
  fn (a : Nat) is
    NatElim
      (fn (x : Nat) is
         (b : Nat) -> Eq Bool (or (lte x b) (lte b x)) true end)
      (fn (b : Nat) is refl true end)
      (fn (a' : Nat)
          (ih : (b : Nat) -> Eq Bool (or (lte a' b) (lte b a')) true) is
         fn (b : Nat) is
           NatElim
             (fn (y : Nat) is
                Eq Bool (or (lte (succ a') y) (lte y (succ a'))) true end)
             (refl true)
             (fn (b' : Nat)
                 (ihb : Eq Bool (or (lte (succ a') b') (lte b' (succ a'))) true) is
                ih b'
              end)
             b
         end
       end)
      a
  end
end

-- ----------------------------------------------------------------------------
-- NEW Nat-order lemmas: the cancellation + monotonicity algebra that powers the
-- well-definedness of zle / qle.  All by induction; no admits.
-- ----------------------------------------------------------------------------

-- LEFT CANCELLATION (as a Bool equality):  lte (k + x) (k + y) = lte x y.
-- By induction on k: add zero x = x definitionally (base, refl); add (succ k) x =
-- succ (add k x), and lte (succ _) (succ _) reduces to lte _ _, so the succ step IS
-- the IH on the nose.
lteAddCancelL : (k : Nat) -> (x : Nat) -> (y : Nat)
   -> Eq Bool (lte (add k x) (add k y)) (lte x y) is
  fn (k : Nat) (x : Nat) (y : Nat) is
    NatElim (fn (z : Nat) is Eq Bool (lte (add z x) (add z y)) (lte x y) end)
      (refl (lte x y))
      (fn (j : Nat) (ih : Eq Bool (lte (add j x) (add j y)) (lte x y)) is ih end)
      k
  end
end

-- RIGHT CANCELLATION:  lte (x + k) (y + k) = lte x y.  Convert each side to the
-- left-cancellation form with addComm, then apply lteAddCancelL.
lteAddCancelR : (k : Nat) -> (x : Nat) -> (y : Nat)
   -> Eq Bool (lte (add x k) (add y k)) (lte x y) is
  fn (k : Nat) (x : Nat) (y : Nat) is
    trans
      (cong2 (fn (u : Nat) (v : Nat) is lte u v end)
        (addComm x k) (addComm y k))
      (lteAddCancelL k x y)
  end
end

-- ADD A CONSTANT TO BOTH SIDES (forward, true-direction): from lte x y = true derive
-- lte (x + k) (y + k) = true.  (The reverse of lteAddCancelR.)
lteAddBothR : (k : Nat) -> (x : Nat) -> (y : Nat)
   -> Eq Bool (lte x y) true -> Eq Bool (lte (add x k) (add y k)) true is
  fn (k : Nat) (x : Nat) (y : Nat) (h : Eq Bool (lte x y) true) is
    trans (lteAddCancelR k x y) h
  end
end

-- MONOTONICITY OF ADDITION over the order:  lte x y = true and lte u v = true imply
-- lte (x + u) (y + v) = true.  Bridge through lte (y + u): the first step adds u on the
-- right to x <= y (lteAddBothR), the second adds y on the left to u <= v
-- (via lteAddCancelL reversed), then lteTrans.
lteAddMono : (x : Nat) -> (y : Nat) -> (u : Nat) -> (v : Nat)
   -> Eq Bool (lte x y) true -> Eq Bool (lte u v) true
   -> Eq Bool (lte (add x u) (add y v)) true is
  fn (x : Nat) (y : Nat) (u : Nat) (v : Nat)
     (hxy : Eq Bool (lte x y) true) (huv : Eq Bool (lte u v) true) is
    lteTrans (add x u) (add y u) (add y v)
      -- x + u <= y + u  (right-add u to x <= y)
      (lteAddBothR u x y hxy)
      -- y + u <= y + v  (left-add y to u <= v): lte (y+u)(y+v) = lte u v = true
      (trans (lteAddCancelL y u v) huv)
  end
end

-- ----------------------------------------------------------------------------
-- THE ℤ ORDER.  On representatives (a,b) (denoting a−b) and (c,d) (denoting c−d):
--   (a,b) ≤ (c,d)   iff   a + d ≤ c + b      (in Nat, via lte).
-- This is the standard difference order; it respects ZRel by Nat add-cancellation.
-- ----------------------------------------------------------------------------
zleP : NatPair -> NatPair -> Bool is
  fn (p : NatPair) (q : NatPair) is
    lte (add (fst p) (snd q)) (add (fst q) (snd p))
  end
end

-- A 3-term reorder:  (x + y) + z = (x + z) + y.   (addAssoc to the right, addComm the
-- inner pair, addAssoc back.)  The shuffling workhorse for the zle respect proofs.
add3swap : (x : Nat) -> (y : Nat) -> (z : Nat)
   -> Eq Nat (add (add x y) z) (add (add x z) y) is
  fn (x : Nat) (y : Nat) (z : Nat) is
    trans (addAssoc x y z)
      (trans (cong (fn (s : Nat) is add x s end) (addComm y z))
        (sym (addAssoc x z y)))
  end
end

-- RIGHT RESPECT: ZRel q q' (i.e. fst q + snd q' = fst q' + snd q) implies
--   zleP p q = zleP p q'.   Both sides are made equal by adding the *other's*
-- second-component on both sides (sym lteAddCancelR), then a pure Nat reorder lands
-- them on the common canonical form, the ZRel hypothesis crossing in the right slot.
zleRespR : (p : NatPair) -> (q : NatPair) -> (q' : NatPair) ->
    ZRel q q' -> Eq Bool (zleP p q) (zleP p q') is
  fn (p : NatPair) (q : NatPair) (q' : NatPair) (h : ZRel q q') is
    -- LHS = lte (a + dq) (cq + b);  RHS = lte (a + dq') (cq' + b),
    -- where a=fst p, b=snd p, cq=fst q, dq=snd q, cq'=fst q', dq'=snd q'.
    -- hyp h : add cq dq' = add cq' dq.
    trans
      -- LHS = lte ((a+dq)+dq') ((cq+b)+dq')      [add dq' both sides]
      (sym (lteAddCancelR (snd q') (add (fst p) (snd q)) (add (fst q) (snd p))))
      (trans
        -- rewrite both args to the common canonical form
        (cong2 (fn (u : Nat) (v : Nat) is lte u v end)
          -- (a+dq)+dq' = (a+dq')+dq
          (add3swap (fst p) (snd q) (snd q'))
          -- (cq+b)+dq' = (cq'+b)+dq :
          --   (cq+b)+dq' = (cq+dq')+b   [add3swap]
          --             = (cq'+dq)+b    [h]
          --             = (cq'+b)+dq    [add3swap back]
          (trans (add3swap (fst q) (snd p) (snd q'))
            (trans (cong (fn (s : Nat) is add s (snd p) end) h)
              (add3swap (fst q') (snd q) (snd p)))))
        -- RHS = lte ((a+dq')+dq) ((cq'+b)+dq)     [cancel dq]
        (lteAddCancelR (snd q) (add (fst p) (snd q')) (add (fst q') (snd p))))
  end
end

-- LEFT RESPECT: ZRel p p' implies zleP p q = zleP p' q.  Symmetric shuffle; the
-- hypothesis crosses in the FIRST slot this time.
zleRespL : (p : NatPair) -> (p' : NatPair) -> (q : NatPair) ->
    ZRel p p' -> Eq Bool (zleP p q) (zleP p' q) is
  fn (p : NatPair) (p' : NatPair) (q : NatPair) (h : ZRel p p') is
    -- LHS = lte (ap + dq) (cq + bp);  RHS = lte (ap' + dq) (cq + bp'),
    -- ap=fst p, bp=snd p, ap'=fst p', bp'=snd p', cq=fst q, dq=snd q.
    -- hyp h : add ap bp' = add ap' bp.
    trans
      -- add bp' both sides
      (sym (lteAddCancelR (snd p') (add (fst p) (snd q)) (add (fst q) (snd p))))
      (trans
        (cong2 (fn (u : Nat) (v : Nat) is lte u v end)
          -- (ap+dq)+bp' = (ap'+dq)+bp :
          --   (ap+dq)+bp' = (ap+bp')+dq  [add3swap]
          --              = (ap'+bp)+dq   [h]
          --              = (ap'+dq)+bp   [add3swap back]
          (trans (add3swap (fst p) (snd q) (snd p'))
            (trans (cong (fn (s : Nat) is add s (snd q) end) h)
              (add3swap (fst p') (snd p) (snd q))))
          -- (cq+bp)+bp' = (cq+bp')+bp
          (add3swap (fst q) (snd p) (snd p')))
        (lteAddCancelR (snd p) (add (fst p') (snd q)) (add (fst q) (snd p'))))
  end
end

-- Lift zleP through ZRel, twice (the double-qind pattern).
zleR : NatPair -> Z -> Bool is
  fn (p : NatPair) is
    qlift NatPair ZRel Bool
      (fn (q : NatPair) is zleP p q end)
      (fn (q : NatPair) (q' : NatPair) (r : ZRel q q') is
        zleRespR p q q' r
      end)
  end
end

zle : Z -> Z -> Bool is
  qlift NatPair ZRel (Z -> Bool) zleR
    (fn (p : NatPair) (p' : NatPair) (r : ZRel p p') is
      fn (z : Z) is
        qind NatPair ZRel (fn (w : Z) is Eq Bool (zleR p w) (zleR p' w) end)
          (fn (q : NatPair) is zleRespL p p' q r end)
          z
      end
    end)
end

-- ----------------------------------------------------------------------------
-- THE ℤ ORDER AXIOMS, lifted from Nat lte through qind.
-- ----------------------------------------------------------------------------

-- REFLEXIVITY: zle x x = true.  On a rep p, zleP p p = lte (a+b)(a+b) = true (lteRefl).
zleRefl : (x : Z) -> Eq Bool (zle x x) true is
  fn (x : Z) is
    qind NatPair ZRel (fn (w : Z) is Eq Bool (zle w w) true end)
      (fn (p : NatPair) is lteRefl (add (fst p) (snd p)) end)
      x
  end
end

-- TRANSITIVITY: zle x y = true and zle y z = true imply zle x z = true.
-- On reps p=(a,b), q=(c,d), r=(e,f):
--   H1 : lte (a+d)(c+b) = true      (a−b ≤ c−d)
--   H2 : lte (c+f)(e+d) = true      (c−d ≤ e−f)
-- Add them (lteAddMono): lte ((a+d)+(c+f)) ((c+b)+(e+d)) = true.  Reassociate both
-- sides to expose the common summand (c+d):  LHS = (a+f)+(c+d), RHS = (e+b)+(c+d),
-- then cancel it (lteAddCancelR) to get lte (a+f)(e+b) = zleP p r.
zleTransP : (p : NatPair) -> (q : NatPair) -> (r : NatPair)
   -> Eq Bool (zleP p q) true -> Eq Bool (zleP q r) true
   -> Eq Bool (zleP p r) true is
  fn (p : NatPair) (q : NatPair) (r : NatPair)
     (h1 : Eq Bool (zleP p q) true) (h2 : Eq Bool (zleP q r) true) is
    -- target: lte (add (fst p) (snd r)) (add (fst r) (snd p)) = true.
    -- Let a=fst p, b=snd p, c=fst q, d=snd q, e=fst r, f=snd r.
    -- We cancel (c+d) from the summed inequality H1 + H2 (lteAddMono):
    --   lte ((a+d)+(c+f)) ((c+b)+(e+d)) = true.
    trans
      -- lte (a+f) (e+b) = lte ((a+f)+(c+d)) ((e+b)+(c+d))   [sym lteAddCancelR]
      (sym (lteAddCancelR (add (fst q) (snd q))
              (add (fst p) (snd r)) (add (fst r) (snd p))))
      (trans
        -- rewrite both args:  (a+f)+(c+d) -> (a+d)+(c+f)  and  (e+b)+(c+d) -> (c+b)+(e+d)
        (cong2 (fn (u : Nat) (v : Nat) is lte u v end)
          -- (a+f)+(c+d) = (a+c)+(f+d) = (a+c)+(d+f) = (a+d)+(c+f)
          (trans (interchange (fst p) (snd r) (fst q) (snd q))
            (trans (cong (fn (s : Nat) is add (add (fst p) (fst q)) s end)
                     (addComm (snd r) (snd q)))
              (sym (interchange (fst p) (snd q) (fst q) (snd r)))))
          -- (e+b)+(c+d) = (e+c)+(b+d) = (c+e)+(b+d) ; (c+b)+(e+d) = (c+e)+(b+d)
          (trans (interchange (fst r) (snd p) (fst q) (snd q))
            (trans (cong (fn (s : Nat) is add s (add (snd p) (snd q)) end)
                     (addComm (fst r) (fst q)))
              (sym (interchange (fst q) (snd p) (fst r) (snd q))))))
        -- the summed inequality, by lteAddMono on H1 and H2
        (lteAddMono (add (fst p) (snd q)) (add (fst q) (snd p))
                    (add (fst q) (snd r)) (add (fst r) (snd q))
                    h1 h2))
  end
end

-- TRANSITIVITY at ℤ: zle x y = true and zle y z = true imply zle x z = true.
-- Triple qind to representatives, then zleTransP.
zleTrans : (x : Z) -> (y : Z) -> (z : Z)
   -> Eq Bool (zle x y) true -> Eq Bool (zle y z) true -> Eq Bool (zle x z) true is
  fn (x : Z) is
    qind NatPair ZRel
      (fn (wx : Z) is (y : Z) -> (z : Z)
         -> Eq Bool (zle wx y) true -> Eq Bool (zle y z) true -> Eq Bool (zle wx z) true end)
      (fn (p : NatPair) is
        fn (y : Z) is
          qind NatPair ZRel
            (fn (wy : Z) is (z : Z)
               -> Eq Bool (zle (qin NatPair ZRel p) wy) true -> Eq Bool (zle wy z) true
               -> Eq Bool (zle (qin NatPair ZRel p) z) true end)
            (fn (q : NatPair) is
              fn (z : Z) is
                qind NatPair ZRel
                  (fn (wz : Z) is
                     Eq Bool (zle (qin NatPair ZRel p) (qin NatPair ZRel q)) true
                       -> Eq Bool (zle (qin NatPair ZRel q) wz) true
                       -> Eq Bool (zle (qin NatPair ZRel p) wz) true end)
                  (fn (r : NatPair) is
                    fn (h1 : Eq Bool (zleP p q) true) (h2 : Eq Bool (zleP q r) true) is
                      zleTransP p q r h1 h2
                    end
                  end)
                  z
              end
            end)
            y
        end
      end)
      x
  end
end

-- ANTISYMMETRY at ℤ: zle x y = true and zle y x = true imply Eq Z x y.
-- On reps p,q: zleP p q = lte (a+d)(c+b), zleP q p = lte (c+b)(a+d); lteAntisym gives
-- Eq Nat (a+d)(c+b) = ZRel p q exactly, so qsound delivers Eq Z.
zleAntisym : (x : Z) -> (y : Z)
   -> Eq Bool (zle x y) true -> Eq Bool (zle y x) true -> Eq Z x y is
  fn (x : Z) is
    qind NatPair ZRel
      (fn (wx : Z) is (y : Z)
         -> Eq Bool (zle wx y) true -> Eq Bool (zle y wx) true -> Eq Z wx y end)
      (fn (p : NatPair) is
        fn (y : Z) is
          qind NatPair ZRel
            (fn (wy : Z) is
               Eq Bool (zle (qin NatPair ZRel p) wy) true
                 -> Eq Bool (zle wy (qin NatPair ZRel p)) true
                 -> Eq Z (qin NatPair ZRel p) wy end)
            (fn (q : NatPair) is
              fn (h1 : Eq Bool (zleP p q) true) (h2 : Eq Bool (zleP q p) true) is
                qsound NatPair ZRel p q
                  (lteAntisym (add (fst p) (snd q)) (add (fst q) (snd p)) h1 h2)
              end
            end)
            y
        end
      end)
      x
  end
end

-- TOTALITY at ℤ: every pair is comparable.
zleTotal : (x : Z) -> (y : Z) -> Eq Bool (or (zle x y) (zle y x)) true is
  fn (x : Z) is
    qind NatPair ZRel
      (fn (wx : Z) is (y : Z) -> Eq Bool (or (zle wx y) (zle y wx)) true end)
      (fn (p : NatPair) is
        fn (y : Z) is
          qind NatPair ZRel
            (fn (wy : Z) is Eq Bool (or (zle (qin NatPair ZRel p) wy) (zle wy (qin NatPair ZRel p))) true end)
            (fn (q : NatPair) is
              lteTotal (add (fst p) (snd q)) (add (fst q) (snd p))
            end)
            y
        end
      end)
      x
  end
end

-- ----------------------------------------------------------------------------
-- POSITIVE-MULTIPLIER ORDER INVARIANCE (the qle well-definedness fuel).
--   lte (x · succ n) (y · succ n)  =  lte x y.
-- Multiplying both sides of a comparison by a POSITIVE Nat (succ n) neither changes
-- nor reflects-falsely the order. By double induction on x then y (n fixed):
--   x=0          : lte 0 _ = true on both sides (mul 0 k = 0 def.).
--   x=succ, y=0  : mul (succ x') k = succ(...) so lte (succ _) 0 = false on both.
--   x=succ,y=succ: mul (succ _) k = add k (mul _ k) def., so the common k cancels
--                  (lteAddCancelL) leaving lte (x'·k)(y'·k) = lte x' y' by the IH.
lteMulPos : (n : Nat) -> (x : Nat) -> (y : Nat)
   -> Eq Bool (lte (mul x (succ n)) (mul y (succ n))) (lte x y) is
  fn (n : Nat) (x : Nat) is
    NatElim
      (fn (w : Nat) is
         (y : Nat) -> Eq Bool (lte (mul w (succ n)) (mul y (succ n))) (lte w y) end)
      -- x = 0: lte 0 (mul y k) = true = lte 0 y.
      (fn (y : Nat) is refl true end)
      -- x = succ x', IH at x'.
      (fn (x' : Nat)
          (ih : (y : Nat) -> Eq Bool (lte (mul x' (succ n)) (mul y (succ n))) (lte x' y)) is
         fn (y : Nat) is
           NatElim
             (fn (w : Nat) is
                Eq Bool (lte (mul (succ x') (succ n)) (mul w (succ n))) (lte (succ x') w) end)
             -- y = 0: mul (succ x') (succ n) = succ(...), lte (succ _) 0 = false = lte (succ x') 0.
             (refl false)
             -- y = succ y': common (succ n) cancels via lteAddCancelL, then IH.
             (fn (y' : Nat)
                 (ihy : Eq Bool (lte (mul (succ x') (succ n)) (mul y' (succ n))) (lte (succ x') y')) is
                -- mul (succ x')(succ n) = add (succ n) (mul x' (succ n)) def.,
                -- mul (succ y')(succ n) = add (succ n) (mul y' (succ n)) def.,
                -- so the goal is lte (add (succ n)(x'·k)) (add (succ n)(y'·k)) = lte (succ x')(succ y'),
                -- and lte (succ x')(succ y') = lte x' y' def.
                trans (lteAddCancelL (succ n) (mul x' (succ n)) (mul y' (succ n)))
                  (ih y')
              end)
             y
         end
       end)
      x
  end
end

-- ----------------------------------------------------------------------------
-- ℤ ORDER INVARIANCE UNDER A POSITIVE MULTIPLIER, at the REPRESENTATIVE level.
-- Multiplying both ℤ-sides (as reps) by a positive embedded nat (succ m, 0) leaves
-- zleP unchanged.  pmul p (sm,0) has rep (a·sm + b·0, a·0 + b·sm); after mulZeroR the
-- cross sum (a·sm + d·sm) factors (mulDistR) to (a+d)·sm, and lteMulPos cancels sm.
-- ----------------------------------------------------------------------------

-- the simplification fst(pmul p k) + snd(pmul q k) = (fst p + snd q) · succ m,
-- where k = (succ m, 0).
zleMulArg : (p : NatPair) -> (q : NatPair) -> (m : Nat)
   -> Eq Nat
        (add (fst (pmul p (npair (succ m) zero))) (snd (pmul q (npair (succ m) zero))))
        (mul (add (fst p) (snd q)) (succ m)) is
  fn (p : NatPair) (q : NatPair) (m : Nat) is
    -- LHS = add (add (mul (fst p) (succ m)) (mul (snd p) zero))
    --           (add (mul (fst q) zero) (mul (snd q) (succ m)))
    trans
      -- collapse the two `mul _ zero` summands to zero
      (cong2 (fn (u : Nat) (v : Nat) is add u v end)
        (trans (cong (fn (s : Nat) is add (mul (fst p) (succ m)) s end) (mulZeroR (snd p)))
          (addZeroR (mul (fst p) (succ m))))
        -- add (mul (fst q) zero) (mul (snd q) (succ m)) = mul (snd q) (succ m)
        --   (mul (fst q) zero = zero def. via mulZeroR; add zero x = x def.)
        (cong (fn (s : Nat) is add s (mul (snd q) (succ m)) end) (mulZeroR (fst q))))
      -- add (mul (fst p) (succ m)) (mul (snd q) (succ m)) = mul (add (fst p)(snd q))(succ m)
      (sym (mulDistR (fst p) (snd q) (succ m)))
  end
end

zlePMulR : (p : NatPair) -> (q : NatPair) -> (m : Nat)
   -> Eq Bool
        (zleP (pmul p (npair (succ m) zero)) (pmul q (npair (succ m) zero)))
        (zleP p q) is
  fn (p : NatPair) (q : NatPair) (m : Nat) is
    -- zleP (pmul p k)(pmul q k) = lte (fst(pmul p k)+snd(pmul q k)) (fst(pmul q k)+snd(pmul p k))
    trans
      (cong2 (fn (u : Nat) (v : Nat) is lte u v end)
        (zleMulArg p q m)
        (zleMulArg q p m))
      -- lte ((a+d)·sm) ((c+b)·sm) = lte (a+d)(c+b) = zleP p q
      (lteMulPos m (add (fst p) (snd q)) (add (fst q) (snd p)))
  end
end

-- LIFT to ℤ: multiplying both ℤ-sides by zfrom (succ m) (a positive integer) leaves
-- zle unchanged.  Double qind to reps; zmul (qin p)(qin (succ m,0)) ~> qin (pmul p _)
-- and zle (qin _)(qin _) ~> zleP _ _, so the obligation is exactly zlePMulR.
zleMulPosZ : (x : Z) -> (y : Z) -> (m : Nat)
   -> Eq Bool (zle (zmul x (zfrom (succ m))) (zmul y (zfrom (succ m)))) (zle x y) is
  fn (x : Z) is
    qind NatPair ZRel
      (fn (wx : Z) is (y : Z) -> (m : Nat)
         -> Eq Bool (zle (zmul wx (zfrom (succ m))) (zmul y (zfrom (succ m)))) (zle wx y) end)
      (fn (p : NatPair) is
        fn (y : Z) is
          qind NatPair ZRel
            (fn (wy : Z) is (m : Nat)
               -> Eq Bool (zle (zmul (qin NatPair ZRel p) (zfrom (succ m))) (zmul wy (zfrom (succ m))))
                          (zle (qin NatPair ZRel p) wy) end)
            (fn (q : NatPair) is
              fn (m : Nat) is zlePMulR p q m end
            end)
            y
        end
      end)
      x
  end
end

-- ----------------------------------------------------------------------------
-- THE ℚ ORDER.  a/sb ≤ c/sd  iff  a·sd ≤ c·sb  (cross-multiply against the POSITIVE
-- denominators; the +1 trick makes sb, sd positive so the direction is preserved).
-- ----------------------------------------------------------------------------
qleP : QPair -> QPair -> Bool is
  fn (p : QPair) (q : QPair) is
    zle (zmul (qnum p) (zden q)) (zmul (qnum q) (zden p))
  end
end

-- swap the last two ℤ factors:  (x·y)·z = (x·z)·y.
zmul3swap : (x : Z) -> (y : Z) -> (z : Z)
   -> Eq Z (zmul (zmul x y) z) (zmul (zmul x z) y) is
  fn (x : Z) (y : Z) (z : Z) is
    trans (zmulAssoc x y z)
      (trans (cong (fn (s : Z) is zmul x s end) (zmulComm y z))
        (sym (zmulAssoc x z y)))
  end
end

-- RIGHT RESPECT — the well-definedness crux.  QRel q q' (qnum q · zden q' = qnum q' ·
-- zden q) implies qleP p q = qleP p q'.  Multiply qleP p q by the positive zden q' and
-- qleP p q' by the positive zden q (zleMulPosZ), reorder the ℤ factors (zmul3swap), and
-- cross the hypothesis in the second slot.
qleRespR : (p : QPair) -> (q : QPair) -> (q' : QPair) ->
    QRel q q' -> Eq Bool (qleP p q) (qleP p q') is
  fn (p : QPair) (q : QPair) (q' : QPair) (h : QRel q q') is
    -- a=qnum p, zb=zden p, cq=qnum q, zdq=zden q, cq'=qnum q', zdq'=zden q'.
    -- h : zmul cq zdq' = zmul cq' zdq.
    trans
      -- qleP p q = zle ((a·zdq)·zdq') ((cq·zb)·zdq')   [mult by zden q', positive]
      (sym (zleMulPosZ (zmul (qnum p) (zden q)) (zmul (qnum q) (zden p)) (qdenN q')))
      (trans
        (cong2 (fn (u : Z) (v : Z) is zle u v end)
          -- (a·zdq)·zdq' = (a·zdq')·zdq
          (zmul3swap (qnum p) (zden q) (zden q'))
          -- (cq·zb)·zdq' = (cq·zdq')·zb = (cq'·zdq)·zb = (cq'·zb)·zdq
          (trans (zmul3swap (qnum q) (zden p) (zden q'))
            (trans (cong (fn (s : Z) is zmul s (zden p) end) h)
              (zmul3swap (qnum q') (zden q) (zden p)))))
        -- zle ((a·zdq')·zdq) ((cq'·zb)·zdq) = zle (a·zdq')(cq'·zb) = qleP p q'  [mult by zden q]
        (zleMulPosZ (zmul (qnum p) (zden q')) (zmul (qnum q') (zden p)) (qdenN q)))
  end
end

-- LEFT RESPECT.  QRel p p' (qnum p · zden p' = qnum p' · zden p) implies
--   qleP p q = qleP p' q.  Symmetric: the hypothesis crosses in the FIRST slot.
qleRespL : (p : QPair) -> (p' : QPair) -> (q : QPair) ->
    QRel p p' -> Eq Bool (qleP p q) (qleP p' q) is
  fn (p : QPair) (p' : QPair) (q : QPair) (h : QRel p p') is
    -- ap=qnum p, zbp=zden p, ap'=qnum p', zbp'=zden p', cq=qnum q, zdq=zden q.
    -- qleP p q = zle (ap·zdq) (cq·zbp);  qleP p' q = zle (ap'·zdq) (cq·zbp').
    -- h : zmul ap zbp' = zmul ap' zbp.
    trans
      -- mult by zden p' (positive)
      (sym (zleMulPosZ (zmul (qnum p) (zden q)) (zmul (qnum q) (zden p)) (qdenN p')))
      (trans
        (cong2 (fn (u : Z) (v : Z) is zle u v end)
          -- (ap·zdq)·zbp' = (ap·zbp')·zdq = (ap'·zbp)·zdq = (ap'·zdq)·zbp
          (trans (zmul3swap (qnum p) (zden q) (zden p'))
            (trans (cong (fn (s : Z) is zmul s (zden q) end) h)
              (zmul3swap (qnum p') (zden p) (zden q))))
          -- (cq·zbp)·zbp' = (cq·zbp')·zbp
          (zmul3swap (qnum q) (zden p) (zden p')))
        -- mult by zden p (positive)
        (zleMulPosZ (zmul (qnum p') (zden q)) (zmul (qnum q) (zden p')) (qdenN p)))
  end
end

-- Lift qleP through QRel, twice.
qleR : QPair -> Q -> Bool is
  fn (p : QPair) is
    qlift QPair QRel Bool
      (fn (q : QPair) is qleP p q end)
      (fn (q : QPair) (q' : QPair) (r : QRel q q') is
        qleRespR p q q' r
      end)
  end
end

qle : Q -> Q -> Bool is
  qlift QPair QRel (Q -> Bool) qleR
    (fn (p : QPair) (p' : QPair) (r : QRel p p') is
      fn (z : Q) is
        qind QPair QRel (fn (w : Q) is Eq Bool (qleR p w) (qleR p' w) end)
          (fn (q : QPair) is qleRespL p p' q r end)
          z
      end
    end)
end

-- ----------------------------------------------------------------------------
-- THE ℚ ORDER AXIOMS, lifted through qind.
-- ----------------------------------------------------------------------------

-- REFLEXIVITY: qle x x = true.  On a rep p, qleP p p = zle (a·zb)(a·zb) = true (zleRefl).
qleRefl : (x : Q) -> Eq Bool (qle x x) true is
  fn (x : Q) is
    qind QPair QRel (fn (w : Q) is Eq Bool (qle w w) true end)
      (fn (p : QPair) is zleRefl (zmul (qnum p) (zden p)) end)
      x
  end
end

-- TRANSITIVITY at the representative level.  qleP p q = true and qleP q r = true imply
-- qleP p r = true.  Multiply H1 by the positive zden r and H2 by the positive zden p,
-- chain through zle transitivity at the common middle (cq·zb·zdr = cq·zdr·zb via
-- zmul3swap), reorder to expose the common positive factor zden q, and cancel it
-- (zleMulPosZ).
qleTransP : (p : QPair) -> (q : QPair) -> (r : QPair)
   -> Eq Bool (qleP p q) true -> Eq Bool (qleP q r) true
   -> Eq Bool (qleP p r) true is
  fn (p : QPair) (q : QPair) (r : QPair)
     (h1 : Eq Bool (qleP p q) true) (h2 : Eq Bool (qleP q r) true) is
    -- a=qnum p, zb=zden p, cq=qnum q, zdq=zden q, cr=qnum r, zdr=zden r.
    trans
      -- qleP p r = zle (a·zdr)(cr·zb) = zle ((a·zdr)·zdq) ((cr·zb)·zdq)  [mult zden q]
      (sym (zleMulPosZ (zmul (qnum p) (zden r)) (zmul (qnum r) (zden p)) (qdenN q)))
      (trans
        -- rewrite ((a·zdr)·zdq) -> ((a·zdq)·zdr) and ((cr·zb)·zdq) -> ((cr·zdq)·zb)
        (cong2 (fn (u : Z) (v : Z) is zle u v end)
          (zmul3swap (qnum p) (zden r) (zden q))
          (zmul3swap (qnum r) (zden p) (zden q)))
        -- zle ((a·zdq)·zdr) ((cr·zdq)·zb) = true, by chaining the two scaled hypotheses
        (zleTrans
          (zmul (zmul (qnum p) (zden q)) (zden r))
          (zmul (zmul (qnum q) (zden p)) (zden r))
          (zmul (zmul (qnum r) (zden q)) (zden p))
          -- step 1: scale H1 by zden r
          (trans (zleMulPosZ (zmul (qnum p) (zden q)) (zmul (qnum q) (zden p)) (qdenN r)) h1)
          -- step 2: rewrite the left endpoint then scale H2 by zden p
          (trans
            (cong (fn (s : Z) is zle s (zmul (zmul (qnum r) (zden q)) (zden p)) end)
              (zmul3swap (qnum q) (zden p) (zden r)))
            (trans (zleMulPosZ (zmul (qnum q) (zden r)) (zmul (qnum r) (zden q)) (qdenN p)) h2))))
  end
end

-- TRANSITIVITY at ℚ: lift qleTransP through triple qind.
qleTrans : (x : Q) -> (y : Q) -> (z : Q)
   -> Eq Bool (qle x y) true -> Eq Bool (qle y z) true -> Eq Bool (qle x z) true is
  fn (x : Q) is
    qind QPair QRel
      (fn (wx : Q) is (y : Q) -> (z : Q)
         -> Eq Bool (qle wx y) true -> Eq Bool (qle y z) true -> Eq Bool (qle wx z) true end)
      (fn (p : QPair) is
        fn (y : Q) is
          qind QPair QRel
            (fn (wy : Q) is (z : Q)
               -> Eq Bool (qle (qin QPair QRel p) wy) true -> Eq Bool (qle wy z) true
               -> Eq Bool (qle (qin QPair QRel p) z) true end)
            (fn (q : QPair) is
              fn (z : Q) is
                qind QPair QRel
                  (fn (wz : Q) is
                     Eq Bool (qle (qin QPair QRel p) (qin QPair QRel q)) true
                       -> Eq Bool (qle (qin QPair QRel q) wz) true
                       -> Eq Bool (qle (qin QPair QRel p) wz) true end)
                  (fn (r : QPair) is
                    fn (h1 : Eq Bool (qleP p q) true) (h2 : Eq Bool (qleP q r) true) is
                      qleTransP p q r h1 h2
                    end
                  end)
                  z
              end
            end)
            y
        end
      end)
      x
  end
end

-- TOTALITY at ℚ: every pair is comparable.  On reps, qleP p q = zle (a·zdq)(cq·zb) and
-- qleP q p = zle (cq·zb)(a·zdq), so the disjunction is zleTotal on those two ℤ values.
qleTotal : (x : Q) -> (y : Q) -> Eq Bool (or (qle x y) (qle y x)) true is
  fn (x : Q) is
    qind QPair QRel
      (fn (wx : Q) is (y : Q) -> Eq Bool (or (qle wx y) (qle y wx)) true end)
      (fn (p : QPair) is
        fn (y : Q) is
          qind QPair QRel
            (fn (wy : Q) is Eq Bool (or (qle (qin QPair QRel p) wy) (qle wy (qin QPair QRel p))) true end)
            (fn (q : QPair) is
              zleTotal (zmul (qnum p) (zden q)) (zmul (qnum q) (zden p))
            end)
            y
        end
      end)
      x
  end
end

-- ANTISYMMETRY at ℚ: qle x y = true and qle y x = true imply x = y (in Q).  On reps,
-- the two hypotheses are zle (a·zdq)(cq·zb) = true and zle (cq·zb)(a·zdq) = true, so
-- zleAntisym delivers Eq Z (a·zdq)(cq·zb) — which is exactly QRel p q — and qsound lifts
-- it to Eq Q.
qleAntisym : (x : Q) -> (y : Q)
   -> Eq Bool (qle x y) true -> Eq Bool (qle y x) true -> Eq Q x y is
  fn (x : Q) is
    qind QPair QRel
      (fn (wx : Q) is (y : Q)
         -> Eq Bool (qle wx y) true -> Eq Bool (qle y wx) true -> Eq Q wx y end)
      (fn (p : QPair) is
        fn (y : Q) is
          qind QPair QRel
            (fn (wy : Q) is
               Eq Bool (qle (qin QPair QRel p) wy) true
                 -> Eq Bool (qle wy (qin QPair QRel p)) true
                 -> Eq Q (qin QPair QRel p) wy end)
            (fn (q : QPair) is
              fn (h1 : Eq Bool (qleP p q) true) (h2 : Eq Bool (qleP q p) true) is
                qsound QPair QRel p q
                  (zleAntisym (zmul (qnum p) (zden q)) (zmul (qnum q) (zden p)) h1 h2)
              end
            end)
            y
        end
      end)
      x
  end
end

-- ----------------------------------------------------------------------------
-- ℤ ORDER / ADDITION COMPATIBILITY (for the ordered-field law qaddMono).
--   zle x y = true  implies  zle (x + w) (y + w) = true   (translation invariance in ℤ).
-- ----------------------------------------------------------------------------

-- rep level: zleP (padd p w)(padd q w) follows from zleP p q by adding the common
-- (g+h) on both Nat sides (lteAddBothR), the two args reassociated by interchange.
zleAddCompatP : (p : NatPair) -> (q : NatPair) -> (w : NatPair)
   -> Eq Bool (zleP p q) true -> Eq Bool (zleP (padd p w) (padd q w)) true is
  fn (p : NatPair) (q : NatPair) (w : NatPair) (h : Eq Bool (zleP p q) true) is
    -- target: lte ((a+g)+(d+h)) ((c+g)+(b+h)) = true, a=fst p,b=snd p,c=fst q,d=snd q,
    -- g=fst w,h=snd w.  Reassociate to lte ((a+d)+(g+h)) ((c+b)+(g+h)) then lteAddBothR.
    trans
      (cong2 (fn (u : Nat) (v : Nat) is lte u v end)
        -- (a+g)+(d+h) = (a+d)+(g+h)
        (interchange (fst p) (fst w) (snd q) (snd w))
        -- (c+g)+(b+h) = (c+b)+(g+h)
        (interchange (fst q) (fst w) (snd p) (snd w)))
      (lteAddBothR (add (fst w) (snd w))
        (add (fst p) (snd q)) (add (fst q) (snd p)) h)
  end
end

-- ℤ level: lift through triple qind.
zleAddCompatR : (x : Z) -> (y : Z) -> (w : Z)
   -> Eq Bool (zle x y) true -> Eq Bool (zle (zadd x w) (zadd y w)) true is
  fn (x : Z) is
    qind NatPair ZRel
      (fn (wx : Z) is (y : Z) -> (w : Z)
         -> Eq Bool (zle wx y) true -> Eq Bool (zle (zadd wx w) (zadd y w)) true end)
      (fn (p : NatPair) is
        fn (y : Z) is
          qind NatPair ZRel
            (fn (wy : Z) is (w : Z)
               -> Eq Bool (zle (qin NatPair ZRel p) wy) true
               -> Eq Bool (zle (zadd (qin NatPair ZRel p) w) (zadd wy w)) true end)
            (fn (q : NatPair) is
              fn (w : Z) is
                qind NatPair ZRel
                  (fn (ww : Z) is
                     Eq Bool (zle (qin NatPair ZRel p) (qin NatPair ZRel q)) true
                       -> Eq Bool (zle (zadd (qin NatPair ZRel p) ww) (zadd (qin NatPair ZRel q) ww)) true end)
                  (fn (r : NatPair) is
                    fn (h : Eq Bool (zleP p q) true) is
                      zleAddCompatP p q r h
                    end
                  end)
                  w
              end
            end)
            y
        end
      end)
      x
  end
end

-- ----------------------------------------------------------------------------
-- ORDERED-FIELD COMPATIBILITY:  qle x y  implies  qle (x + z) (y + z).
-- Translation invariance of the order under ℚ addition — the additive compatibility
-- law of an ordered field.  On representatives p=(a/zb), q=(c/zd), s=(e/zs):
--   qaddP p s = (a·zs + e·zb) / (zb·zs),  qaddP q s = (c·zs + e·zd) / (zd·zs).
-- Cross-multiplying and distributing (zmulDistL), the e-cross terms coincide
--   (e·zb)·(zd·zs) = (e·zd)·(zb·zs)  [zmulInterchange],
-- while the a/c terms regroup to  (a·zd)·(zs·zs) ≤ (c·zb)·(zs·zs), which is the
-- hypothesis a·zd ≤ c·zb scaled by the POSITIVE square zs·zs (zleMulPosZ).  Adding the
-- common e-term back preserves the order (zleAddCompatR).
-- ----------------------------------------------------------------------------

-- the scaled a/c inequality:  zle ((a·zs)·(zd·zs)) ((c·zs)·(zb·zs)) = true.
-- From hyp zle (a·zd)(c·zb) = true, scale by the positive zs·zs = zfrom(succ M)
-- (M = qmulDen (qdenN s)(qdenN s), so mul (succ ms)(succ ms) = succ M definitionally),
-- then regroup each side by zmulInterchange.
qaddMonoAC : (p : QPair) -> (q : QPair) -> (s : QPair)
   -> Eq Bool (qleP p q) true
   -> Eq Bool
        (zle (zmul (zmul (qnum p) (zden s)) (zmul (zden q) (zden s)))
             (zmul (zmul (qnum q) (zden s)) (zmul (zden p) (zden s)))) true is
  fn (p : QPair) (q : QPair) (s : QPair) (h : Eq Bool (qleP p q) true) is
    -- target args:  (a·zs)·(zd·zs)  and  (c·zs)·(zb·zs).
    -- (a·zs)·(zd·zs) = (a·zd)·(zs·zs)   [zmulInterchange a zs zd zs]
    -- (c·zs)·(zb·zs) = (c·zb)·(zs·zs)   [zmulInterchange c zs zb zs]
    trans
      (cong2 (fn (u : Z) (v : Z) is zle u v end)
        (zmulInterchange (qnum p) (zden s) (zden q) (zden s))
        (zmulInterchange (qnum q) (zden s) (zden p) (zden s)))
      -- zle ((a·zd)·(zs·zs)) ((c·zb)·(zs·zs)) = true.
      -- zmul (zden s) (zden s) = zfrom (mul (succ ms)(succ ms)) [sym zmulHom], and
      -- mul (succ ms)(succ ms) = succ M definitionally, so this is zleMulPosZ at M.
      (trans
        (cong2 (fn (u : Z) (v : Z) is zle u v end)
          (cong (fn (t : Z) is zmul (zmul (qnum p) (zden q)) t end)
            (sym (zmulHom (succ (qdenN s)) (succ (qdenN s)))))
          (cong (fn (t : Z) is zmul (zmul (qnum q) (zden p)) t end)
            (sym (zmulHom (succ (qdenN s)) (succ (qdenN s))))))
        (trans
          (zleMulPosZ (zmul (qnum p) (zden q)) (zmul (qnum q) (zden p))
            (add (qdenN s) (mul (qdenN s) (succ (qdenN s)))))
          h))
  end
end

-- the representative-level monotonicity.
qaddMonoP : (p : QPair) -> (q : QPair) -> (s : QPair)
   -> Eq Bool (qleP p q) true
   -> Eq Bool (qleP (qaddP p s) (qaddP q s)) true is
  fn (p : QPair) (q : QPair) (s : QPair) (h : Eq Bool (qleP p q) true) is
    -- qleP (qaddP p s)(qaddP q s)
    --   = zle (zmul N1 (zden (qaddP q s))) (zmul N2 (zden (qaddP p s)))
    -- N1 = a·zs + e·zb, N2 = c·zs + e·zd.
    trans
      -- (1) rewrite both denominators by qaddDenZ
      (cong2 (fn (u : Z) (v : Z) is zle u v end)
        (cong (fn (t : Z) is zmul (zadd (zmul (qnum p) (zden s)) (zmul (qnum s) (zden p))) t end)
          (qaddDenZ q s))
        (cong (fn (t : Z) is zmul (zadd (zmul (qnum q) (zden s)) (zmul (qnum s) (zden q))) t end)
          (qaddDenZ p s)))
      (trans
        -- (2) distribute each product over the sum (zmulDistL)
        (cong2 (fn (u : Z) (v : Z) is zle u v end)
          (zmulDistL (zmul (qnum p) (zden s)) (zmul (qnum s) (zden p)) (zmul (zden q) (zden s)))
          (zmulDistL (zmul (qnum q) (zden s)) (zmul (qnum s) (zden q)) (zmul (zden p) (zden s))))
        (trans
          -- (3) coincide the e-cross terms: make BOTH equal to (e·zb)·(zd·zs).
          --   RHS e-term (e·zd)·(zb·zs) = (e·zb)·(zd·zs)  [zmulInterchange e zd zb zs]
          (cong (fn (t : Z) is
                   zle (zadd (zmul (zmul (qnum p) (zden s)) (zmul (zden q) (zden s)))
                             (zmul (zmul (qnum s) (zden p)) (zmul (zden q) (zden s))))
                       (zadd (zmul (zmul (qnum q) (zden s)) (zmul (zden p) (zden s))) t) end)
            (zmulInterchange (qnum s) (zden q) (zden p) (zden s)))
          -- (4) now both args are (a/c-term) + common (e·zb)·(zd·zs); add it back via
          -- zleAddCompatR onto the scaled a/c inequality (qaddMonoAC).
          (zleAddCompatR
            (zmul (zmul (qnum p) (zden s)) (zmul (zden q) (zden s)))
            (zmul (zmul (qnum q) (zden s)) (zmul (zden p) (zden s)))
            (zmul (zmul (qnum s) (zden p)) (zmul (zden q) (zden s)))
            (qaddMonoAC p q s h))))
  end
end

-- TRANSLATION INVARIANCE at ℚ: qle x y = true implies qle (qadd x z) (qadd y z) = true.
-- Triple qind to reps; qadd (qin p)(qin s) ~> qin (qaddP p s) and qle (qin _)(qin _) ~>
-- qleP _ _, so the obligation is exactly qaddMonoP.
qaddMono : (x : Q) -> (y : Q) -> (z : Q)
   -> Eq Bool (qle x y) true -> Eq Bool (qle (qadd x z) (qadd y z)) true is
  fn (x : Q) is
    qind QPair QRel
      (fn (wx : Q) is (y : Q) -> (z : Q)
         -> Eq Bool (qle wx y) true -> Eq Bool (qle (qadd wx z) (qadd y z)) true end)
      (fn (p : QPair) is
        fn (y : Q) is
          qind QPair QRel
            (fn (wy : Q) is (z : Q)
               -> Eq Bool (qle (qin QPair QRel p) wy) true
               -> Eq Bool (qle (qadd (qin QPair QRel p) z) (qadd wy z)) true end)
            (fn (q : QPair) is
              fn (z : Q) is
                qind QPair QRel
                  (fn (wz : Q) is
                     Eq Bool (qle (qin QPair QRel p) (qin QPair QRel q)) true
                       -> Eq Bool (qle (qadd (qin QPair QRel p) wz) (qadd (qin QPair QRel q) wz)) true end)
                  (fn (s : QPair) is
                    fn (h : Eq Bool (qleP p q) true) is
                      qaddMonoP p q s h
                    end
                  end)
                  z
              end
            end)
            y
        end
      end)
      x
  end
end

-- ============================================================================
-- Sanity: the order COMPUTES through the quotient on concrete rationals.
-- ============================================================================

-- 1/2  (numerator 1, denominator succ 1 = 2)  and  2/3  (numerator 2, denominator
-- succ 2 = 3).
qOneHalf : Q is qin QPair QRel (qpair zone (succ zero)) end
qTwoThirds : Q is qin QPair QRel (qpair (zfrom (succ (succ zero))) (succ (succ zero))) end

-- 1/2 ≤ 2/3 is TRUE: cross-multiply 1·3 ≤ 2·2, i.e. 3 ≤ 4 — computes to refl true.
qleHalfTwoThirds : Eq Bool (qle qOneHalf qTwoThirds) true is
  refl true
end

-- 2/3 ≤ 1/2 is FALSE: 2·2 ≤ 1·3, i.e. 4 ≤ 3 — computes to refl false.
qleTwoThirdsHalf : Eq Bool (qle qTwoThirds qOneHalf) false is
  refl false
end

-- reflexivity on a concrete rational, both as a computed `refl true` and via qleRefl.
qleHalfReflCompute : Eq Bool (qle qOneHalf qOneHalf) true is refl true end
qleHalfRefl : Eq Bool (qle qOneHalf qOneHalf) true is qleRefl qOneHalf end

-- transitivity on concretes: 1/2 ≤ 2/3 ≤ 2/3 gives 1/2 ≤ 2/3, by qleTrans.
qleHalfTrans : Eq Bool (qle qOneHalf qTwoThirds) true is
  qleTrans qOneHalf qTwoThirds qTwoThirds (refl true) (qleRefl qTwoThirds)
end

-- ============================================================================
-- CHAPTER 203 (merged) — THE INTEGER-DIVISION ENGINE (from ch12).
-- Everything above is the ch119 ordered-field development, verbatim. Below is
-- the ch12 flooring-division engine, ADAPTED to ch119's glyph-free vocabulary:
-- ch12's Nat `+ * -` and the integer ring (`zadd`/`zmul`/`pneg`/`padd`/`pmul`,
-- `NatPair`/`npair`/`fst`/`snd`/`ZRel`/`Z`) ALREADY EXIST above (under the names
-- `add`/`mul` and the qlift-ring `zadd`/`zmul`), so they are NOT re-added; only
-- the division-specific definitions and their unique supporting lemmas appear here.
-- Resolved clashes: ch12's `pred/-/leb/divF/// ceilDiv` Nat machinery is brought
-- in glyph-free (monus `-` becomes `monus`); ch12's obs-based `zadd/zmul/zneg`
-- are NOT re-added (ch119's ring `zadd`/`zmul` are kept) — only `zneg`/`zsub`
-- (genuinely new) join, built on ch119's `zadd` and the new `obs`.
-- ============================================================================

-- ----------------------------------------------------------------------------
-- Nat division machinery (ch12), glyph-free.
-- ----------------------------------------------------------------------------

pred : Nat -> Nat is
  fn (n : Nat) is
    case n of
    | zero -> zero
    | succ k -> k
    end
  end
end

-- monus: truncated subtraction (ch12's `-` on Nat).
monus : Nat -> Nat -> Nat is
  fn (m : Nat) (n : Nat) is
    case n of
    | zero -> m
    | succ k with ih -> pred ih
    end
  end
end

-- Boolean ≤ on Nat (ch12's leb), recurses on the first argument.
leb : Nat -> Nat -> Bool is
  fn (m : Nat) is
    case m of
    | zero -> fn (n : Nat) is true end
    | succ k with ih -> fn (n : Nat) is
        case n of
        | zero -> false
        | succ j -> ih j
        end
      end
    end
  end
end

-- Fuelled flooring division on Nat (ch12).
divF : Nat -> Nat -> Nat -> Nat is
  fn (fuel : Nat) is
    case fuel of
    | zero -> fn (a : Nat) (b : Nat) is zero end
    | succ f with ih -> fn (a : Nat) (b : Nat) is
        case b of
        | zero -> zero
        | succ k ->
            case leb b a of
            | true -> succ (ih (monus a b) b)
            | false -> zero
            end
        end
      end
    end
  end
end

-- Nat flooring quotient (ch12's `//` on Nat).
natDiv : Nat -> Nat -> Nat is
  fn (m : Nat) (n : Nat) is divF m m n end
end

-- ceilDiv x y = ⌈x/y⌉ for y > 0 (ch12); rounds away from zero on magnitudes.
ceilDiv : Nat -> Nat -> Nat is
  fn (x : Nat) (y : Nat) is natDiv (add x (monus y (succ zero))) y end
end

-- ----------------------------------------------------------------------------
-- The monus toolkit feeding canonicalization (ch12), glyph-free.
-- ----------------------------------------------------------------------------

zeroMonus : (b : Nat) -> Eq Nat (monus zero b) zero is
  fn (b : Nat) is
    case b of
    | zero -> refl zero
    | succ k with ih -> cong pred ih
    end
  end
end

monusSuccSucc : (b : Nat) -> (a : Nat) -> Eq Nat (monus (succ a) (succ b)) (monus a b) is
  fn (b : Nat) is
    case b of
    | zero -> fn (a : Nat) is refl a end
    | succ k with ih -> fn (a : Nat) is cong pred (ih a) end
    end
  end
end

monusAddCancel : (d : Nat) -> (a : Nat) -> Eq Nat (monus (add a d) d) a is
  fn (d : Nat) is
    case d of
    | zero -> fn (a : Nat) is addZeroR a end
    | succ k with ih -> fn (a : Nat) is
        calc monus (add a (succ k)) (succ k)
          = monus (succ (add a k)) (succ k) by cong (fn (s : Nat) is monus s (succ k) end) (addSuccR a k)
          = monus (add a k) k               by monusSuccSucc k (add a k)
          = a                               by ih a
        end
      end
    end
  end
end

monusAddZero : (c : Nat) -> (b : Nat) -> Eq Nat (monus c (add c b)) zero is
  fn (c : Nat) is
    case c of
    | zero -> fn (b : Nat) is zeroMonus b end
    | succ k with ih -> fn (b : Nat) is
        calc monus (succ k) (add (succ k) b)
          = monus k (add k b) by monusSuccSucc (add k b) k
          = zero              by ih b
        end
      end
    end
  end
end

succInj : {a : Nat} -> {b : Nat} -> Eq Nat (succ a) (succ b) -> Eq Nat a b is
  fn {a : Nat} {b : Nat} (p : Eq Nat (succ a) (succ b)) is cong pred p end
end

-- The workhorse: equal differences have equal monuses (ch12), glyph-free.
monusEq : (b : Nat) -> (a : Nat) -> (c : Nat) -> (d : Nat) ->
    Eq Nat (add a d) (add c b) -> Eq Nat (monus a b) (monus c d) is
  fn (b : Nat) is
    case b of
    | zero -> fn (a : Nat) (c : Nat) (d : Nat) (r : Eq Nat (add a d) (add c zero)) is
        sym (calc monus c d
          = monus (add a d) d by cong (fn (s : Nat) is monus s d end) (sym (trans r (addZeroR c)))
          = a                 by monusAddCancel d a
        end)
      end
    | succ b' with ih -> fn (a : Nat) is
        case a of
        | zero -> fn (c : Nat) (d : Nat) (r : Eq Nat (add zero d) (add c (succ b'))) is
            trans (zeroMonus (succ b'))
              (sym (calc monus c d
                = monus c (add c (succ b')) by cong (fn (s : Nat) is monus c s end) r
                = zero                      by monusAddZero c (succ b')
              end))
          end
        | succ a' -> fn (c : Nat) (d : Nat) (r : Eq Nat (add (succ a') d) (add c (succ b'))) is
            trans (monusSuccSucc b' a')
              (ih a' c d (succInj (trans r (addSuccR c b'))))
          end
        end
      end
    end
  end
end

-- ----------------------------------------------------------------------------
-- The canonical form + its respect proof + the observer obs (ch12).
-- ----------------------------------------------------------------------------

-- canon (a,b) = (a − b, b − a): exactly one component survives.
canon : NatPair -> NatPair is
  fn (p : NatPair) is npair (monus (fst p) (snd p)) (monus (snd p) (fst p)) end
end

-- THE respect proof — related pairs have equal canonical forms.
canonResp : (p : NatPair) -> (q : NatPair) -> ZRel p q -> Eq NatPair (canon p) (canon q) is
  fn (p : NatPair) (q : NatPair) (r : ZRel p q) is
    cong2 npair
      (monusEq (snd p) (fst p) (fst q) (snd q) r)
      (monusEq (fst p) (snd p) (snd q) (fst q)
        (trans (addComm (snd p) (fst q)) (trans (sym r) (addComm (fst p) (snd q)))))
  end
end

-- obs: the quotient's observer. qlift pays the setoid tax with canonResp;
-- every operation below factors through obs and needs no proof of its own.
obs : Z -> NatPair is
  qlift NatPair ZRel NatPair canon canonResp
end

-- The Nat→ℤ embedding (ch12's intOf; ch119 has zfrom, this is the canonical-engine name).
intOf : Nat -> Z is fn (n : Nat) is qin NatPair ZRel (npair n zero) end end

-- ----------------------------------------------------------------------------
-- Division on representatives (ch12). pdiv/pquot dispatch on the sign structure
-- of CANONICAL pairs (at most one component nonzero).
-- ----------------------------------------------------------------------------

pdiv : NatPair -> NatPair -> NatPair is
  fn (a : NatPair) (b : NatPair) is
    case snd b of
    | zero ->
        case fst b of
        | zero -> npair zero zero
        | succ bm ->
            case snd a of
            | zero -> npair (natDiv (fst a) (succ bm)) zero
            | succ an -> npair zero (ceilDiv (succ an) (succ bm))
            end
        end
    | succ bn ->
        case snd a of
        | zero -> npair zero (ceilDiv (fst a) (succ bn))
        | succ an -> npair (natDiv (succ an) (succ bn)) zero
        end
    end
  end
end

pquot : NatPair -> NatPair -> NatPair is
  fn (a : NatPair) (b : NatPair) is
    case snd b of
    | zero ->
        case fst b of
        | zero -> npair zero zero
        | succ bm ->
            case snd a of
            | zero -> npair (natDiv (fst a) (succ bm)) zero
            | succ an -> npair zero (natDiv (succ an) (succ bm))
            end
        end
    | succ bn ->
        case snd a of
        | zero -> npair zero (natDiv (fst a) (succ bn))
        | succ an -> npair (natDiv (succ an) (succ bn)) zero
        end
    end
  end
end

-- ----------------------------------------------------------------------------
-- The integer division/negation operations: compose through obs, return by qin.
-- ch119's ring `zadd`/`zmul`/`pneg`/`padd`/`pmul` are reused; `zneg`/`zsub` are new.
-- ----------------------------------------------------------------------------

zneg : Z -> Z is fn (z : Z) is qin NatPair ZRel (pneg (obs z)) end end

zsub : Z -> Z -> Z is fn (y : Z) (z : Z) is zadd y (zneg z) end end

zfdiv : Z -> Z -> Z is
  fn (y : Z) (z : Z) is qin NatPair ZRel (pdiv (obs y) (obs z)) end
end

-- The flooring remainder IS the division law, read as a definition.
zfmod : Z -> Z -> Z is
  fn (y : Z) (z : Z) is zsub y (zmul z (zfdiv y z)) end
end

-- The truncated pair (sign of remainder follows the DIVIDEND).
quot : Z -> Z -> Z is
  fn (y : Z) (z : Z) is qin NatPair ZRel (pquot (obs y) (obs z)) end
end

rem : Z -> Z -> Z is
  fn (y : Z) (z : Z) is zsub y (zmul z (quot y z)) end
end

natAbs : Z -> Nat is
  fn (z : Z) is add (fst (obs z)) (snd (obs z)) end
end

-- ----------------------------------------------------------------------------
-- Certificates: the F-convention division law computes through the quotient.
-- ----------------------------------------------------------------------------
floorPosPos : Eq NatPair (obs (zfdiv (intOf (succ (succ (succ (succ (succ (succ (succ zero))))))))
                                     (intOf (succ (succ zero))))) (npair (succ (succ (succ zero))) zero) is
  refl (npair (succ (succ (succ zero))) zero)
end

natAbsFloor : Eq Nat (natAbs (zfdiv (zneg (intOf (succ (succ (succ (succ (succ (succ (succ zero)))))))))
                                    (intOf (succ (succ zero)))))
                     (succ (succ (succ (succ zero)))) is
  refl (succ (succ (succ (succ zero))))
end

-- ============================================================================
-- THE REPEATING-DECIMAL LAYER.  to_radix of a rational, on the canonical QPair
-- representative.  A QPair p denotes (qnum p) / succ (qdenN p); its decimal is
-- the sign of the numerator, the integer part natDiv |num| den, and the long
-- division of the fractional remainder with CYCLE DETECTION (a remainder that
-- recurs starts the repetend).  Every division here is small (rem < den), so
-- nothing approaches a fuel wall; the dividend-as-fuel budget suffices exactly.
-- This is the rep-level computation; the qlift onto Q (well-definedness via
-- floorUnique) is the floor section near the file tail (floorQ / floorUnique).
-- ============================================================================

-- Bind digit literals (the chapter declared `data Nat` above; this binds 0,1,…).
builtin nat Nat zero succ

-- Nat remainder: a % b = a − (a // b)·b.  a % 0 = a, keeping DIV-LAW at b = 0.
natMod : Nat -> Nat -> Nat is
  fn (a : Nat) (b : Nat) is monus a (mul (natDiv a b) b) end
end

-- A Z is negative iff its canonical negative part (snd ∘ obs) is nonzero.
isNegZ : Z -> Bool is
  fn (z : Z) is case snd (obs z) of | zero -> false | succ k -> true end end
end

-- |numerator|, denominator, and sign of a QPair, as the long division needs them.
qmagNum : QPair -> Nat is fn (p : QPair) is natAbs (qnum p) end end
qmagDen : QPair -> Nat is fn (p : QPair) is succ (qdenN p) end end
qsign   : QPair -> Bool is fn (p : QPair) is isNegZ (qnum p) end end

powTen : Nat -> Nat is
  fn (n : Nat) is case n of | zero -> 1 | succ k with ih -> mul 10 ih end end
end

eqW : Nat -> Nat -> Bool is
  fn (m : Nat) is
    case m of
    | zero -> fn (n : Nat) is case n of | zero -> true | succ j -> false end end
    | succ k with ih -> fn (n : Nat) is case n of | zero -> false | succ j -> ih j end end
    end
  end
end

-- A list of remainders/digits seen in position order.
data WList : U is wnil : WList | wcons : Nat -> WList -> WList end

wsnoc : WList -> Nat -> WList is
  fn (xs : WList) (x : Nat) is
    case xs of
    | wnil -> wcons x wnil
    | wcons h t with ih -> wcons h ih
    end
  end
end
wmember : Nat -> WList -> Bool is
  fn (x : Nat) (xs : WList) is
    case xs of
    | wnil -> false
    | wcons h t with ih -> case eqW x h of | true -> true | false -> ih end
    end
  end
end
windex : Nat -> WList -> Nat is
  fn (x : Nat) (xs : WList) is
    case xs of
    | wnil -> 0
    | wcons h t with ih -> case eqW x h of | true -> 0 | false -> succ ih end
    end
  end
end

-- The fractional expansion: digits, where the repetend begins, and whether it
-- terminates (no repetend).
data FBody : U is fbody : WList -> Nat -> Bool -> FBody end
fbDigits : FBody -> WList is fn (b : FBody) is case b of | fbody d r t -> d end end end
fbRep    : FBody -> Nat  is fn (b : FBody) is case b of | fbody d r t -> r end end end
fbTerm   : FBody -> Bool is fn (b : FBody) is case b of | fbody d r t -> t end end end

-- Long division with cycle detection.  fuel bounds the loop (a remainder recurs
-- within `den` steps by pigeonhole); `seen` records remainders in position order
-- so a recurrence gives the repetend's start index.
expand : Nat -> Nat -> Nat -> WList -> FBody is
  fn (den : Nat) (fuel : Nat) is
    case fuel of
    | zero -> fn (rem : Nat) (seen : WList) is fbody wnil 0 true end
    | succ fl with ih -> fn (rem : Nat) (seen : WList) is
        case rem of
        | zero -> fbody wnil 0 true
        | succ rp ->
            case wmember rem seen of
            | true  -> fbody wnil (windex rem seen) false
            | false ->
                let r10  : Nat   = mul rem 10 in
                let rest : FBody = ih (natMod r10 den) (wsnoc seen rem) in
                fbody (wcons (natDiv r10 den) (fbDigits rest)) (fbRep rest) (fbTerm rest)
            end
        end
      end
    end
  end
end

-- The exact decimal of a rational, sign and integer part and repetend and all,
-- on the QPair representative.  rdec sign intPart digits repIndex terminates.
data RDec : U is rdec : Bool -> Nat -> WList -> Nat -> Bool -> RDec end

toRadixRep : QPair -> RDec is
  fn (p : QPair) is
    let body : FBody =
      expand (qmagDen p) (succ (qmagDen p)) (natMod (qmagNum p) (qmagDen p)) wnil in
    rdec (qsign p) (natDiv (qmagNum p) (qmagDen p)) (fbDigits body) (fbRep body) (fbTerm body)
  end
end

-- ----------------------------------------------------------------------------
-- Certificates: the repeating decimal COMPUTES through the canonical rep.
-- A QPair (qpair (intOf n) d) denotes n / succ d.
-- ----------------------------------------------------------------------------

-- 3/4 = 0.75  (terminating): qpair (intOf 3) 3 is 3 / succ 3 = 3/4.
radixThreeQuarters :
  Eq RDec (toRadixRep (qpair (intOf 3) 3))
          (rdec false 0 (wcons 7 (wcons 5 wnil)) 0 true) is
  refl (rdec false 0 (wcons 7 (wcons 5 wnil)) 0 true)
end

-- 1/3 = 0.{3}  (immediate repetend): qpair (intOf 1) 2 is 1 / succ 2 = 1/3.
radixThird :
  Eq RDec (toRadixRep (qpair (intOf 1) 2))
          (rdec false 0 (wcons 3 wnil) 0 false) is
  refl (rdec false 0 (wcons 3 wnil) 0 false)
end

-- -1/3 = -0.{3}: the sign rides the numerator (zneg (intOf 1)).
radixNegThird :
  Eq RDec (toRadixRep (qpair (zneg (intOf 1)) 2))
          (rdec true 0 (wcons 3 wnil) 0 false) is
  refl (rdec true 0 (wcons 3 wnil) 0 false)
end

-- 1/7 = 0.{142857}  (six-digit repetend): qpair (intOf 1) 6 is 1/7.
radixSeventh :
  Eq RDec (toRadixRep (qpair (intOf 1) 6))
          (rdec false 0 (wcons 1 (wcons 4 (wcons 2 (wcons 8 (wcons 5 (wcons 7 wnil)))))) 0 false) is
  refl (rdec false 0 (wcons 1 (wcons 4 (wcons 2 (wcons 8 (wcons 5 (wcons 7 wnil)))))) 0 false)
end

-- 1/6 = 0.1{6}  (a non-repeating head digit, then a cycle): qpair (intOf 1) 5 is 1/6.
radixSixth :
  Eq RDec (toRadixRep (qpair (intOf 1) 5))
          (rdec false 0 (wcons 1 (wcons 6 wnil)) 1 false) is
  refl (rdec false 0 (wcons 1 (wcons 6 wnil)) 1 false)
end

-- ============================================================================
-- CH203 — DIVISION-ALGORITHM LEMMAS (ported from ch13, adapted to the FUELLED
-- natDiv/natMod and the glyph-free add/mul/monus/leb). divLaw + remBound +
-- divUnique, then the scaling lemmas natDivScale/natModScale via divUnique.
-- ============================================================================

-- leb b a = true  ⟹  (a − b) + b = a.  Induction on b, a varying.
monusAddInv : (b : Nat) -> (a : Nat) -> Eq Bool (leb b a) true -> Eq Nat (add (monus a b) b) a is
  fn (b : Nat) is
    case b of
    | zero -> fn (a : Nat) (h : Eq Bool true true) is addZeroR (monus a zero) end
    | succ k with ih -> fn (a : Nat) is
        case a of
        | zero -> fn (h : Eq Bool false true) is lteAbsurdNat (add (monus zero (succ k)) (succ k)) zero h end
        | succ j -> fn (h : Eq Bool (leb k j) true) is
            calc add (monus (succ j) (succ k)) (succ k)
              = add (monus j k) (succ k) by cong (fn (s : Nat) is add s (succ k) end) (monusSuccSucc k j)
              = succ (add (monus j k) k)  by addSuccR (monus j k) k
              = succ j                    by cong succ (ih j h)
            end
          end
        end
      end
    end
  end
end

-- add (succ c) x = succ (add c x).  add recurses on its 2nd arg, so the leading
-- successor does not peel definitionally; prove it by induction on x.
addSuccL : (c : Nat) -> (x : Nat) -> Eq Nat (add (succ c) x) (succ (add c x)) is
  fn (c : Nat) (x : Nat) is
    NatElim (fn (z : Nat) is Eq Nat (add (succ c) z) (succ (add c z)) end)
      (trans (addZeroR (succ c)) (cong succ (sym (addZeroR c))))
      (fn (k : Nat) (ih : Eq Nat (add (succ c) k) (succ (add c k))) is
         trans (addSuccR (succ c) k)
           (trans (cong succ ih) (cong succ (sym (addSuccR c k)))) end)
      x
  end
end

-- leb is monotone under a common left summand: x ≤ y ⟹ c+x ≤ c+y.  Induction on c.
lebAddMono : (c : Nat) -> (x : Nat) -> (y : Nat) -> Eq Bool (leb x y) true
    -> Eq Bool (leb (add c x) (add c y)) true is
  fn (c : Nat) is
    case c of
    | zero -> fn (x : Nat) (y : Nat) (h : Eq Bool (leb x y) true) is h end
    | succ d with ih -> fn (x : Nat) (y : Nat) (h : Eq Bool (leb x y) true) is
        subst Nat (succ (add d x)) (add (succ d) x) (sym (addSuccL d x))
          (fn (s : Nat) is Eq Bool (leb s (add (succ d) y)) true end)
          (subst Nat (succ (add d y)) (add (succ d) y) (sym (addSuccL d y))
            (fn (t : Nat) is Eq Bool (leb (succ (add d x)) t) true end)
            (ih x y h))
      end
    end
  end
end

-- b ≤ a  and  x ≤ a−b   ⟹   b+x ≤ a.   (monotonicity + monusAddInv.)
lebAddMonus : (a : Nat) -> (b : Nat) -> (x : Nat)
    -> Eq Bool (leb b a) true -> Eq Bool (leb x (monus a b)) true
    -> Eq Bool (leb (add b x) a) true is
  fn (a : Nat) (b : Nat) (x : Nat) (hba : Eq Bool (leb b a) true)
     (hx : Eq Bool (leb x (monus a b)) true) is
    subst Nat (add b (monus a b)) a (trans (addComm b (monus a b)) (monusAddInv b a hba))
      (fn (s : Nat) is Eq Bool (leb (add b x) s) true end)
      (lebAddMono b x (monus a b) hx)
  end
end

-- The divisor step under a known boolean: case on the value `lv` of `leb (succ k) a`
-- WITH its defining equation, so divF's branch reduces and the true branch carries
-- `leb (succ k) a = true` to feed lebAddMonus.  `q'` is the recursive quotient.
divStepMulLe : (a : Nat) -> (k : Nat) -> (q' : Nat)
    -> Eq Bool (leb (mul q' (succ k)) (monus a (succ k))) true
    -> (lv : Bool) -> Eq Bool (leb (succ k) a) lv
    -> Eq Bool (leb (mul (BoolElim (fn (w : Bool) is Nat end) (succ q') zero lv) (succ k)) a) true is
  fn (a : Nat) (k : Nat) (q' : Nat)
     (hrec : Eq Bool (leb (mul q' (succ k)) (monus a (succ k))) true) (lv : Bool) is
    case lv of
    | true  -> fn (h : Eq Bool (leb (succ k) a) true) is
        -- BoolElim ... true = succ q'; mul (succ q') (succ k) = (succ k) + mul q' (succ k).
        lebAddMonus a (succ k) (mul q' (succ k)) h hrec
      end
    | false -> fn (h : Eq Bool (leb (succ k) a) false) is
        -- BoolElim ... false = zero; mul 0 (succ k) = 0; leb 0 a = true.
        refl true
      end
    end
  end
end

-- The fuelled quotient times the divisor never exceeds the dividend:
-- (divF f a b)·b ≤ a, for ANY fuel.  Induction on fuel; the recursive call's
-- bound (on a−b) lifts back to a via divStepMulLe.
divFMulLe : (f : Nat) -> (a : Nat) -> (b : Nat) -> Eq Bool (leb (mul (divF f a b) b) a) true is
  fn (f : Nat) is
    case f of
    | zero -> fn (a : Nat) (b : Nat) is refl true end
    | succ g with ih -> fn (a : Nat) (b : Nat) is
        case b of
        | zero -> refl true
        | succ k ->
            divStepMulLe a k (divF g (monus a (succ k)) (succ k))
              (ih (monus a (succ k)) (succ k))
              (leb (succ k) a) (refl (leb (succ k) a))
        end
      end
    end
  end
end

-- Specialise to natDiv (fuel = the dividend): (natDiv a b)·b ≤ a.
divMulLe : (a : Nat) -> (b : Nat) -> Eq Bool (leb (mul (natDiv a b) b) a) true is
  fn (a : Nat) (b : Nat) is divFMulLe a a b end
end

-- THE DIVISION LAW (F-convention):  (natDiv a b)·b + natMod a b = a.
-- natMod a b = a − (natDiv a b)·b, and (natDiv a b)·b ≤ a (divMulLe), so adding the
-- remainder back recovers a (monusAddInv, commuted).
divLaw : (a : Nat) -> (b : Nat)
    -> Eq Nat (add (mul (natDiv a b) b) (natMod a b)) a is
  fn (a : Nat) (b : Nat) is
    trans (addComm (mul (natDiv a b) b) (natMod a b))
      (monusAddInv (mul (natDiv a b) b) a (divMulLe a b))
  end
end

-- Strict order (ported from ch13), case-based like leb.
ltb : Nat -> Nat -> Bool is
  fn (m : Nat) is
    case m of
    | zero -> fn (n : Nat) is case n of | zero -> false | succ j -> true end end
    | succ k with ih -> fn (n : Nat) is case n of | zero -> false | succ j -> ih j end end
    end
  end
end
ltbZero : (r : Nat) -> Eq Bool (ltb r zero) false is
  fn (r : Nat) is case r of | zero -> refl false | succ k -> refl false end end
end
Lt : Nat -> Nat -> Prop is fn (a : Nat) (b : Nat) is Eq Bool (ltb a b) true end end

-- monus over a sum:  a − (b + c) = (a − b) − c.   Induction on c (add recurses there).
monusAdd : (a : Nat) -> (b : Nat) -> (c : Nat)
    -> Eq Nat (monus a (add b c)) (monus (monus a b) c) is
  fn (a : Nat) (b : Nat) (c : Nat) is
    NatElim (fn (z : Nat) is Eq Nat (monus a (add b z)) (monus (monus a b) z) end)
      (cong (fn (s : Nat) is monus a s end) (addZeroR b))
      (fn (k : Nat) (ih : Eq Nat (monus a (add b k)) (monus (monus a b) k)) is
         trans (cong (fn (s : Nat) is monus a s end) (addSuccR b k))
           (cong pred ih) end)
      c
  end
end

-- leb is transitive (induction on the first argument; same shape as lteTrans).
lebTrans : (a : Nat) -> (b : Nat) -> (c : Nat)
    -> Eq Bool (leb a b) true -> Eq Bool (leb b c) true -> Eq Bool (leb a c) true is
  fn (a : Nat) is
    case a of
    | zero -> fn (b : Nat) (c : Nat) (hab : Eq Bool true true) (hbc : Eq Bool (leb b c) true) is
        refl true end
    | succ a2 with ih -> fn (b : Nat) is
        case b of
        | zero -> fn (c : Nat) (hab : Eq Bool false true) (hbc : Eq Bool (leb zero c) true) is
            lteAbsurd (succ a2) c hab end
        | succ b2 -> fn (c : Nat) is
            case c of
            | zero -> fn (hab : Eq Bool (leb a2 b2) true) (hbc : Eq Bool false true) is
                lteAbsurd (succ a2) zero hbc end
            | succ c2 -> fn (hab : Eq Bool (leb a2 b2) true) (hbc : Eq Bool (leb b2 c2) true) is
                ih b2 c2 hab hbc end
            end
          end
        end
      end
    end
  end
end

-- leb is reflexive (induction on the argument).
lebRefl : (a : Nat) -> Eq Bool (leb a a) true is
  fn (a : Nat) is
    case a of
    | zero -> refl true
    | succ k with ih -> ih
    end
  end
end
-- a ≤ succ a (induction on a).
lebSuccSelf : (a : Nat) -> Eq Bool (leb a (succ a)) true is
  fn (a : Nat) is
    case a of
    | zero -> refl true
    | succ k with ih -> ih
    end
  end
end
-- a − d ≤ a always.   Induction on a; chains via lebTrans and lebSuccSelf.
monusLe : (a : Nat) -> (d : Nat) -> Eq Bool (leb (monus a d) a) true is
  fn (a : Nat) is
    case a of
    | zero -> fn (d : Nat) is
        subst Nat zero (monus zero d) (sym (zeroMonus d))
          (fn (s : Nat) is Eq Bool (leb s zero) true end) (refl true) end
    | succ a2 with ih -> fn (d : Nat) is
        case d of
        | zero -> lebRefl (succ a2)
        | succ d2 ->
            subst Nat (monus a2 d2) (monus (succ a2) (succ d2)) (sym (monusSuccSucc d2 a2))
              (fn (s : Nat) is Eq Bool (leb s (succ a2)) true end)
              (lebTrans (monus a2 d2) a2 (succ a2) (ih d2) (lebSuccSelf a2))
        end
      end
    end
  end
end

-- monus is antitone in its subtrahend:  c ≤ d  ⟹  a−d ≤ a−c.   Induction on a.
monusLeMono2 : (a : Nat) -> (c : Nat) -> (d : Nat)
    -> Eq Bool (leb c d) true -> Eq Bool (leb (monus a d) (monus a c)) true is
  fn (a : Nat) is
    case a of
    | zero -> fn (c : Nat) (d : Nat) (h : Eq Bool (leb c d) true) is
        subst Nat zero (monus zero d) (sym (zeroMonus d))
          (fn (s : Nat) is Eq Bool (leb s (monus zero c)) true end)
          (subst Nat zero (monus zero c) (sym (zeroMonus c))
            (fn (t : Nat) is Eq Bool (leb zero t) true end) (refl true)) end
    | succ a2 with ih -> fn (c : Nat) is
        case c of
        | zero -> fn (d : Nat) (h : Eq Bool true true) is
            -- monus (succ a2) zero = succ a2 (def. monus zero-case); monusLe closes it.
            monusLe (succ a2) d end
        | succ c2 -> fn (d : Nat) is
            case d of
            | zero -> fn (h : Eq Bool (leb (succ c2) zero) true) is
                subst Bool false true h
                  (fn (z : Bool) is case z of
                     | true  -> Eq Bool (leb (monus (succ a2) zero) (monus (succ a2) (succ c2))) true
                     | false -> Eq Bool true true end end)
                  (refl true) end
            | succ d2 -> fn (h : Eq Bool (leb c2 d2) true) is
                subst Nat (monus a2 d2) (monus (succ a2) (succ d2)) (sym (monusSuccSucc d2 a2))
                  (fn (s : Nat) is Eq Bool (leb s (monus (succ a2) (succ c2))) true end)
                  (subst Nat (monus a2 c2) (monus (succ a2) (succ c2)) (sym (monusSuccSucc c2 a2))
                    (fn (t : Nat) is Eq Bool (leb (monus a2 d2) t) true end)
                    (ih c2 d2 h)) end
            end
          end
        end
      end
    end
  end
end

-- From false = true, any Bool-equation goal (the leb-flavoured absurdity).
boolAbsurd : (x : Nat) -> (y : Nat) -> Eq Bool false true -> Eq Bool (leb x y) true is
  fn (x : Nat) (y : Nat) (h : Eq Bool false true) is
    subst Bool false true h
      (fn (z : Bool) is case z of
         | true  -> Eq Bool (leb x y) true
         | false -> Eq Bool true true end end)
      (refl true)
  end
end

-- a ≤ succ g  ⟹  pred a ≤ g.   Case on a (no induction; succ-case is leb-definitional).
predLebFuel : (a : Nat) -> (g : Nat) -> Eq Bool (leb a (succ g)) true -> Eq Bool (leb (pred a) g) true is
  fn (a : Nat) is
    case a of
    | zero -> fn (g : Nat) (h : Eq Bool true true) is refl true end
    | succ j -> fn (g : Nat) (h : Eq Bool (leb j g) true) is h end
    end
  end
end

-- monus a 1 = pred a (monus succ-case then zero-case; definitional).
predIsMonusOne : (a : Nat) -> Eq Nat (monus a (succ zero)) (pred a) is
  fn (a : Nat) is refl (pred a) end
end

-- FUEL DESCENT:  succ b0 ≤ a  and  a ≤ succ g   ⟹   a − succ b0 ≤ g.
-- a−(succ b0) ≤ a−1 = pred a (monusLeMono2, succ 0 ≤ succ b0), and pred a ≤ g.
lebMonusFuel : (a : Nat) -> (b0 : Nat) -> (g : Nat)
    -> Eq Bool (leb (succ b0) a) true -> Eq Bool (leb a (succ g)) true
    -> Eq Bool (leb (monus a (succ b0)) g) true is
  fn (a : Nat) (b0 : Nat) (g : Nat)
     (hba : Eq Bool (leb (succ b0) a) true) (hfuel : Eq Bool (leb a (succ g)) true) is
    lebTrans (monus a (succ b0)) (pred a) g
      (subst Nat (monus a (succ zero)) (pred a) (predIsMonusOne a)
        (fn (s : Nat) is Eq Bool (leb (monus a (succ b0)) s) true end)
        (monusLeMono2 a (succ zero) (succ b0) (refl true)))
      (predLebFuel a g hfuel)
  end
end

-- leb (succ b0) a = false  ⟹  a < succ b0  (the false branch of the divisor test
-- gives the remainder-is-the-dividend bound).   Induction on b0, a varying.
lebFalseLt : (b0 : Nat) -> (a : Nat)
    -> Eq Bool (leb (succ b0) a) false -> Eq Bool (ltb a (succ b0)) true is
  fn (b0 : Nat) is
    case b0 of
    | zero -> fn (a : Nat) is
        case a of
        | zero -> fn (h : Eq Bool false false) is refl true end
        | succ j -> fn (h : Eq Bool true false) is
            subst Bool true false h
              (fn (z : Bool) is case z of
                 | true  -> Eq Bool true true
                 | false -> Eq Bool (ltb (succ j) (succ zero)) true end end)
              (refl true) end
        end
      end
    | succ b1 with ih -> fn (a : Nat) is
        case a of
        | zero -> fn (h : Eq Bool false false) is refl true end
        | succ j -> fn (h : Eq Bool (leb (succ b1) j) false) is ih j h end
        end
      end
    end
  end
end

-- The remainder step under a known boolean lv = leb (succ b0) a, WITH its equation.
-- true:  rem = (a − succ b0) − q'·(succ b0) = the recursive remainder  (< succ b0 by hrec).
-- false: rem = a,  a < succ b0  by lebFalseLt.
remStepLt : (a : Nat) -> (b0 : Nat) -> (q' : Nat)
    -> (Eq Bool (leb (succ b0) a) true
        -> Lt (monus (monus a (succ b0)) (mul q' (succ b0))) (succ b0))
    -> (lv : Bool) -> Eq Bool (leb (succ b0) a) lv
    -> Lt (monus a (mul (BoolElim (fn (w : Bool) is Nat end) (succ q') zero lv) (succ b0))) (succ b0) is
  fn (a : Nat) (b0 : Nat) (q' : Nat)
     (hrec : Eq Bool (leb (succ b0) a) true
        -> Lt (monus (monus a (succ b0)) (mul q' (succ b0))) (succ b0)) (lv : Bool) is
    case lv of
    | true  -> fn (h : Eq Bool (leb (succ b0) a) true) is
        -- mul (succ q') (succ b0) = (succ b0) + q'·(succ b0); monusAdd splits the subtraction.
        subst Nat (monus (monus a (succ b0)) (mul q' (succ b0)))
                  (monus a (add (succ b0) (mul q' (succ b0))))
          (sym (monusAdd a (succ b0) (mul q' (succ b0))))
          (fn (s : Nat) is Lt s (succ b0) end)
          (hrec h)
      end
    | false -> fn (h : Eq Bool (leb (succ b0) a) false) is
        -- BoolElim ... false = 0; mul 0 (succ b0) = 0; monus a 0 = a; a < succ b0.
        lebFalseLt b0 a h
      end
    end
  end
end

-- The fuelled remainder is bounded WHEN the fuel covers the dividend (leb a f).
remLtFuel : (f : Nat) -> (a : Nat) -> (b0 : Nat) -> Eq Bool (leb a f) true
    -> Lt (monus a (mul (divF f a (succ b0)) (succ b0))) (succ b0) is
  fn (f : Nat) is
    case f of
    | zero -> fn (a : Nat) is
        case a of
        | zero -> fn (b0 : Nat) (hf : Eq Bool true true) is refl true end
        | succ j -> fn (b0 : Nat) (hf : Eq Bool false true) is
            subst Bool false true hf
              (fn (z : Bool) is case z of
                 | true  -> Lt (monus (succ j) (mul (divF zero (succ j) (succ b0)) (succ b0))) (succ b0)
                 | false -> Eq Bool true true end end)
              (refl true) end
        end
      end
    | succ g with ih -> fn (a : Nat) (b0 : Nat) (hf : Eq Bool (leb a (succ g)) true) is
        remStepLt a b0 (divF g (monus a (succ b0)) (succ b0))
          (fn (h : Eq Bool (leb (succ b0) a) true) is
             ih (monus a (succ b0)) b0 (lebMonusFuel a b0 g h hf) end)
          (leb (succ b0) a) (refl (leb (succ b0) a))
      end
    end
  end
end

-- REMAINDER BOUND:  natMod a (succ b0) < succ b0.   natMod unfolds to the fuelled
-- remainder with fuel = a, and leb a a (lebRefl) discharges the fuel precondition.
remBound : (a : Nat) -> (b0 : Nat) -> Lt (natMod a (succ b0)) (succ b0) is
  fn (a : Nat) (b0 : Nat) is remLtFuel a a b0 (lebRefl a) end
end

-- Bool discriminators (ported from ch13).
trueNotFalse : {P : U} -> Eq Bool true false -> P is
  fn {P : U} (h : Eq Bool true false) is
    subst Bool true false h (fn (z : Bool) is case z of | true -> P | false -> P end end)
      (subst Bool false true (sym h) (fn (z : Bool) is case z of | true -> P | false -> P -> P end end)
        (fn (p : P) is p end))
  end
end
falseNotTrue : {P : U} -> Eq Bool false true -> P is
  fn {P : U} (h : Eq Bool false true) is trueNotFalse (sym h) end
end

-- add cancels on the right (ported from ch13's addCancelR; add recurses on 2nd arg).
addCancelR : (z : Nat) -> (x : Nat) -> (y : Nat) -> Eq Nat (add x z) (add y z) -> Eq Nat x y is
  fn (z : Nat) is
    case z of
    | zero -> fn (x : Nat) (y : Nat) (r : Eq Nat (add x zero) (add y zero)) is
        trans (sym (addZeroR x)) (trans r (addZeroR y)) end
    | succ k with ih -> fn (x : Nat) (y : Nat) (r : Eq Nat (add x (succ k)) (add y (succ k))) is
        ih x y (succInj (trans (sym (addSuccR x k)) (trans r (addSuccR y k)))) end
    end
  end
end
-- add cancels on the left (via commutation to addCancelR).
addCancelL : (c : Nat) -> (x : Nat) -> (y : Nat) -> Eq Nat (add c x) (add c y) -> Eq Nat x y is
  fn (c : Nat) (x : Nat) (y : Nat) (r : Eq Nat (add c x) (add c y)) is
    addCancelR c x y (trans (addComm x c) (trans r (addComm c y)))
  end
end

-- (x + b) + y is never < b (ported from ch13's notLtMidB), glyph-free.
notLtMidB : (x : Nat) -> (b : Nat) -> (y : Nat) -> Eq Bool (ltb (add (add x b) y) b) false is
  fn (x : Nat) (b : Nat) is
    case b of
    | zero -> fn (y : Nat) is ltbZero (add (add x zero) y) end
    | succ b2 with ih -> fn (y : Nat) is
        subst Nat (succ (add (add x b2) y)) (add (add x (succ b2)) y)
          (sym (cong (fn (w : Nat) is add w y end) (addSuccR x b2)))
          (fn (z : Nat) is Eq Bool (ltb z (succ b2)) false end)
          (ih y)
      end
    end
  end
end
-- (xx + b) + r = (xx + r) + b   (ported from ch13's midComm), glyph-free.
midComm : (xx : Nat) -> (b : Nat) -> (r : Nat) -> Eq Nat (add (add xx b) r) (add (add xx r) b) is
  fn (xx : Nat) (b : Nat) (r : Nat) is
    trans (addAssoc xx b r) (trans (cong (fn (w : Nat) is add xx w end) (addComm b r)) (sym (addAssoc xx r b)))
  end
end

-- add zero r = r  (add recurses on its 2nd arg, so this needs induction on r).
addZeroL : (r : Nat) -> Eq Nat (add zero r) r is
  fn (r : Nat) is
    NatElim (fn (z : Nat) is Eq Nat (add zero z) z end)
      (refl zero)
      (fn (k : Nat) (ih : Eq Nat (add zero k) k) is
         trans (addSuccR zero k) (cong succ ih) end)
      r
  end
end

-- QUOTIENT UNIQUENESS (ported from ch13's divUnique; ch203's mul puts the divisor
-- on the LEFT — mul (succ q) b = add b (mul q b) — so the leading b cancels via
-- addCancelL, and the cross-case contradiction reuses notLtMidB after an addComm.)
divUnique : (b : Nat) -> (q1 : Nat) -> (q2 : Nat) -> (r1 : Nat) -> (r2 : Nat)
    -> Lt r1 b -> Lt r2 b
    -> Eq Nat (add (mul q1 b) r1) (add (mul q2 b) r2) -> Eq Nat q1 q2 is
  fn (b : Nat) (q1 : Nat) is
    case q1 of
    | zero -> fn (q2 : Nat) is
        case q2 of
        | zero -> fn (r1 : Nat) (r2 : Nat) (b1 : Lt r1 b) (b2 : Lt r2 b)
            (h : Eq Nat (add zero r1) (add zero r2)) is refl zero end
        | succ q2b -> fn (r1 : Nat) (r2 : Nat) (b1 : Lt r1 b) (b2 : Lt r2 b)
            (h : Eq Nat (add zero r1) (add (add b (mul q2b b)) r2)) is
            -- r1 < b but r1 = (b + q2b·b) + r2 ≥ b: contradiction.
            trueNotFalse (trans (sym b1)
              (trans (cong (fn (z : Nat) is ltb z b end)
                       (trans (sym (addZeroL r1))
                         (trans h (cong (fn (w : Nat) is add w r2 end) (addComm b (mul q2b b))))))
                (notLtMidB (mul q2b b) b r2)))
          end
        end
      end
    | succ q1b with ih -> fn (q2 : Nat) is
        case q2 of
        | zero -> fn (r1 : Nat) (r2 : Nat) (b1 : Lt r1 b) (b2 : Lt r2 b)
            (h : Eq Nat (add (add b (mul q1b b)) r1) (add zero r2)) is
            trueNotFalse (trans (sym b2)
              (trans (cong (fn (z : Nat) is ltb z b end)
                       (trans (sym (addZeroL r2))
                         (trans (sym h) (cong (fn (w : Nat) is add w r1 end) (addComm b (mul q1b b))))))
                (notLtMidB (mul q1b b) b r1)))
          end
        | succ q2b -> fn (r1 : Nat) (r2 : Nat) (b1 : Lt r1 b) (b2 : Lt r2 b)
            (h : Eq Nat (add (add b (mul q1b b)) r1) (add (add b (mul q2b b)) r2)) is
            -- cancel the leading b: addAssoc reveals add b (add (q·b) r), then addCancelL.
            cong succ (ih q2b r1 r2 b1 b2
              (addCancelL b (add (mul q1b b) r1) (add (mul q2b b) r2)
                (trans (sym (addAssoc b (mul q1b b) r1))
                  (trans h (addAssoc b (mul q2b b) r2)))))
          end
        end
      end
    end
  end
end

-- ltb a s = leb (succ a) s   (ported from ch13's ltLeSucc).
ltLeSucc : (a : Nat) -> (s : Nat) -> Eq Bool (ltb a s) (leb (succ a) s) is
  fn (a : Nat) is
    case a of
    | zero -> fn (s : Nat) is case s of | zero -> refl false | succ s2 -> refl true end end
    | succ a2 with ih -> fn (s : Nat) is case s of | zero -> refl false | succ s2 -> ih s2 end end
    end
  end
end
-- ltb x (x + succ m) = true   (ported from ch13's ltbAddSucc; add recurses on 2nd arg,
-- and ltb on the first, so we induct on x and peel both via addSuccL is not needed —
-- x + succ m has a succ head after addSuccR, lining ltb's succ/succ recursion up).
ltbAddSucc : (x : Nat) -> (m : Nat) -> Eq Bool (ltb x (add x (succ m))) true is
  fn (x : Nat) is
    case x of
    | zero -> fn (m : Nat) is
        -- ltb 0 (add 0 (succ m)); add 0 (succ m) = succ (add 0 m) is succ-headed.
        subst Nat (succ (add zero m)) (add zero (succ m)) (sym (addSuccR zero m))
          (fn (z : Nat) is Eq Bool (ltb zero z) true end) (refl true) end
    | succ x2 with ih -> fn (m : Nat) is
        -- ltb (succ x2) (add (succ x2) (succ m)); rewrite the bound to succ (add x2 (succ m)).
        subst Nat (succ (add x2 (succ m))) (add (succ x2) (succ m)) (sym (addSuccL x2 (succ m)))
          (fn (z : Nat) is Eq Bool (ltb (succ x2) z) true end) (ih m) end
    end
  end
end

-- STRICT MONOTONICITY of scaling:  r < b  ⟹  r·(succ k) < b·(succ k).
-- b = (b−succ r) + succ r (monusAddInv); distribute over (succ k); reassociate so the
-- bound is r·(succ k) + succ M, then ltbAddSucc.
mulLtMono : (r : Nat) -> (b : Nat) -> (k : Nat)
    -> Lt r b -> Lt (mul r (succ k)) (mul b (succ k)) is
  fn (r : Nat) (b : Nat) (k : Nat) (lt : Lt r b) is
    let lesr : Eq Bool (leb (succ r) b) true =
      subst Bool (ltb r b) (leb (succ r) b) (ltLeSucc r b) (fn (z : Bool) is Eq Bool z true end) lt in
    let g : Nat = monus b (succ r) in
    let bEq : Eq Nat (add g (succ r)) b = monusAddInv (succ r) b lesr in
    -- mul b (succ k) = mul (add g (succ r)) (succ k) = g·k' + (succ k + r·k'), reassociated
    -- to r·k' + succ (g·k' + k).
    let A : Nat = mul g (succ k) in
    let B : Nat = mul r (succ k) in
    let boundEq : Eq Nat (mul b (succ k)) (add B (succ (add A k))) =
      trans (cong (fn (s : Nat) is mul s (succ k) end) (sym bEq))
        (trans (mulDistR g (succ r) (succ k))
          (trans (cong (fn (s : Nat) is add A s end) (refl (add (succ k) B)))
            (trans (cong (fn (s : Nat) is add A s end) (addSuccL k B))
              (trans (addSuccR A (add k B))
                (trans (cong succ (sym (addAssoc A k B)))
                  (trans (cong succ (addComm (add A k) B))
                    (sym (addSuccR B (add A k))))))))) in
    subst Nat (add B (succ (add A k))) (mul b (succ k)) (sym boundEq)
      (fn (z : Nat) is Eq Bool (ltb B z) true end)
      (ltbAddSucc B (add A k))
  end
end

-- natDiv x 0 = 0  (case on x; both divF clauses with b=0 return 0).
natDivZero : (x : Nat) -> Eq Nat (natDiv x zero) zero is
  fn (x : Nat) is case x of | zero -> refl zero | succ j -> refl zero end end
end

-- mul (succ b0) (succ k) is succ-headed:  = succ (k + b0·(succ k)).
-- mul (succ b0) c = add c (mul b0 c) = add (succ k) (mul b0 (succ k)) = succ (k + …).
mulSuccPosForm : (b0 : Nat) -> (k : Nat)
    -> Eq Nat (mul (succ b0) (succ k)) (succ (add k (mul b0 (succ k)))) is
  fn (b0 : Nat) (k : Nat) is addSuccL k (mul b0 (succ k)) end
end

-- SCALED DIVISION LAW:  q·(b·k') + r·k' = a·k'   (q=natDiv a b, r=natMod a b, b=succ b0,
-- k'=succ k).  Multiply divLaw by k' (mulDistR), then mulAssoc on the quotient term.
scaledDivLaw : (a : Nat) -> (b0 : Nat) -> (k : Nat)
    -> Eq Nat (add (mul (natDiv a (succ b0)) (mul (succ b0) (succ k)))
                   (mul (natMod a (succ b0)) (succ k)))
              (mul a (succ k)) is
  fn (a : Nat) (b0 : Nat) (k : Nat) is
    trans (cong (fn (s : Nat) is add s (mul (natMod a (succ b0)) (succ k)) end)
             (sym (mulAssoc (natDiv a (succ b0)) (succ b0) (succ k))))
      (trans (sym (mulDistR (mul (natDiv a (succ b0)) (succ b0)) (natMod a (succ b0)) (succ k)))
        (cong (fn (s : Nat) is mul s (succ k) end) (divLaw a (succ b0))))
  end
end

-- remBound transported along a proof that the modulus is succ-headed.
remBoundGen : (x : Nat) -> (b : Nat) -> (b0 : Nat) -> Eq Nat b (succ b0)
    -> Lt (natMod x b) b is
  fn (x : Nat) (b : Nat) (b0 : Nat) (hb : Eq Nat b (succ b0)) is
    subst Nat (succ b0) b (sym hb)
      (fn (z : Nat) is Lt (natMod x z) z end)
      (remBound x b0)
  end
end

-- DIVISION RESPECTS SCALING:  (a·k') // (b·k') = a // b.   b=0 collapses both to 0;
-- b=succ b0 invokes divUnique on the scaled division (two presentations of a·k'),
-- the remainders bounded by remBoundGen and mulLtMono.
natDivScale : (a : Nat) -> (b : Nat) -> (k : Nat)
    -> Eq Nat (natDiv (mul a (succ k)) (mul b (succ k))) (natDiv a b) is
  fn (a : Nat) (b : Nat) (k : Nat) is
    case b of
    | zero -> trans (natDivZero (mul a (succ k))) (sym (natDivZero a))
    | succ b0 ->
        let kp : Nat = succ k in
        let bp : Nat = succ b0 in
        let bigB : Nat = mul bp kp in
        let q : Nat = natDiv a bp in
        let r : Nat = natMod a bp in
        let Q : Nat = natDiv (mul a kp) bigB in
        let R : Nat = natMod (mul a kp) bigB in
        -- bigB is succ-headed (mulSuccPosForm) ⇒ R < bigB.
        let ltR : Lt R bigB =
          remBoundGen (mul a kp) bigB (add k (mul b0 kp)) (mulSuccPosForm b0 k) in
        -- r < bp (remBound), scaled ⇒ r·kp < bp·kp = bigB.
        let ltRr : Lt (mul r kp) bigB = mulLtMono r bp k (remBound a b0) in
        -- two presentations of a·kp: scaled divLaw vs divLaw of the scaled division.
        let hEq : Eq Nat (add (mul Q bigB) R) (add (mul q bigB) (mul r kp)) =
          trans (divLaw (mul a kp) bigB) (sym (scaledDivLaw a b0 k)) in
        divUnique bigB Q q R (mul r kp) ltR ltRr hEq
    end
  end
end

-- natMod x 0 = x.   natMod x 0 = x − (natDiv x 0)·0 = x − 0 = x  (mulZeroR, monus zero-case).
natModZero : (x : Nat) -> Eq Nat (natMod x zero) x is
  fn (x : Nat) is
    trans (cong (fn (s : Nat) is monus x s end) (mulZeroR (natDiv x zero)))
      (refl x)
  end
end

-- REMAINDER RESPECTS SCALING:  (a·k') % (b·k') = (a % b)·k'.   b=0 collapses both to a·k';
-- b=succ b0: divUnique gave Q=q, so cancelling q·(b·k') in the two presentations of a·k'
-- (hEq) leaves R = r·k'.
natModScale : (a : Nat) -> (b : Nat) -> (k : Nat)
    -> Eq Nat (natMod (mul a (succ k)) (mul b (succ k))) (mul (natMod a b) (succ k)) is
  fn (a : Nat) (b : Nat) (k : Nat) is
    case b of
    | zero -> trans (natModZero (mul a (succ k)))
        (sym (cong (fn (s : Nat) is mul s (succ k) end) (natModZero a)))
    | succ b0 ->
        let kp : Nat = succ k in
        let bp : Nat = succ b0 in
        let bigB : Nat = mul bp kp in
        let q : Nat = natDiv a bp in
        let r : Nat = natMod a bp in
        let Q : Nat = natDiv (mul a kp) bigB in
        let R : Nat = natMod (mul a kp) bigB in
        let qQ : Eq Nat Q q = natDivScale a bp k in
        let hEq : Eq Nat (add (mul Q bigB) R) (add (mul q bigB) (mul r kp)) =
          trans (divLaw (mul a kp) bigB) (sym (scaledDivLaw a b0 k)) in
        -- rewrite Q to q in hEq, then cancel mul q bigB on the left.
        addCancelL (mul q bigB) R (mul r kp)
          (subst Nat Q q qQ (fn (z : Nat) is Eq Nat (add (mul z bigB) R) (add (mul q bigB) (mul r kp)) end) hEq)
    end
  end
end

-- floorUniqueGeneral: EQUAL FRACTIONS HAVE EQUAL FLOORS.  If a / succ b0 and
-- c / succ d0 are the same rational (cross-multiplication a·succ d0 = c·succ b0),
-- their flooring quotients agree.  The Euclidean-uniqueness payoff at Nat: expand
-- both by divLaw against the COMMON denominator (succ b0)·(succ d0), bound the two
-- remainders (mul ra d, mul rc b) below it, and divUnique forces the quotients
-- equal.  This is exactly what makes each decimal DIGIT a function of the rational
-- value — the engine of the to_radix respect proof.
floorUniqueGeneral : (b0 : Nat) -> (d0 : Nat) -> (a : Nat) -> (c : Nat)
    -> Eq Nat (mul a (succ d0)) (mul c (succ b0))
    -> Eq Nat (natDiv a (succ b0)) (natDiv c (succ d0)) is
  fn (b0 : Nat) (d0 : Nat) (a : Nat) (c : Nat)
     (hyp : Eq Nat (mul a (succ d0)) (mul c (succ b0))) is
    let b  : Nat = succ b0 in
    let d  : Nat = succ d0 in
    let qa : Nat = natDiv a b in
    let ra : Nat = natMod a b in
    let qc : Nat = natDiv c d in
    let rc : Nat = natMod c d in
    let bd : Nat = mul b d in
    let lhsEq : Eq Nat (add (mul qa bd) (mul ra d)) (mul a d) =
      trans (cong (fn (s : Nat) is add s (mul ra d) end) (sym (mulAssoc qa b d)))
        (trans (sym (mulDistR (mul qa b) ra d))
          (cong (fn (s : Nat) is mul s d end) (divLaw a b))) in
    let rhsEq : Eq Nat (add (mul qc bd) (mul rc b)) (mul c b) =
      trans (cong (fn (s : Nat) is add s (mul rc b) end)
              (sym (trans (mulAssoc qc d b)
                     (cong (fn (s : Nat) is mul qc s end) (mulComm d b)))))
        (trans (sym (mulDistR (mul qc d) rc b))
          (cong (fn (s : Nat) is mul s b end) (divLaw c d))) in
    let keyEq : Eq Nat (add (mul qa bd) (mul ra d)) (add (mul qc bd) (mul rc b)) =
      trans lhsEq (trans hyp (sym rhsEq)) in
    let bound1 : Lt (mul ra d) bd = mulLtMono ra b d0 (remBound a b0) in
    let bound2 : Lt (mul rc b) bd =
      subst Nat (mul d b) bd (mulComm d b)
        (fn (s : Nat) is Lt (mul rc b) s end)
        (mulLtMono rc d b0 (remBound c d0)) in
    divUnique bd qa qc (mul ra d) (mul rc b) bound1 bound2 keyEq
  end
end

-- ============================================================================
-- APPENDED Z-level lemmas (natAbs / sign laws).
-- ============================================================================

-- monus n zero = n.  Definitional: monus scrutinizes its SECOND argument, so
-- monus m zero ~> m by ι; refl suffices.
monusZeroR : (n : Nat) -> Eq Nat (monus n zero) n is
  fn (n : Nat) is refl n end
end

-- |zfrom n| = n.  obs (zfrom n) = canon (npair n zero) = npair (monus n zero)
-- (monus zero n) = npair n zero; natAbs = add n zero = n.
natAbsZfrom : (n : Nat) -> Eq Nat (natAbs (zfrom n)) n is
  fn (n : Nat) is
    calc natAbs (zfrom n)
      = add n (monus zero n) by cong (fn (s : Nat) is add n s end) (refl (monus zero n))
      = add n zero           by cong (fn (s : Nat) is add n s end) (zeroMonus n)
      = n                    by addZeroR n
    end
  end
end

-- predMul: (pred x)·n = (x·n) − n.  pred drops one copy of n from the row of n's.
-- x=0: both 0 (zeroMonus).  x=succ k: x·n = n + k·n, and (n + k·n) − n = k·n by
-- monusAddCancel (after addComm lines the cancelled n up on the right).
predMul : (x : Nat) -> (n : Nat) -> Eq Nat (mul (pred x) n) (monus (mul x n) n) is
  fn (x : Nat) (n : Nat) is
    case x of
    | zero -> sym (zeroMonus n)
    | succ k ->
        sym (trans (cong (fn (s : Nat) is monus s n end) (addComm n (mul k n)))
                   (monusAddCancel n (mul k n)))
    end
  end
end

-- RIGHT-distribution of multiplication over truncated subtraction:
-- (a − b)·n = a·n − b·n.  TRUE even with underflow (a<b ⇒ both sides 0, since
-- mul is order-preserving), but the naive "(a−b)+(c−d) = (a+c)−(b+d)" step is
-- FALSE truncated, so the proof inducts on b through predMul, never splitting the
-- monus pair.  Step: monus a (succ k) ≡ pred (monus a k); predMul peels the n,
-- the IH rewrites, monusAdd re-nests, addComm aligns.
mulMonusDistR : (a : Nat) -> (n : Nat) -> (b : Nat)
    -> Eq Nat (mul (monus a b) n) (monus (mul a n) (mul b n)) is
  fn (a : Nat) (n : Nat) (b : Nat) is
    NatElim (fn (x : Nat) is Eq Nat (mul (monus a x) n) (monus (mul a n) (mul x n)) end)
      (refl (mul a n))
      (fn (k : Nat) (ih : Eq Nat (mul (monus a k) n) (monus (mul a n) (mul k n))) is
        trans (predMul (monus a k) n)
          (trans (cong (fn (s : Nat) is monus s n end) ih)
            (trans (sym (monusAdd (mul a n) (mul k n) n))
              (cong (fn (s : Nat) is monus (mul a n) s end)
                    (addComm (mul k n) n))))
      end)
      b
  end
end

-- THE SIGN-BRIDGE (non-negative case): |m · zfrom n| = |m| · n.  The full
-- multiplicativity of natAbs needs a four-way sign split; here the SECOND factor
-- is a genuine natural (zfrom n, never negative), and that is all the to_radix
-- respect proof needs (it multiplies a numerator by a positive denominator
-- zden q = zfrom (succ (qdenN q))).  qind drops m to a representative (a, b);
-- then zmul (qin (a,b)) (zfrom n) ≡ qin (a·n + b·0, a·0 + b·n), whose canon-abs
-- is add (monus (a·n)(b·n)) (monus (b·n)(a·n)) once the 0-products clear — and
-- |m|·n = (|a−b|)·n distributes to exactly that pair via mulMonusDistR (twice).
natAbsMulZfrom : (m : Z) -> (n : Nat)
    -> Eq Nat (natAbs (zmul m (zfrom n))) (mul (natAbs m) n) is
  fn (m : Z) (n : Nat) is
    qind NatPair ZRel
      (fn (w : Z) is Eq Nat (natAbs (zmul w (zfrom n))) (mul (natAbs w) n) end)
      (fn (p : NatPair) is
        let a : Nat = fst p in
        let b : Nat = snd p in
        let feq : Eq Nat (add (mul a n) (mul b zero)) (mul a n) =
          trans (cong (fn (s : Nat) is add (mul a n) s end) (mulZeroR b))
                (addZeroR (mul a n)) in
        let snz : Eq Nat (add (mul a zero) (mul b n)) (mul b n) =
          cong (fn (s : Nat) is add s (mul b n) end) (mulZeroR a) in
        calc natAbs (zmul (qin NatPair ZRel p) (zfrom n))
          = add (monus (add (mul a n) (mul b zero)) (add (mul a zero) (mul b n)))
                (monus (add (mul a zero) (mul b n)) (add (mul a n) (mul b zero)))
              by refl (natAbs (zmul (qin NatPair ZRel p) (zfrom n)))
          = add (monus (mul a n) (mul b n)) (monus (mul b n) (mul a n))
              by cong2 (fn (u : Nat) (v : Nat) is add (monus u v) (monus v u) end) feq snz
          = mul (add (monus a b) (monus b a)) n
              by sym (trans (mulDistR (monus a b) (monus b a) n)
                        (cong2 (fn (u : Nat) (v : Nat) is add u v end)
                          (mulMonusDistR a n b)
                          (mulMonusDistR b n a)))
        end
      end)
      m
  end
end

-- INTEGER-PART RESPECT (the first rung of the to_radix qlift): QRel-related
-- QPairs have the SAME integer part.  QRel p q is cross-multiplication in ℤ,
-- zmul (qnum p) (zden q) = zmul (qnum q) (zden p); take |·| of both sides and the
-- non-negative-factor bridge (natAbsMulZfrom, since zden _ = zfrom (succ …)) turns
-- it into the Nat cross-product  |num p|·den q = |num q|·den p,  which is exactly
-- floorUniqueGeneral's hypothesis — so the flooring quotients (integer parts)
-- agree.  This is what makes the integer part a FUNCTION of the rational value.
intPartResp : (p : QPair) -> (q : QPair) -> QRel p q
    -> Eq Nat (natDiv (qmagNum p) (qmagDen p)) (natDiv (qmagNum q) (qmagDen q)) is
  fn (p : QPair) (q : QPair) (h : QRel p q) is
    floorUniqueGeneral (qdenN p) (qdenN q) (qmagNum p) (qmagNum q)
      (trans (sym (natAbsMulZfrom (qnum p) (succ (qdenN q))))
        (trans (cong natAbs h)
               (natAbsMulZfrom (qnum q) (succ (qdenN p)))))
  end
end

-- MULTIPLYING BY A POSITIVE PRESERVES ZERO-NESS (the Bool-sign engine).  The
-- nonzero-test  case _ of zero->false | succ->true  agrees on  x  and  x·(succ n):
-- x=0 ⇒ mul 0 (succ n) ≡ 0 (mul recurses on its first arg), both false; x=succ j ⇒
-- mul (succ j)(succ n) ≡ succ (…) (add recurses on succ n's head), both true.  This
-- is the sign analogue of monusZeroR for natAbs — a positive factor never flips a
-- nonzero magnitude to zero or back.
nzMulSucc : (x : Nat) -> (n : Nat)
    -> Eq Bool (case (mul x (succ n)) of | zero -> false | succ k -> true end)
               (case x of | zero -> false | succ k -> true end) is
  fn (x : Nat) (n : Nat) is
    case x of
    | zero -> refl false
    | succ j -> refl true
    end
  end
end

-- THE SIGN-BRIDGE (non-negative case): isNegZ (m · zfrom (succ n)) = isNegZ m.  Dual
-- of natAbsMulZfrom for the sign rather than the magnitude.  qind drops m to (a, b);
-- then the negative part of m · zfrom (succ n) is  snd (canon (pmul (a,b)(succ n, 0)))
-- = monus (a·0 + b·(succ n)) (a·(succ n) + b·0), whose 0-products clear (snz/feq) to
-- monus (b·(succ n)) (a·(succ n)) = (b−a)·(succ n)  (mulMonusDistR).  isNegZ m itself
-- is  case (monus b a) of …,  so the goal is exactly nzMulSucc (monus b a) n: scaling
-- the negative part b−a by the positive (succ n) cannot change whether it is zero.
isNegZMulZfromSucc : (m : Z) -> (n : Nat)
    -> Eq Bool (isNegZ (zmul m (zfrom (succ n)))) (isNegZ m) is
  fn (m : Z) (n : Nat) is
    qind NatPair ZRel
      (fn (w : Z) is Eq Bool (isNegZ (zmul w (zfrom (succ n)))) (isNegZ w) end)
      (fn (p : NatPair) is
        let a : Nat = fst p in
        let b : Nat = snd p in
        let snz : Eq Nat (add (mul a zero) (mul b (succ n))) (mul b (succ n)) =
          cong (fn (s : Nat) is add s (mul b (succ n)) end) (mulZeroR a) in
        let feq : Eq Nat (add (mul a (succ n)) (mul b zero)) (mul a (succ n)) =
          trans (cong (fn (s : Nat) is add (mul a (succ n)) s end) (mulZeroR b))
                (addZeroR (mul a (succ n))) in
        let sndEq : Eq Nat (snd (obs (zmul (qin NatPair ZRel p) (zfrom (succ n)))))
                           (mul (monus b a) (succ n)) =
          calc snd (obs (zmul (qin NatPair ZRel p) (zfrom (succ n))))
            = monus (add (mul a zero) (mul b (succ n)))
                    (add (mul a (succ n)) (mul b zero))
                by refl (snd (obs (zmul (qin NatPair ZRel p) (zfrom (succ n)))))
            = monus (mul b (succ n)) (mul a (succ n))
                by cong2 (fn (u : Nat) (v : Nat) is monus u v end) snz feq
            = mul (monus b a) (succ n)
                by sym (mulMonusDistR b (succ n) a)
          end in
        trans (cong (fn (s : Nat) is case s of | zero -> false | succ k -> true end end)
                    sndEq)
              (nzMulSucc (monus b a) n)
      end)
      m
  end
end

-- SIGN RESPECT (the second rung of the to_radix qlift): QRel-related QPairs have the
-- SAME sign.  QRel p q cross-multiplies in ℤ; take isNegZ of both sides and the
-- non-negative-factor sign-bridge (isNegZMulZfromSucc, since zden _ = zfrom (succ …))
-- turns it into  isNegZ (qnum p) = isNegZ (qnum q),  i.e.  qsign p = qsign q.  This is
-- what makes the sign a FUNCTION of the rational value.
signResp : (p : QPair) -> (q : QPair) -> QRel p q
    -> Eq Bool (qsign p) (qsign q) is
  fn (p : QPair) (q : QPair) (h : QRel p q) is
    trans (sym (isNegZMulZfromSucc (qnum p) (qdenN q)))
      (trans (cong isNegZ h)
             (isNegZMulZfromSucc (qnum q) (qdenN p)))
  end
end

-- ============================================================================
-- RUNG 3 (fractional digits) — foundations.
-- ============================================================================

-- CANCELLATION of a positive multiplier:  x·(succ k) = y·(succ k)  ⟹  x = y.
-- The equality gives lte both ways on the products; lteMulPos strips the common
-- (succ k) from each, and lteAntisym pins x = y.  The Nat injectivity that lets a
-- cross-equality  rem_p·den_q = rem_q·den_p  be cancelled to compare remainders.
mulRightCancel : (k : Nat) -> (x : Nat) -> (y : Nat)
    -> Eq Nat (mul x (succ k)) (mul y (succ k)) -> Eq Nat x y is
  fn (k : Nat) (x : Nat) (y : Nat) (h : Eq Nat (mul x (succ k)) (mul y (succ k))) is
    let lexy : Eq Bool (lte (mul x (succ k)) (mul y (succ k))) true =
      subst Nat (mul x (succ k)) (mul y (succ k)) h
        (fn (z : Nat) is Eq Bool (lte (mul x (succ k)) z) true end)
        (lteRefl (mul x (succ k))) in
    let leyx : Eq Bool (lte (mul y (succ k)) (mul x (succ k))) true =
      subst Nat (mul x (succ k)) (mul y (succ k)) h
        (fn (z : Nat) is Eq Bool (lte z (mul x (succ k))) true end)
        (lteRefl (mul x (succ k))) in
    lteAntisym x y
      (trans (sym (lteMulPos k x y)) lexy)
      (trans (sym (lteMulPos k y x)) leyx)
  end
end

-- eqW is REFLEXIVE:  eqW n n = true.  succ/succ reduces to the recursive call by ι.
eqWRefl : (n : Nat) -> Eq Bool (eqW n n) true is
  fn (n : Nat) is
    NatElim (fn (x : Nat) is Eq Bool (eqW x x) true end)
      (refl true)
      (fn (k : Nat) (ih : Eq Bool (eqW k k) true) is ih end)
      n
  end
end

-- eqW is COMPLETE:  x = y  ⟹  eqW x y = true.  Transport eqWRefl along the equality.
eqWComplete : (x : Nat) -> (y : Nat) -> Eq Nat x y -> Eq Bool (eqW x y) true is
  fn (x : Nat) (y : Nat) (h : Eq Nat x y) is
    subst Nat x y h (fn (z : Nat) is Eq Bool (eqW x z) true end) (eqWRefl x)
  end
end

-- eqW is SOUND:  eqW x y = true  ⟹  x = y.  Double induction; the mismatched-head
-- branches discharge an absurd  false = true  via lteAbsurdNat, the succ/succ branch
-- recurses (eqW (succ k)(succ u) ≡ eqW k u) and re-applies succ.
eqWSound : (x : Nat) -> (y : Nat) -> Eq Bool (eqW x y) true -> Eq Nat x y is
  fn (x : Nat) is
    NatElim (fn (w : Nat) is (y : Nat) -> Eq Bool (eqW w y) true -> Eq Nat w y end)
      (fn (y : Nat) is
        NatElim (fn (u : Nat) is Eq Bool (eqW zero u) true -> Eq Nat zero u end)
          (fn (h : Eq Bool (eqW zero zero) true) is refl zero end)
          (fn (u' : Nat) (ihu : Eq Bool (eqW zero u') true -> Eq Nat zero u') is
            fn (h : Eq Bool (eqW zero (succ u')) true) is
              lteAbsurdNat zero (succ u') h end
          end)
          y
      end)
      (fn (k : Nat) (ih : (y : Nat) -> Eq Bool (eqW k y) true -> Eq Nat k y) is
        fn (y : Nat) is
          NatElim (fn (u : Nat) is Eq Bool (eqW (succ k) u) true -> Eq Nat (succ k) u end)
            (fn (h : Eq Bool (eqW (succ k) zero) true) is
              lteAbsurdNat (succ k) zero h end)
            (fn (u' : Nat) (ihu : Eq Bool (eqW (succ k) u') true -> Eq Nat (succ k) u') is
              fn (h : Eq Bool (eqW (succ k) (succ u')) true) is
                cong (fn (z : Nat) is succ z end) (ih u' h) end
            end)
            y
        end
      end)
      x
  end
end

-- Boolean conjunction:  and true b = b, and false b = false.
and : Bool -> Bool -> Bool is
  fn (a : Bool) (b : Bool) is BoolElim (fn (x : Bool) is Bool end) b false a end
end

-- BOOL EXTENSIONALITY:  two bools sharing the same truth value are equal.  The
-- p=true case syms f (refl true); the p=false case splits q — true contradicts via
-- g (refl true), false is refl.  The decidable bridge: it turns a biconditional on
-- nonzero-tests into an actual Bool equality.
boolTrueIff : (p : Bool) -> (q : Bool)
    -> (Eq Bool p true -> Eq Bool q true)
    -> (Eq Bool q true -> Eq Bool p true)
    -> Eq Bool p q is
  fn (p : Bool) (q : Bool)
     (f : Eq Bool p true -> Eq Bool q true)
     (g : Eq Bool q true -> Eq Bool p true) is
    BoolElim
      (fn (b : Bool) is
         (Eq Bool b true -> Eq Bool q true)
           -> (Eq Bool q true -> Eq Bool b true)
           -> Eq Bool b q end)
      (fn (f1 : Eq Bool true true -> Eq Bool q true)
          (g1 : Eq Bool q true -> Eq Bool true true) is
         sym (f1 (refl true)) end)
      (fn (f0 : Eq Bool false true -> Eq Bool q true)
          (g0 : Eq Bool q true -> Eq Bool false true) is
         BoolElim
           (fn (c : Bool) is (Eq Bool c true -> Eq Bool false true) -> Eq Bool false c end)
           (fn (g0t : Eq Bool true true -> Eq Bool false true) is g0t (refl true) end)
           (fn (g0f : Eq Bool false true -> Eq Bool false true) is refl false end)
           q g0 end)
      p f g
  end
end

-- eqW RESPECTS CROSS-EQUALITY:  if rP·sd = rQ·sb and x·sd = y·sb (sb = succ b0,
-- sd = succ d0), then eqW rP x = eqW rQ y.  Each direction: decode one eqW to a Nat
-- equality (eqWSound), transport it across the two cross-products and cancel the
-- positive factor (mulRightCancel) to get the other Nat equality, re-encode
-- (eqWComplete); boolTrueIff glues the directions.  This is what makes the cycle
-- detector see the SAME recurrences in two equivalent long divisions even though the
-- recorded remainders differ.
eqWCross : (b0 : Nat) -> (d0 : Nat) -> (rP : Nat) -> (rQ : Nat) -> (x : Nat) -> (y : Nat)
    -> Eq Nat (mul rP (succ d0)) (mul rQ (succ b0))
    -> Eq Nat (mul x (succ d0)) (mul y (succ b0))
    -> Eq Bool (eqW rP x) (eqW rQ y) is
  fn (b0 : Nat) (d0 : Nat) (rP : Nat) (rQ : Nat) (x : Nat) (y : Nat)
     (hr : Eq Nat (mul rP (succ d0)) (mul rQ (succ b0)))
     (hx : Eq Nat (mul x (succ d0)) (mul y (succ b0))) is
    boolTrueIff (eqW rP x) (eqW rQ y)
      (fn (e : Eq Bool (eqW rP x) true) is
         let hpx : Eq Nat rP x = eqWSound rP x e in
         let hqy : Eq Nat rQ y =
           mulRightCancel b0 rQ y
             (trans (sym hr)
               (trans (cong (fn (z : Nat) is mul z (succ d0) end) hpx) hx)) in
         eqWComplete rQ y hqy end)
      (fn (e : Eq Bool (eqW rQ y) true) is
         let hqy : Eq Nat rQ y = eqWSound rQ y e in
         let hpx : Eq Nat rP x =
           mulRightCancel d0 rP x
             (trans hr
               (trans (cong (fn (z : Nat) is mul z (succ b0) end) hqy) (sym hx))) in
         eqWComplete rP x hpx end)
  end
end

-- EX FALSO from a disjoint Bool equation:  false = true entails anything.  The motive
-- is C at true and the inhabited (Eq Bool false false) at false; subst along the
-- false=true proof ships refl into C.
boolDisjoint : (C : U) -> Eq Bool false true -> C is
  fn (C : U) (h : Eq Bool false true) is
    subst Bool false true h
      (fn (z : Bool) is
         case z of
         | true  -> C
         | false -> Eq Bool false false
         end
       end)
      (refl false)
  end
end

-- Projections of a true conjunction.  and false _ ≡ false, so a false left factor
-- makes the whole thing a false = true absurdity (boolDisjoint for the right one).
andTrueL : (a : Bool) -> (b : Bool) -> Eq Bool (and a b) true -> Eq Bool a true is
  fn (a : Bool) (b : Bool) (h : Eq Bool (and a b) true) is
    BoolElim (fn (x : Bool) is (Eq Bool (and x b) true -> Eq Bool x true) end)
      (fn (h1 : Eq Bool (and true b) true) is refl true end)
      (fn (h0 : Eq Bool (and false b) true) is h0 end)
      a h
  end
end
andTrueR : (a : Bool) -> (b : Bool) -> Eq Bool (and a b) true -> Eq Bool b true is
  fn (a : Bool) (b : Bool) (h : Eq Bool (and a b) true) is
    BoolElim (fn (x : Bool) is (Eq Bool (and x b) true -> Eq Bool b true) end)
      (fn (h1 : Eq Bool (and true b) true) is h1 end)
      (fn (h0 : Eq Bool (and false b) true) is boolDisjoint (Eq Bool b true) h0 end)
      a h
  end
end

-- THE SEEN-LIST CORRESPONDENCE.  wcrossB b0 d0 sP sQ = true means the two recorded
-- remainder lists have equal length and position-wise cross-equal entries
-- (sP[i]·(succ d0) = sQ[i]·(succ b0)), checked by eqW on the cross-products.
-- Structural on sP; the mismatched-length cases are false.
wcrossB : Nat -> Nat -> WList -> WList -> Bool is
  fn (b0 : Nat) (d0 : Nat) (sP : WList) is
    WListElim (fn (w : WList) is WList -> Bool end)
      (fn (sQ : WList) is case sQ of | wnil -> true | wcons y ys -> false end end)
      (fn (x : Nat) (xs : WList) (ih : WList -> Bool) is
         fn (sQ : WList) is
           case sQ of
           | wnil -> false
           | wcons y ys -> and (eqW (mul x (succ d0)) (mul y (succ b0))) (ih ys)
           end
         end
       end)
      sP
  end
end

-- MEMBERSHIP RESPECTS THE CORRESPONDENCE.  Under wcrossB and a cross-equal current
-- remainder, the cycle detector reports the same hit/miss in both expansions.  The
-- head comparison agrees by eqWCross; the tails recurse; cong2 rebuilds the case.
wmemberCross : (b0 : Nat) -> (d0 : Nat) -> (sP : WList) -> (sQ : WList)
    -> Eq Bool (wcrossB b0 d0 sP sQ) true
    -> (rP : Nat) -> (rQ : Nat)
    -> Eq Nat (mul rP (succ d0)) (mul rQ (succ b0))
    -> Eq Bool (wmember rP sP) (wmember rQ sQ) is
  fn (b0 : Nat) (d0 : Nat) (sP : WList) is
    WListElim
      (fn (w : WList) is
         (sQ : WList) -> Eq Bool (wcrossB b0 d0 w sQ) true
           -> (rP : Nat) -> (rQ : Nat)
           -> Eq Nat (mul rP (succ d0)) (mul rQ (succ b0))
           -> Eq Bool (wmember rP w) (wmember rQ sQ) end)
      (fn (sQ : WList) is
         case sQ of
         | wnil ->
             fn (h : Eq Bool (wcrossB b0 d0 wnil wnil) true) (rP : Nat) (rQ : Nat)
                (hc : Eq Nat (mul rP (succ d0)) (mul rQ (succ b0))) is refl false end
         | wcons y ys ->
             fn (h : Eq Bool (wcrossB b0 d0 wnil (wcons y ys)) true) (rP : Nat) (rQ : Nat)
                (hc : Eq Nat (mul rP (succ d0)) (mul rQ (succ b0))) is
               boolDisjoint (Eq Bool (wmember rP wnil) (wmember rQ (wcons y ys))) h end
         end
       end)
      (fn (x : Nat) (xs : WList)
          (ih : (sQ : WList) -> Eq Bool (wcrossB b0 d0 xs sQ) true -> (rP : Nat) -> (rQ : Nat)
                  -> Eq Nat (mul rP (succ d0)) (mul rQ (succ b0))
                  -> Eq Bool (wmember rP xs) (wmember rQ sQ)) is
         fn (sQ : WList) is
           case sQ of
           | wnil ->
               fn (h : Eq Bool (wcrossB b0 d0 (wcons x xs) wnil) true) (rP : Nat) (rQ : Nat)
                  (hc : Eq Nat (mul rP (succ d0)) (mul rQ (succ b0))) is
                 boolDisjoint (Eq Bool (wmember rP (wcons x xs)) (wmember rQ wnil)) h end
           | wcons y ys ->
               fn (h : Eq Bool (wcrossB b0 d0 (wcons x xs) (wcons y ys)) true) (rP : Nat) (rQ : Nat)
                  (hc : Eq Nat (mul rP (succ d0)) (mul rQ (succ b0))) is
                 let hxy : Eq Nat (mul x (succ d0)) (mul y (succ b0)) =
                   eqWSound (mul x (succ d0)) (mul y (succ b0))
                     (andTrueL (eqW (mul x (succ d0)) (mul y (succ b0)))
                               (wcrossB b0 d0 xs ys) h) in
                 let hTail : Eq Bool (wcrossB b0 d0 xs ys) true =
                   andTrueR (eqW (mul x (succ d0)) (mul y (succ b0)))
                            (wcrossB b0 d0 xs ys) h in
                 let hEqW : Eq Bool (eqW rP x) (eqW rQ y) =
                   eqWCross b0 d0 rP rQ x y hc hxy in
                 let ihTail : Eq Bool (wmember rP xs) (wmember rQ ys) =
                   ih ys hTail rP rQ hc in
                 cong2 (fn (sc : Bool) (fb : Bool) is
                          BoolElim (fn (w : Bool) is Bool end) true fb sc end)
                   hEqW ihTail end
           end
         end
       end)
      sP
  end
end

-- THE RECURRENCE INDEX RESPECTS THE CORRESPONDENCE.  Same structure as wmemberCross
-- but the false-branch carries succ of the recursive index, so the repetend's start
-- position is identical in both expansions.
windexCross : (b0 : Nat) -> (d0 : Nat) -> (sP : WList) -> (sQ : WList)
    -> Eq Bool (wcrossB b0 d0 sP sQ) true
    -> (rP : Nat) -> (rQ : Nat)
    -> Eq Nat (mul rP (succ d0)) (mul rQ (succ b0))
    -> Eq Nat (windex rP sP) (windex rQ sQ) is
  fn (b0 : Nat) (d0 : Nat) (sP : WList) is
    WListElim
      (fn (w : WList) is
         (sQ : WList) -> Eq Bool (wcrossB b0 d0 w sQ) true
           -> (rP : Nat) -> (rQ : Nat)
           -> Eq Nat (mul rP (succ d0)) (mul rQ (succ b0))
           -> Eq Nat (windex rP w) (windex rQ sQ) end)
      (fn (sQ : WList) is
         case sQ of
         | wnil ->
             fn (h : Eq Bool (wcrossB b0 d0 wnil wnil) true) (rP : Nat) (rQ : Nat)
                (hc : Eq Nat (mul rP (succ d0)) (mul rQ (succ b0))) is refl zero end
         | wcons y ys ->
             fn (h : Eq Bool (wcrossB b0 d0 wnil (wcons y ys)) true) (rP : Nat) (rQ : Nat)
                (hc : Eq Nat (mul rP (succ d0)) (mul rQ (succ b0))) is
               boolDisjoint (Eq Nat (windex rP wnil) (windex rQ (wcons y ys))) h end
         end
       end)
      (fn (x : Nat) (xs : WList)
          (ih : (sQ : WList) -> Eq Bool (wcrossB b0 d0 xs sQ) true -> (rP : Nat) -> (rQ : Nat)
                  -> Eq Nat (mul rP (succ d0)) (mul rQ (succ b0))
                  -> Eq Nat (windex rP xs) (windex rQ sQ)) is
         fn (sQ : WList) is
           case sQ of
           | wnil ->
               fn (h : Eq Bool (wcrossB b0 d0 (wcons x xs) wnil) true) (rP : Nat) (rQ : Nat)
                  (hc : Eq Nat (mul rP (succ d0)) (mul rQ (succ b0))) is
                 boolDisjoint (Eq Nat (windex rP (wcons x xs)) (windex rQ wnil)) h end
           | wcons y ys ->
               fn (h : Eq Bool (wcrossB b0 d0 (wcons x xs) (wcons y ys)) true) (rP : Nat) (rQ : Nat)
                  (hc : Eq Nat (mul rP (succ d0)) (mul rQ (succ b0))) is
                 let hxy : Eq Nat (mul x (succ d0)) (mul y (succ b0)) =
                   eqWSound (mul x (succ d0)) (mul y (succ b0))
                     (andTrueL (eqW (mul x (succ d0)) (mul y (succ b0)))
                               (wcrossB b0 d0 xs ys) h) in
                 let hTail : Eq Bool (wcrossB b0 d0 xs ys) true =
                   andTrueR (eqW (mul x (succ d0)) (mul y (succ b0)))
                            (wcrossB b0 d0 xs ys) h in
                 let hEqW : Eq Bool (eqW rP x) (eqW rQ y) =
                   eqWCross b0 d0 rP rQ x y hc hxy in
                 let ihTail : Eq Nat (windex rP xs) (windex rQ ys) =
                   ih ys hTail rP rQ hc in
                 cong2 (fn (sc : Bool) (t : Nat) is
                          BoolElim (fn (w : Bool) is Nat end) zero (succ t) sc end)
                   hEqW ihTail end
           end
         end
       end)
      sP
  end
end

-- ============================================================================
-- RUNG 3 — the per-step cross-equality is preserved through the long division.
-- ============================================================================

-- a=true and b=true give and a b = true (and true b ≡ b).
andBoth : (a : Bool) -> (b : Bool) -> Eq Bool a true -> Eq Bool b true -> Eq Bool (and a b) true is
  fn (a : Bool) (b : Bool) (ha : Eq Bool a true) (hb : Eq Bool b true) is
    trans (cong (fn (z : Bool) is and z b end) ha) hb
  end
end

-- Scaling the cross-equality by the radix 10:  remP·sd = remQ·sb  ⟹
-- (remP·10)·sd = (remQ·10)·sb.  Reassociate so the shared 10 floats to the outside.
mul10Cross : (b0 : Nat) -> (d0 : Nat) -> (remP : Nat) -> (remQ : Nat)
    -> Eq Nat (mul remP (succ d0)) (mul remQ (succ b0))
    -> Eq Nat (mul (mul remP 10) (succ d0)) (mul (mul remQ 10) (succ b0)) is
  fn (b0 : Nat) (d0 : Nat) (remP : Nat) (remQ : Nat)
     (hr : Eq Nat (mul remP (succ d0)) (mul remQ (succ b0))) is
    trans (mulAssoc remP 10 (succ d0))
      (trans (cong (fn (z : Nat) is mul remP z end) (mulComm 10 (succ d0)))
        (trans (sym (mulAssoc remP (succ d0) 10))
          (trans (cong (fn (z : Nat) is mul z 10 end) hr)
            (trans (mulAssoc remQ (succ b0) 10)
              (trans (cong (fn (z : Nat) is mul remQ z end) (mulComm (succ b0) 10))
                (sym (mulAssoc remQ 10 (succ b0))))))))
  end
end

-- THE REMAINDER STAYS CROSS-EQUAL.  If a·sd = c·sb then the long-division remainders
-- satisfy (a % sb)·sd = (c % sd)·sb.  natMod x m = x − (x//m)·m; distribute ·sd / ·sb
-- over the monus (mulMonusDistR), equate the minuends by hypothesis and the quotient
-- terms via floorUniqueGeneral (the floors agree) plus a commute of sb·sd.
natModCrossStep : (b0 : Nat) -> (d0 : Nat) -> (a : Nat) -> (c : Nat)
    -> Eq Nat (mul a (succ d0)) (mul c (succ b0))
    -> Eq Nat (mul (natMod a (succ b0)) (succ d0)) (mul (natMod c (succ d0)) (succ b0)) is
  fn (b0 : Nat) (d0 : Nat) (a : Nat) (c : Nat)
     (hyp : Eq Nat (mul a (succ d0)) (mul c (succ b0))) is
    let qa : Nat = natDiv a (succ b0) in
    let qc : Nat = natDiv c (succ d0) in
    let hq : Eq Nat qa qc = floorUniqueGeneral b0 d0 a c hyp in
    let midEq : Eq Nat (mul (mul qa (succ b0)) (succ d0)) (mul (mul qc (succ d0)) (succ b0)) =
      trans (mulAssoc qa (succ b0) (succ d0))
        (trans (cong2 (fn (u : Nat) (v : Nat) is mul u v end) hq (mulComm (succ b0) (succ d0)))
               (sym (mulAssoc qc (succ d0) (succ b0)))) in
    calc mul (natMod a (succ b0)) (succ d0)
      = mul (monus a (mul qa (succ b0))) (succ d0)
          by refl (mul (natMod a (succ b0)) (succ d0))
      = monus (mul a (succ d0)) (mul (mul qa (succ b0)) (succ d0))
          by mulMonusDistR a (succ d0) (mul qa (succ b0))
      = monus (mul c (succ b0)) (mul (mul qc (succ d0)) (succ b0))
          by cong2 (fn (u : Nat) (v : Nat) is monus u v end) hyp midEq
      = mul (monus c (mul qc (succ d0))) (succ b0)
          by sym (mulMonusDistR c (succ b0) (mul qc (succ d0)))
      = mul (natMod c (succ d0)) (succ b0)
          by refl (mul (natMod c (succ d0)) (succ b0))
    end
  end
end

-- APPENDING CROSS-EQUAL REMAINDERS PRESERVES THE CORRESPONDENCE.  wsnoc appends at the
-- tail, so the induction walks both lists down to their (corresponding) ends and snocs
-- the new cross-equal pair (eqWComplete on the scaled equality); andBoth re-knits.
wcrossSnoc : (b0 : Nat) -> (d0 : Nat) -> (seenP : WList) -> (seenQ : WList)
    -> (remP : Nat) -> (remQ : Nat)
    -> Eq Bool (wcrossB b0 d0 seenP seenQ) true
    -> Eq Nat (mul remP (succ d0)) (mul remQ (succ b0))
    -> Eq Bool (wcrossB b0 d0 (wsnoc seenP remP) (wsnoc seenQ remQ)) true is
  fn (b0 : Nat) (d0 : Nat) (seenP : WList) is
    WListElim
      (fn (w : WList) is
         (seenQ : WList) -> (remP : Nat) -> (remQ : Nat)
           -> Eq Bool (wcrossB b0 d0 w seenQ) true
           -> Eq Nat (mul remP (succ d0)) (mul remQ (succ b0))
           -> Eq Bool (wcrossB b0 d0 (wsnoc w remP) (wsnoc seenQ remQ)) true end)
      (fn (seenQ : WList) is
         case seenQ of
         | wnil ->
             fn (remP : Nat) (remQ : Nat)
                (hw : Eq Bool (wcrossB b0 d0 wnil wnil) true)
                (hr : Eq Nat (mul remP (succ d0)) (mul remQ (succ b0))) is
               cong (fn (z : Bool) is and z true end)
                 (eqWComplete (mul remP (succ d0)) (mul remQ (succ b0)) hr) end
         | wcons y ys ->
             fn (remP : Nat) (remQ : Nat)
                (hw : Eq Bool (wcrossB b0 d0 wnil (wcons y ys)) true)
                (hr : Eq Nat (mul remP (succ d0)) (mul remQ (succ b0))) is
               boolDisjoint
                 (Eq Bool (wcrossB b0 d0 (wsnoc wnil remP) (wsnoc (wcons y ys) remQ)) true) hw end
         end
       end)
      (fn (x : Nat) (xs : WList)
          (ih : (seenQ : WList) -> (remP : Nat) -> (remQ : Nat)
                  -> Eq Bool (wcrossB b0 d0 xs seenQ) true
                  -> Eq Nat (mul remP (succ d0)) (mul remQ (succ b0))
                  -> Eq Bool (wcrossB b0 d0 (wsnoc xs remP) (wsnoc seenQ remQ)) true) is
         fn (seenQ : WList) is
           case seenQ of
           | wnil ->
               fn (remP : Nat) (remQ : Nat)
                  (hw : Eq Bool (wcrossB b0 d0 (wcons x xs) wnil) true)
                  (hr : Eq Nat (mul remP (succ d0)) (mul remQ (succ b0))) is
                 boolDisjoint
                   (Eq Bool (wcrossB b0 d0 (wsnoc (wcons x xs) remP) (wsnoc wnil remQ)) true) hw end
           | wcons y ys ->
               fn (remP : Nat) (remQ : Nat)
                  (hw : Eq Bool (wcrossB b0 d0 (wcons x xs) (wcons y ys)) true)
                  (hr : Eq Nat (mul remP (succ d0)) (mul remQ (succ b0))) is
                 andBoth (eqW (mul x (succ d0)) (mul y (succ b0)))
                   (wcrossB b0 d0 (wsnoc xs remP) (wsnoc ys remQ))
                   (andTrueL (eqW (mul x (succ d0)) (mul y (succ b0))) (wcrossB b0 d0 xs ys) hw)
                   (ih ys remP remQ
                      (andTrueR (eqW (mul x (succ d0)) (mul y (succ b0))) (wcrossB b0 d0 xs ys) hw)
                      hr) end
           end
         end
       end)
      seenP
  end
end

-- ============================================================================
-- RUNG 3 — the lockstep:  equal fuel + cross-equal state ⟹ equal FBody.
-- ============================================================================

-- Ex falso for a successor equal to zero (succ-headed terms never equal zero).
succNotZero : (C : U) -> (n : Nat) -> Eq Nat (succ n) zero -> C is
  fn (C : U) (n : Nat) (h : Eq Nat (succ n) zero) is
    subst Nat (succ n) zero h
      (fn (z : Nat) is case z of | zero -> C | succ k -> Eq Nat zero zero end end)
      (refl zero)
  end
end

-- THE LOCKSTEP.  With the SAME fuel, two long divisions whose current remainders are
-- cross-equal (remP·sd = remQ·sb) and whose seen-lists correspond (wcrossB) emit the
-- SAME FBody.  Induction on fuel; the per-step case structure mirrors expand:
--   * fuel 0           — both hit the floor fbody wnil 0 true (refl);
--   * rem 0 / rem 0    — both terminate (refl); the mixed 0/succ corners are impossible
--                        by succNotZero on the cross-equality;
--   * succ / succ      — wmemberCross aligns the cycle test, windexCross the repetend
--                        index (true branch), and on the false branch the digit agrees
--                        (floorUniqueGeneral), the next remainder stays cross-equal
--                        (natModCrossStep ∘ mul10Cross), the seen-lists stay corresponding
--                        (wcrossSnoc), so the IH equates the recursive tails.
expandCross : (b0 : Nat) -> (d0 : Nat) -> (fuel : Nat)
    -> (remP : Nat) -> (remQ : Nat) -> (seenP : WList) -> (seenQ : WList)
    -> Eq Nat (mul remP (succ d0)) (mul remQ (succ b0))
    -> Eq Bool (wcrossB b0 d0 seenP seenQ) true
    -> Eq FBody (expand (succ b0) fuel remP seenP) (expand (succ d0) fuel remQ seenQ) is
  fn (b0 : Nat) (d0 : Nat) is
    NatElim
      (fn (f : Nat) is
         (remP : Nat) -> (remQ : Nat) -> (seenP : WList) -> (seenQ : WList)
           -> Eq Nat (mul remP (succ d0)) (mul remQ (succ b0))
           -> Eq Bool (wcrossB b0 d0 seenP seenQ) true
           -> Eq FBody (expand (succ b0) f remP seenP) (expand (succ d0) f remQ seenQ) end)
      (fn (remP : Nat) (remQ : Nat) (seenP : WList) (seenQ : WList)
          (hcross : Eq Nat (mul remP (succ d0)) (mul remQ (succ b0)))
          (hwcross : Eq Bool (wcrossB b0 d0 seenP seenQ) true) is
         refl (fbody wnil zero true) end)
      (fn (fl : Nat)
          (ih : (remP : Nat) -> (remQ : Nat) -> (seenP : WList) -> (seenQ : WList)
                  -> Eq Nat (mul remP (succ d0)) (mul remQ (succ b0))
                  -> Eq Bool (wcrossB b0 d0 seenP seenQ) true
                  -> Eq FBody (expand (succ b0) fl remP seenP) (expand (succ d0) fl remQ seenQ)) is
         fn (remP : Nat) (remQ : Nat) (seenP : WList) (seenQ : WList) is
           case remP of
           | zero ->
               case remQ of
               | zero ->
                   fn (hcross : Eq Nat (mul zero (succ d0)) (mul zero (succ b0)))
                      (hwcross : Eq Bool (wcrossB b0 d0 seenP seenQ) true) is
                     refl (fbody wnil zero true) end
               | succ rq ->
                   fn (hcross : Eq Nat (mul zero (succ d0)) (mul (succ rq) (succ b0)))
                      (hwcross : Eq Bool (wcrossB b0 d0 seenP seenQ) true) is
                     succNotZero
                       (Eq FBody (expand (succ b0) (succ fl) zero seenP)
                                 (expand (succ d0) (succ fl) (succ rq) seenQ))
                       (add b0 (mul rq (succ b0))) (sym hcross) end
               end
           | succ rp ->
               case remQ of
               | zero ->
                   fn (hcross : Eq Nat (mul (succ rp) (succ d0)) (mul zero (succ b0)))
                      (hwcross : Eq Bool (wcrossB b0 d0 seenP seenQ) true) is
                     succNotZero
                       (Eq FBody (expand (succ b0) (succ fl) (succ rp) seenP)
                                 (expand (succ d0) (succ fl) zero seenQ))
                       (add d0 (mul rp (succ d0))) hcross end
               | succ rq ->
                   fn (hcross : Eq Nat (mul (succ rp) (succ d0)) (mul (succ rq) (succ b0)))
                      (hwcross : Eq Bool (wcrossB b0 d0 seenP seenQ) true) is
                     let hmem : Eq Bool (wmember (succ rp) seenP) (wmember (succ rq) seenQ) =
                       wmemberCross b0 d0 seenP seenQ hwcross (succ rp) (succ rq) hcross in
                     let hidx : Eq Nat (windex (succ rp) seenP) (windex (succ rq) seenQ) =
                       windexCross b0 d0 seenP seenQ hwcross (succ rp) (succ rq) hcross in
                     let htrue : Eq FBody (fbody wnil (windex (succ rp) seenP) false)
                                          (fbody wnil (windex (succ rq) seenQ) false) =
                       cong (fn (i : Nat) is fbody wnil i false end) hidx in
                     let hr10 : Eq Nat (mul (mul (succ rp) 10) (succ d0))
                                       (mul (mul (succ rq) 10) (succ b0)) =
                       mul10Cross b0 d0 (succ rp) (succ rq) hcross in
                     let hdigit : Eq Nat (natDiv (mul (succ rp) 10) (succ b0))
                                         (natDiv (mul (succ rq) 10) (succ d0)) =
                       floorUniqueGeneral b0 d0 (mul (succ rp) 10) (mul (succ rq) 10) hr10 in
                     let hnext : Eq Nat (mul (natMod (mul (succ rp) 10) (succ b0)) (succ d0))
                                        (mul (natMod (mul (succ rq) 10) (succ d0)) (succ b0)) =
                       natModCrossStep b0 d0 (mul (succ rp) 10) (mul (succ rq) 10) hr10 in
                     let hsnoc : Eq Bool
                         (wcrossB b0 d0 (wsnoc seenP (succ rp)) (wsnoc seenQ (succ rq))) true =
                       wcrossSnoc b0 d0 seenP seenQ (succ rp) (succ rq) hwcross hcross in
                     let ihRest : Eq FBody
                         (expand (succ b0) fl (natMod (mul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp)))
                         (expand (succ d0) fl (natMod (mul (succ rq) 10) (succ d0)) (wsnoc seenQ (succ rq))) =
                       ih (natMod (mul (succ rp) 10) (succ b0)) (natMod (mul (succ rq) 10) (succ d0))
                          (wsnoc seenP (succ rp)) (wsnoc seenQ (succ rq)) hnext hsnoc in
                     let arg1Eq : Eq WList
                         (wcons (natDiv (mul (succ rp) 10) (succ b0))
                                (fbDigits (expand (succ b0) fl (natMod (mul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp)))))
                         (wcons (natDiv (mul (succ rq) 10) (succ d0))
                                (fbDigits (expand (succ d0) fl (natMod (mul (succ rq) 10) (succ d0)) (wsnoc seenQ (succ rq))))) =
                       cong2 (fn (d : Nat) (ds : WList) is wcons d ds end)
                         hdigit (cong (fn (b : FBody) is fbDigits b end) ihRest) in
                     let hfalse : Eq FBody
                         (fbody (wcons (natDiv (mul (succ rp) 10) (succ b0))
                                       (fbDigits (expand (succ b0) fl (natMod (mul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp)))))
                                (fbRep (expand (succ b0) fl (natMod (mul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp))))
                                (fbTerm (expand (succ b0) fl (natMod (mul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp)))))
                         (fbody (wcons (natDiv (mul (succ rq) 10) (succ d0))
                                       (fbDigits (expand (succ d0) fl (natMod (mul (succ rq) 10) (succ d0)) (wsnoc seenQ (succ rq)))))
                                (fbRep (expand (succ d0) fl (natMod (mul (succ rq) 10) (succ d0)) (wsnoc seenQ (succ rq))))
                                (fbTerm (expand (succ d0) fl (natMod (mul (succ rq) 10) (succ d0)) (wsnoc seenQ (succ rq))))) =
                       trans
                         (cong (fn (a : WList) is
                                  fbody a
                                    (fbRep (expand (succ b0) fl (natMod (mul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp))))
                                    (fbTerm (expand (succ b0) fl (natMod (mul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp)))) end)
                               arg1Eq)
                         (cong2 (fn (r : Nat) (t : Bool) is
                                   fbody (wcons (natDiv (mul (succ rq) 10) (succ d0))
                                                (fbDigits (expand (succ d0) fl (natMod (mul (succ rq) 10) (succ d0)) (wsnoc seenQ (succ rq)))))
                                         r t end)
                            (cong (fn (b : FBody) is fbRep b end) ihRest)
                            (cong (fn (b : FBody) is fbTerm b end) ihRest)) in
                     trans
                       (cong (fn (sc : Bool) is
                                BoolElim (fn (w : Bool) is FBody end)
                                  (fbody wnil (windex (succ rp) seenP) false)
                                  (fbody (wcons (natDiv (mul (succ rp) 10) (succ b0))
                                                (fbDigits (expand (succ b0) fl (natMod (mul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp)))))
                                         (fbRep (expand (succ b0) fl (natMod (mul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp))))
                                         (fbTerm (expand (succ b0) fl (natMod (mul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp)))))
                                  sc end)
                             hmem)
                       (cong2 (fn (tb : FBody) (fb : FBody) is
                                 BoolElim (fn (w : Bool) is FBody end) tb fb
                                   (wmember (succ rq) seenQ) end)
                          htrue hfalse) end
               end
           end
         end
       end)
  end
end

-- ============================================================================
-- RUNG 3 — fuel sufficiency (pigeonhole).  List infrastructure first.
-- ============================================================================

-- Boolean negation and its reflection.
notB : Bool -> Bool is fn (b : Bool) is BoolElim (fn (x : Bool) is Bool end) false true b end end
notTrueIsFalse : (b : Bool) -> Eq Bool (notB b) true -> Eq Bool b false is
  fn (b : Bool) is
    BoolElim (fn (x : Bool) is (Eq Bool (notB x) true -> Eq Bool x false) end)
      (fn (h : Eq Bool (notB true) true) is boolDisjoint (Eq Bool true false) h end)
      (fn (h : Eq Bool (notB false) true) is refl false end)
      b
  end
end
falseIsNotTrue : (b : Bool) -> Eq Bool b false -> Eq Bool (notB b) true is
  fn (b : Bool) (h : Eq Bool b false) is
    subst Bool false b (sym h) (fn (z : Bool) is Eq Bool (notB z) true end) (refl true)
  end
end

-- Length, all-below-N, no-duplicates, and first-occurrence deletion on WList.
wlen : WList -> Nat is
  fn (xs : WList) is
    WListElim (fn (w : WList) is Nat end) zero
      (fn (h : Nat) (t : WList) (ih : Nat) is succ ih end) xs
  end
end
allLt : Nat -> WList -> Bool is
  fn (n : Nat) (xs : WList) is
    WListElim (fn (w : WList) is Bool end) true
      (fn (h : Nat) (t : WList) (ih : Bool) is and (ltb h n) ih end) xs
  end
end
noDupW : WList -> Bool is
  fn (xs : WList) is
    WListElim (fn (w : WList) is Bool end) true
      (fn (h : Nat) (t : WList) (ih : Bool) is and (notB (wmember h t)) ih end) xs
  end
end
wdelete : Nat -> WList -> WList is
  fn (x : Nat) (xs : WList) is
    WListElim (fn (w : WList) is WList end) wnil
      (fn (h : Nat) (t : WList) (ih : WList) is
         case eqW x h of | true -> t | false -> wcons h ih end
       end)
      xs
  end
end

-- eqW is symmetric (as a Bool equation): decode/recode each direction.
eqWSym : (a : Nat) -> (b : Nat) -> Eq Bool (eqW a b) (eqW b a) is
  fn (a : Nat) (b : Nat) is
    boolTrueIff (eqW a b) (eqW b a)
      (fn (e : Eq Bool (eqW a b) true) is eqWComplete b a (sym (eqWSound a b e)) end)
      (fn (e : Eq Bool (eqW b a) true) is eqWComplete a b (sym (eqWSound b a e)) end)
  end
end

-- lte n (succ n) and monotone weakening of the bound.
lteSuccSelf : (n : Nat) -> Eq Bool (lte n (succ n)) true is
  fn (n : Nat) is
    NatElim (fn (x : Nat) is Eq Bool (lte x (succ x)) true end)
      (refl true)
      (fn (k : Nat) (ih : Eq Bool (lte k (succ k)) true) is ih end)
      n
  end
end
lteSuccR : (a : Nat) -> (b : Nat) -> Eq Bool (lte a b) true -> Eq Bool (lte a (succ b)) true is
  fn (a : Nat) (b : Nat) (h : Eq Bool (lte a b) true) is
    lteTrans a b (succ b) h (lteSuccSelf b)
  end
end

-- x < succ d and x ≠ d ⟹ x < d.  Double induction; mismatched corners are absurd.
ltSuccNe : (h : Nat) -> (d : Nat) -> Eq Bool (ltb h (succ d)) true -> Eq Bool (eqW h d) false
    -> Eq Bool (ltb h d) true is
  fn (h : Nat) is
    NatElim (fn (x : Nat) is
        (d : Nat) -> Eq Bool (ltb x (succ d)) true -> Eq Bool (eqW x d) false
          -> Eq Bool (ltb x d) true end)
      (fn (d : Nat) is
         case d of
         | zero -> fn (hlt : Eq Bool (ltb zero (succ zero)) true) (hne : Eq Bool (eqW zero zero) false) is
             boolDisjoint (Eq Bool (ltb zero zero) true) (trans (sym hne) (eqWRefl zero)) end
         | succ d' -> fn (hlt : Eq Bool (ltb zero (succ (succ d'))) true) (hne : Eq Bool (eqW zero (succ d')) false) is
             refl true end
         end
       end)
      (fn (k : Nat) (ih : (d : Nat) -> Eq Bool (ltb k (succ d)) true -> Eq Bool (eqW k d) false
                            -> Eq Bool (ltb k d) true) is
         fn (d : Nat) is
           case d of
           | zero -> fn (hlt : Eq Bool (ltb (succ k) (succ zero)) true) (hne : Eq Bool (eqW (succ k) zero) false) is
               boolDisjoint (Eq Bool (ltb (succ k) zero) true) (trans (sym (ltbZero k)) hlt) end
           | succ d' -> fn (hlt : Eq Bool (ltb (succ k) (succ (succ d'))) true) (hne : Eq Bool (eqW (succ k) (succ d')) false) is
               ih d' hlt hne end
           end
         end
       end)
      h
  end
end

-- or-projections (wmember (wcons h t) ≡ or (eqW _ h) (wmember _ t)).
orFalseL : (a : Bool) -> (b : Bool) -> Eq Bool (or a b) false -> Eq Bool a false is
  fn (a : Bool) (b : Bool) (h : Eq Bool (or a b) false) is
    BoolElim (fn (x : Bool) is (Eq Bool (or x b) false -> Eq Bool x false) end)
      (fn (h1 : Eq Bool (or true b) false) is h1 end)
      (fn (h0 : Eq Bool (or false b) false) is refl false end)
      a h
  end
end
orFalseR : (a : Bool) -> (b : Bool) -> Eq Bool (or a b) false -> Eq Bool b false is
  fn (a : Bool) (b : Bool) (h : Eq Bool (or a b) false) is
    BoolElim (fn (x : Bool) is (Eq Bool (or x b) false -> Eq Bool b false) end)
      (fn (h1 : Eq Bool (or true b) false) is boolDisjoint (Eq Bool b false) (sym h1) end)
      (fn (h0 : Eq Bool (or false b) false) is h0 end)
      a h
  end
end
orBothFalse : (a : Bool) -> (b : Bool) -> Eq Bool a false -> Eq Bool b false -> Eq Bool (or a b) false is
  fn (a : Bool) (b : Bool) (ha : Eq Bool a false) (hb : Eq Bool b false) is
    trans (cong (fn (z : Bool) is or z b end) ha) hb
  end
end
orTrueR : (a : Bool) -> (b : Bool) -> Eq Bool (or a b) true -> Eq Bool a false -> Eq Bool b true is
  fn (a : Bool) (b : Bool) (h : Eq Bool (or a b) true) (ha : Eq Bool a false) is
    trans (sym (cong (fn (z : Bool) is or z b end) ha)) h
  end
end

-- Deletion never introduces a member:  h ∉ t  ⟹  h ∉ wdelete x t.
notMemberDelete : (hh : Nat) -> (x : Nat) -> (t : WList)
    -> Eq Bool (wmember hh t) false -> Eq Bool (wmember hh (wdelete x t)) false is
  fn (hh : Nat) (x : Nat) (t : WList) is
    WListElim (fn (w : WList) is (Eq Bool (wmember hh w) false -> Eq Bool (wmember hh (wdelete x w)) false) end)
      (fn (h0 : Eq Bool (wmember hh wnil) false) is refl false end)
      (fn (e : Nat) (t' : WList)
          (ih : Eq Bool (wmember hh t') false -> Eq Bool (wmember hh (wdelete x t')) false) is
         fn (hm : Eq Bool (wmember hh (wcons e t')) false) is
           BoolElim
             (fn (z : Bool) is
                Eq Bool (wmember hh (case z of | true -> t' | false -> wcons e (wdelete x t') end)) false end)
             (orFalseR (eqW hh e) (wmember hh t') hm)
             (orBothFalse (eqW hh e) (wmember hh (wdelete x t'))
                (orFalseL (eqW hh e) (wmember hh t') hm)
                (ih (orFalseR (eqW hh e) (wmember hh t') hm)))
             (eqW x e)
         end
       end)
      t
  end
end

-- allLt weakening:  all entries < succ d and d absent  ⟹  all entries < d.
allLtWeaken : (d : Nat) -> (xs : WList)
    -> Eq Bool (allLt (succ d) xs) true -> Eq Bool (wmember d xs) false
    -> Eq Bool (allLt d xs) true is
  fn (d : Nat) (xs : WList) is
    WListElim (fn (w : WList) is
        (Eq Bool (allLt (succ d) w) true -> Eq Bool (wmember d w) false -> Eq Bool (allLt d w) true) end)
      (fn (hal : Eq Bool (allLt (succ d) wnil) true) (hm : Eq Bool (wmember d wnil) false) is refl true end)
      (fn (h : Nat) (t : WList)
          (ih : Eq Bool (allLt (succ d) t) true -> Eq Bool (wmember d t) false -> Eq Bool (allLt d t) true) is
         fn (hal : Eq Bool (allLt (succ d) (wcons h t)) true) (hm : Eq Bool (wmember d (wcons h t)) false) is
           andBoth (ltb h d) (allLt d t)
             (ltSuccNe h d
                (andTrueL (ltb h (succ d)) (allLt (succ d) t) hal)
                (trans (eqWSym h d) (orFalseL (eqW d h) (wmember d t) hm)))
             (ih (andTrueR (ltb h (succ d)) (allLt (succ d) t) hal)
                 (orFalseR (eqW d h) (wmember d t) hm))
         end
       end)
      xs
  end
end

-- Deletion preserves the all-below-N bound (entries only removed).
deleteAllLt : (n : Nat) -> (x : Nat) -> (xs : WList)
    -> Eq Bool (allLt n xs) true -> Eq Bool (allLt n (wdelete x xs)) true is
  fn (n : Nat) (x : Nat) (xs : WList) is
    WListElim (fn (w : WList) is (Eq Bool (allLt n w) true -> Eq Bool (allLt n (wdelete x w)) true) end)
      (fn (h0 : Eq Bool (allLt n wnil) true) is refl true end)
      (fn (h : Nat) (t : WList)
          (ih : Eq Bool (allLt n t) true -> Eq Bool (allLt n (wdelete x t)) true) is
         fn (hal : Eq Bool (allLt n (wcons h t)) true) is
           BoolElim
             (fn (z : Bool) is
                Eq Bool (allLt n (case z of | true -> t | false -> wcons h (wdelete x t) end)) true end)
             (andTrueR (ltb h n) (allLt n t) hal)
             (andBoth (ltb h n) (allLt n (wdelete x t))
                (andTrueL (ltb h n) (allLt n t) hal)
                (ih (andTrueR (ltb h n) (allLt n t) hal)))
             (eqW x h)
         end
       end)
      xs
  end
end

-- Deletion preserves no-duplicates.
deleteNoDup : (x : Nat) -> (xs : WList)
    -> Eq Bool (noDupW xs) true -> Eq Bool (noDupW (wdelete x xs)) true is
  fn (x : Nat) (xs : WList) is
    WListElim (fn (w : WList) is (Eq Bool (noDupW w) true -> Eq Bool (noDupW (wdelete x w)) true) end)
      (fn (h0 : Eq Bool (noDupW wnil) true) is refl true end)
      (fn (h : Nat) (t : WList)
          (ih : Eq Bool (noDupW t) true -> Eq Bool (noDupW (wdelete x t)) true) is
         fn (hnd : Eq Bool (noDupW (wcons h t)) true) is
           BoolElim
             (fn (z : Bool) is
                Eq Bool (noDupW (case z of | true -> t | false -> wcons h (wdelete x t) end)) true end)
             (andTrueR (notB (wmember h t)) (noDupW t) hnd)
             (andBoth (notB (wmember h (wdelete x t))) (noDupW (wdelete x t))
                (falseIsNotTrue (wmember h (wdelete x t))
                   (notMemberDelete h x t
                      (notTrueIsFalse (wmember h t)
                         (andTrueL (notB (wmember h t)) (noDupW t) hnd))))
                (ih (andTrueR (notB (wmember h t)) (noDupW t) hnd)))
             (eqW x h)
         end
       end)
      xs
  end
end

-- Deleting a member drops the length by one.
wlenDeleteMember : (x : Nat) -> (xs : WList)
    -> Eq Bool (wmember x xs) true -> Eq Nat (wlen xs) (succ (wlen (wdelete x xs))) is
  fn (x : Nat) (xs : WList) is
    WListElim (fn (w : WList) is (Eq Bool (wmember x w) true -> Eq Nat (wlen w) (succ (wlen (wdelete x w)))) end)
      (fn (h0 : Eq Bool (wmember x wnil) true) is boolDisjoint (Eq Nat (wlen wnil) (succ (wlen (wdelete x wnil)))) h0 end)
      (fn (h : Nat) (t : WList)
          (ih : Eq Bool (wmember x t) true -> Eq Nat (wlen t) (succ (wlen (wdelete x t)))) is
         fn (hm : Eq Bool (wmember x (wcons h t)) true) is
           BoolElim
             (fn (z : Bool) is
                (Eq Bool (eqW x h) z
                   -> Eq Nat (wlen (wcons h t)) (succ (wlen (wdelete x (wcons h t))))) end)
             (fn (ev : Eq Bool (eqW x h) true) is
                subst Bool true (eqW x h) (sym ev)
                  (fn (z : Bool) is
                     Eq Nat (wlen (wcons h t))
                       (succ (wlen (case z of | true -> t | false -> wcons h (wdelete x t) end))) end)
                  (refl (succ (wlen t))) end)
             (fn (ev : Eq Bool (eqW x h) false) is
                subst Bool false (eqW x h) (sym ev)
                  (fn (z : Bool) is
                     Eq Nat (wlen (wcons h t))
                       (succ (wlen (case z of | true -> t | false -> wcons h (wdelete x t) end))) end)
                  (cong (fn (n : Nat) is succ n end)
                     (ih (orTrueR (eqW x h) (wmember x t) hm ev))) end)
             (eqW x h)
             (refl (eqW x h))
         end
       end)
      xs
  end
end

-- Deleting the target leaves it absent (given no duplicates).
deleteRemovesMember : (x : Nat) -> (xs : WList)
    -> Eq Bool (noDupW xs) true -> Eq Bool (wmember x (wdelete x xs)) false is
  fn (x : Nat) (xs : WList) is
    WListElim (fn (w : WList) is (Eq Bool (noDupW w) true -> Eq Bool (wmember x (wdelete x w)) false) end)
      (fn (h0 : Eq Bool (noDupW wnil) true) is refl false end)
      (fn (h : Nat) (t : WList)
          (ih : Eq Bool (noDupW t) true -> Eq Bool (wmember x (wdelete x t)) false) is
         fn (hnd : Eq Bool (noDupW (wcons h t)) true) is
           BoolElim
             (fn (z : Bool) is
                (Eq Bool (eqW x h) z -> Eq Bool (wmember x (wdelete x (wcons h t))) false) end)
             (fn (ev : Eq Bool (eqW x h) true) is
                subst Bool true (eqW x h) (sym ev)
                  (fn (z : Bool) is
                     Eq Bool (wmember x (case z of | true -> t | false -> wcons h (wdelete x t) end)) false end)
                  (subst Nat h x (sym (eqWSound x h ev))
                     (fn (w : Nat) is Eq Bool (wmember w t) false end)
                     (notTrueIsFalse (wmember h t)
                        (andTrueL (notB (wmember h t)) (noDupW t) hnd))) end)
             (fn (ev : Eq Bool (eqW x h) false) is
                subst Bool false (eqW x h) (sym ev)
                  (fn (z : Bool) is
                     Eq Bool (wmember x (case z of | true -> t | false -> wcons h (wdelete x t) end)) false end)
                  (orBothFalse (eqW x h) (wmember x (wdelete x t)) ev
                     (ih (andTrueR (notB (wmember h t)) (noDupW t) hnd))) end)
             (eqW x h)
             (refl (eqW x h))
         end
       end)
      xs
  end
end

-- THE PIGEONHOLE.  A duplicate-free WList whose entries are all < den has length
-- ≤ den.  Induction on den: at den = 0 nothing is < 0 so the list is empty; at
-- succ d, either d is absent (weaken the bound and recurse) or present (delete it —
-- length drops by one, no-dup/bound/absence are preserved — recurse at d).
lenBound : (den : Nat) -> (xs : WList)
    -> Eq Bool (noDupW xs) true -> Eq Bool (allLt den xs) true
    -> Eq Bool (lte (wlen xs) den) true is
  fn (den : Nat) is
    NatElim
      (fn (n : Nat) is
         (xs : WList) -> Eq Bool (noDupW xs) true -> Eq Bool (allLt n xs) true
           -> Eq Bool (lte (wlen xs) n) true end)
      (fn (xs : WList) is
         case xs of
         | wnil -> fn (hnd : Eq Bool (noDupW wnil) true) (hal : Eq Bool (allLt zero wnil) true) is
             refl true end
         | wcons h t -> fn (hnd : Eq Bool (noDupW (wcons h t)) true) (hal : Eq Bool (allLt zero (wcons h t)) true) is
             boolDisjoint (Eq Bool (lte (wlen (wcons h t)) zero) true)
               (trans (sym (ltbZero h)) (andTrueL (ltb h zero) (allLt zero t) hal)) end
         end
       end)
      (fn (d : Nat)
          (ih : (xs : WList) -> Eq Bool (noDupW xs) true -> Eq Bool (allLt d xs) true
                  -> Eq Bool (lte (wlen xs) d) true) is
         fn (xs : WList) (hnd : Eq Bool (noDupW xs) true) (hal : Eq Bool (allLt (succ d) xs) true) is
           BoolElim
             (fn (z : Bool) is
                (Eq Bool (wmember d xs) z -> Eq Bool (lte (wlen xs) (succ d)) true) end)
             (fn (ev : Eq Bool (wmember d xs) true) is
                subst Nat (succ (wlen (wdelete d xs))) (wlen xs)
                  (sym (wlenDeleteMember d xs ev))
                  (fn (m : Nat) is Eq Bool (lte m (succ d)) true end)
                  (ih (wdelete d xs)
                     (deleteNoDup d xs hnd)
                     (allLtWeaken d (wdelete d xs)
                        (deleteAllLt (succ d) d xs hal)
                        (deleteRemovesMember d xs hnd))) end)
             (fn (ev : Eq Bool (wmember d xs) false) is
                lteSuccR (wlen xs) d
                  (ih xs hnd (allLtWeaken d xs hal ev)) end)
             (wmember d xs)
             (refl (wmember d xs))
         end
       end)
      den
  end
end

-- or laws + snoc algebra for threading the no-dup invariant through expand's wsnoc.
orFalseRight : (b : Bool) -> Eq Bool (or b false) b is
  fn (b : Bool) is
    BoolElim (fn (x : Bool) is Eq Bool (or x false) x end) (refl true) (refl false) b
  end
end
orAssoc : (a : Bool) -> (b : Bool) -> (c : Bool) -> Eq Bool (or a (or b c)) (or (or a b) c) is
  fn (a : Bool) (b : Bool) (c : Bool) is
    BoolElim (fn (x : Bool) is Eq Bool (or x (or b c)) (or (or x b) c) end)
      (refl true) (refl (or b c)) a
  end
end
memberSnoc : (a : Nat) -> (y : Nat) -> (t : WList)
    -> Eq Bool (wmember a (wsnoc t y)) (or (wmember a t) (eqW a y)) is
  fn (a : Nat) (y : Nat) (t : WList) is
    WListElim (fn (w : WList) is Eq Bool (wmember a (wsnoc w y)) (or (wmember a w) (eqW a y)) end)
      (orFalseRight (eqW a y))
      (fn (h : Nat) (t' : WList) (ih : Eq Bool (wmember a (wsnoc t' y)) (or (wmember a t') (eqW a y))) is
         trans (cong (fn (z : Bool) is or (eqW a h) z end) ih)
               (orAssoc (eqW a h) (wmember a t') (eqW a y)) end)
      t
  end
end
wlenSnoc : (y : Nat) -> (xs : WList) -> Eq Nat (wlen (wsnoc xs y)) (succ (wlen xs)) is
  fn (y : Nat) (xs : WList) is
    WListElim (fn (w : WList) is Eq Nat (wlen (wsnoc w y)) (succ (wlen w)) end)
      (refl (succ zero))
      (fn (h : Nat) (t : WList) (ih : Eq Nat (wlen (wsnoc t y)) (succ (wlen t))) is
         cong (fn (n : Nat) is succ n end) ih end)
      xs
  end
end
allLtSnoc : (n : Nat) -> (y : Nat) -> (xs : WList)
    -> Eq Bool (allLt n xs) true -> Eq Bool (ltb y n) true -> Eq Bool (allLt n (wsnoc xs y)) true is
  fn (n : Nat) (y : Nat) (xs : WList) is
    WListElim (fn (w : WList) is
        (Eq Bool (allLt n w) true -> Eq Bool (ltb y n) true -> Eq Bool (allLt n (wsnoc w y)) true) end)
      (fn (hal : Eq Bool (allLt n wnil) true) (hy : Eq Bool (ltb y n) true) is
         andBoth (ltb y n) true hy (refl true) end)
      (fn (h : Nat) (t : WList)
          (ih : Eq Bool (allLt n t) true -> Eq Bool (ltb y n) true -> Eq Bool (allLt n (wsnoc t y)) true) is
         fn (hal : Eq Bool (allLt n (wcons h t)) true) (hy : Eq Bool (ltb y n) true) is
           andBoth (ltb h n) (allLt n (wsnoc t y))
             (andTrueL (ltb h n) (allLt n t) hal)
             (ih (andTrueR (ltb h n) (allLt n t) hal) hy) end
         end)
      xs
  end
end
noDupSnoc : (y : Nat) -> (xs : WList)
    -> Eq Bool (noDupW xs) true -> Eq Bool (wmember y xs) false -> Eq Bool (noDupW (wsnoc xs y)) true is
  fn (y : Nat) (xs : WList) is
    WListElim (fn (w : WList) is
        (Eq Bool (noDupW w) true -> Eq Bool (wmember y w) false -> Eq Bool (noDupW (wsnoc w y)) true) end)
      (fn (hnd : Eq Bool (noDupW wnil) true) (hm : Eq Bool (wmember y wnil) false) is
         andBoth (notB (wmember y wnil)) (noDupW wnil)
           (falseIsNotTrue (wmember y wnil) (refl false)) (refl true) end)
      (fn (h : Nat) (t : WList)
          (ih : Eq Bool (noDupW t) true -> Eq Bool (wmember y t) false -> Eq Bool (noDupW (wsnoc t y)) true) is
         fn (hnd : Eq Bool (noDupW (wcons h t)) true) (hm : Eq Bool (wmember y (wcons h t)) false) is
           andBoth (notB (wmember h (wsnoc t y))) (noDupW (wsnoc t y))
             (falseIsNotTrue (wmember h (wsnoc t y))
                (trans (memberSnoc h y t)
                   (orBothFalse (wmember h t) (eqW h y)
                      (notTrueIsFalse (wmember h t)
                         (andTrueL (notB (wmember h t)) (noDupW t) hnd))
                      (trans (eqWSym h y) (orFalseL (eqW y h) (wmember y t) hm)))))
             (ih (andTrueR (notB (wmember h t)) (noDupW t) hnd)
                 (orFalseR (eqW y h) (wmember y t) hm)) end
         end)
      xs
  end
end
lteSuccSelfFalse : (n : Nat) -> Eq Bool (lte (succ n) n) false is
  fn (n : Nat) is
    NatElim (fn (x : Nat) is Eq Bool (lte (succ x) x) false end)
      (refl false)
      (fn (k : Nat) (ih : Eq Bool (lte (succ k) k) false) is ih end)
      n
  end
end

-- FUEL SUFFICIENCY.  Two same-denominator long divisions with DIFFERENT fuels agree,
-- provided both fuels cover the remaining capacity (cap = den − |seen|).  Induction on
-- cap, threading the seen-list invariants (no-dup, all < den, exact capacity, rem in
-- range).  At cap 0 the seen-list is full: any unseen nonzero rem would make
-- (wcons rem seen) a distinct list of length den+1 bounded by den — impossible by
-- lenBound — so wmember fires and both terminate identically; otherwise the floor is
-- never reached.  At cap > 0 the cycle test aligns the two (same scrutinee), the digit
-- is identical, and the IH (one less capacity, one less fuel each) closes the tails.
expandFuelStable : (b0 : Nat) -> (cap : Nat) -> (rem : Nat) -> (seen : WList) -> (F : Nat) -> (G : Nat)
    -> Eq Bool (noDupW seen) true
    -> Eq Bool (allLt (succ b0) seen) true
    -> Eq Nat (add (wlen seen) cap) (succ b0)
    -> Eq Bool (ltb rem (succ b0)) true
    -> Eq Bool (lte (succ cap) F) true
    -> Eq Bool (lte (succ cap) G) true
    -> Eq FBody (expand (succ b0) F rem seen) (expand (succ b0) G rem seen) is
  fn (b0 : Nat) (cap : Nat) is
    NatElim
      (fn (c : Nat) is
         (rem : Nat) -> (seen : WList) -> (F : Nat) -> (G : Nat)
           -> Eq Bool (noDupW seen) true
           -> Eq Bool (allLt (succ b0) seen) true
           -> Eq Nat (add (wlen seen) c) (succ b0)
           -> Eq Bool (ltb rem (succ b0)) true
           -> Eq Bool (lte (succ c) F) true
           -> Eq Bool (lte (succ c) G) true
           -> Eq FBody (expand (succ b0) F rem seen) (expand (succ b0) G rem seen) end)
      (fn (rem : Nat) (seen : WList) (F : Nat) (G : Nat)
          (hnd : Eq Bool (noDupW seen) true) (hal : Eq Bool (allLt (succ b0) seen) true)
          (hcap : Eq Nat (add (wlen seen) zero) (succ b0)) (hrem : Eq Bool (ltb rem (succ b0)) true) is
         case F of
         | zero -> fn (hF : Eq Bool (lte (succ zero) zero) true) (hG : Eq Bool (lte (succ zero) G) true) is
             boolDisjoint (Eq FBody (expand (succ b0) zero rem seen) (expand (succ b0) G rem seen)) hF end
         | succ F' ->
             case G of
             | zero -> fn (hF : Eq Bool (lte (succ zero) (succ F')) true) (hG : Eq Bool (lte (succ zero) zero) true) is
                 boolDisjoint (Eq FBody (expand (succ b0) (succ F') rem seen) (expand (succ b0) zero rem seen)) hG end
             | succ G' -> fn (hF : Eq Bool (lte (succ zero) (succ F')) true) (hG : Eq Bool (lte (succ zero) (succ G')) true) is
                 NatElim (fn (rv : Nat) is (Eq Bool (ltb rv (succ b0)) true
                            -> Eq FBody (expand (succ b0) (succ F') rv seen) (expand (succ b0) (succ G') rv seen)) end)
                   (fn (hrem0 : Eq Bool (ltb zero (succ b0)) true) is refl (fbody wnil zero true) end)
                   (fn (rp : Nat) (ihr : Eq Bool (ltb rp (succ b0)) true
                          -> Eq FBody (expand (succ b0) (succ F') rp seen) (expand (succ b0) (succ G') rp seen))
                       (hrem1 : Eq Bool (ltb (succ rp) (succ b0)) true) is
                     let hlen : Eq Nat (wlen seen) (succ b0) = trans (sym (addZeroR (wlen seen))) hcap in
                     let dec : Nat = natDiv (mul (succ rp) 10) (succ b0) in
                     let nxt : Nat = natMod (mul (succ rp) 10) (succ b0) in
                     let snc : WList = wsnoc seen (succ rp) in
                     let hfull : Eq Bool (wmember (succ rp) seen) true =
                       BoolElim (fn (z : Bool) is (Eq Bool (wmember (succ rp) seen) z -> Eq Bool (wmember (succ rp) seen) true) end)
                         (fn (ev : Eq Bool (wmember (succ rp) seen) true) is ev end)
                         (fn (ev : Eq Bool (wmember (succ rp) seen) false) is
                            boolDisjoint (Eq Bool (wmember (succ rp) seen) true)
                              (trans (sym (lteSuccSelfFalse (succ b0)))
                                 (subst Nat (wlen seen) (succ b0) hlen
                                    (fn (m : Nat) is Eq Bool (lte (succ m) (succ b0)) true end)
                                    (lenBound (succ b0) (wcons (succ rp) seen)
                                       (andBoth (notB (wmember (succ rp) seen)) (noDupW seen)
                                          (falseIsNotTrue (wmember (succ rp) seen) ev) hnd)
                                       (andBoth (ltb (succ rp) (succ b0)) (allLt (succ b0) seen) hrem1 hal)))) end)
                         (wmember (succ rp) seen) (refl (wmember (succ rp) seen)) in
                     trans
                       (cong (fn (sc : Bool) is BoolElim (fn (w : Bool) is FBody end)
                                (fbody wnil (windex (succ rp) seen) false)
                                (fbody (wcons dec (fbDigits (expand (succ b0) F' nxt snc)))
                                       (fbRep (expand (succ b0) F' nxt snc)) (fbTerm (expand (succ b0) F' nxt snc)))
                                sc end) hfull)
                       (sym (cong (fn (sc : Bool) is BoolElim (fn (w : Bool) is FBody end)
                                (fbody wnil (windex (succ rp) seen) false)
                                (fbody (wcons dec (fbDigits (expand (succ b0) G' nxt snc)))
                                       (fbRep (expand (succ b0) G' nxt snc)) (fbTerm (expand (succ b0) G' nxt snc)))
                                sc end) hfull)) end)
                   rem hrem end
             end
         end
       end)
      (fn (cap0 : Nat)
          (ih : (rem : Nat) -> (seen : WList) -> (F : Nat) -> (G : Nat)
                  -> Eq Bool (noDupW seen) true -> Eq Bool (allLt (succ b0) seen) true
                  -> Eq Nat (add (wlen seen) cap0) (succ b0) -> Eq Bool (ltb rem (succ b0)) true
                  -> Eq Bool (lte (succ cap0) F) true -> Eq Bool (lte (succ cap0) G) true
                  -> Eq FBody (expand (succ b0) F rem seen) (expand (succ b0) G rem seen)) is
         fn (rem : Nat) (seen : WList) (F : Nat) (G : Nat)
            (hnd : Eq Bool (noDupW seen) true) (hal : Eq Bool (allLt (succ b0) seen) true)
            (hcap : Eq Nat (add (wlen seen) (succ cap0)) (succ b0)) (hrem : Eq Bool (ltb rem (succ b0)) true) is
           case F of
           | zero -> fn (hF : Eq Bool (lte (succ (succ cap0)) zero) true) (hG : Eq Bool (lte (succ (succ cap0)) G) true) is
               boolDisjoint (Eq FBody (expand (succ b0) zero rem seen) (expand (succ b0) G rem seen)) hF end
           | succ F' ->
               case G of
               | zero -> fn (hF : Eq Bool (lte (succ (succ cap0)) (succ F')) true) (hG : Eq Bool (lte (succ (succ cap0)) zero) true) is
                   boolDisjoint (Eq FBody (expand (succ b0) (succ F') rem seen) (expand (succ b0) zero rem seen)) hG end
               | succ G' -> fn (hF : Eq Bool (lte (succ (succ cap0)) (succ F')) true) (hG : Eq Bool (lte (succ (succ cap0)) (succ G')) true) is
                   NatElim (fn (rv : Nat) is (Eq Bool (ltb rv (succ b0)) true
                              -> Eq FBody (expand (succ b0) (succ F') rv seen) (expand (succ b0) (succ G') rv seen)) end)
                     (fn (hrem0 : Eq Bool (ltb zero (succ b0)) true) is refl (fbody wnil zero true) end)
                     (fn (rp : Nat) (ihr : Eq Bool (ltb rp (succ b0)) true
                            -> Eq FBody (expand (succ b0) (succ F') rp seen) (expand (succ b0) (succ G') rp seen))
                         (hrem1 : Eq Bool (ltb (succ rp) (succ b0)) true) is
                       let dec : Nat = natDiv (mul (succ rp) 10) (succ b0) in
                       let nxt : Nat = natMod (mul (succ rp) 10) (succ b0) in
                       let snc : WList = wsnoc seen (succ rp) in
                       BoolElim (fn (z : Bool) is (Eq Bool (wmember (succ rp) seen) z -> Eq FBody (expand (succ b0) (succ F') (succ rp) seen) (expand (succ b0) (succ G') (succ rp) seen)) end)
                         (fn (ev : Eq Bool (wmember (succ rp) seen) true) is
                            trans
                              (cong (fn (sc : Bool) is BoolElim (fn (w : Bool) is FBody end)
                                       (fbody wnil (windex (succ rp) seen) false)
                                       (fbody (wcons dec (fbDigits (expand (succ b0) F' nxt snc)))
                                              (fbRep (expand (succ b0) F' nxt snc)) (fbTerm (expand (succ b0) F' nxt snc)))
                                       sc end) ev)
                              (sym (cong (fn (sc : Bool) is BoolElim (fn (w : Bool) is FBody end)
                                       (fbody wnil (windex (succ rp) seen) false)
                                       (fbody (wcons dec (fbDigits (expand (succ b0) G' nxt snc)))
                                              (fbRep (expand (succ b0) G' nxt snc)) (fbTerm (expand (succ b0) G' nxt snc)))
                                       sc end) ev)) end)
                         (fn (ev : Eq Bool (wmember (succ rp) seen) false) is
                            let ihres : Eq FBody (expand (succ b0) F' nxt snc) (expand (succ b0) G' nxt snc) =
                              ih nxt snc F' G'
                                (noDupSnoc (succ rp) seen hnd ev)
                                (allLtSnoc (succ b0) (succ rp) seen hal hrem1)
                                (trans (cong (fn (m : Nat) is add m cap0 end) (wlenSnoc (succ rp) seen))
                                   (trans (sym (addSuccR (wlen seen) cap0)) hcap))
                                (remBound (mul (succ rp) 10) b0)
                                hF hG in
                            cong (fn (fb : FBody) is BoolElim (fn (w : Bool) is FBody end)
                                     (fbody wnil (windex (succ rp) seen) false) fb (wmember (succ rp) seen) end)
                              (trans
                                 (cong (fn (a : WList) is
                                          fbody (wcons dec a)
                                            (fbRep (expand (succ b0) F' nxt snc)) (fbTerm (expand (succ b0) F' nxt snc)) end)
                                       (cong (fn (bb : FBody) is fbDigits bb end) ihres))
                                 (cong2 (fn (r : Nat) (tb : Bool) is
                                           fbody (wcons dec (fbDigits (expand (succ b0) G' nxt snc))) r tb end)
                                    (cong (fn (bb : FBody) is fbRep bb end) ihres)
                                    (cong (fn (bb : FBody) is fbTerm bb end) ihres))) end)
                         (wmember (succ rp) seen) (refl (wmember (succ rp) seen)) end)
                     rem hrem end
               end
           end
         end
       end)
      cap
  end
end

-- ============================================================================
-- RUNG 3 assembled + THE QLIFT.  toRadixRep respects QRel; lift it onto Q.
-- ============================================================================

lteAddR : (a : Nat) -> (b : Nat) -> Eq Bool (lte a (add a b)) true is
  fn (a : Nat) (b : Nat) is
    NatElim (fn (x : Nat) is Eq Bool (lte x (add x b)) true end)
      (refl true)
      (fn (k : Nat) (ih : Eq Bool (lte k (add k b)) true) is ih end)
      a
  end
end
lteAddL : (a : Nat) -> (b : Nat) -> Eq Bool (lte b (add a b)) true is
  fn (a : Nat) (b : Nat) is
    subst Nat (add b a) (add a b) (addComm b a)
      (fn (z : Nat) is Eq Bool (lte b z) true end) (lteAddR b a)
  end
end

-- MAGNITUDE CROSS-PRODUCT.  QRel-related QPairs satisfy |num p|·den q = |num q|·den p
-- (the non-negative-factor bridge applied to both sides of the ℤ cross-multiplication).
magCross : (p : QPair) -> (q : QPair) -> QRel p q
    -> Eq Nat (mul (qmagNum p) (qmagDen q)) (mul (qmagNum q) (qmagDen p)) is
  fn (p : QPair) (q : QPair) (h : QRel p q) is
    trans (sym (natAbsMulZfrom (qnum p) (succ (qdenN q))))
      (trans (cong natAbs h)
             (natAbsMulZfrom (qnum q) (succ (qdenN p))))
  end
end

-- FRACTIONAL EXPANSION RESPECTS QRel (rung 3, assembled).  Align both representatives'
-- own fuels to a common large fuel (expandFuelStable, both sufficient), then equate the
-- two expansions at that fuel (expandCross); the initial remainders are cross-equal by
-- natModCrossStep on magCross.
bodyResp : (p : QPair) -> (q : QPair) -> QRel p q
    -> Eq FBody
         (expand (qmagDen p) (succ (qmagDen p)) (natMod (qmagNum p) (qmagDen p)) wnil)
         (expand (qmagDen q) (succ (qmagDen q)) (natMod (qmagNum q) (qmagDen q)) wnil) is
  fn (p : QPair) (q : QPair) (h : QRel p q) is
    let remP : Nat = natMod (qmagNum p) (qmagDen p) in
    let remQ : Nat = natMod (qmagNum q) (qmagDen q) in
    let big : Nat = add (succ (succ (qdenN p))) (succ (succ (qdenN q))) in
    let crossEq : Eq Nat (mul remP (succ (qdenN q))) (mul remQ (succ (qdenN p))) =
      natModCrossStep (qdenN p) (qdenN q) (qmagNum p) (qmagNum q) (magCross p q h) in
    trans
      (expandFuelStable (qdenN p) (succ (qdenN p)) remP wnil (succ (succ (qdenN p))) big
         (refl true) (refl true) (refl (succ (qdenN p))) (remBound (qmagNum p) (qdenN p))
         (lteRefl (succ (succ (qdenN p))))
         (lteAddR (succ (succ (qdenN p))) (succ (succ (qdenN q)))))
      (trans
         (expandCross (qdenN p) (qdenN q) big remP remQ wnil wnil crossEq (refl true))
         (sym
            (expandFuelStable (qdenN q) (succ (qdenN q)) remQ wnil (succ (succ (qdenN q))) big
               (refl true) (refl true) (refl (succ (qdenN q))) (remBound (qmagNum q) (qdenN q))
               (lteRefl (succ (succ (qdenN q))))
               (lteAddL (succ (succ (qdenN p))) (succ (succ (qdenN q)))))))
  end
end

-- THE WELL-DEFINEDNESS: toRadixRep is constant on each QRel class — equal sign
-- (signResp), equal integer part (intPartResp), equal fractional body (bodyResp).
toRadixRespects : (p : QPair) -> (q : QPair) -> QRel p q
    -> Eq RDec (toRadixRep p) (toRadixRep q) is
  fn (p : QPair) (q : QPair) (h : QRel p q) is
    trans (cong (fn (s : Bool) is
                  rdec s (natDiv (qmagNum p) (qmagDen p))
                    (fbDigits (expand (qmagDen p) (succ (qmagDen p)) (natMod (qmagNum p) (qmagDen p)) wnil))
                    (fbRep (expand (qmagDen p) (succ (qmagDen p)) (natMod (qmagNum p) (qmagDen p)) wnil))
                    (fbTerm (expand (qmagDen p) (succ (qmagDen p)) (natMod (qmagNum p) (qmagDen p)) wnil)) end)
                (signResp p q h))
      (trans (cong (fn (i : Nat) is
                     rdec (qsign q) i
                       (fbDigits (expand (qmagDen p) (succ (qmagDen p)) (natMod (qmagNum p) (qmagDen p)) wnil))
                       (fbRep (expand (qmagDen p) (succ (qmagDen p)) (natMod (qmagNum p) (qmagDen p)) wnil))
                       (fbTerm (expand (qmagDen p) (succ (qmagDen p)) (natMod (qmagNum p) (qmagDen p)) wnil)) end)
                   (intPartResp p q h))
        (trans (cong (fn (d : WList) is
                       rdec (qsign q) (natDiv (qmagNum q) (qmagDen q)) d
                         (fbRep (expand (qmagDen p) (succ (qmagDen p)) (natMod (qmagNum p) (qmagDen p)) wnil))
                         (fbTerm (expand (qmagDen p) (succ (qmagDen p)) (natMod (qmagNum p) (qmagDen p)) wnil)) end)
                     (cong (fn (bb : FBody) is fbDigits bb end) (bodyResp p q h)))
          (trans (cong (fn (r : Nat) is
                         rdec (qsign q) (natDiv (qmagNum q) (qmagDen q))
                           (fbDigits (expand (qmagDen q) (succ (qmagDen q)) (natMod (qmagNum q) (qmagDen q)) wnil))
                           r
                           (fbTerm (expand (qmagDen p) (succ (qmagDen p)) (natMod (qmagNum p) (qmagDen p)) wnil)) end)
                       (cong (fn (bb : FBody) is fbRep bb end) (bodyResp p q h)))
            (cong (fn (t : Bool) is
                    rdec (qsign q) (natDiv (qmagNum q) (qmagDen q))
                      (fbDigits (expand (qmagDen q) (succ (qmagDen q)) (natMod (qmagNum q) (qmagDen q)) wnil))
                      (fbRep (expand (qmagDen q) (succ (qmagDen q)) (natMod (qmagNum q) (qmagDen q)) wnil))
                      t end)
                  (cong (fn (bb : FBody) is fbTerm bb end) (bodyResp p q h))))))
  end
end

-- THE DECIMAL OF A RATIONAL, on Q itself — the qlift of toRadixRep through QRel.
toRadixQ : Q -> RDec is
  qlift QPair QRel RDec toRadixRep toRadixRespects
end

-- ----------------------------------------------------------------------------
-- Q-LEVEL CERTIFICATES.  The lift COMPUTES through qin (qlift ι-rule), and the
-- well-definedness pays off: two representatives of one rational, identified by
-- qsound, map to the SAME decimal under toRadixQ.
-- ----------------------------------------------------------------------------

-- toRadixQ computes: 3/4 at the Q level is 0.75 (qlift ι: toRadixQ (qin p) ~> toRadixRep p).
radixQThreeQuarters :
  Eq RDec (toRadixQ (qin QPair QRel (qpair (intOf 3) 3)))
          (rdec false 0 (wcons 7 (wcons 5 wnil)) 0 true) is
  refl (rdec false 0 (wcons 7 (wcons 5 wnil)) 0 true)
end

-- 1/2 and 2/4 are the SAME rational: cross-multiplication 1·4 = 2·2 holds in ℤ.
halfEquiv : QRel (qpair (intOf 1) 1) (qpair (intOf 2) 3) is
  refl (zmul (intOf 1) (zfrom (succ (succ (succ (succ zero)))))) end
sameHalfQ : Eq Q (qin QPair QRel (qpair (intOf 1) 1)) (qin QPair QRel (qpair (intOf 2) 3)) is
  qsound QPair QRel (qpair (intOf 1) 1) (qpair (intOf 2) 3) halfEquiv
end

-- THE PAYOFF: toRadixQ assigns 1/2 and 2/4 the SAME decimal — the decimal is a
-- function of the rational VALUE, not the chosen fraction.  cong of the lift over
-- the qsound identification.
radixQHalfWellDefined :
  Eq RDec (toRadixQ (qin QPair QRel (qpair (intOf 1) 1)))
          (toRadixQ (qin QPair QRel (qpair (intOf 2) 3))) is
  cong (fn (x : Q) is toRadixQ x end) sameHalfQ
end

-- ============================================================================
-- THE FLOOR ON Q  (floorQ : Q -> Z)  AND ITS WELL-DEFINEDNESS  (floorUnique).
--
-- The integer floor of a rational, toward -infinity.  ch13 built this on the
-- RPair (Nat-pair-difference) representation with a bespoke sign trick; Rule 5
-- retires RPair for the canonical QPair, so the floor (and its proof that it is
-- a FUNCTION of the rational value, not of the chosen fraction) is ported here.
-- This is the rung ch203's to_radix section named as "next" (well-definedness
-- via floorUnique) and the last theorem that was unique to ch13.
--
-- A QPair p denotes (qnum p) / succ (qdenN p), a signed numerator over a
-- positive denominator.  The floor is determined by THREE quantities, each of
-- which is already a function of the rational value:
--   * the sign           qsign p        (signResp)
--   * the magnitude floor natDiv |num| den   (intPartResp / floorUniqueGeneral)
--   * whether it divides  natMod |num| den = 0?   (modIndResp, below)
-- because floor(-a/b) = -(|a| div b)  when b | a  and  -(|a| div b + 1) otherwise
-- (round toward -infinity), while floor(a/b) = |a| div b for a >= 0.  So floorQ
-- factors through mkFloor and RESPECTS QRel by congruence in those three slots —
-- no fresh sign analysis, reusing the canonical division engine wholesale.
-- ============================================================================

-- the zero/nonzero test on a Nat (matches nzMulSucc's inline case shape).
nzNat : Nat -> Bool is
  fn (t : Nat) is case t of | zero -> false | succ k -> true end end
end

-- does the denominator NOT divide the numerator (is there a nonzero remainder)?
nzMod : Nat -> Nat -> Bool is
  fn (a : Nat) (b : Nat) is nzNat (natMod a b) end
end

-- assemble the signed floor from (sign, magnitude floor, has-remainder):
--   non-negative          -> +q
--   negative, divides      -> -q          (exact: floor is the negation)
--   negative, has rem      -> -(q+1)      (round toward -infinity)
mkFloor : Bool -> Nat -> Bool -> Z is
  fn (s : Bool) (q : Nat) (nz : Bool) is
    case s of
    | false -> intOf q
    | true ->
        case nz of
        | false -> zneg (intOf q)
        | true  -> zneg (intOf (succ q))
        end
    end
  end
end

-- the floor of a QPair representative.
floorRep : QPair -> Z is
  fn (p : QPair) is
    mkFloor (qsign p) (natDiv (qmagNum p) (qmagDen p)) (nzMod (qmagNum p) (qmagDen p))
  end
end

-- the magnitude cross-product the respect proofs share: QRel (cross-mult in Z),
-- |.|'d through natAbsMulZfrom, becomes the Nat cross-product on |num| and den.
-- (Same bridge intPartResp/signResp use; named here for reuse by modIndResp.)
magCross : (p : QPair) -> (q : QPair) -> QRel p q
    -> Eq Nat (mul (qmagNum p) (succ (qdenN q))) (mul (qmagNum q) (succ (qdenN p))) is
  fn (p : QPair) (q : QPair) (h : QRel p q) is
    trans (sym (natAbsMulZfrom (qnum p) (succ (qdenN q))))
      (trans (cong natAbs h)
             (natAbsMulZfrom (qnum q) (succ (qdenN p))))
  end
end

-- DIVISIBILITY-INDICATOR RESPECT: QRel-related QPairs agree on whether the
-- denominator divides the numerator.  natModCrossStep carries the magnitude
-- cross-product to the REMAINDERS (rem_p . den_q = rem_q . den_p), and nzMulSucc
-- says a positive factor never flips a remainder's zero-ness; so the has-remainder
-- bit is a function of the rational value.  This is the only piece the signed
-- floor needs beyond the existing magnitude (intPartResp) and sign (signResp).
modIndResp : (p : QPair) -> (q : QPair) -> QRel p q
    -> Eq Bool (nzMod (qmagNum p) (qmagDen p)) (nzMod (qmagNum q) (qmagDen q)) is
  fn (p : QPair) (q : QPair) (h : QRel p q) is
    trans (sym (nzMulSucc (natMod (qmagNum p) (qmagDen p)) (qdenN q)))
      (trans (cong nzNat
                (natModCrossStep (qdenN p) (qdenN q) (qmagNum p) (qmagNum q) (magCross p q h)))
             (nzMulSucc (natMod (qmagNum q) (qmagDen q)) (qdenN p)))
  end
end

-- FLOOR IS WELL-DEFINED ON THE QUOTIENT: QRel-related representatives have the
-- SAME floor.  floorRep factors through mkFloor in three slots, each respecting
-- QRel, so three substitutions (sign, magnitude floor, has-remainder) rewrite
-- the representative p into q.  This is ch13's floorUnique on the canonical Q.
floorUnique : (p : QPair) -> (q : QPair) -> QRel p q
    -> Eq Z (floorRep p) (floorRep q) is
  fn (p : QPair) (q : QPair) (h : QRel p q) is
    subst Bool (qsign p) (qsign q) (signResp p q h)
      (fn (s : Bool) is
         Eq Z (floorRep p)
              (mkFloor s (natDiv (qmagNum q) (qmagDen q)) (nzMod (qmagNum q) (qmagDen q))) end)
      (subst Nat (natDiv (qmagNum p) (qmagDen p)) (natDiv (qmagNum q) (qmagDen q)) (intPartResp p q h)
        (fn (n : Nat) is
           Eq Z (floorRep p) (mkFloor (qsign p) n (nzMod (qmagNum q) (qmagDen q))) end)
        (subst Bool (nzMod (qmagNum p) (qmagDen p)) (nzMod (qmagNum q) (qmagDen q)) (modIndResp p q h)
          (fn (b : Bool) is
             Eq Z (floorRep p) (mkFloor (qsign p) (natDiv (qmagNum p) (qmagDen p)) b) end)
          (refl (floorRep p))))
  end
end

-- THE FLOOR ON Q: the lift of floorRep along floorUnique.  floorQ (qin p) computes
-- to floorRep p, and floorUnique is the proof obligation qlift demands.
floorQ : Q -> Z is qlift QPair QRel Z floorRep floorUnique end

-- CERTIFICATES (the gated value checks, ch13's answer=105 analogue):
-- floor(7/2) = 3.
floorSevenHalves : Eq Z (floorQ (qin QPair QRel (qpair (intOf 7) 1))) (intOf 3) is
  refl (intOf 3)
end

-- floor(-7/2) = -4 (rounds toward -infinity; this is FLOOR, not truncation,
-- which would give -3 -- the semantic witness that distinguishes the two).
floorNegSevenHalves : Eq Z (floorQ (qin QPair QRel (qpair (zneg (intOf 7)) 1))) (zneg (intOf 4)) is
  refl (zneg (intOf 4))
end

-- floor(-4/2) = -2 (exact division: no over-flooring).
floorNegFourHalves : Eq Z (floorQ (qin QPair QRel (qpair (zneg (intOf 4)) 1))) (zneg (intOf 2)) is
  refl (zneg (intOf 2))
end

-- THE PAYOFF: floorQ assigns 1/2 and 2/4 the SAME floor -- the floor is a function
-- of the rational VALUE, witnessed by cong of the lift over the qsound identity
-- (reusing sameHalfQ from the to_radix payoff above).
floorQHalfWellDefined :
  Eq Z (floorQ (qin QPair QRel (qpair (intOf 1) 1)))
       (floorQ (qin QPair QRel (qpair (intOf 2) 3))) is
  cong (fn (x : Q) is floorQ x end) sameHalfQ
end
