                  (iadd (wsub (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c))))
                        (wsub (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))
                  (wsub (addW (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))))
                        (addW (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))
                  (congIaddR (wsub (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c)))) (imul b c) (wsub (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))) (imulSpec b c))
                  (iaddWsub2 (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c)))
                             (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))))))))
  end
end

idistribL : DistribLT Int iadd imul is
  fn (a : Int) (b : Int) (c : Int) is
    transEq Int (imul a (iadd b c)) (imul (iadd b c) a) (iadd (imul a b) (imul a c))
      (imulComm a (iadd b c))
      (transEq Int (imul (iadd b c) a) (iadd (imul b a) (imul c a)) (iadd (imul a b) (imul a c))
         (idistribR b c a)
         (transEq Int (iadd (imul b a) (imul c a)) (iadd (imul a b) (imul c a)) (iadd (imul a b) (imul a c))
            (congIaddL (imul b a) (imul a b) (imul c a) (imulComm b a))
            (congIaddR (imul a b) (imul c a) (imul a c) (imulComm c a))))
  end
end

imulAssoc : AssocT Int imul is
  fn (a : Int) (b : Int) (c : Int) is
    transEq Int (imul (imul a b) c)
      (wsub (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (posP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (negP c)))
            (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (negP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (posP c))))
      (imul a (imul b c))
      (transEq Int (imul (imul a b) c)
         (imul (wsub (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b)))) c)
         (wsub (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (posP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (negP c)))
               (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (negP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (posP c))))
         (congImulL (imul a b) (wsub (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b)))) c (imulSpec a b))
         (imulWsub (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) c))
      (transEq Int
         (wsub (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (posP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (negP c)))
               (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (negP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (posP c))))
         (wsub (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (posP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (negP a)))
               (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a))))
         (imul a (imul b c))
         (congWsub2
            (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (posP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (negP c)))
            (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (posP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (negP a)))
            (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (negP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (posP c)))
            (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a)))
            (mulAssocCol (posP a) (negP a) (posP b) (negP b) (posP c) (negP c))
            (transEq Whole
               (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (negP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (posP c)))
               (addW (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a)) (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)))
               (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a)))
               (mulAssocCol (posP a) (negP a) (posP b) (negP b) (negP c) (posP c))
               (addWComm (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a)) (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)))))
         (symEq Int (imul a (imul b c))
            (wsub (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (posP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (negP a)))
                  (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a))))
            (transEq Int (imul a (imul b c))
               (imul a (wsub (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))
               (wsub (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (posP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (negP a)))
                     (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a))))
               (congImulR a (imul b c) (wsub (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))) (imulSpec b c))
               (imulWsubR a (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))))
  end
end

imulOneL : IdLT Int imul (nonneg (succ zero)) is
  fn (a : Int) is
    transEq Int (imul (nonneg (succ zero)) a)
      (wsub (addW (posP a) zero) (addW (negP a) zero))
      a
      (imulSpec (nonneg (succ zero)) a)
      (transEq Int (wsub (addW (posP a) zero) (addW (negP a) zero)) (wsub (posP a) (negP a)) a
         (congWsub2 (addW (posP a) zero) (posP a) (addW (negP a) zero) (negP a) (addWZeroR (posP a)) (addWZeroR (negP a)))
         (wsubRep a))
  end
end

imulOneR : IdRT Int imul (nonneg (succ zero)) is
  fn (a : Int) is
    transEq Int (imul a (nonneg (succ zero)))
      (wsub (addW (posP a) zero) (addW (negP a) zero))
      a
      (imulWsubR a (succ zero) zero)
      (transEq Int (wsub (addW (posP a) zero) (addW (negP a) zero)) (wsub (posP a) (negP a)) a
         (congWsub2 (addW (posP a) zero) (posP a) (addW (negP a) zero) (negP a) (addWZeroR (posP a)) (addWZeroR (negP a)))
         (wsubRep a))
  end
end

semiringLawsInt : SemiringLaws Int (ringInt.1) is
  mkAnd (AssocT Int iadd)
        (And (CommT Int iadd)
        (And (IdLT Int iadd (nonneg zero))
        (And (IdRT Int iadd (nonneg zero))
        (And (AssocT Int imul)
        (And (IdLT Int imul (nonneg (succ zero)))
        (And (IdRT Int imul (nonneg (succ zero)))
        (And (DistribLT Int iadd imul)
        (And (DistribRT Int iadd imul)
        (And (AnnihLT Int imul (nonneg zero))
             (AnnihRT Int imul (nonneg zero)))))))))))
    iaddAssoc
    (mkAnd (CommT Int iadd)
          (And (IdLT Int iadd (nonneg zero))
          (And (IdRT Int iadd (nonneg zero))
          (And (AssocT Int imul)
          (And (IdLT Int imul (nonneg (succ zero)))
          (And (IdRT Int imul (nonneg (succ zero)))
          (And (DistribLT Int iadd imul)
          (And (DistribRT Int iadd imul)
          (And (AnnihLT Int imul (nonneg zero))
               (AnnihRT Int imul (nonneg zero))))))))))
      iaddComm
      (mkAnd (IdLT Int iadd (nonneg zero))
            (And (IdRT Int iadd (nonneg zero))
            (And (AssocT Int imul)
            (And (IdLT Int imul (nonneg (succ zero)))
            (And (IdRT Int imul (nonneg (succ zero)))
            (And (DistribLT Int iadd imul)
            (And (DistribRT Int iadd imul)
            (And (AnnihLT Int imul (nonneg zero))
                 (AnnihRT Int imul (nonneg zero)))))))))
        iaddZeroL
        (mkAnd (IdRT Int iadd (nonneg zero))
              (And (AssocT Int imul)
              (And (IdLT Int imul (nonneg (succ zero)))
              (And (IdRT Int imul (nonneg (succ zero)))
              (And (DistribLT Int iadd imul)
              (And (DistribRT Int iadd imul)
              (And (AnnihLT Int imul (nonneg zero))
                   (AnnihRT Int imul (nonneg zero))))))))
          iaddZeroR
          (mkAnd (AssocT Int imul)
                (And (IdLT Int imul (nonneg (succ zero)))
                (And (IdRT Int imul (nonneg (succ zero)))
                (And (DistribLT Int iadd imul)
                (And (DistribRT Int iadd imul)
                (And (AnnihLT Int imul (nonneg zero))
                     (AnnihRT Int imul (nonneg zero)))))))
            imulAssoc
            (mkAnd (IdLT Int imul (nonneg (succ zero)))
                  (And (IdRT Int imul (nonneg (succ zero)))
                  (And (DistribLT Int iadd imul)
                  (And (DistribRT Int iadd imul)
                  (And (AnnihLT Int imul (nonneg zero))
                       (AnnihRT Int imul (nonneg zero))))))
              imulOneL
              (mkAnd (IdRT Int imul (nonneg (succ zero)))
                    (And (DistribLT Int iadd imul)
                    (And (DistribRT Int iadd imul)
                    (And (AnnihLT Int imul (nonneg zero))
                         (AnnihRT Int imul (nonneg zero)))))
                imulOneR
                (mkAnd (DistribLT Int iadd imul)
                      (And (DistribRT Int iadd imul)
                      (And (AnnihLT Int imul (nonneg zero))
                           (AnnihRT Int imul (nonneg zero))))
                  idistribL
                  (mkAnd (DistribRT Int iadd imul)
                        (And (AnnihLT Int imul (nonneg zero))
                             (AnnihRT Int imul (nonneg zero)))
                    idistribR
                    (mkAnd (AnnihLT Int imul (nonneg zero))
                           (AnnihRT Int imul (nonneg zero))
                      imulZeroL
                      imulZeroR)))))))))
end

ringLawsInt : RingLaws Int ringInt is
  mkAnd (SemiringLaws Int (ringInt.1))
    (And (NegInvLT Int iadd ineg (nonneg zero)) (NegInvRT Int iadd ineg (nonneg zero)))
    semiringLawsInt
    (mkAnd (NegInvLT Int iadd ineg (nonneg zero)) (NegInvRT Int iadd ineg (nonneg zero))
      inegInvL inegInvR)
end

isZeroInt : Int -> Bool is
  fn (i : Int) is
    case i of
    | nonneg n -> isZero n
    | negsucc k -> false
    end
  end
end

isZeroIntSound : (a : Int) -> Eq Bool (isZeroInt a) true -> Eq Int a (nonneg zero) is
  fn (a : Int) is
    IntElim (fn (w : Int) is Eq Bool (isZeroInt w) true -> Eq Int w (nonneg zero) end)
      (fn (n : Whole) is
         WholeElim (fn (m : Whole) is Eq Bool (isZeroInt (nonneg m)) true -> Eq Int (nonneg m) (nonneg zero) end)
           (fn (h : Eq Bool (isZeroInt (nonneg zero)) true) is refl (nonneg zero) end)
           (fn (k : Whole) (ih : Eq Bool (isZeroInt (nonneg k)) true -> Eq Int (nonneg k) (nonneg zero)) is
              fn (h : Eq Bool (isZeroInt (nonneg (succ k))) true) is
                boolDiscTF (Eq Int (nonneg (succ k)) (nonneg zero))
                  (symEq Bool (isZeroInt (nonneg (succ k))) true h)
              end
            end)
           n
       end)
      (fn (k : Whole) is
         fn (h : Eq Bool (isZeroInt (negsucc k)) true) is
           boolDiscTF (Eq Int (negsucc k) (nonneg zero))
             (symEq Bool (isZeroInt (negsucc k)) true h)
         end
       end)
      a
  end
end

nonnegInj : (a : Whole) -> (b : Whole) -> Eq Int (nonneg a) (nonneg b) -> Eq Whole a b is
  fn (a : Whole) (b : Whole) (h : Eq Int (nonneg a) (nonneg b)) is
    subst Int (nonneg a) (nonneg b) h (fn (z : Int) is Eq Whole a (imag z) end) (refl a)
  end
end

intTagDisc : (k : Whole) -> (n : Whole) -> Eq Int (negsucc k) (nonneg n) -> Eq Bool true false is
  fn (k : Whole) (n : Whole) (h : Eq Int (negsucc k) (nonneg n)) is
    subst Int (negsucc k) (nonneg n) h (fn (z : Int) is Eq Bool true (isign z) end) (refl true)
  end
end

addWPosR : (x : Whole) -> (d : Whole) -> Eq Bool (isZero (addW x (succ d))) false is
  fn (x : Whole) (d : Whole) is
    subst Whole (succ (addW x d)) (addW x (succ d))
      (symEq Whole (addW x (succ d)) (succ (addW x d)) (addWSuccR x d))
      (fn (z : Whole) is Eq Bool (isZero z) false end)
      (refl false)
  end
end

mulWPosZero : (n : Whole) -> (d : Whole) -> Eq Whole (mulW n (succ d)) zero -> Eq Whole n zero is
  fn (n : Whole) (d : Whole) is
    WholeElim (fn (m : Whole) is Eq Whole (mulW m (succ d)) zero -> Eq Whole m zero end)
      (fn (h : Eq Whole (mulW zero (succ d)) zero) is refl zero end)
      (fn (k : Whole) (ih : Eq Whole (mulW k (succ d)) zero -> Eq Whole k zero) is
         fn (h : Eq Whole (mulW (succ k) (succ d)) zero) is
           boolDiscTF (Eq Whole (succ k) zero)
             (transEq Bool true (isZero (mulW (succ k) (succ d))) false
                (symEq Bool (isZero (mulW (succ k) (succ d))) true
                   (subst Whole (mulW (succ k) (succ d)) zero h
                      (fn (z : Whole) is Eq Bool (isZero (mulW (succ k) (succ d))) (isZero z) end)
                      (refl (isZero (mulW (succ k) (succ d))))))
                (addWPosR (mulW k (succ d)) d))
         end
       end)
      n
  end
end

imulPosZero : (a : Int) -> (d : Whole) -> Eq Int (imul a (nonneg (succ d))) (nonneg zero) -> Eq Int a (nonneg zero) is
  fn (a : Int) (d : Whole) is
    IntElim (fn (w : Int) is Eq Int (imul w (nonneg (succ d))) (nonneg zero) -> Eq Int w (nonneg zero) end)
      (fn (n : Whole) is
         fn (h : Eq Int (imul (nonneg n) (nonneg (succ d))) (nonneg zero)) is
           congNonneg n zero (mulWPosZero n d (nonnegInj (mulW n (succ d)) zero h))
         end
       end)
      (fn (k : Whole) is
         fn (h : Eq Int (imul (negsucc k) (nonneg (succ d))) (nonneg zero)) is
           boolDiscTF (Eq Int (negsucc k) (nonneg zero))
             (intTagDisc (addW (mulW k (succ d)) d) zero
                (subst Whole (addW (mulW k (succ d)) (succ d)) (succ (addW (mulW k (succ d)) d))
                   (addWSuccR (mulW k (succ d)) d)
                   (fn (z : Whole) is Eq Int (ineg (nonneg z)) (nonneg zero) end)
                   h))
         end
       end)
      a
  end
end

data QPair : U is qpair : Int -> Whole -> QPair end

qnum   : QPair -> Int   is fn (p : QPair) is case p of | qpair i d -> i end end end

qdpred : QPair -> Whole is fn (p : QPair) is case p of | qpair i d -> d end end end

qden : QPair -> Int is fn (p : QPair) is nonneg (succ (qdpred p)) end end

QRel : QPair -> QPair -> Prop is
  fn (p : QPair) (q : QPair) is
    Eq Int (imul (qnum p) (qden q)) (imul (qnum q) (qden p))
  end
end

Frac : U is Quot QPair QRel end

fracOf : Whole -> Frac is fn (n : Whole) is qin QPair QRel (qpair (nonneg n) zero) end end
builtin rat Frac fracOf

dmul : Whole -> Whole -> Whole is
  fn (a : Whole) (b : Whole) is addW (mulW a (succ b)) b end
end

dmulSucc : (a : Whole) -> (b : Whole) -> Eq Whole (mulW (succ a) (succ b)) (succ (dmul a b)) is
  fn (a : Whole) (b : Whole) is addWSuccR (mulW a (succ b)) b end
end

rawMul : QPair -> QPair -> QPair is
  fn (p : QPair) (q : QPair) is
    qpair (imul (qnum p) (qnum q)) (dmul (qdpred p) (qdpred q))
  end
end

rawAdd : QPair -> QPair -> QPair is
  fn (p : QPair) (q : QPair) is
    qpair (iadd (imul (qnum p) (qden q)) (imul (qnum q) (qden p))) (dmul (qdpred p) (qdpred q))
  end
end

rawNeg : QPair -> QPair is
  fn (p : QPair) is qpair (ineg (qnum p)) (qdpred p) end
end

rawRecipOn : Int -> Whole -> QPair is
  fn (i : Int) (d : Whole) is
    case i of
    | nonneg n ->
        case n of
        | zero -> qpair (nonneg zero) zero
        | succ k -> qpair (nonneg (succ d)) k
        end
    | negsucc k -> qpair (negsucc d) k
    end
  end
end

rawRecip : QPair -> QPair is fn (p : QPair) is rawRecipOn (qnum p) (qdpred p) end end

congE : (A : U) -> (B : U) -> (f : A -> B) -> (x : A) -> (y : A) -> Eq A x y -> Eq B (f x) (f y) is
  fn (A : U) (B : U) (f : A -> B) (x : A) (y : A) (p : Eq A x y) is
    subst A x y p (fn (z : A) is Eq B (f x) (f z) end) (refl (f x))
  end
end

congIadd2 : (x1 : Int) -> (y1 : Int) -> (x2 : Int) -> (y2 : Int)
  -> Eq Int x1 y1 -> Eq Int x2 y2 -> Eq Int (iadd x1 x2) (iadd y1 y2) is
  fn (x1 : Int) (y1 : Int) (x2 : Int) (y2 : Int) (p : Eq Int x1 y1) (q : Eq Int x2 y2) is
    transEq Int (iadd x1 x2) (iadd y1 x2) (iadd y1 y2)
      (congIaddL x1 y1 x2 p)
      (congIaddR y1 x2 y2 q)
  end
end

imulInterchange : (a : Int) -> (b : Int) -> (c : Int) -> (d : Int)
  -> Eq Int (imul (imul a b) (imul c d)) (imul (imul a c) (imul b d)) is
  fn (a : Int) (b : Int) (c : Int) (d : Int) is
    transEq Int (imul (imul a b) (imul c d)) (imul a (imul b (imul c d))) (imul (imul a c) (imul b d))
      (imulAssoc a b (imul c d))
      (transEq Int (imul a (imul b (imul c d))) (imul a (imul (imul b c) d)) (imul (imul a c) (imul b d))
         (congImulR a (imul b (imul c d)) (imul (imul b c) d)
            (symEq Int (imul (imul b c) d) (imul b (imul c d)) (imulAssoc b c d)))
         (transEq Int (imul a (imul (imul b c) d)) (imul a (imul (imul c b) d)) (imul (imul a c) (imul b d))
            (congImulR a (imul (imul b c) d) (imul (imul c b) d)
               (congImulL (imul b c) (imul c b) d (imulComm b c)))
            (transEq Int (imul a (imul (imul c b) d)) (imul a (imul c (imul b d))) (imul (imul a c) (imul b d))
               (congImulR a (imul (imul c b) d) (imul c (imul b d)) (imulAssoc c b d))
               (symEq Int (imul (imul a c) (imul b d)) (imul a (imul c (imul b d))) (imulAssoc a c (imul b d))))))
  end
end

qdenMul : (p : QPair) -> (q : QPair) -> Eq Int (qden (rawMul p q)) (imul (qden p) (qden q)) is
  fn (p : QPair) (q : QPair) is
    symEq Int (imul (qden p) (qden q)) (qden (rawMul p q))
      (congNonneg (mulW (succ (qdpred p)) (succ (qdpred q))) (succ (dmul (qdpred p) (qdpred q)))
         (dmulSucc (qdpred p) (qdpred q)))
  end
end

mulRespR : (p : QPair) -> (q : QPair) -> (q' : QPair) -> QRel q q' -> QRel (rawMul p q) (rawMul p q') is
  fn (p : QPair) (q : QPair) (q' : QPair) (h : QRel q q') is
    let np : Int = qnum p in
    let nq : Int = qnum q in
    let nq' : Int = qnum q' in
    let dp : Int = qden p in
    let dq : Int = qden q in
    let dq' : Int = qden q' in
    transEq Int
      (imul (imul np nq) (qden (rawMul p q')))
      (imul (imul np nq) (imul dp dq'))
      (imul (imul np nq') (qden (rawMul p q)))
      (congImulR (imul np nq) (qden (rawMul p q')) (imul dp dq') (qdenMul p q'))
      (transEq Int
         (imul (imul np nq) (imul dp dq'))
         (imul (imul np dp) (imul nq dq'))
         (imul (imul np nq') (qden (rawMul p q)))
         (imulInterchange np nq dp dq')
         (transEq Int
            (imul (imul np dp) (imul nq dq'))
            (imul (imul np dp) (imul nq' dq))
            (imul (imul np nq') (qden (rawMul p q)))
            (congImulR (imul np dp) (imul nq dq') (imul nq' dq) h)
            (transEq Int
               (imul (imul np dp) (imul nq' dq))
               (imul (imul np nq') (imul dp dq))
               (imul (imul np nq') (qden (rawMul p q)))
               (symEq Int (imul (imul np nq') (imul dp dq)) (imul (imul np dp) (imul nq' dq)) (imulInterchange np nq' dp dq))
               (congImulR (imul np nq') (imul dp dq) (qden (rawMul p q)) (symEq Int (qden (rawMul p q)) (imul dp dq) (qdenMul p q))))))
  end
end

mulRespL : (p : QPair) -> (p' : QPair) -> (q : QPair) -> QRel p p' -> QRel (rawMul p q) (rawMul p' q) is
  fn (p : QPair) (p' : QPair) (q : QPair) (h : QRel p p') is
    let np : Int = qnum p in
    let np' : Int = qnum p' in
    let nq : Int = qnum q in
    let dp : Int = qden p in
    let dp' : Int = qden p' in
    let dq : Int = qden q in
    transEq Int
      (imul (imul np nq) (qden (rawMul p' q)))
      (imul (imul np nq) (imul dp' dq))
      (imul (imul np' nq) (qden (rawMul p q)))
      (congImulR (imul np nq) (qden (rawMul p' q)) (imul dp' dq) (qdenMul p' q))
      (transEq Int
         (imul (imul np nq) (imul dp' dq))
         (imul (imul np dp') (imul nq dq))
         (imul (imul np' nq) (qden (rawMul p q)))
         (imulInterchange np nq dp' dq)
         (transEq Int
            (imul (imul np dp') (imul nq dq))
            (imul (imul np' dp) (imul nq dq))
            (imul (imul np' nq) (qden (rawMul p q)))
            (congImulL (imul np dp') (imul np' dp) (imul nq dq) h)
            (transEq Int
               (imul (imul np' dp) (imul nq dq))
               (imul (imul np' nq) (imul dp dq))
               (imul (imul np' nq) (qden (rawMul p q)))
               (symEq Int (imul (imul np' nq) (imul dp dq)) (imul (imul np' dp) (imul nq dq)) (imulInterchange np' nq dp dq))
               (congImulR (imul np' nq) (imul dp dq) (qden (rawMul p q)) (symEq Int (qden (rawMul p q)) (imul dp dq) (qdenMul p q))))))
  end
end

mulFR : QPair -> Frac -> Frac is
  fn (p : QPair) is
    qlift QPair QRel Frac
      (fn (q : QPair) is qin QPair QRel (rawMul p q) end)
      (fn (q : QPair) (q' : QPair) (r : QRel q q') is
        qsound QPair QRel (rawMul p q) (rawMul p q') (mulRespR p q q' r)
      end)
  end
end

mulF : Frac -> Frac -> Frac is
  qlift QPair QRel (Frac -> Frac) mulFR
    (fn (p : QPair) (p' : QPair) (r : QRel p p') is
      fn (z : Frac) is
        qind QPair QRel (fn (w : Frac) is Eq Frac (mulFR p w) (mulFR p' w) end)
          (fn (q : QPair) is
            qsound QPair QRel (rawMul p q) (rawMul p' q) (mulRespL p p' q r)
          end)
          z
      end
    end)
end

addRespR : (p : QPair) -> (q : QPair) -> (q' : QPair) -> QRel q q' -> QRel (rawAdd p q) (rawAdd p q') is
  fn (p : QPair) (q : QPair) (q' : QPair) (h : QRel q q') is
    let np : Int = qnum p in
    let nq : Int = qnum q in
    let nq' : Int = qnum q' in
    let dp : Int = qden p in
    let dq : Int = qden q in
    let dq' : Int = qden q' in
    let n1 : Int = iadd (imul np dq) (imul nq dp) in
    let n2 : Int = iadd (imul np dq') (imul nq' dp) in
    let term1 : Eq Int (imul (imul np dq) (imul dp dq')) (imul (imul np dq') (imul dp dq)) =
      transEq Int (imul (imul np dq) (imul dp dq')) (imul (imul np dp) (imul dq dq')) (imul (imul np dq') (imul dp dq))
        (imulInterchange np dq dp dq')
        (transEq Int (imul (imul np dp) (imul dq dq')) (imul (imul np dp) (imul dq' dq)) (imul (imul np dq') (imul dp dq))
           (congImulR (imul np dp) (imul dq dq') (imul dq' dq) (imulComm dq dq'))
           (symEq Int (imul (imul np dq') (imul dp dq)) (imul (imul np dp) (imul dq' dq)) (imulInterchange np dq' dp dq))) in
    let term2 : Eq Int (imul (imul nq dp) (imul dp dq')) (imul (imul nq' dp) (imul dp dq)) =
      transEq Int (imul (imul nq dp) (imul dp dq')) (imul (imul nq dp) (imul dq' dp)) (imul (imul nq' dp) (imul dp dq))
        (congImulR (imul nq dp) (imul dp dq') (imul dq' dp) (imulComm dp dq'))
        (transEq Int (imul (imul nq dp) (imul dq' dp)) (imul (imul nq dq') (imul dp dp)) (imul (imul nq' dp) (imul dp dq))
           (imulInterchange nq dp dq' dp)
           (transEq Int (imul (imul nq dq') (imul dp dp)) (imul (imul nq' dq) (imul dp dp)) (imul (imul nq' dp) (imul dp dq))
              (congImulL (imul nq dq') (imul nq' dq) (imul dp dp) h)
              (transEq Int (imul (imul nq' dq) (imul dp dp)) (imul (imul nq' dp) (imul dq dp)) (imul (imul nq' dp) (imul dp dq))
                 (symEq Int (imul (imul nq' dp) (imul dq dp)) (imul (imul nq' dq) (imul dp dp)) (imulInterchange nq' dp dq dp))
                 (congImulR (imul nq' dp) (imul dq dp) (imul dp dq) (imulComm dq dp))))) in
    transEq Int
      (imul n1 (qden (rawAdd p q')))
      (imul n1 (imul dp dq'))
      (imul n2 (qden (rawAdd p q)))
      (congImulR n1 (qden (rawAdd p q')) (imul dp dq') (qdenMul p q'))
      (transEq Int
         (imul n1 (imul dp dq'))
         (iadd (imul (imul np dq) (imul dp dq')) (imul (imul nq dp) (imul dp dq')))
         (imul n2 (qden (rawAdd p q)))
         (idistribR (imul np dq) (imul nq dp) (imul dp dq'))
         (transEq Int
            (iadd (imul (imul np dq) (imul dp dq')) (imul (imul nq dp) (imul dp dq')))
            (iadd (imul (imul np dq') (imul dp dq)) (imul (imul nq' dp) (imul dp dq)))
            (imul n2 (qden (rawAdd p q)))
            (congIadd2
               (imul (imul np dq) (imul dp dq')) (imul (imul np dq') (imul dp dq))
               (imul (imul nq dp) (imul dp dq')) (imul (imul nq' dp) (imul dp dq))
               term1 term2)
            (transEq Int
               (iadd (imul (imul np dq') (imul dp dq)) (imul (imul nq' dp) (imul dp dq)))
               (imul n2 (imul dp dq))
               (imul n2 (qden (rawAdd p q)))
               (symEq Int (imul n2 (imul dp dq)) (iadd (imul (imul np dq') (imul dp dq)) (imul (imul nq' dp) (imul dp dq)))
                  (idistribR (imul np dq') (imul nq' dp) (imul dp dq)))
               (congImulR n2 (imul dp dq) (qden (rawAdd p q)) (symEq Int (qden (rawAdd p q)) (imul dp dq) (qdenMul p q))))))
  end
end

addRespL : (p : QPair) -> (p' : QPair) -> (q : QPair) -> QRel p p' -> QRel (rawAdd p q) (rawAdd p' q) is
  fn (p : QPair) (p' : QPair) (q : QPair) (h : QRel p p') is
    let np : Int = qnum p in
    let np' : Int = qnum p' in
    let nq : Int = qnum q in
    let dp : Int = qden p in
    let dp' : Int = qden p' in
    let dq : Int = qden q in
    let n1 : Int = iadd (imul np dq) (imul nq dp) in
    let n2 : Int = iadd (imul np' dq) (imul nq dp') in
    let term1 : Eq Int (imul (imul np dq) (imul dp' dq)) (imul (imul np' dq) (imul dp dq)) =
      transEq Int (imul (imul np dq) (imul dp' dq)) (imul (imul np dp') (imul dq dq)) (imul (imul np' dq) (imul dp dq))
        (imulInterchange np dq dp' dq)
        (transEq Int (imul (imul np dp') (imul dq dq)) (imul (imul np' dp) (imul dq dq)) (imul (imul np' dq) (imul dp dq))
           (congImulL (imul np dp') (imul np' dp) (imul dq dq) h)
           (symEq Int (imul (imul np' dq) (imul dp dq)) (imul (imul np' dp) (imul dq dq)) (imulInterchange np' dq dp dq))) in
    transEq Int
      (imul n1 (qden (rawAdd p' q)))
      (imul n1 (imul dp' dq))
      (imul n2 (qden (rawAdd p q)))
      (congImulR n1 (qden (rawAdd p' q)) (imul dp' dq) (qdenMul p' q))
      (transEq Int
         (imul n1 (imul dp' dq))
         (iadd (imul (imul np dq) (imul dp' dq)) (imul (imul nq dp) (imul dp' dq)))
         (imul n2 (qden (rawAdd p q)))
         (idistribR (imul np dq) (imul nq dp) (imul dp' dq))
         (transEq Int
            (iadd (imul (imul np dq) (imul dp' dq)) (imul (imul nq dp) (imul dp' dq)))
            (iadd (imul (imul np' dq) (imul dp dq)) (imul (imul nq dp') (imul dp dq)))
            (imul n2 (qden (rawAdd p q)))
            (congIadd2
               (imul (imul np dq) (imul dp' dq)) (imul (imul np' dq) (imul dp dq))
               (imul (imul nq dp) (imul dp' dq)) (imul (imul nq dp') (imul dp dq))
               term1
               (imulInterchange nq dp dp' dq))
            (transEq Int
               (iadd (imul (imul np' dq) (imul dp dq)) (imul (imul nq dp') (imul dp dq)))
               (imul n2 (imul dp dq))
               (imul n2 (qden (rawAdd p q)))
               (symEq Int (imul n2 (imul dp dq)) (iadd (imul (imul np' dq) (imul dp dq)) (imul (imul nq dp') (imul dp dq)))
                  (idistribR (imul np' dq) (imul nq dp') (imul dp dq)))
               (congImulR n2 (imul dp dq) (qden (rawAdd p q)) (symEq Int (qden (rawAdd p q)) (imul dp dq) (qdenMul p q))))))
  end
end

addFR : QPair -> Frac -> Frac is
  fn (p : QPair) is
    qlift QPair QRel Frac
      (fn (q : QPair) is qin QPair QRel (rawAdd p q) end)
      (fn (q : QPair) (q' : QPair) (r : QRel q q') is
        qsound QPair QRel (rawAdd p q) (rawAdd p q') (addRespR p q q' r)
      end)
  end
end

addF : Frac -> Frac -> Frac is
  qlift QPair QRel (Frac -> Frac) addFR
    (fn (p : QPair) (p' : QPair) (r : QRel p p') is
      fn (z : Frac) is
        qind QPair QRel (fn (w : Frac) is Eq Frac (addFR p w) (addFR p' w) end)
          (fn (q : QPair) is
            qsound QPair QRel (rawAdd p q) (rawAdd p' q) (addRespL p p' q r)
          end)
          z
      end
    end)
end

inegInvol : (x : Int) -> Eq Int (ineg (ineg x)) x is
  fn (x : Int) is
    IntElim (fn (w : Int) is Eq Int (ineg (ineg w)) w end)
      (fn (n : Whole) is
        WholeElim (fn (m : Whole) is Eq Int (ineg (ineg (nonneg m))) (nonneg m) end)
          (refl (nonneg zero))
          (fn (k : Whole) (ih : Eq Int (ineg (ineg (nonneg k))) (nonneg k)) is refl (nonneg (succ k)) end)
          n
      end)
      (fn (k : Whole) is refl (negsucc k) end)
      x
  end
end

inegImul : (a : Int) -> (b : Int) -> Eq Int (imul (ineg a) b) (ineg (imul a b)) is
  fn (a : Int) (b : Int) is
    IntElim (fn (w : Int) is Eq Int (imul (ineg w) b) (ineg (imul w b)) end)
      (fn (n : Whole) is
        WholeElim (fn (m : Whole) is Eq Int (imul (ineg (nonneg m)) b) (ineg (imul (nonneg m) b)) end)
          (IntElim (fn (w2 : Int) is Eq Int (imul (ineg (nonneg zero)) w2) (ineg (imul (nonneg zero) w2)) end)
             (fn (c : Whole) is refl (nonneg zero) end)
             (fn (d : Whole) is refl (nonneg zero) end)
             b)
          (fn (k : Whole) (ih : Eq Int (imul (ineg (nonneg k)) b) (ineg (imul (nonneg k) b))) is
             IntElim (fn (w2 : Int) is Eq Int (imul (ineg (nonneg (succ k))) w2) (ineg (imul (nonneg (succ k)) w2)) end)
               (fn (c : Whole) is refl (ineg (nonneg (mulW (succ k) c))) end)
               (fn (d : Whole) is
                  symEq Int (ineg (ineg (nonneg (mulW (succ k) (succ d))))) (nonneg (mulW (succ k) (succ d)))
                    (inegInvol (nonneg (mulW (succ k) (succ d))))
                end)
               b
           end)
          n
      end)
      (fn (k : Whole) is
        IntElim (fn (w2 : Int) is Eq Int (imul (ineg (negsucc k)) w2) (ineg (imul (negsucc k) w2)) end)
          (fn (c : Whole) is
             symEq Int (ineg (ineg (nonneg (mulW (succ k) c)))) (nonneg (mulW (succ k) c))
               (inegInvol (nonneg (mulW (succ k) c)))
           end)
          (fn (d : Whole) is refl (ineg (nonneg (mulW (succ k) (succ d)))) end)
          b
      end)
      a
  end
end

negResp : (p : QPair) -> (p' : QPair) -> QRel p p' -> QRel (rawNeg p) (rawNeg p') is
  fn (p : QPair) (p' : QPair) (h : QRel p p') is
    transEq Int (imul (ineg (qnum p)) (qden p')) (ineg (imul (qnum p) (qden p'))) (imul (ineg (qnum p')) (qden p))
      (inegImul (qnum p) (qden p'))
      (transEq Int (ineg (imul (qnum p) (qden p'))) (ineg (imul (qnum p') (qden p))) (imul (ineg (qnum p')) (qden p))
         (congE Int Int ineg (imul (qnum p) (qden p')) (imul (qnum p') (qden p)) h)
         (symEq Int (imul (ineg (qnum p')) (qden p)) (ineg (imul (qnum p') (qden p))) (inegImul (qnum p') (qden p))))
  end
end

fnegate : Frac -> Frac is
  qlift QPair QRel Frac
    (fn (p : QPair) is qin QPair QRel (rawNeg p) end)
    (fn (p : QPair) (p' : QPair) (r : QRel p p') is
      qsound QPair QRel (rawNeg p) (rawNeg p') (negResp p p' r)
    end)
end

mulSuccPos : (a : Whole) -> (b : Whole) -> Eq Bool (isZero (mulW (succ a) (succ b))) false is
  fn (a : Whole) (b : Whole) is
    congE Whole Bool isZero (mulW (succ a) (succ b)) (succ (dmul a b)) (dmulSucc a b)
  end
end

negMulSS : (a : Whole) -> (b : Whole) -> Eq Int (imul (negsucc a) (nonneg (succ b))) (negsucc (dmul a b)) is
  fn (a : Whole) (b : Whole) is
    congE Whole Int (fn (w : Whole) is ineg (nonneg w) end) (mulW (succ a) (succ b)) (succ (dmul a b)) (dmulSucc a b)
  end
end

recipRespOn : (d : Whole) -> (d' : Whole) -> (i : Int) -> (i' : Int)
  -> Eq Int (imul i (nonneg (succ d'))) (imul i' (nonneg (succ d)))
  -> QRel (rawRecipOn i d) (rawRecipOn i' d') is
  fn (d : Whole) (d' : Whole) (i : Int) is
    IntElim (fn (w : Int) is
        (i' : Int) -> Eq Int (imul w (nonneg (succ d'))) (imul i' (nonneg (succ d)))
        -> QRel (rawRecipOn w d) (rawRecipOn i' d') end)
      (fn (n : Whole) is
        WholeElim (fn (m : Whole) is
            (i' : Int) -> Eq Int (imul (nonneg m) (nonneg (succ d'))) (imul i' (nonneg (succ d)))
            -> QRel (rawRecipOn (nonneg m) d) (rawRecipOn i' d') end)
          (fn (i' : Int) is
            IntElim (fn (w' : Int) is
                Eq Int (imul (nonneg zero) (nonneg (succ d'))) (imul w' (nonneg (succ d)))
                -> QRel (qpair (nonneg zero) zero) (rawRecipOn w' d') end)
              (fn (m' : Whole) is
                WholeElim (fn (mm : Whole) is
                    Eq Int (imul (nonneg zero) (nonneg (succ d'))) (imul (nonneg mm) (nonneg (succ d)))
                    -> QRel (qpair (nonneg zero) zero) (rawRecipOn (nonneg mm) d') end)
                  (fn (h2 : Eq Int (imul (nonneg zero) (nonneg (succ d'))) (imul (nonneg zero) (nonneg (succ d)))) is
                     refl (nonneg zero)
                   end)
                  (fn (j : Whole) (ihj : Eq Int (imul (nonneg zero) (nonneg (succ d'))) (imul (nonneg j) (nonneg (succ d))) -> QRel (qpair (nonneg zero) zero) (rawRecipOn (nonneg j) d')) is
                     fn (h2 : Eq Int (imul (nonneg zero) (nonneg (succ d'))) (imul (nonneg (succ j)) (nonneg (succ d)))) is
                       boolDiscTF (QRel (qpair (nonneg zero) zero) (rawRecipOn (nonneg (succ j)) d'))
                         (transEq Bool true (isZero (mulW (succ j) (succ d))) false
                            (congE Int Bool (fn (z : Int) is isZero (imag z) end)
                               (imul (nonneg zero) (nonneg (succ d'))) (imul (nonneg (succ j)) (nonneg (succ d))) h2)
                            (mulSuccPos j d))
                     end
                   end)
                  m'
               end)
              (fn (k' : Whole) is
                fn (h2 : Eq Int (imul (nonneg zero) (nonneg (succ d'))) (imul (negsucc k') (nonneg (succ d)))) is
                  boolDiscTF (QRel (qpair (nonneg zero) zero) (rawRecipOn (negsucc k') d'))
                    (symEq Bool false true
                       (congE Int Bool isign
                          (imul (nonneg zero) (nonneg (succ d'))) (negsucc (dmul k' d))
                          (transEq Int (imul (nonneg zero) (nonneg (succ d'))) (imul (negsucc k') (nonneg (succ d))) (negsucc (dmul k' d))
                             h2 (negMulSS k' d))))
                end
               end)
              i'
           end)
          (fn (k : Whole) (ihk : (i' : Int) -> Eq Int (imul (nonneg k) (nonneg (succ d'))) (imul i' (nonneg (succ d))) -> QRel (rawRecipOn (nonneg k) d) (rawRecipOn i' d')) is
            fn (i' : Int) is
              IntElim (fn (w' : Int) is
                  Eq Int (imul (nonneg (succ k)) (nonneg (succ d'))) (imul w' (nonneg (succ d)))
                  -> QRel (qpair (nonneg (succ d)) k) (rawRecipOn w' d') end)
                (fn (m' : Whole) is
                  WholeElim (fn (mm : Whole) is
                      Eq Int (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (nonneg mm) (nonneg (succ d)))
                      -> QRel (qpair (nonneg (succ d)) k) (rawRecipOn (nonneg mm) d') end)
                    (fn (h2 : Eq Int (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (nonneg zero) (nonneg (succ d)))) is
                       boolDiscTF (QRel (qpair (nonneg (succ d)) k) (rawRecipOn (nonneg zero) d'))
                         (transEq Bool true (isZero (mulW (succ k) (succ d'))) false
                            (symEq Bool (isZero (mulW (succ k) (succ d'))) true
                               (congE Int Bool (fn (z : Int) is isZero (imag z) end)
                                  (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (nonneg zero) (nonneg (succ d))) h2))
                            (mulSuccPos k d'))
                     end)
                    (fn (j : Whole) (ihj : Eq Int (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (nonneg j) (nonneg (succ d))) -> QRel (qpair (nonneg (succ d)) k) (rawRecipOn (nonneg j) d')) is
                       fn (h2 : Eq Int (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (nonneg (succ j)) (nonneg (succ d)))) is
                         transEq Int (imul (nonneg (succ d)) (nonneg (succ j))) (imul (nonneg (succ j)) (nonneg (succ d))) (imul (nonneg (succ d')) (nonneg (succ k)))
                           (imulComm (nonneg (succ d)) (nonneg (succ j)))
                           (transEq Int (imul (nonneg (succ j)) (nonneg (succ d))) (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (nonneg (succ d')) (nonneg (succ k)))
                              (symEq Int (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (nonneg (succ j)) (nonneg (succ d))) h2)
                              (imulComm (nonneg (succ k)) (nonneg (succ d'))))
                       end
                     end)
                    m'
                 end)
                (fn (k' : Whole) is
                  fn (h2 : Eq Int (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (negsucc k') (nonneg (succ d)))) is
                    boolDiscTF (QRel (qpair (nonneg (succ d)) k) (rawRecipOn (negsucc k') d'))
                      (symEq Bool false true
                         (congE Int Bool isign
                            (imul (nonneg (succ k)) (nonneg (succ d'))) (negsucc (dmul k' d))
                            (transEq Int (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (negsucc k') (nonneg (succ d))) (negsucc (dmul k' d))
                               h2 (negMulSS k' d))))
                  end
                 end)
                i'
            end
           end)
          n
       end)
      (fn (k : Whole) is
        fn (i' : Int) is
          IntElim (fn (w' : Int) is
              Eq Int (imul (negsucc k) (nonneg (succ d'))) (imul w' (nonneg (succ d)))
              -> QRel (qpair (negsucc d) k) (rawRecipOn w' d') end)
            (fn (m' : Whole) is
              WholeElim (fn (mm : Whole) is
                  Eq Int (imul (negsucc k) (nonneg (succ d'))) (imul (nonneg mm) (nonneg (succ d)))
                  -> QRel (qpair (negsucc d) k) (rawRecipOn (nonneg mm) d') end)
                (fn (h2 : Eq Int (imul (negsucc k) (nonneg (succ d'))) (imul (nonneg zero) (nonneg (succ d)))) is
                   boolDiscTF (QRel (qpair (negsucc d) k) (rawRecipOn (nonneg zero) d'))
                     (congE Int Bool isign (negsucc (dmul k d')) (imul (nonneg zero) (nonneg (succ d)))
                        (transEq Int (negsucc (dmul k d')) (imul (negsucc k) (nonneg (succ d'))) (imul (nonneg zero) (nonneg (succ d)))
                           (symEq Int (imul (negsucc k) (nonneg (succ d'))) (negsucc (dmul k d')) (negMulSS k d'))
                           h2))
                 end)
                (fn (j : Whole) (ihj : Eq Int (imul (negsucc k) (nonneg (succ d'))) (imul (nonneg j) (nonneg (succ d))) -> QRel (qpair (negsucc d) k) (rawRecipOn (nonneg j) d')) is
                   fn (h2 : Eq Int (imul (negsucc k) (nonneg (succ d'))) (imul (nonneg (succ j)) (nonneg (succ d)))) is
                     boolDiscTF (QRel (qpair (negsucc d) k) (rawRecipOn (nonneg (succ j)) d'))
                       (congE Int Bool isign (negsucc (dmul k d')) (imul (nonneg (succ j)) (nonneg (succ d)))
                          (transEq Int (negsucc (dmul k d')) (imul (negsucc k) (nonneg (succ d'))) (imul (nonneg (succ j)) (nonneg (succ d)))
                             (symEq Int (imul (negsucc k) (nonneg (succ d'))) (negsucc (dmul k d')) (negMulSS k d'))
                             h2))
                   end
                 end)
                m'
             end)
            (fn (k' : Whole) is
              fn (h2 : Eq Int (imul (negsucc k) (nonneg (succ d'))) (imul (negsucc k') (nonneg (succ d)))) is
                let hA : Eq Int (negsucc (dmul k d')) (negsucc (dmul k' d)) =
                  transEq Int (negsucc (dmul k d')) (imul (negsucc k) (nonneg (succ d'))) (negsucc (dmul k' d))
                    (symEq Int (imul (negsucc k) (nonneg (succ d'))) (negsucc (dmul k d')) (negMulSS k d'))
                    (transEq Int (imul (negsucc k) (nonneg (succ d'))) (imul (negsucc k') (nonneg (succ d))) (negsucc (dmul k' d))
                       h2 (negMulSS k' d)) in
                let hW : Eq Whole (succ (dmul k d')) (succ (dmul k' d)) =
                  congE Int Whole imag (negsucc (dmul k d')) (negsucc (dmul k' d)) hA in
                let hM : Eq Whole (mulW (succ k) (succ d')) (mulW (succ k') (succ d)) =
                  transEq Whole (mulW (succ k) (succ d')) (succ (dmul k d')) (mulW (succ k') (succ d))
                    (dmulSucc k d')
                    (transEq Whole (succ (dmul k d')) (succ (dmul k' d)) (mulW (succ k') (succ d))
                       hW
                       (symEq Whole (mulW (succ k') (succ d)) (succ (dmul k' d)) (dmulSucc k' d))) in
                let hswap : Eq Whole (mulW (succ d) (succ k')) (mulW (succ d') (succ k)) =
                  transEq Whole (mulW (succ d) (succ k')) (mulW (succ k') (succ d)) (mulW (succ d') (succ k))
                    (mulWComm (succ d) (succ k'))
                    (transEq Whole (mulW (succ k') (succ d)) (mulW (succ k) (succ d')) (mulW (succ d') (succ k))
                       (symEq Whole (mulW (succ k) (succ d')) (mulW (succ k') (succ d)) hM)
                       (mulWComm (succ k) (succ d'))) in
                congE Whole Int (fn (w : Whole) is ineg (nonneg w) end)
                  (mulW (succ d) (succ k')) (mulW (succ d') (succ k)) hswap
              end
             end)
            i'
        end
       end)
      i
  end
end

recipResp : (p : QPair) -> (p' : QPair) -> QRel p p' -> QRel (rawRecip p) (rawRecip p') is
  fn (p : QPair) (p' : QPair) (h : QRel p p') is
    recipRespOn (qdpred p) (qdpred p') (qnum p) (qnum p') h
  end
end

recipF : Frac -> Frac is
  qlift QPair QRel Frac
    (fn (p : QPair) is qin QPair QRel (rawRecip p) end)
    (fn (p : QPair) (p' : QPair) (r : QRel p p') is
      qsound QPair QRel (rawRecip p) (rawRecip p') (recipResp p p' r)
    end)
end

divRingFrac : DivRing Frac is
  mkDivRing Frac
    (mkRing Frac (mkSemiring Frac addF (fracOf zero) mulF (fracOf (succ zero))) fnegate)
    recipF
end

instance semiringFrac : Semiring Frac is divRingFrac.1.1 end

qnumZeroTransfer : (p : QPair) -> (q : QPair) -> QRel p q
  -> Eq Int (qnum p) (nonneg zero) -> Eq Int (qnum q) (nonneg zero) is
  fn (p : QPair) (q : QPair) (r : QRel p q) (hz : Eq Int (qnum p) (nonneg zero)) is
    imulPosZero (qnum q) (qdpred p)
      (subst Int (qnum p) (nonneg zero) hz
         (fn (z : Int) is Eq Int (imul (qnum q) (qden p)) (imul z (qden q)) end)
         (symEq Int (imul (qnum p) (qden q)) (imul (qnum q) (qden p)) r))
  end
end

isZeroResp : (p : QPair) -> (q : QPair) -> QRel p q
  -> Eq Bool (isZeroInt (qnum p)) (isZeroInt (qnum q)) is
  fn (p : QPair) (q : QPair) (r : QRel p q) is
    boolCaseEq (isZeroInt (qnum p))
      (fn (b : Bool) is Eq Bool b (isZeroInt (qnum q)) end)
      (fn (hp : Eq Bool (isZeroInt (qnum p)) true) is
         subst Int (nonneg zero) (qnum q)
           (symEq Int (qnum q) (nonneg zero)
              (qnumZeroTransfer p q r (isZeroIntSound (qnum p) hp)))
           (fn (z : Int) is Eq Bool true (isZeroInt z) end)
           (refl true)
       end)
      (fn (hp : Eq Bool (isZeroInt (qnum p)) false) is
         boolCaseEq (isZeroInt (qnum q))
           (fn (b : Bool) is Eq Bool false b end)
           (fn (hq : Eq Bool (isZeroInt (qnum q)) true) is
              boolDiscTF (Eq Bool false true)
                (transEq Bool true (isZeroInt (qnum p)) false
                   (symEq Bool (isZeroInt (qnum p)) true
                      (subst Int (nonneg zero) (qnum p)
                         (symEq Int (qnum p) (nonneg zero)
                            (qnumZeroTransfer q p
                               (symEq Int (imul (qnum p) (qden q)) (imul (qnum q) (qden p)) r)
                               (isZeroIntSound (qnum q) hq)))
                         (fn (z : Int) is Eq Bool (isZeroInt z) true end)
                         (refl true)))
                   hp)
            end)
           (fn (hq : Eq Bool (isZeroInt (qnum q)) false) is
              refl false
            end)
       end)
  end
end

isZeroF : Frac -> Bool is
  qlift QPair QRel Bool (fn (p : QPair) is isZeroInt (qnum p) end) isZeroResp
end

nzFrac : Frac -> U is fn (x : Frac) is Eq Bool (isZeroF x) false end end

addCommP : (p : QPair) -> (q : QPair) -> QRel (rawAdd p q) (rawAdd q p) is
  fn (p : QPair) (q : QPair) is
    let np : Int = qnum p in
    let nq : Int = qnum q in
    let dp : Int = qden p in
    let dq : Int = qden q in
    let n1 : Int = iadd (imul np dq) (imul nq dp) in
    let n2 : Int = iadd (imul nq dp) (imul np dq) in
    transEq Int
      (imul n1 (qden (rawAdd q p)))
      (imul n1 (imul dq dp))
      (imul n2 (qden (rawAdd p q)))
      (congImulR n1 (qden (rawAdd q p)) (imul dq dp) (qdenMul q p))
      (transEq Int
         (imul n1 (imul dq dp))
         (imul n2 (imul dq dp))
         (imul n2 (qden (rawAdd p q)))
         (congImulL n1 n2 (imul dq dp) (iaddComm (imul np dq) (imul nq dp)))
         (transEq Int
            (imul n2 (imul dq dp))
            (imul n2 (imul dp dq))
            (imul n2 (qden (rawAdd p q)))
            (congImulR n2 (imul dq dp) (imul dp dq) (imulComm dq dp))
            (congImulR n2 (imul dp dq) (qden (rawAdd p q))
               (symEq Int (qden (rawAdd p q)) (imul dp dq) (qdenMul p q)))))
  end
end

addZeroLP : (p : QPair) -> QRel (rawAdd (qpair (nonneg zero) zero) p) p is
  fn (p : QPair) is
    let z0 : QPair = qpair (nonneg zero) zero in
    let np : Int = qnum p in
    let dp : Int = qden p in
    let n0 : Int = iadd (imul (nonneg zero) dp) (imul np (nonneg (succ zero))) in
    let hn : Eq Int n0 np =
      transEq Int n0 (iadd (nonneg zero) np) np
        (congIadd2 (imul (nonneg zero) dp) (nonneg zero) (imul np (nonneg (succ zero))) np
           (imulZeroL dp) (imulOneR np))
        (iaddZeroL np) in
    let hd : Eq Int (qden (rawAdd z0 p)) dp =
      transEq Int (qden (rawAdd z0 p)) (imul (nonneg (succ zero)) dp) dp
        (qdenMul z0 p)
        (imulOneL dp) in
    transEq Int
      (imul n0 dp)
      (imul np dp)
      (imul np (qden (rawAdd z0 p)))
      (congImulL n0 np dp hn)
      (congImulR np dp (qden (rawAdd z0 p)) (symEq Int (qden (rawAdd z0 p)) dp hd))
  end
end

addZeroRP : (p : QPair) -> QRel (rawAdd p (qpair (nonneg zero) zero)) p is
  fn (p : QPair) is
    let z0 : QPair = qpair (nonneg zero) zero in
    let np : Int = qnum p in
    let dp : Int = qden p in
    let n0 : Int = iadd (imul np (nonneg (succ zero))) (imul (nonneg zero) dp) in
    let hn : Eq Int n0 np =
      transEq Int n0 (iadd np (nonneg zero)) np
        (congIadd2 (imul np (nonneg (succ zero))) np (imul (nonneg zero) dp) (nonneg zero)
           (imulOneR np) (imulZeroL dp))
        (iaddZeroR np) in
    let hd : Eq Int (qden (rawAdd p z0)) dp =
      transEq Int (qden (rawAdd p z0)) (imul dp (nonneg (succ zero))) dp
        (qdenMul p z0)
        (imulOneR dp) in
    transEq Int
      (imul n0 dp)
      (imul np dp)
      (imul np (qden (rawAdd p z0)))
      (congImulL n0 np dp hn)
      (congImulR np dp (qden (rawAdd p z0)) (symEq Int (qden (rawAdd p z0)) dp hd))
  end
end

addAssocNum : (a : Int) -> (b : Int) -> (c : Int) -> (x : Int) -> (y : Int) -> (z : Int)
  -> Eq Int
       (iadd (imul (iadd (imul a y) (imul b x)) z) (imul c (imul x y)))
       (iadd (imul a (imul y z)) (imul (iadd (imul b z) (imul c y)) x)) is
  fn (a : Int) (b : Int) (c : Int) (x : Int) (y : Int) (z : Int) is
    let t1 : Int = imul (imul a y) z in
    let t2 : Int = imul (imul b x) z in
    let t3 : Int = imul c (imul x y) in
    let s2 : Eq Int t2 (imul (imul b z) x) =
      transEq Int t2 (imul b (imul x z)) (imul (imul b z) x)
        (imulAssoc b x z)
        (transEq Int (imul b (imul x z)) (imul b (imul z x)) (imul (imul b z) x)
           (congImulR b (imul x z) (imul z x) (imulComm x z))
           (symEq Int (imul (imul b z) x) (imul b (imul z x)) (imulAssoc b z x))) in
    let s3 : Eq Int t3 (imul (imul c y) x) =
      transEq Int t3 (imul c (imul y x)) (imul (imul c y) x)
        (congImulR c (imul x y) (imul y x) (imulComm x y))
        (symEq Int (imul (imul c y) x) (imul c (imul y x)) (imulAssoc c y x)) in
    transEq Int
      (iadd (imul (iadd (imul a y) (imul b x)) z) t3)
      (iadd (iadd t1 t2) t3)
      (iadd (imul a (imul y z)) (imul (iadd (imul b z) (imul c y)) x))
      (congIaddL (imul (iadd (imul a y) (imul b x)) z) (iadd t1 t2) t3
         (idistribR (imul a y) (imul b x) z))
      (transEq Int
         (iadd (iadd t1 t2) t3)
         (iadd t1 (iadd t2 t3))
         (iadd (imul a (imul y z)) (imul (iadd (imul b z) (imul c y)) x))
         (iaddAssoc t1 t2 t3)
         (transEq Int
            (iadd t1 (iadd t2 t3))
            (iadd (imul a (imul y z)) (iadd (imul (imul b z) x) (imul (imul c y) x)))
            (iadd (imul a (imul y z)) (imul (iadd (imul b z) (imul c y)) x))
            (congIadd2 t1 (imul a (imul y z)) (iadd t2 t3) (iadd (imul (imul b z) x) (imul (imul c y) x))
               (imulAssoc a y z)
               (congIadd2 t2 (imul (imul b z) x) t3 (imul (imul c y) x) s2 s3))
            (congIaddR (imul a (imul y z)) (iadd (imul (imul b z) x) (imul (imul c y) x))
               (imul (iadd (imul b z) (imul c y)) x)
               (symEq Int (imul (iadd (imul b z) (imul c y)) x) (iadd (imul (imul b z) x) (imul (imul c y) x))
                  (idistribR (imul b z) (imul c y) x)))))
  end
end

addAssocP : (p : QPair) -> (q : QPair) -> (r : QPair)
  -> QRel (rawAdd (rawAdd p q) r) (rawAdd p (rawAdd q r)) is
  fn (p : QPair) (q : QPair) (r : QPair) is
    let np : Int = qnum p in
    let nq : Int = qnum q in
    let nr : Int = qnum r in
    let dp : Int = qden p in
    let dq : Int = qden q in
    let dr : Int = qden r in
    let dpq : Int = qden (rawAdd p q) in
    let dqr : Int = qden (rawAdd q r) in
    let nL : Int = iadd (imul (iadd (imul np dq) (imul nq dp)) dr) (imul nr dpq) in
    let nR : Int = iadd (imul np dqr) (imul (iadd (imul nq dr) (imul nr dq)) dp) in
    let nLf : Int = iadd (imul (iadd (imul np dq) (imul nq dp)) dr) (imul nr (imul dp dq)) in
    let nRf : Int = iadd (imul np (imul dq dr)) (imul (iadd (imul nq dr) (imul nr dq)) dp) in
    transEq Int
      (imul nL (qden (rawAdd p (rawAdd q r))))
      (imul nL (imul dp dqr))
      (imul nR (qden (rawAdd (rawAdd p q) r)))
      (congImulR nL (qden (rawAdd p (rawAdd q r))) (imul dp dqr) (qdenMul p (rawAdd q r)))
      (transEq Int
         (imul nL (imul dp dqr))
         (imul nL (imul dp (imul dq dr)))
         (imul nR (qden (rawAdd (rawAdd p q) r)))
         (congImulR nL (imul dp dqr) (imul dp (imul dq dr))
            (congImulR dp dqr (imul dq dr) (qdenMul q r)))
         (transEq Int
            (imul nL (imul dp (imul dq dr)))
            (imul nLf (imul dp (imul dq dr)))
            (imul nR (qden (rawAdd (rawAdd p q) r)))
            (congImulL nL nLf (imul dp (imul dq dr))
               (congIaddR (imul (iadd (imul np dq) (imul nq dp)) dr) (imul nr dpq) (imul nr (imul dp dq))
                  (congImulR nr dpq (imul dp dq) (qdenMul p q))))
            (transEq Int
               (imul nLf (imul dp (imul dq dr)))
               (imul nRf (imul dp (imul dq dr)))
               (imul nR (qden (rawAdd (rawAdd p q) r)))
               (congImulL nLf nRf (imul dp (imul dq dr))
                  (addAssocNum np nq nr dp dq dr))
               (transEq Int
                  (imul nRf (imul dp (imul dq dr)))
                  (imul nRf (imul (imul dp dq) dr))
                  (imul nR (qden (rawAdd (rawAdd p q) r)))
                  (congImulR nRf (imul dp (imul dq dr)) (imul (imul dp dq) dr)
                     (symEq Int (imul (imul dp dq) dr) (imul dp (imul dq dr)) (imulAssoc dp dq dr)))
                  (transEq Int
                     (imul nRf (imul (imul dp dq) dr))
                     (imul nR (imul (imul dp dq) dr))
                     (imul nR (qden (rawAdd (rawAdd p q) r)))
                     (congImulL nRf nR (imul (imul dp dq) dr)
                        (congIaddL (imul np (imul dq dr)) (imul np dqr) (imul (iadd (imul nq dr) (imul nr dq)) dp)
                           (congImulR np (imul dq dr) dqr
                              (symEq Int dqr (imul dq dr) (qdenMul q r)))))
                     (congImulR nR (imul (imul dp dq) dr) (qden (rawAdd (rawAdd p q) r))
                        (symEq Int (qden (rawAdd (rawAdd p q) r)) (imul (imul dp dq) dr)
                           (transEq Int (qden (rawAdd (rawAdd p q) r)) (imul dpq dr) (imul (imul dp dq) dr)
                              (qdenMul (rawAdd p q) r)
                              (congImulL dpq (imul dp dq) dr (qdenMul p q))))))))))
  end
end

addFAssoc : (x : Frac) -> (y : Frac) -> (z : Frac)
  -> Eq Frac (addF (addF x y) z) (addF x (addF y z)) is
  fn (x : Frac) is
    qind QPair QRel
      (fn (wx : Frac) is (y : Frac) -> (z : Frac) -> Eq Frac (addF (addF wx y) z) (addF wx (addF y z)) end)
      (fn (p : QPair) is
        fn (y : Frac) is
          qind QPair QRel
            (fn (wy : Frac) is (z : Frac) -> Eq Frac (addF (addF (qin QPair QRel p) wy) z) (addF (qin QPair QRel p) (addF wy z)) end)
            (fn (q : QPair) is
              fn (z : Frac) is
                qind QPair QRel
                  (fn (wz : Frac) is Eq Frac (addF (addF (qin QPair QRel p) (qin QPair QRel q)) wz) (addF (qin QPair QRel p) (addF (qin QPair QRel q) wz)) end)
                  (fn (r : QPair) is
                    qsound QPair QRel
                      (rawAdd (rawAdd p q) r) (rawAdd p (rawAdd q r))
                      (addAssocP p q r)
                  end)
                  z
              end
            end)
            y
        end
      end)
      x
  end
end

addFComm : (x : Frac) -> (y : Frac) -> Eq Frac (addF x y) (addF y x) is
  fn (x : Frac) is
    qind QPair QRel
      (fn (wx : Frac) is (y : Frac) -> Eq Frac (addF wx y) (addF y wx) end)
      (fn (p : QPair) is
        fn (y : Frac) is
          qind QPair QRel
            (fn (wy : Frac) is Eq Frac (addF (qin QPair QRel p) wy) (addF wy (qin QPair QRel p)) end)
            (fn (q : QPair) is
              qsound QPair QRel (rawAdd p q) (rawAdd q p) (addCommP p q)
            end)
            y
        end
      end)
      x
  end
end

addFZeroL : (x : Frac) -> Eq Frac (addF (fracOf zero) x) x is
  fn (x : Frac) is
    qind QPair QRel
      (fn (w : Frac) is Eq Frac (addF (fracOf zero) w) w end)
      (fn (p : QPair) is
        qsound QPair QRel (rawAdd (qpair (nonneg zero) zero) p) p (addZeroLP p)
      end)
      x
  end
end

addFZeroR : (x : Frac) -> Eq Frac (addF x (fracOf zero)) x is
  fn (x : Frac) is
    qind QPair QRel
      (fn (w : Frac) is Eq Frac (addF w (fracOf zero)) w end)
      (fn (p : QPair) is
        qsound QPair QRel (rawAdd p (qpair (nonneg zero) zero)) p (addZeroRP p)
      end)
      x
  end
end

mulCommP : (p : QPair) -> (q : QPair) -> QRel (rawMul p q) (rawMul q p) is
  fn (p : QPair) (q : QPair) is
    let np : Int = qnum p in
    let nq : Int = qnum q in
    let dp : Int = qden p in
    let dq : Int = qden q in
    let n1 : Int = imul np nq in
    let n2 : Int = imul nq np in
    transEq Int
      (imul n1 (qden (rawMul q p)))
      (imul n1 (imul dq dp))
      (imul n2 (qden (rawMul p q)))
      (congImulR n1 (qden (rawMul q p)) (imul dq dp) (qdenMul q p))
      (transEq Int
         (imul n1 (imul dq dp))
         (imul n2 (imul dq dp))
         (imul n2 (qden (rawMul p q)))
         (congImulL n1 n2 (imul dq dp) (imulComm np nq))
         (transEq Int
            (imul n2 (imul dq dp))
            (imul n2 (imul dp dq))
            (imul n2 (qden (rawMul p q)))
            (congImulR n2 (imul dq dp) (imul dp dq) (imulComm dq dp))
            (congImulR n2 (imul dp dq) (qden (rawMul p q))
               (symEq Int (qden (rawMul p q)) (imul dp dq) (qdenMul p q)))))
  end
end

mulOneLP : (p : QPair) -> QRel (rawMul (qpair (nonneg (succ zero)) zero) p) p is
  fn (p : QPair) is
    let one : QPair = qpair (nonneg (succ zero)) zero in
    let np : Int = qnum p in
    let dp : Int = qden p in
    let n1 : Int = imul (nonneg (succ zero)) np in
    let hd : Eq Int (qden (rawMul one p)) dp =
      transEq Int (qden (rawMul one p)) (imul (nonneg (succ zero)) dp) dp
        (qdenMul one p)
        (imulOneL dp) in
    transEq Int
      (imul n1 dp)
      (imul np dp)
      (imul np (qden (rawMul one p)))
      (congImulL n1 np dp (imulOneL np))
      (congImulR np dp (qden (rawMul one p)) (symEq Int (qden (rawMul one p)) dp hd))
  end
end

mulOneRP : (p : QPair) -> QRel (rawMul p (qpair (nonneg (succ zero)) zero)) p is
  fn (p : QPair) is
    let one : QPair = qpair (nonneg (succ zero)) zero in
    let np : Int = qnum p in
    let dp : Int = qden p in
    let n1 : Int = imul np (nonneg (succ zero)) in
    let hd : Eq Int (qden (rawMul p one)) dp =
      transEq Int (qden (rawMul p one)) (imul dp (nonneg (succ zero))) dp
        (qdenMul p one)
        (imulOneR dp) in
    transEq Int
      (imul n1 dp)
      (imul np dp)
      (imul np (qden (rawMul p one)))
      (congImulL n1 np dp (imulOneR np))
      (congImulR np dp (qden (rawMul p one)) (symEq Int (qden (rawMul p one)) dp hd))
  end
end

mulZeroLP : (p : QPair) -> QRel (rawMul (qpair (nonneg zero) zero) p) (qpair (nonneg zero) zero) is
  fn (p : QPair) is
    let z0 : QPair = qpair (nonneg zero) zero in
    let np : Int = qnum p in
    transEq Int
      (imul (imul (nonneg zero) np) (nonneg (succ zero)))
      (imul (nonneg zero) (nonneg (succ zero)))
      (imul (nonneg zero) (qden (rawMul z0 p)))
      (congImulL (imul (nonneg zero) np) (nonneg zero) (nonneg (succ zero)) (imulZeroL np))
      (transEq Int
         (imul (nonneg zero) (nonneg (succ zero)))
         (nonneg zero)
         (imul (nonneg zero) (qden (rawMul z0 p)))
         (imulZeroL (nonneg (succ zero)))
         (symEq Int (imul (nonneg zero) (qden (rawMul z0 p))) (nonneg zero)
            (imulZeroL (qden (rawMul z0 p)))))
  end
end

mulZeroRP : (p : QPair) -> QRel (rawMul p (qpair (nonneg zero) zero)) (qpair (nonneg zero) zero) is
  fn (p : QPair) is
    let z0 : QPair = qpair (nonneg zero) zero in
    let np : Int = qnum p in
    transEq Int
      (imul (imul np (nonneg zero)) (nonneg (succ zero)))
      (imul (nonneg zero) (nonneg (succ zero)))
      (imul (nonneg zero) (qden (rawMul p z0)))
      (congImulL (imul np (nonneg zero)) (nonneg zero) (nonneg (succ zero)) (imulZeroR np))
      (transEq Int
         (imul (nonneg zero) (nonneg (succ zero)))
         (nonneg zero)
         (imul (nonneg zero) (qden (rawMul p z0)))
         (imulZeroL (nonneg (succ zero)))
         (symEq Int (imul (nonneg zero) (qden (rawMul p z0))) (nonneg zero)
            (imulZeroL (qden (rawMul p z0)))))
  end
end

mulAssocP : (p : QPair) -> (q : QPair) -> (r : QPair)
  -> QRel (rawMul (rawMul p q) r) (rawMul p (rawMul q r)) is
  fn (p : QPair) (q : QPair) (r : QPair) is
    let np : Int = qnum p in
    let nq : Int = qnum q in
    let nr : Int = qnum r in
    let dp : Int = qden p in
    let dq : Int = qden q in
    let dr : Int = qden r in
    let dpq : Int = qden (rawMul p q) in
    let dqr : Int = qden (rawMul q r) in
    let nL : Int = imul (imul np nq) nr in
    let nR : Int = imul np (imul nq nr) in
    transEq Int
      (imul nL (qden (rawMul p (rawMul q r))))
      (imul nL (imul dp dqr))
      (imul nR (qden (rawMul (rawMul p q) r)))
      (congImulR nL (qden (rawMul p (rawMul q r))) (imul dp dqr) (qdenMul p (rawMul q r)))
      (transEq Int
         (imul nL (imul dp dqr))
         (imul nL (imul dp (imul dq dr)))
         (imul nR (qden (rawMul (rawMul p q) r)))
         (congImulR nL (imul dp dqr) (imul dp (imul dq dr))
            (congImulR dp dqr (imul dq dr) (qdenMul q r)))
         (transEq Int
            (imul nL (imul dp (imul dq dr)))
            (imul nR (imul dp (imul dq dr)))
            (imul nR (qden (rawMul (rawMul p q) r)))
            (congImulL nL nR (imul dp (imul dq dr)) (imulAssoc np nq nr))
            (transEq Int
               (imul nR (imul dp (imul dq dr)))
               (imul nR (imul (imul dp dq) dr))
               (imul nR (qden (rawMul (rawMul p q) r)))
               (congImulR nR (imul dp (imul dq dr)) (imul (imul dp dq) dr)
                  (symEq Int (imul (imul dp dq) dr) (imul dp (imul dq dr)) (imulAssoc dp dq dr)))
               (congImulR nR (imul (imul dp dq) dr) (qden (rawMul (rawMul p q) r))
                  (symEq Int (qden (rawMul (rawMul p q) r)) (imul (imul dp dq) dr)
                     (transEq Int (qden (rawMul (rawMul p q) r)) (imul dpq dr) (imul (imul dp dq) dr)
                        (qdenMul (rawMul p q) r)
                        (congImulL dpq (imul dp dq) dr (qdenMul p q))))))))
  end
end

distribRNum : (a : Int) -> (b : Int) -> (c : Int) -> (x : Int) -> (y : Int) -> (z : Int)
  -> Eq Int
       (imul (imul (iadd (imul a y) (imul b x)) c) (imul (imul x z) (imul y z)))
       (imul (iadd (imul (imul a c) (imul y z)) (imul (imul b c) (imul x z))) (imul (imul x y) z)) is
  fn (a : Int) (b : Int) (c : Int) (x : Int) (y : Int) (z : Int) is
    let s : Int = iadd (imul a y) (imul b x) in
    let xy : Int = imul x y in
    let zz : Int = imul z z in
    let cz : Int = imul c z in
    let m : Int = iadd (imul (imul a c) (imul y z)) (imul (imul b c) (imul x z)) in
    let hm : Eq Int (imul s cz) m =
      transEq Int (imul s cz) (iadd (imul (imul a y) cz) (imul (imul b x) cz)) m
        (idistribR (imul a y) (imul b x) cz)
        (congIadd2 (imul (imul a y) cz) (imul (imul a c) (imul y z))
                   (imul (imul b x) cz) (imul (imul b c) (imul x z))
           (symEq Int (imul (imul a c) (imul y z)) (imul (imul a y) cz) (imulInterchange a c y z))
           (symEq Int (imul (imul b c) (imul x z)) (imul (imul b x) cz) (imulInterchange b c x z))) in
    transEq Int
      (imul (imul s c) (imul (imul x z) (imul y z)))
      (imul (imul s c) (imul xy zz))
      (imul m (imul xy z))
      (congImulR (imul s c) (imul (imul x z) (imul y z)) (imul xy zz) (imulInterchange x z y z))
      (transEq Int
         (imul (imul s c) (imul xy zz))
         (imul (imul s xy) (imul c zz))
         (imul m (imul xy z))
         (imulInterchange s c xy zz)
         (transEq Int
            (imul (imul s xy) (imul c zz))
            (imul (imul s xy) (imul cz z))
            (imul m (imul xy z))
            (congImulR (imul s xy) (imul c zz) (imul cz z)
               (symEq Int (imul (imul c z) z) (imul c (imul z z)) (imulAssoc c z z)))
            (transEq Int
               (imul (imul s xy) (imul cz z))
               (imul (imul s cz) (imul xy z))
               (imul m (imul xy z))
               (symEq Int (imul (imul s cz) (imul xy z)) (imul (imul s xy) (imul cz z))
                  (imulInterchange s cz xy z))
               (congImulL (imul s cz) m (imul xy z) hm))))
  end
end

distribRP : (p : QPair) -> (q : QPair) -> (r : QPair)
  -> QRel (rawMul (rawAdd p q) r) (rawAdd (rawMul p r) (rawMul q r)) is
  fn (p : QPair) (q : QPair) (r : QPair) is
    let np : Int = qnum p in
    let nq : Int = qnum q in
    let nr : Int = qnum r in
    let dp : Int = qden p in
    let dq : Int = qden q in
    let dr : Int = qden r in
    let dpr : Int = qden (rawMul p r) in
    let dqr : Int = qden (rawMul q r) in
    let nA : Int = imul (iadd (imul np dq) (imul nq dp)) nr in
    let nB : Int = iadd (imul (imul np nr) dqr) (imul (imul nq nr) dpr) in
    let nBf : Int = iadd (imul (imul np nr) (imul dq dr)) (imul (imul nq nr) (imul dp dr)) in
    transEq Int
      (imul nA (qden (rawAdd (rawMul p r) (rawMul q r))))
      (imul nA (imul dpr dqr))
      (imul nB (qden (rawMul (rawAdd p q) r)))
      (congImulR nA (qden (rawAdd (rawMul p r) (rawMul q r))) (imul dpr dqr)
         (qdenMul (rawMul p r) (rawMul q r)))
      (transEq Int
         (imul nA (imul dpr dqr))
         (imul nA (imul (imul dp dr) dqr))
         (imul nB (qden (rawMul (rawAdd p q) r)))
         (congImulR nA (imul dpr dqr) (imul (imul dp dr) dqr)
            (congImulL dpr (imul dp dr) dqr (qdenMul p r)))
         (transEq Int
            (imul nA (imul (imul dp dr) dqr))
            (imul nA (imul (imul dp dr) (imul dq dr)))
            (imul nB (qden (rawMul (rawAdd p q) r)))
            (congImulR nA (imul (imul dp dr) dqr) (imul (imul dp dr) (imul dq dr))
               (congImulR (imul dp dr) dqr (imul dq dr) (qdenMul q r)))
            (transEq Int
               (imul nA (imul (imul dp dr) (imul dq dr)))
               (imul nBf (imul (imul dp dq) dr))
               (imul nB (qden (rawMul (rawAdd p q) r)))
               (distribRNum np nq nr dp dq dr)
               (transEq Int
                  (imul nBf (imul (imul dp dq) dr))
                  (imul nB (imul (imul dp dq) dr))
                  (imul nB (qden (rawMul (rawAdd p q) r)))
                  (congImulL nBf nB (imul (imul dp dq) dr)
                     (congIadd2 (imul (imul np nr) (imul dq dr)) (imul (imul np nr) dqr)
                                (imul (imul nq nr) (imul dp dr)) (imul (imul nq nr) dpr)
                        (congImulR (imul np nr) (imul dq dr) dqr (symEq Int dqr (imul dq dr) (qdenMul q r)))
                        (congImulR (imul nq nr) (imul dp dr) dpr (symEq Int dpr (imul dp dr) (qdenMul p r)))))
                  (congImulR nB (imul (imul dp dq) dr) (qden (rawMul (rawAdd p q) r))
                     (symEq Int (qden (rawMul (rawAdd p q) r)) (imul (imul dp dq) dr)
                        (transEq Int (qden (rawMul (rawAdd p q) r)) (imul (qden (rawAdd p q)) dr) (imul (imul dp dq) dr)
                           (qdenMul (rawAdd p q) r)
                           (congImulL (qden (rawAdd p q)) (imul dp dq) dr (qdenMul p q)))))))))
  end
end

distribLNum : (a : Int) -> (b : Int) -> (c : Int) -> (x : Int) -> (y : Int) -> (z : Int)
  -> Eq Int
       (imul (imul a (iadd (imul b z) (imul c y))) (imul (imul x y) (imul x z)))
       (imul (iadd (imul (imul a b) (imul x z)) (imul (imul a c) (imul x y))) (imul x (imul y z))) is
  fn (a : Int) (b : Int) (c : Int) (x : Int) (y : Int) (z : Int) is
    let t : Int = iadd (imul b z) (imul c y) in
    let ax : Int = imul a x in
    let xx : Int = imul x x in
    let yz : Int = imul y z in
    let m : Int = iadd (imul (imul a b) (imul x z)) (imul (imul a c) (imul x y)) in
    let hm : Eq Int (imul ax t) m =
      transEq Int (imul ax t) (iadd (imul ax (imul b z)) (imul ax (imul c y))) m
        (idistribL ax (imul b z) (imul c y))
        (congIadd2 (imul ax (imul b z)) (imul (imul a b) (imul x z))
                   (imul ax (imul c y)) (imul (imul a c) (imul x y))
           (symEq Int (imul (imul a b) (imul x z)) (imul ax (imul b z)) (imulInterchange a b x z))
           (symEq Int (imul (imul a c) (imul x y)) (imul ax (imul c y)) (imulInterchange a c x y))) in
    transEq Int
      (imul (imul a t) (imul (imul x y) (imul x z)))
      (imul (imul a t) (imul xx yz))
      (imul m (imul x yz))
      (congImulR (imul a t) (imul (imul x y) (imul x z)) (imul xx yz) (imulInterchange x y x z))
      (transEq Int
         (imul (imul a t) (imul xx yz))
         (imul (imul a xx) (imul t yz))
         (imul m (imul x yz))
         (imulInterchange a t xx yz)
         (transEq Int
            (imul (imul a xx) (imul t yz))
            (imul (imul ax x) (imul t yz))
            (imul m (imul x yz))
            (congImulL (imul a xx) (imul ax x) (imul t yz)
               (symEq Int (imul (imul a x) x) (imul a (imul x x)) (imulAssoc a x x)))
            (transEq Int
               (imul (imul ax x) (imul t yz))
               (imul (imul ax t) (imul x yz))
               (imul m (imul x yz))
               (symEq Int (imul (imul ax t) (imul x yz)) (imul (imul ax x) (imul t yz))
                  (imulInterchange ax t x yz))
               (congImulL (imul ax t) m (imul x yz) hm))))
  end
end

distribLP : (p : QPair) -> (q : QPair) -> (r : QPair)
  -> QRel (rawMul p (rawAdd q r)) (rawAdd (rawMul p q) (rawMul p r)) is
  fn (p : QPair) (q : QPair) (r : QPair) is
    let np : Int = qnum p in
    let nq : Int = qnum q in
    let nr : Int = qnum r in
    let dp : Int = qden p in
    let dq : Int = qden q in
    let dr : Int = qden r in
    let dpq : Int = qden (rawMul p q) in
    let dpr : Int = qden (rawMul p r) in
    let nA : Int = imul np (iadd (imul nq dr) (imul nr dq)) in
    let nB : Int = iadd (imul (imul np nq) dpr) (imul (imul np nr) dpq) in
    let nBf : Int = iadd (imul (imul np nq) (imul dp dr)) (imul (imul np nr) (imul dp dq)) in
    transEq Int
      (imul nA (qden (rawAdd (rawMul p q) (rawMul p r))))
      (imul nA (imul dpq dpr))
      (imul nB (qden (rawMul p (rawAdd q r))))
      (congImulR nA (qden (rawAdd (rawMul p q) (rawMul p r))) (imul dpq dpr)
         (qdenMul (rawMul p q) (rawMul p r)))
      (transEq Int
         (imul nA (imul dpq dpr))
         (imul nA (imul (imul dp dq) dpr))
         (imul nB (qden (rawMul p (rawAdd q r))))
         (congImulR nA (imul dpq dpr) (imul (imul dp dq) dpr)
            (congImulL dpq (imul dp dq) dpr (qdenMul p q)))
         (transEq Int
            (imul nA (imul (imul dp dq) dpr))
            (imul nA (imul (imul dp dq) (imul dp dr)))
            (imul nB (qden (rawMul p (rawAdd q r))))
            (congImulR nA (imul (imul dp dq) dpr) (imul (imul dp dq) (imul dp dr))
               (congImulR (imul dp dq) dpr (imul dp dr) (qdenMul p r)))
            (transEq Int
               (imul nA (imul (imul dp dq) (imul dp dr)))
               (imul nBf (imul dp (imul dq dr)))
               (imul nB (qden (rawMul p (rawAdd q r))))
               (distribLNum np nq nr dp dq dr)
               (transEq Int
                  (imul nBf (imul dp (imul dq dr)))
                  (imul nB (imul dp (imul dq dr)))
                  (imul nB (qden (rawMul p (rawAdd q r))))
                  (congImulL nBf nB (imul dp (imul dq dr))
                     (congIadd2 (imul (imul np nq) (imul dp dr)) (imul (imul np nq) dpr)
                                (imul (imul np nr) (imul dp dq)) (imul (imul np nr) dpq)
                        (congImulR (imul np nq) (imul dp dr) dpr (symEq Int dpr (imul dp dr) (qdenMul p r)))
                        (congImulR (imul np nr) (imul dp dq) dpq (symEq Int dpq (imul dp dq) (qdenMul p q)))))
                  (congImulR nB (imul dp (imul dq dr)) (qden (rawMul p (rawAdd q r)))
                     (symEq Int (qden (rawMul p (rawAdd q r))) (imul dp (imul dq dr))
                        (transEq Int (qden (rawMul p (rawAdd q r))) (imul dp (qden (rawAdd q r))) (imul dp (imul dq dr))
                           (qdenMul p (rawAdd q r))
                           (congImulR dp (qden (rawAdd q r)) (imul dq dr) (qdenMul q r)))))))))
  end
end

mulFAssoc : (x : Frac) -> (y : Frac) -> (z : Frac)
  -> Eq Frac (mulF (mulF x y) z) (mulF x (mulF y z)) is
  fn (x : Frac) is
    qind QPair QRel
      (fn (wx : Frac) is (y : Frac) -> (z : Frac) -> Eq Frac (mulF (mulF wx y) z) (mulF wx (mulF y z)) end)
      (fn (p : QPair) is
        fn (y : Frac) is
          qind QPair QRel
            (fn (wy : Frac) is (z : Frac) -> Eq Frac (mulF (mulF (qin QPair QRel p) wy) z) (mulF (qin QPair QRel p) (mulF wy z)) end)
            (fn (q : QPair) is
              fn (z : Frac) is
                qind QPair QRel
                  (fn (wz : Frac) is Eq Frac (mulF (mulF (qin QPair QRel p) (qin QPair QRel q)) wz) (mulF (qin QPair QRel p) (mulF (qin QPair QRel q) wz)) end)
                  (fn (r : QPair) is
                    qsound QPair QRel
                      (rawMul (rawMul p q) r) (rawMul p (rawMul q r))
                      (mulAssocP p q r)
                  end)
                  z
              end
            end)
            y
        end
      end)
      x
  end
end

mulFComm : (x : Frac) -> (y : Frac) -> Eq Frac (mulF x y) (mulF y x) is
  fn (x : Frac) is
    qind QPair QRel
      (fn (wx : Frac) is (y : Frac) -> Eq Frac (mulF wx y) (mulF y wx) end)
      (fn (p : QPair) is
        fn (y : Frac) is
          qind QPair QRel
            (fn (wy : Frac) is Eq Frac (mulF (qin QPair QRel p) wy) (mulF wy (qin QPair QRel p)) end)
            (fn (q : QPair) is
              qsound QPair QRel (rawMul p q) (rawMul q p) (mulCommP p q)
            end)
            y
        end
      end)
      x
  end
end

mulFOneL : (x : Frac) -> Eq Frac (mulF (fracOf (succ zero)) x) x is
  fn (x : Frac) is
    qind QPair QRel
      (fn (w : Frac) is Eq Frac (mulF (fracOf (succ zero)) w) w end)
      (fn (p : QPair) is
        qsound QPair QRel (rawMul (qpair (nonneg (succ zero)) zero) p) p (mulOneLP p)
      end)
      x
  end
end

mulFOneR : (x : Frac) -> Eq Frac (mulF x (fracOf (succ zero))) x is
  fn (x : Frac) is
    qind QPair QRel
      (fn (w : Frac) is Eq Frac (mulF w (fracOf (succ zero))) w end)
      (fn (p : QPair) is
        qsound QPair QRel (rawMul p (qpair (nonneg (succ zero)) zero)) p (mulOneRP p)
      end)
      x
  end
end

distribFL : (x : Frac) -> (y : Frac) -> (z : Frac)
  -> Eq Frac (mulF x (addF y z)) (addF (mulF x y) (mulF x z)) is
  fn (x : Frac) is
    qind QPair QRel
      (fn (wx : Frac) is (y : Frac) -> (z : Frac) -> Eq Frac (mulF wx (addF y z)) (addF (mulF wx y) (mulF wx z)) end)
      (fn (p : QPair) is
        fn (y : Frac) is
          qind QPair QRel
            (fn (wy : Frac) is (z : Frac) -> Eq Frac (mulF (qin QPair QRel p) (addF wy z)) (addF (mulF (qin QPair QRel p) wy) (mulF (qin QPair QRel p) z)) end)
            (fn (q : QPair) is
              fn (z : Frac) is
                qind QPair QRel
                  (fn (wz : Frac) is Eq Frac (mulF (qin QPair QRel p) (addF (qin QPair QRel q) wz)) (addF (mulF (qin QPair QRel p) (qin QPair QRel q)) (mulF (qin QPair QRel p) wz)) end)
                  (fn (r : QPair) is
                    qsound QPair QRel
                      (rawMul p (rawAdd q r)) (rawAdd (rawMul p q) (rawMul p r))
                      (distribLP p q r)
                  end)
                  z
              end
            end)
            y
        end
      end)
      x
  end
end

distribFR : (x : Frac) -> (y : Frac) -> (z : Frac)
  -> Eq Frac (mulF (addF x y) z) (addF (mulF x z) (mulF y z)) is
  fn (x : Frac) is
    qind QPair QRel
      (fn (wx : Frac) is (y : Frac) -> (z : Frac) -> Eq Frac (mulF (addF wx y) z) (addF (mulF wx z) (mulF y z)) end)
      (fn (p : QPair) is
        fn (y : Frac) is
          qind QPair QRel
            (fn (wy : Frac) is (z : Frac) -> Eq Frac (mulF (addF (qin QPair QRel p) wy) z) (addF (mulF (qin QPair QRel p) z) (mulF wy z)) end)
            (fn (q : QPair) is
              fn (z : Frac) is
                qind QPair QRel
                  (fn (wz : Frac) is Eq Frac (mulF (addF (qin QPair QRel p) (qin QPair QRel q)) wz) (addF (mulF (qin QPair QRel p) wz) (mulF (qin QPair QRel q) wz)) end)
                  (fn (r : QPair) is
                    qsound QPair QRel
                      (rawMul (rawAdd p q) r) (rawAdd (rawMul p r) (rawMul q r))
                      (distribRP p q r)
                  end)
                  z
              end
            end)
            y
        end
      end)
      x
  end
end

mulFZeroL : (x : Frac) -> Eq Frac (mulF (fracOf zero) x) (fracOf zero) is
  fn (x : Frac) is
    qind QPair QRel
      (fn (w : Frac) is Eq Frac (mulF (fracOf zero) w) (fracOf zero) end)
      (fn (p : QPair) is
        qsound QPair QRel (rawMul (qpair (nonneg zero) zero) p) (qpair (nonneg zero) zero) (mulZeroLP p)
      end)
      x
  end
end

mulFZeroR : (x : Frac) -> Eq Frac (mulF x (fracOf zero)) (fracOf zero) is
  fn (x : Frac) is
    qind QPair QRel
      (fn (w : Frac) is Eq Frac (mulF w (fracOf zero)) (fracOf zero) end)
      (fn (p : QPair) is
        qsound QPair QRel (rawMul p (qpair (nonneg zero) zero)) (qpair (nonneg zero) zero) (mulZeroRP p)
      end)
      x
  end
end

negInvLP : (p : QPair) -> QRel (rawAdd (rawNeg p) p) (qpair (nonneg zero) zero) is
  fn (p : QPair) is
    let np : Int = qnum p in
    let dp : Int = qden p in
    let n0 : Int = iadd (imul (ineg np) dp) (imul np dp) in
    transEq Int
      (imul n0 (nonneg (succ zero)))
      n0
      (imul (nonneg zero) (qden (rawAdd (rawNeg p) p)))
      (imulOneR n0)
      (transEq Int
         n0
         (imul (iadd (ineg np) np) dp)
         (imul (nonneg zero) (qden (rawAdd (rawNeg p) p)))
         (symEq Int (imul (iadd (ineg np) np) dp) n0 (idistribR (ineg np) np dp))
         (transEq Int
            (imul (iadd (ineg np) np) dp)
            (imul (nonneg zero) dp)
            (imul (nonneg zero) (qden (rawAdd (rawNeg p) p)))
            (congImulL (iadd (ineg np) np) (nonneg zero) dp (inegInvL np))
            (transEq Int
               (imul (nonneg zero) dp)
               (nonneg zero)
               (imul (nonneg zero) (qden (rawAdd (rawNeg p) p)))
               (imulZeroL dp)
               (symEq Int (imul (nonneg zero) (qden (rawAdd (rawNeg p) p))) (nonneg zero)
                  (imulZeroL (qden (rawAdd (rawNeg p) p)))))))
  end
end

negInvRP : (p : QPair) -> QRel (rawAdd p (rawNeg p)) (qpair (nonneg zero) zero) is
  fn (p : QPair) is
    let np : Int = qnum p in
    let dp : Int = qden p in
    let n0 : Int = iadd (imul np dp) (imul (ineg np) dp) in
    transEq Int
      (imul n0 (nonneg (succ zero)))
      n0
      (imul (nonneg zero) (qden (rawAdd p (rawNeg p))))
      (imulOneR n0)
      (transEq Int
         n0
         (imul (iadd np (ineg np)) dp)
         (imul (nonneg zero) (qden (rawAdd p (rawNeg p))))
         (symEq Int (imul (iadd np (ineg np)) dp) n0 (idistribR np (ineg np) dp))
         (transEq Int
            (imul (iadd np (ineg np)) dp)
            (imul (nonneg zero) dp)
            (imul (nonneg zero) (qden (rawAdd p (rawNeg p))))
            (congImulL (iadd np (ineg np)) (nonneg zero) dp (inegInvR np))
            (transEq Int
               (imul (nonneg zero) dp)
               (nonneg zero)
               (imul (nonneg zero) (qden (rawAdd p (rawNeg p))))
               (imulZeroL dp)
               (symEq Int (imul (nonneg zero) (qden (rawAdd p (rawNeg p)))) (nonneg zero)
                  (imulZeroL (qden (rawAdd p (rawNeg p))))))))
  end
end

fnegInvL : (x : Frac) -> Eq Frac (addF (fnegate x) x) (fracOf zero) is
  fn (x : Frac) is
    qind QPair QRel
      (fn (w : Frac) is Eq Frac (addF (fnegate w) w) (fracOf zero) end)
      (fn (p : QPair) is
        qsound QPair QRel (rawAdd (rawNeg p) p) (qpair (nonneg zero) zero) (negInvLP p)
      end)
      x
  end
end

fnegInvR : (x : Frac) -> Eq Frac (addF x (fnegate x)) (fracOf zero) is
  fn (x : Frac) is
    qind QPair QRel
      (fn (w : Frac) is Eq Frac (addF w (fnegate w)) (fracOf zero) end)
      (fn (p : QPair) is
        qsound QPair QRel (rawAdd p (rawNeg p)) (qpair (nonneg zero) zero) (negInvRP p)
      end)
      x
  end
end

semiringLawsFrac : SemiringLaws Frac (divRingFrac.1.1) is
  mkAnd (AssocT Frac addF)
        (And (CommT Frac addF)
        (And (IdLT Frac addF (fracOf zero))
        (And (IdRT Frac addF (fracOf zero))
        (And (AssocT Frac mulF)
        (And (IdLT Frac mulF (fracOf (succ zero)))
        (And (IdRT Frac mulF (fracOf (succ zero)))
        (And (DistribLT Frac addF mulF)
        (And (DistribRT Frac addF mulF)
        (And (AnnihLT Frac mulF (fracOf zero))
             (AnnihRT Frac mulF (fracOf zero)))))))))))
    addFAssoc
    (mkAnd (CommT Frac addF)
          (And (IdLT Frac addF (fracOf zero))
          (And (IdRT Frac addF (fracOf zero))
          (And (AssocT Frac mulF)
          (And (IdLT Frac mulF (fracOf (succ zero)))
          (And (IdRT Frac mulF (fracOf (succ zero)))
          (And (DistribLT Frac addF mulF)
          (And (DistribRT Frac addF mulF)
          (And (AnnihLT Frac mulF (fracOf zero))
               (AnnihRT Frac mulF (fracOf zero))))))))))
      addFComm
      (mkAnd (IdLT Frac addF (fracOf zero))
            (And (IdRT Frac addF (fracOf zero))
            (And (AssocT Frac mulF)
            (And (IdLT Frac mulF (fracOf (succ zero)))
            (And (IdRT Frac mulF (fracOf (succ zero)))
            (And (DistribLT Frac addF mulF)
            (And (DistribRT Frac addF mulF)
            (And (AnnihLT Frac mulF (fracOf zero))
                 (AnnihRT Frac mulF (fracOf zero)))))))))
        addFZeroL
        (mkAnd (IdRT Frac addF (fracOf zero))
              (And (AssocT Frac mulF)
              (And (IdLT Frac mulF (fracOf (succ zero)))
              (And (IdRT Frac mulF (fracOf (succ zero)))
              (And (DistribLT Frac addF mulF)
              (And (DistribRT Frac addF mulF)
              (And (AnnihLT Frac mulF (fracOf zero))
                   (AnnihRT Frac mulF (fracOf zero))))))))
          addFZeroR
          (mkAnd (AssocT Frac mulF)
                (And (IdLT Frac mulF (fracOf (succ zero)))
                (And (IdRT Frac mulF (fracOf (succ zero)))
                (And (DistribLT Frac addF mulF)
                (And (DistribRT Frac addF mulF)
                (And (AnnihLT Frac mulF (fracOf zero))
                     (AnnihRT Frac mulF (fracOf zero)))))))
            mulFAssoc
            (mkAnd (IdLT Frac mulF (fracOf (succ zero)))
                  (And (IdRT Frac mulF (fracOf (succ zero)))
                  (And (DistribLT Frac addF mulF)
                  (And (DistribRT Frac addF mulF)
                  (And (AnnihLT Frac mulF (fracOf zero))
                       (AnnihRT Frac mulF (fracOf zero))))))
              mulFOneL
              (mkAnd (IdRT Frac mulF (fracOf (succ zero)))
                    (And (DistribLT Frac addF mulF)
                    (And (DistribRT Frac addF mulF)
                    (And (AnnihLT Frac mulF (fracOf zero))
                         (AnnihRT Frac mulF (fracOf zero)))))
                mulFOneR
                (mkAnd (DistribLT Frac addF mulF)
                      (And (DistribRT Frac addF mulF)
                      (And (AnnihLT Frac mulF (fracOf zero))
                           (AnnihRT Frac mulF (fracOf zero))))
                  distribFL
                  (mkAnd (DistribRT Frac addF mulF)
                        (And (AnnihLT Frac mulF (fracOf zero))
                             (AnnihRT Frac mulF (fracOf zero)))
                    distribFR
                    (mkAnd (AnnihLT Frac mulF (fracOf zero))
                           (AnnihRT Frac mulF (fracOf zero))
                      mulFZeroL
                      mulFZeroR)))))))))
end

ringLawsFrac : RingLaws Frac (divRingFrac.1) is
  mkAnd (SemiringLaws Frac (divRingFrac.1.1))
    (And (NegInvLT Frac addF fnegate (fracOf zero)) (NegInvRT Frac addF fnegate (fracOf zero)))
    semiringLawsFrac
    (mkAnd (NegInvLT Frac addF fnegate (fracOf zero)) (NegInvRT Frac addF fnegate (fracOf zero))
      fnegInvL fnegInvR)
end

commLawsFrac : CommLaws Frac semiringFrac is mulFComm end

monus : Whole -> Whole -> Whole is fn (a : Whole) (b : Whole) is subW a b end end

cong : {A : U} -> {B : U} -> (f : A -> B) -> {x : A} -> {y : A} -> Eq A x y -> Eq B (f x) (f y) is
  fn {A : U} {B : U} (f : A -> B) {x : A} {y : A} (p : Eq A x y) is
    subst A x y p (fn (z : A) is Eq B (f x) (f z) end) refl
  end
end

sym : {A : U} -> {x : A} -> {y : A} -> Eq A x y -> Eq A y x is
  fn {A : U} {x : A} {y : A} (p : Eq A x y) is
    subst A x y p (fn (z : A) is Eq A z x end) refl
  end
end

trans : {A : U} -> {x : A} -> {y : A} -> {z : A} -> Eq A x y -> Eq A y z -> Eq A x z is
  fn {A : U} {x : A} {y : A} {z : A} (p : Eq A x y) (q : Eq A y z) is
    subst A y z q (fn (w : A) is Eq A x w end) p
  end
end

addZeroR : (n : Whole) -> Eq Whole (addW n zero) n is
  fn (n : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (addW x zero) x end)
      (refl zero)
      (fn (k : Whole) (ih : Eq Whole (addW k zero) k) is
         subst Whole (addW k zero) k ih
           (fn (z : Whole) is Eq Whole (addW (succ k) zero) (succ z) end)
           (refl (addW (succ k) zero))
       end)
      n
  end
end

addSuccR : (n : Whole) -> (m : Whole) -> Eq Whole (addW n (succ m)) (succ (addW n m)) is
  fn (n : Whole) (m : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (addW x (succ m)) (succ (addW x m)) end)
      (refl (succ m))
      (fn (k : Whole) (ih : Eq Whole (addW k (succ m)) (succ (addW k m))) is
         subst Whole (addW k (succ m)) (succ (addW k m)) ih
           (fn (z : Whole) is Eq Whole (addW (succ k) (succ m)) (succ z) end)
           (refl (addW (succ k) (succ m)))
       end)
      n
  end
end

addComm : (n : Whole) -> (m : Whole) -> Eq Whole (addW n m) (addW m n) is
  fn (n : Whole) (m : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (addW x m) (addW m x) end)
      (subst Whole (addW m zero) m (addZeroR m)
         (fn (z : Whole) is Eq Whole z (addW m zero) end)
         (refl (addW m zero)))
      (fn (k : Whole) (ih : Eq Whole (addW k m) (addW m k)) is
         subst Whole (succ (addW m k)) (addW m (succ k))
           (subst Whole (addW m (succ k)) (succ (addW m k)) (addSuccR m k)
              (fn (z : Whole) is Eq Whole z (addW m (succ k)) end)
              (refl (addW m (succ k))))
           (fn (z : Whole) is Eq Whole (succ (addW k m)) z end)
           (subst Whole (addW k m) (addW m k) ih
              (fn (z : Whole) is Eq Whole (succ (addW k m)) (succ z) end)
              (refl (succ (addW k m))))
       end)
      n
  end
end

or : Bool -> Bool -> Bool is
  fn (a : Bool) (b : Bool) is
    BoolElim (fn (x : Bool) is Bool end) true b a
  end
end


-- ============================================================
-- THE ORD LAYER (ch574, imported verbatim). The Ordering verdict type, the
-- Ord ops class, the erased Le view, the comparison defaults, the OrdLaws
-- record, and the Whole / Int / Frac order instances with their six laws
-- each -- including the positive-scaling respect proofs that carry leF over
-- the quotient. The ordered-algebra bridge is built on top of all of it.
-- ============================================================
data Ordering : U is
  lt : Ordering
| eq : Ordering
| gt : Ordering
end

Ord : U -> U is
  fn (A : U) is
    Sig (A -> A -> Bool) (fn (_le : A -> A -> Bool) is A -> A -> Ordering end)
  end
end

mkOrd : (A : U) -> (A -> A -> Bool) -> (A -> A -> Ordering) -> Ord A is
  fn (A : U) (le : A -> A -> Bool) (cmp : A -> A -> Ordering) is
    Pair (A -> A -> Bool) (fn (_le : A -> A -> Bool) is A -> A -> Ordering end) le cmp
  end
end

leOf : (A : U) -> Ord A -> A -> A -> Bool is
  fn (A : U) (o : Ord A) is o.1 end
end

compareOf : (A : U) -> Ord A -> A -> A -> Ordering is
  fn (A : U) (o : Ord A) is o.2 end
end

Le : (A : U) -> Ord A -> A -> A -> U is
  fn (A : U) (o : Ord A) (a : A) (b : A) is Eq Bool (leOf A o a b) true end
end

compareFromLe : (A : U) -> (A -> A -> Bool) -> A -> A -> Ordering is
  fn (A : U) (le : A -> A -> Bool) (a : A) (b : A) is
    let lab : Bool = le a b in
    let lba : Bool = le b a in
    case lab of
    | true  -> case lba of | true -> eq | false -> lt end
    | false -> gt
    end
  end
end

OrdLaws : (A : U) -> Ord A -> U is
  fn (A : U) (o : Ord A) is
    And ((a : A) -> Le A o a a)
    (And ((a : A) -> (b : A) -> (c : A) -> Le A o a b -> Le A o b c -> Le A o a c)
    (And ((a : A) -> (b : A) -> Le A o a b -> Le A o b a -> Eq A a b)
    (And ((a : A) -> (b : A) -> Eq Bool (or (leOf A o a b) (leOf A o b a)) true)
    (And ((a : A) -> (b : A) -> Eq Ordering (compareOf A o a b) eq -> Eq A a b)
         ((a : A) -> (b : A) -> Eq Ordering (compareOf A o a b) lt -> Le A o a b)))))
  end
end

notEqOrd : Ordering -> Bool is
  fn (o : Ordering) is case o of | lt -> true | eq -> false | gt -> true end end
end

isGtOrd : Ordering -> Bool is
  fn (o : Ordering) is case o of | lt -> false | eq -> false | gt -> true end end
end

compareFromLeEq : (A : U) -> (le : A -> A -> Bool) -> (a : A) -> (b : A)
    -> Eq Ordering (compareFromLe A le a b) eq
    -> And (Eq Bool (le a b) true) (Eq Bool (le b a) true) is
  fn (A : U) (le : A -> A -> Bool) (a : A) (b : A)
     (h : Eq Ordering (compareFromLe A le a b) eq) is
    boolCaseEq (le a b)
      (fn (_g1 : Bool) is And (Eq Bool (le a b) true) (Eq Bool (le b a) true) end)
      (fn (e1 : Eq Bool (le a b) true) is
         boolCaseEq (le b a)
           (fn (_g2 : Bool) is And (Eq Bool (le a b) true) (Eq Bool (le b a) true) end)
           (fn (e2 : Eq Bool (le b a) true) is
              mkAnd (Eq Bool (le a b) true) (Eq Bool (le b a) true) e1 e2 end)
           (fn (e2 : Eq Bool (le b a) false) is
              let h1 : Eq Ordering
                  (case true of
                   | true  -> (case (le b a) of | true -> eq | false -> lt end)
                   | false -> gt
                   end) eq =
                subst Bool (le a b) true e1
                  (fn (w1 : Bool) is Eq Ordering
                     (case w1 of
                      | true  -> (case (le b a) of | true -> eq | false -> lt end)
                      | false -> gt
                      end) eq end)
                  h in
              let h2 : Eq Ordering lt eq =
                subst Bool (le b a) false e2
                  (fn (w2 : Bool) is Eq Ordering
                     (case w2 of | true -> eq | false -> lt end) eq end)
                  h1 in
              boolDiscTF (And (Eq Bool (le a b) true) (Eq Bool (le b a) true))
                (congE Ordering Bool notEqOrd lt eq h2)
            end)
       end)
      (fn (e1 : Eq Bool (le a b) false) is
         let hgt : Eq Ordering gt eq =
           subst Bool (le a b) false e1
             (fn (w1 : Bool) is Eq Ordering
                (case w1 of
                 | true  -> (case (le b a) of | true -> eq | false -> lt end)
                 | false -> gt
                 end) eq end)
             h in
         boolDiscTF (And (Eq Bool (le a b) true) (Eq Bool (le b a) true))
           (congE Ordering Bool notEqOrd gt eq hgt)
       end)
  end
end

compareFromLeLt : (A : U) -> (le : A -> A -> Bool) -> (a : A) -> (b : A)
    -> Eq Ordering (compareFromLe A le a b) lt
    -> Eq Bool (le a b) true is
  fn (A : U) (le : A -> A -> Bool) (a : A) (b : A)
     (h : Eq Ordering (compareFromLe A le a b) lt) is
    boolCaseEq (le a b)
      (fn (_g1 : Bool) is Eq Bool (le a b) true end)
      (fn (e1 : Eq Bool (le a b) true) is e1 end)
      (fn (e1 : Eq Bool (le a b) false) is
         let hgt : Eq Ordering gt lt =
           subst Bool (le a b) false e1
             (fn (w1 : Bool) is Eq Ordering
                (case w1 of
                 | true  -> (case (le b a) of | true -> eq | false -> lt end)
                 | false -> gt
                 end) lt end)
             h in
         boolDiscTF (Eq Bool (le a b) true)
           (congE Ordering Bool isGtOrd gt lt hgt)
       end)
  end
end

lteAbsurd : (a : Whole) -> (c : Whole) -> Eq Bool false true -> Eq Bool (leb a c) true is
  fn (a : Whole) (c : Whole) (h : Eq Bool false true) is
    subst Bool false true h
      (fn (z : Bool) is
         case z of
         | true  -> Eq Bool (leb a c) true
         | false -> Eq Bool true true
         end
       end)
      (refl true)
  end
end

lteAbsurdNat : (a : Whole) -> (b : Whole) -> Eq Bool false true -> Eq Whole a b is
  fn (a : Whole) (b : Whole) (h : Eq Bool false true) is
    subst Bool false true h
      (fn (z : Bool) is
         case z of
         | true  -> Eq Whole a b
         | false -> Eq Whole a a
         end
       end)
      (refl a)
  end
end

lteAntisym : (a : Whole) -> (b : Whole)
   -> Eq Bool (leb a b) true -> Eq Bool (leb b a) true -> Eq Whole a b is
  fn (a : Whole) is
    WholeElim
      (fn (x : Whole) is
         (b : Whole)
           -> Eq Bool (leb x b) true -> Eq Bool (leb b x) true
           -> Eq Whole x b end)
      (fn (b : Whole) is
         WholeElim
           (fn (y : Whole) is
              Eq Bool (leb zero y) true -> Eq Bool (leb y zero) true
                -> Eq Whole zero y end)
           (fn (hab : Eq Bool (leb zero zero) true)
               (hba : Eq Bool (leb zero zero) true) is
              refl zero end)
           (fn (b' : Whole)
               (ihb : Eq Bool (leb zero b') true -> Eq Bool (leb b' zero) true
                        -> Eq Whole zero b') is
              fn (hab : Eq Bool (leb zero (succ b')) true)
                 (hba : Eq Bool false true) is
                lteAbsurdNat zero (succ b') hba end
            end)
           b
       end)
      (fn (a' : Whole)
          (ih : (b : Whole)
                  -> Eq Bool (leb a' b) true -> Eq Bool (leb b a') true
                  -> Eq Whole a' b) is
         fn (b : Whole) is
           WholeElim
             (fn (y : Whole) is
                Eq Bool (leb (succ a') y) true -> Eq Bool (leb y (succ a')) true
                  -> Eq Whole (succ a') y end)
             (fn (hab : Eq Bool false true)
                 (hba : Eq Bool (leb zero (succ a')) true) is
                lteAbsurdNat (succ a') zero hab end)
             (fn (b' : Whole)
                 (ihb : Eq Bool (leb (succ a') b') true
                          -> Eq Bool (leb b' (succ a')) true
                          -> Eq Whole (succ a') b') is
                fn (hab : Eq Bool (leb a' b') true)
                   (hba : Eq Bool (leb b' a') true) is
                  subst Whole a' b' (ih b' hab hba)
                    (fn (z : Whole) is Eq Whole (succ a') (succ z) end)
                    (refl (succ a'))
                end
              end)
             b
         end
       end)
      a
  end
end

zeroMonus : (b : Whole) -> Eq Whole (monus zero b) zero is
  fn (b : Whole) is
    case b of
    | zero -> refl zero
    | succ k with ih -> cong pred ih
    end
  end
end

monusSuccSucc : (b : Whole) -> (a : Whole) -> Eq Whole (monus (succ a) (succ b)) (monus a b) is
  fn (b : Whole) is
    case b of
    | zero -> fn (a : Whole) is refl a end
    | succ k with ih -> fn (a : Whole) is cong pred (ih a) end
    end
  end
end

addSuccL : (c : Whole) -> (x : Whole) -> Eq Whole (addW (succ c) x) (succ (addW c x)) is
  fn (c : Whole) (x : Whole) is
    WholeElim (fn (z : Whole) is Eq Whole (addW (succ c) z) (succ (addW c z)) end)
      (trans (addZeroR (succ c)) (cong succ (sym (addZeroR c))))
      (fn (k : Whole) (ih : Eq Whole (addW (succ c) k) (succ (addW c k))) is
         trans (addSuccR (succ c) k)
           (trans (cong succ ih) (cong succ (sym (addSuccR c k)))) end)
      x
  end
end

lebAddMono : (c : Whole) -> (x : Whole) -> (y : Whole) -> Eq Bool (leb x y) true
    -> Eq Bool (leb (addW c x) (addW c y)) true is
  fn (c : Whole) is
    case c of
    | zero -> fn (x : Whole) (y : Whole) (h : Eq Bool (leb x y) true) is h end
    | succ d with ih -> fn (x : Whole) (y : Whole) (h : Eq Bool (leb x y) true) is
        subst Whole (succ (addW d x)) (addW (succ d) x) (sym (addSuccL d x))
          (fn (s : Whole) is Eq Bool (leb s (addW (succ d) y)) true end)
          (subst Whole (succ (addW d y)) (addW (succ d) y) (sym (addSuccL d y))
            (fn (t : Whole) is Eq Bool (leb (succ (addW d x)) t) true end)
            (ih x y h))
      end
    end
  end
end

lebTrans : (a : Whole) -> (b : Whole) -> (c : Whole)
    -> Eq Bool (leb a b) true -> Eq Bool (leb b c) true -> Eq Bool (leb a c) true is
  fn (a : Whole) is
    case a of
    | zero -> fn (b : Whole) (c : Whole) (hab : Eq Bool true true) (hbc : Eq Bool (leb b c) true) is
        refl true end
    | succ a2 with ih -> fn (b : Whole) is
        case b of
        | zero -> fn (c : Whole) (hab : Eq Bool false true) (hbc : Eq Bool (leb zero c) true) is
            lteAbsurd (succ a2) c hab end
        | succ b2 -> fn (c : Whole) is
            case c of
            | zero -> fn (hab : Eq Bool (leb a2 b2) true) (hbc : Eq Bool false true) is
                lteAbsurd (succ a2) zero hbc end
            | succ c2 -> fn (hab : Eq Bool (leb a2 b2) true) (hbc : Eq Bool (leb b2 c2) true) is
                ih b2 c2 hab hbc end
            end
          end
        end
      end
    end
  end
end

lebRefl : (a : Whole) -> Eq Bool (leb a a) true is
  fn (a : Whole) is
    case a of
    | zero -> refl true
    | succ k with ih -> ih
    end
  end
end

lebSuccSelf : (a : Whole) -> Eq Bool (leb a (succ a)) true is
  fn (a : Whole) is
    case a of
    | zero -> refl true
    | succ k with ih -> ih
    end
  end
end

monusLe : (a : Whole) -> (d : Whole) -> Eq Bool (leb (monus a d) a) true is
  fn (a : Whole) is
    case a of
    | zero -> fn (d : Whole) is
        subst Whole zero (monus zero d) (sym (zeroMonus d))
          (fn (s : Whole) is Eq Bool (leb s zero) true end) (refl true) end
    | succ a2 with ih -> fn (d : Whole) is
        case d of
        | zero -> lebRefl (succ a2)
        | succ d2 ->
            subst Whole (monus a2 d2) (monus (succ a2) (succ d2)) (sym (monusSuccSucc d2 a2))
              (fn (s : Whole) is Eq Bool (leb s (succ a2)) true end)
              (lebTrans (monus a2 d2) a2 (succ a2) (ih d2) (lebSuccSelf a2))
        end
      end
    end
  end
end

monusLeMono2 : (a : Whole) -> (c : Whole) -> (d : Whole)
    -> Eq Bool (leb c d) true -> Eq Bool (leb (monus a d) (monus a c)) true is
  fn (a : Whole) is
    case a of
    | zero -> fn (c : Whole) (d : Whole) (h : Eq Bool (leb c d) true) is
        subst Whole zero (monus zero d) (sym (zeroMonus d))
          (fn (s : Whole) is Eq Bool (leb s (monus zero c)) true end)
          (subst Whole zero (monus zero c) (sym (zeroMonus c))
            (fn (t : Whole) is Eq Bool (leb zero t) true end) (refl true)) end
    | succ a2 with ih -> fn (c : Whole) is
        case c of
        | zero -> fn (d : Whole) (h : Eq Bool true true) is
            -- monus (succ a2) zero = succ a2 (def. monus zero-case); monusLe closes it.
            monusLe (succ a2) d end
        | succ c2 -> fn (d : Whole) is
            case d of
            | zero -> fn (h : Eq Bool (leb (succ c2) zero) true) is
                subst Bool false true h
                  (fn (z : Bool) is case z of
                     | true  -> Eq Bool (leb (monus (succ a2) zero) (monus (succ a2) (succ c2))) true
                     | false -> Eq Bool true true end end)
                  (refl true) end
            | succ d2 -> fn (h : Eq Bool (leb c2 d2) true) is
                subst Whole (monus a2 d2) (monus (succ a2) (succ d2)) (sym (monusSuccSucc d2 a2))
                  (fn (s : Whole) is Eq Bool (leb s (monus (succ a2) (succ c2))) true end)
                  (subst Whole (monus a2 c2) (monus (succ a2) (succ c2)) (sym (monusSuccSucc c2 a2))
                    (fn (t : Whole) is Eq Bool (leb (monus a2 d2) t) true end)
                    (ih c2 d2 h)) end
            end
          end
        end
      end
    end
  end
end

instance ordWhole   : Ord Whole   is mkOrd Whole leb (compareFromLe Whole leb) end

leTotalWhole : (a : Whole) -> (b : Whole) -> Eq Bool (or (leb a b) (leb b a)) true is
  fn (a : Whole) (b : Whole) is
    boolCaseEq (leb a b)
      (fn (g : Bool) is Eq Bool (or g (leb b a)) true end)
      (fn (_e1 : Eq Bool (leb a b) true) is refl true end)
      (fn (e1 : Eq Bool (leb a b) false) is lebComplete a b e1 end)
  end
end

ordLawsWhole : OrdLaws Whole ordWhole is
  mkAnd ((a : Whole) -> Le Whole ordWhole a a)
    (And ((a : Whole) -> (b : Whole) -> (c : Whole) -> Le Whole ordWhole a b -> Le Whole ordWhole b c -> Le Whole ordWhole a c)
    (And ((a : Whole) -> (b : Whole) -> Le Whole ordWhole a b -> Le Whole ordWhole b a -> Eq Whole a b)
    (And ((a : Whole) -> (b : Whole) -> Eq Bool (or (leOf Whole ordWhole a b) (leOf Whole ordWhole b a)) true)
    (And ((a : Whole) -> (b : Whole) -> Eq Ordering (compareOf Whole ordWhole a b) eq -> Eq Whole a b)
         ((a : Whole) -> (b : Whole) -> Eq Ordering (compareOf Whole ordWhole a b) lt -> Le Whole ordWhole a b)))))
    lebRefl
    (mkAnd ((a : Whole) -> (b : Whole) -> (c : Whole) -> Le Whole ordWhole a b -> Le Whole ordWhole b c -> Le Whole ordWhole a c)
      (And ((a : Whole) -> (b : Whole) -> Le Whole ordWhole a b -> Le Whole ordWhole b a -> Eq Whole a b)
      (And ((a : Whole) -> (b : Whole) -> Eq Bool (or (leOf Whole ordWhole a b) (leOf Whole ordWhole b a)) true)
      (And ((a : Whole) -> (b : Whole) -> Eq Ordering (compareOf Whole ordWhole a b) eq -> Eq Whole a b)
           ((a : Whole) -> (b : Whole) -> Eq Ordering (compareOf Whole ordWhole a b) lt -> Le Whole ordWhole a b))))
      lebTrans
      (mkAnd ((a : Whole) -> (b : Whole) -> Le Whole ordWhole a b -> Le Whole ordWhole b a -> Eq Whole a b)
        (And ((a : Whole) -> (b : Whole) -> Eq Bool (or (leOf Whole ordWhole a b) (leOf Whole ordWhole b a)) true)
        (And ((a : Whole) -> (b : Whole) -> Eq Ordering (compareOf Whole ordWhole a b) eq -> Eq Whole a b)
             ((a : Whole) -> (b : Whole) -> Eq Ordering (compareOf Whole ordWhole a b) lt -> Le Whole ordWhole a b)))
        lteAntisym
        (mkAnd ((a : Whole) -> (b : Whole) -> Eq Bool (or (leOf Whole ordWhole a b) (leOf Whole ordWhole b a)) true)
          (And ((a : Whole) -> (b : Whole) -> Eq Ordering (compareOf Whole ordWhole a b) eq -> Eq Whole a b)
               ((a : Whole) -> (b : Whole) -> Eq Ordering (compareOf Whole ordWhole a b) lt -> Le Whole ordWhole a b))
          leTotalWhole
          (mkAnd ((a : Whole) -> (b : Whole) -> Eq Ordering (compareOf Whole ordWhole a b) eq -> Eq Whole a b)
                 ((a : Whole) -> (b : Whole) -> Eq Ordering (compareOf Whole ordWhole a b) lt -> Le Whole ordWhole a b)
            (fn (a : Whole) (b : Whole) (h : Eq Ordering (compareOf Whole ordWhole a b) eq) is
               let pr : And (Eq Bool (leb a b) true) (Eq Bool (leb b a) true) =
                 compareFromLeEq Whole leb a b h in
               lteAntisym a b (pr.1) (pr.2)
             end)
            (fn (a : Whole) (b : Whole) (h : Eq Ordering (compareOf Whole ordWhole a b) lt) is
               compareFromLeLt Whole leb a b h
             end)))))
end

ileb : Int -> Int -> Bool is
  fn (x : Int) (y : Int) is
    case x of
    | nonneg a ->
        case y of
        | nonneg b  -> leb a b
        | negsucc j -> false
        end
    | negsucc k ->
        case y of
        | nonneg b  -> true
        | negsucc j -> leb j k
        end
    end
  end
end

ilebReflP : (a : Int) -> Eq Bool (ileb a a) true is
  fn (a : Int) is
    IntElim (fn (w : Int) is Eq Bool (ileb w w) true end)
      (fn (n : Whole) is lebRefl n end)
      (fn (k : Whole) is lebRefl k end)
      a
  end
end

ilebTransNonneg : (na : Whole) -> (b : Int) -> (c : Int)
    -> Eq Bool (ileb (nonneg na) b) true -> Eq Bool (ileb b c) true
    -> Eq Bool (ileb (nonneg na) c) true is
  fn (na : Whole) is
    IntElim (fn (wb : Int) is (c : Int)
        -> Eq Bool (ileb (nonneg na) wb) true -> Eq Bool (ileb wb c) true
        -> Eq Bool (ileb (nonneg na) c) true end)
      (fn (nb : Whole) is
        IntElim (fn (wc : Int) is
            Eq Bool (ileb (nonneg na) (nonneg nb)) true -> Eq Bool (ileb (nonneg nb) wc) true
            -> Eq Bool (ileb (nonneg na) wc) true end)
          (fn (nc : Whole) (h1 : Eq Bool (leb na nb) true) (h2 : Eq Bool (leb nb nc) true) is
            lebTrans na nb nc h1 h2 end)
          (fn (kc : Whole) (h1 : Eq Bool (leb na nb) true) (h2 : Eq Bool false true) is
            boolDiscTF (Eq Bool (ileb (nonneg na) (negsucc kc)) true)
              (symEq Bool false true h2) end)
       end)
      (fn (kb : Whole) (c : Int) (h1 : Eq Bool false true) (h2 : Eq Bool (ileb (negsucc kb) c) true) is
        boolDiscTF (Eq Bool (ileb (nonneg na) c) true) (symEq Bool false true h1) end)
  end
end

ilebTransNegsucc : (ka : Whole) -> (b : Int) -> (c : Int)
    -> Eq Bool (ileb (negsucc ka) b) true -> Eq Bool (ileb b c) true
    -> Eq Bool (ileb (negsucc ka) c) true is
  fn (ka : Whole) is
    IntElim (fn (wb : Int) is (c : Int)
        -> Eq Bool (ileb (negsucc ka) wb) true -> Eq Bool (ileb wb c) true
        -> Eq Bool (ileb (negsucc ka) c) true end)
      (fn (nb : Whole) is
        IntElim (fn (wc : Int) is
            Eq Bool (ileb (negsucc ka) (nonneg nb)) true -> Eq Bool (ileb (nonneg nb) wc) true
            -> Eq Bool (ileb (negsucc ka) wc) true end)
          (fn (nc : Whole) (h1 : Eq Bool true true) (h2 : Eq Bool (leb nb nc) true) is refl true end)
          (fn (kc : Whole) (h1 : Eq Bool true true) (h2 : Eq Bool false true) is
            boolDiscTF (Eq Bool (ileb (negsucc ka) (negsucc kc)) true)
              (symEq Bool false true h2) end)
       end)
      (fn (kb : Whole) is
        IntElim (fn (wc : Int) is
            Eq Bool (ileb (negsucc ka) (negsucc kb)) true -> Eq Bool (ileb (negsucc kb) wc) true
            -> Eq Bool (ileb (negsucc ka) wc) true end)
          (fn (nc : Whole) (h1 : Eq Bool (leb kb ka) true) (h2 : Eq Bool true true) is refl true end)
          (fn (kc : Whole) (h1 : Eq Bool (leb kb ka) true) (h2 : Eq Bool (leb kc kb) true) is
            lebTrans kc kb ka h2 h1 end)
       end)
  end
end

ilebTransP : (a : Int) -> (b : Int) -> (c : Int)
    -> Eq Bool (ileb a b) true -> Eq Bool (ileb b c) true -> Eq Bool (ileb a c) true is
  fn (a : Int) is
    IntElim (fn (wa : Int) is (b : Int) -> (c : Int)
        -> Eq Bool (ileb wa b) true -> Eq Bool (ileb b c) true -> Eq Bool (ileb wa c) true end)
      (fn (na : Whole) is ilebTransNonneg na end)
      (fn (ka : Whole) is ilebTransNegsucc ka end)
      a
  end
end

ilebAntisymP : (a : Int) -> (b : Int)
    -> Eq Bool (ileb a b) true -> Eq Bool (ileb b a) true -> Eq Int a b is
  fn (a : Int) is
    IntElim (fn (wa : Int) is (b : Int)
        -> Eq Bool (ileb wa b) true -> Eq Bool (ileb b wa) true -> Eq Int wa b end)
      (fn (na : Whole) is
        IntElim (fn (wb : Int) is
            Eq Bool (ileb (nonneg na) wb) true -> Eq Bool (ileb wb (nonneg na)) true
            -> Eq Int (nonneg na) wb end)
          (fn (nb : Whole) (h1 : Eq Bool (leb na nb) true) (h2 : Eq Bool (leb nb na) true) is
            congNonneg na nb (lteAntisym na nb h1 h2) end)
          (fn (kb : Whole) (h1 : Eq Bool false true) (h2 : Eq Bool true true) is
            boolDiscTF (Eq Int (nonneg na) (negsucc kb)) (symEq Bool false true h1) end)
       end)
      (fn (ka : Whole) is
        IntElim (fn (wb : Int) is
            Eq Bool (ileb (negsucc ka) wb) true -> Eq Bool (ileb wb (negsucc ka)) true
            -> Eq Int (negsucc ka) wb end)
          (fn (nb : Whole) (h1 : Eq Bool true true) (h2 : Eq Bool false true) is
            boolDiscTF (Eq Int (negsucc ka) (nonneg nb)) (symEq Bool false true h2) end)
          (fn (kb : Whole) (h1 : Eq Bool (leb kb ka) true) (h2 : Eq Bool (leb ka kb) true) is
            congNegsucc ka kb (symEq Whole kb ka (lteAntisym kb ka h1 h2)) end)
       end)
      a
  end
end

ilebTotalP : (a : Int) -> (b : Int) -> Eq Bool (or (ileb a b) (ileb b a)) true is
  fn (a : Int) is
    IntElim (fn (wa : Int) is (b : Int)
        -> Eq Bool (or (ileb wa b) (ileb b wa)) true end)
      (fn (na : Whole) is
        IntElim (fn (wb : Int) is
            Eq Bool (or (ileb (nonneg na) wb) (ileb wb (nonneg na))) true end)
          (fn (nb : Whole) is leTotalWhole na nb end)
          (fn (kb : Whole) is refl true end)
       end)
      (fn (ka : Whole) is
        IntElim (fn (wb : Int) is
            Eq Bool (or (ileb (negsucc ka) wb) (ileb wb (negsucc ka))) true end)
          (fn (nb : Whole) is refl true end)
          (fn (kb : Whole) is leTotalWhole kb ka end)
       end)
      a
  end
end

instance ordInt   : Ord Int   is mkOrd Int ileb (compareFromLe Int ileb) end

ordLawsInt : OrdLaws Int ordInt is
  mkAnd ((a : Int) -> Le Int ordInt a a)
    (And ((a : Int) -> (b : Int) -> (c : Int) -> Le Int ordInt a b -> Le Int ordInt b c -> Le Int ordInt a c)
    (And ((a : Int) -> (b : Int) -> Le Int ordInt a b -> Le Int ordInt b a -> Eq Int a b)
    (And ((a : Int) -> (b : Int) -> Eq Bool (or (leOf Int ordInt a b) (leOf Int ordInt b a)) true)
    (And ((a : Int) -> (b : Int) -> Eq Ordering (compareOf Int ordInt a b) eq -> Eq Int a b)
         ((a : Int) -> (b : Int) -> Eq Ordering (compareOf Int ordInt a b) lt -> Le Int ordInt a b)))))
    ilebReflP
    (mkAnd ((a : Int) -> (b : Int) -> (c : Int) -> Le Int ordInt a b -> Le Int ordInt b c -> Le Int ordInt a c)
      (And ((a : Int) -> (b : Int) -> Le Int ordInt a b -> Le Int ordInt b a -> Eq Int a b)
      (And ((a : Int) -> (b : Int) -> Eq Bool (or (leOf Int ordInt a b) (leOf Int ordInt b a)) true)
      (And ((a : Int) -> (b : Int) -> Eq Ordering (compareOf Int ordInt a b) eq -> Eq Int a b)
           ((a : Int) -> (b : Int) -> Eq Ordering (compareOf Int ordInt a b) lt -> Le Int ordInt a b))))
      ilebTransP
      (mkAnd ((a : Int) -> (b : Int) -> Le Int ordInt a b -> Le Int ordInt b a -> Eq Int a b)
        (And ((a : Int) -> (b : Int) -> Eq Bool (or (leOf Int ordInt a b) (leOf Int ordInt b a)) true)
        (And ((a : Int) -> (b : Int) -> Eq Ordering (compareOf Int ordInt a b) eq -> Eq Int a b)
             ((a : Int) -> (b : Int) -> Eq Ordering (compareOf Int ordInt a b) lt -> Le Int ordInt a b)))
        ilebAntisymP
        (mkAnd ((a : Int) -> (b : Int) -> Eq Bool (or (leOf Int ordInt a b) (leOf Int ordInt b a)) true)
          (And ((a : Int) -> (b : Int) -> Eq Ordering (compareOf Int ordInt a b) eq -> Eq Int a b)
               ((a : Int) -> (b : Int) -> Eq Ordering (compareOf Int ordInt a b) lt -> Le Int ordInt a b))
          ilebTotalP
          (mkAnd ((a : Int) -> (b : Int) -> Eq Ordering (compareOf Int ordInt a b) eq -> Eq Int a b)
                 ((a : Int) -> (b : Int) -> Eq Ordering (compareOf Int ordInt a b) lt -> Le Int ordInt a b)
            (fn (a : Int) (b : Int) (h : Eq Ordering (compareOf Int ordInt a b) eq) is
               let pr : And (Eq Bool (ileb a b) true) (Eq Bool (ileb b a) true) =
                 compareFromLeEq Int ileb a b h in
               ilebAntisymP a b (pr.1) (pr.2)
             end)
            (fn (a : Int) (b : Int) (h : Eq Ordering (compareOf Int ordInt a b) lt) is
               compareFromLeLt Int ileb a b h
             end)))))
end

and : Bool -> Bool -> Bool is
  fn (a : Bool) (b : Bool) is BoolElim (fn (x : Bool) is Bool end) b false a end
end

lteAddR : (a : Whole) -> (b : Whole) -> Eq Bool (leb a (addW a b)) true is
  fn (a : Whole) (b : Whole) is
    WholeElim (fn (x : Whole) is Eq Bool (leb x (addW x b)) true end)
      (refl true)
      (fn (k : Whole) (ih : Eq Bool (leb k (addW k b)) true) is ih end)
      a
  end
end

lteAddL : (a : Whole) -> (b : Whole) -> Eq Bool (leb b (addW a b)) true is
  fn (a : Whole) (b : Whole) is
    subst Whole (addW b a) (addW a b) (addComm b a)
      (fn (z : Whole) is Eq Bool (leb b z) true end) (lteAddR b a)
  end
end

lebAddSameL : (c : Whole) -> (x : Whole) -> (y : Whole) -> Eq Bool (leb (addW c x) (addW c y)) (leb x y) is
  fn (c : Whole) (x : Whole) (y : Whole) is
    WholeElim (fn (m : Whole) is Eq Bool (leb (addW m x) (addW m y)) (leb x y) end)
      (refl (leb x y))
      (fn (k : Whole) (ih : Eq Bool (leb (addW k x) (addW k y)) (leb x y)) is ih end)
      c
  end
end

lebMulPosR : (x : Whole) -> (y : Whole) -> (d : Whole) -> Eq Bool (leb (mulW x (succ d)) (mulW y (succ d))) (leb x y) is
  fn (x : Whole) (y : Whole) (d : Whole) is
    WholeElim (fn (m : Whole) is (n : Whole) -> Eq Bool (leb (mulW m (succ d)) (mulW n (succ d))) (leb m n) end)
      (fn (n : Whole) is refl (leb zero n) end)
      (fn (k : Whole) (ih : (n : Whole) -> Eq Bool (leb (mulW k (succ d)) (mulW n (succ d))) (leb k n)) is
         fn (n : Whole) is
           WholeElim (fn (nn : Whole) is Eq Bool (leb (mulW (succ k) (succ d)) (mulW nn (succ d))) (leb (succ k) nn) end)
             (subst Whole (succ (dmul k d)) (mulW (succ k) (succ d))
                (symEq Whole (mulW (succ k) (succ d)) (succ (dmul k d)) (dmulSucc k d))
                (fn (w : Whole) is Eq Bool (leb w zero) false end)
                (refl false))
             (fn (j : Whole) (ihj : Eq Bool (leb (mulW (succ k) (succ d)) (mulW j (succ d))) (leb (succ k) j)) is
                transEq Bool
                  (leb (addW (mulW k (succ d)) (succ d)) (addW (mulW j (succ d)) (succ d)))
                  (leb (addW (succ d) (mulW k (succ d))) (addW (succ d) (mulW j (succ d))))
                  (leb k j)
                  (transEq Bool
                     (leb (addW (mulW k (succ d)) (succ d)) (addW (mulW j (succ d)) (succ d)))
                     (leb (addW (succ d) (mulW k (succ d))) (addW (mulW j (succ d)) (succ d)))
                     (leb (addW (succ d) (mulW k (succ d))) (addW (succ d) (mulW j (succ d))))
                     (congE Whole Bool (fn (t : Whole) is leb t (addW (mulW j (succ d)) (succ d)) end)
                        (addW (mulW k (succ d)) (succ d)) (addW (succ d) (mulW k (succ d)))
                        (addWComm (mulW k (succ d)) (succ d)))
                     (congE Whole Bool (fn (t : Whole) is leb (addW (succ d) (mulW k (succ d))) t end)
                        (addW (mulW j (succ d)) (succ d)) (addW (succ d) (mulW j (succ d)))
                        (addWComm (mulW j (succ d)) (succ d))))
                  (transEq Bool
                     (leb (addW (succ d) (mulW k (succ d))) (addW (succ d) (mulW j (succ d))))
                     (leb (mulW k (succ d)) (mulW j (succ d)))
                     (leb k j)
                     (lebAddSameL (succ d) (mulW k (succ d)) (mulW j (succ d)))
                     (ih j))
              end)
             n
         end
       end)
      x y
  end
end

imulSwap3R : (a : Int) -> (b : Int) -> (c : Int) -> Eq Int (imul (imul a b) c) (imul (imul a c) b) is
  fn (a : Int) (b : Int) (c : Int) is
    transEq Int (imul (imul a b) c) (imul a (imul b c)) (imul (imul a c) b)
      (imulAssoc a b c)
      (transEq Int (imul a (imul b c)) (imul a (imul c b)) (imul (imul a c) b)
         (congImulR a (imul b c) (imul c b) (imulComm b c))
         (symEq Int (imul (imul a c) b) (imul a (imul c b)) (imulAssoc a c b)))
  end
end

congIleb2 : (u : Int) -> (u2 : Int) -> (v : Int) -> (v2 : Int)
    -> Eq Int u u2 -> Eq Int v v2 -> Eq Bool (ileb u v) (ileb u2 v2) is
  fn (u : Int) (u2 : Int) (v : Int) (v2 : Int) (eu : Eq Int u u2) (ev : Eq Int v v2) is
    transEq Bool (ileb u v) (ileb u2 v) (ileb u2 v2)
      (congE Int Bool (fn (t : Int) is ileb t v end) u u2 eu)
      (congE Int Bool (fn (t : Int) is ileb u2 t end) v v2 ev)
  end
end

imulNegPos : (j : Whole) -> (d : Whole) -> Eq Int (imul (negsucc j) (nonneg (succ d))) (negsucc (dmul j d)) is
  fn (j : Whole) (d : Whole) is
    subst Whole (succ (dmul j d)) (mulW (succ j) (succ d))
      (symEq Whole (mulW (succ j) (succ d)) (succ (dmul j d)) (dmulSucc j d))
      (fn (w : Whole) is Eq Int (ineg (nonneg w)) (negsucc (dmul j d)) end)
      (refl (negsucc (dmul j d)))
  end
end

ilebMulPosR : (a : Int) -> (b : Int) -> (d : Whole) -> Eq Bool (ileb (imul a (nonneg (succ d))) (imul b (nonneg (succ d)))) (ileb a b) is
  fn (a : Int) (b : Int) (d : Whole) is
    IntElim (fn (wa : Int) is Eq Bool (ileb (imul wa (nonneg (succ d))) (imul b (nonneg (succ d)))) (ileb wa b) end)
      (fn (x : Whole) is
         IntElim (fn (wb : Int) is Eq Bool (ileb (imul (nonneg x) (nonneg (succ d))) (imul wb (nonneg (succ d)))) (ileb (nonneg x) wb) end)
           (fn (y : Whole) is lebMulPosR x y d end)
           (fn (j : Whole) is
              subst Int (negsucc (dmul j d)) (imul (negsucc j) (nonneg (succ d)))
                (symEq Int (imul (negsucc j) (nonneg (succ d))) (negsucc (dmul j d)) (imulNegPos j d))
                (fn (z : Int) is Eq Bool (ileb (imul (nonneg x) (nonneg (succ d))) z) false end)
                (refl false)
            end)
           b
       end)
      (fn (k : Whole) is
         IntElim (fn (wb : Int) is Eq Bool (ileb (imul (negsucc k) (nonneg (succ d))) (imul wb (nonneg (succ d)))) (ileb (negsucc k) wb) end)
           (fn (y : Whole) is
              subst Int (negsucc (dmul k d)) (imul (negsucc k) (nonneg (succ d)))
                (symEq Int (imul (negsucc k) (nonneg (succ d))) (negsucc (dmul k d)) (imulNegPos k d))
                (fn (z : Int) is Eq Bool (ileb z (imul (nonneg y) (nonneg (succ d)))) true end)
                (refl true)
            end)
           (fn (j : Whole) is
              subst Int (negsucc (dmul k d)) (imul (negsucc k) (nonneg (succ d)))
                (symEq Int (imul (negsucc k) (nonneg (succ d))) (negsucc (dmul k d)) (imulNegPos k d))
                (fn (z : Int) is Eq Bool (ileb z (imul (negsucc j) (nonneg (succ d)))) (leb j k) end)
                (subst Int (negsucc (dmul j d)) (imul (negsucc j) (nonneg (succ d)))
                   (symEq Int (imul (negsucc j) (nonneg (succ d))) (negsucc (dmul j d)) (imulNegPos j d))
                   (fn (z : Int) is Eq Bool (ileb (negsucc (dmul k d)) z) (leb j k) end)
                   (transEq Bool
                      (leb (succ (dmul j d)) (succ (dmul k d)))
                      (leb (mulW (succ j) (succ d)) (mulW (succ k) (succ d)))
                      (leb j k)
                      (transEq Bool
                         (leb (succ (dmul j d)) (succ (dmul k d)))
                         (leb (mulW (succ j) (succ d)) (succ (dmul k d)))
                         (leb (mulW (succ j) (succ d)) (mulW (succ k) (succ d)))
                         (congE Whole Bool (fn (t : Whole) is leb t (succ (dmul k d)) end)
                            (succ (dmul j d)) (mulW (succ j) (succ d))
                            (symEq Whole (mulW (succ j) (succ d)) (succ (dmul j d)) (dmulSucc j d)))
                         (congE Whole Bool (fn (t : Whole) is leb (mulW (succ j) (succ d)) t end)
                            (succ (dmul k d)) (mulW (succ k) (succ d))
                            (symEq Whole (mulW (succ k) (succ d)) (succ (dmul k d)) (dmulSucc k d))))
                      (lebMulPosR (succ j) (succ k) d)))
            end)
           b
       end)
      a
  end
end

leRespR : (p : QPair) -> (q : QPair) -> (q' : QPair) -> QRel q q'
    -> Eq Bool (ileb (imul (qnum p) (qden q)) (imul (qnum q) (qden p)))
               (ileb (imul (qnum p) (qden q')) (imul (qnum q') (qden p))) is
  fn (p : QPair) (q : QPair) (q' : QPair) (h : QRel q q') is
    let np : Int = qnum p in
    let dp : Int = qden p in
    let nq : Int = qnum q in
    let dq : Int = qden q in
    let nq' : Int = qnum q' in
    let dq' : Int = qden q' in
    transEq Bool
      (ileb (imul np dq) (imul nq dp))
      (ileb (imul (imul np dq') dq) (imul (imul nq' dp) dq))
      (ileb (imul np dq') (imul nq' dp))
      (transEq Bool
         (ileb (imul np dq) (imul nq dp))
         (ileb (imul (imul np dq) dq') (imul (imul nq dp) dq'))
         (ileb (imul (imul np dq') dq) (imul (imul nq' dp) dq))
         (symEq Bool
            (ileb (imul (imul np dq) dq') (imul (imul nq dp) dq'))
            (ileb (imul np dq) (imul nq dp))
            (ilebMulPosR (imul np dq) (imul nq dp) (qdpred q')))
         (congIleb2 (imul (imul np dq) dq') (imul (imul np dq') dq)
                    (imul (imul nq dp) dq') (imul (imul nq' dp) dq)
            (imulSwap3R np dq dq')
            (transEq Int (imul (imul nq dp) dq') (imul (imul nq dq') dp) (imul (imul nq' dp) dq)
               (imulSwap3R nq dp dq')
               (transEq Int (imul (imul nq dq') dp) (imul (imul nq' dq) dp) (imul (imul nq' dp) dq)
                  (congImulL (imul nq dq') (imul nq' dq) dp h)
                  (imulSwap3R nq' dq dp)))))
      (ilebMulPosR (imul np dq') (imul nq' dp) (qdpred q))
  end
end

leRespL : (p : QPair) -> (p' : QPair) -> (q : QPair) -> QRel p p'
    -> Eq Bool (ileb (imul (qnum p) (qden q)) (imul (qnum q) (qden p)))
               (ileb (imul (qnum p') (qden q)) (imul (qnum q) (qden p'))) is
  fn (p : QPair) (p' : QPair) (q : QPair) (h : QRel p p') is
    let np : Int = qnum p in
    let dp : Int = qden p in
    let np' : Int = qnum p' in
    let dp' : Int = qden p' in
    let nq : Int = qnum q in
    let dq : Int = qden q in
    transEq Bool
      (ileb (imul np dq) (imul nq dp))
      (ileb (imul (imul np' dq) dp) (imul (imul nq dp') dp))
      (ileb (imul np' dq) (imul nq dp'))
      (transEq Bool
         (ileb (imul np dq) (imul nq dp))
         (ileb (imul (imul np dq) dp') (imul (imul nq dp) dp'))
         (ileb (imul (imul np' dq) dp) (imul (imul nq dp') dp))
         (symEq Bool
            (ileb (imul (imul np dq) dp') (imul (imul nq dp) dp'))
            (ileb (imul np dq) (imul nq dp))
            (ilebMulPosR (imul np dq) (imul nq dp) (qdpred p')))
         (congIleb2 (imul (imul np dq) dp') (imul (imul np' dq) dp)
                    (imul (imul nq dp) dp') (imul (imul nq dp') dp)
            (transEq Int (imul (imul np dq) dp') (imul (imul np dp') dq) (imul (imul np' dq) dp)
               (imulSwap3R np dq dp')
               (transEq Int (imul (imul np dp') dq) (imul (imul np' dp) dq) (imul (imul np' dq) dp)
                  (congImulL (imul np dp') (imul np' dp) dq h)
                  (imulSwap3R np' dp dq)))
            (imulSwap3R nq dp dp')))
      (ilebMulPosR (imul np' dq) (imul nq dp') (qdpred p))
  end
end

leFR : QPair -> Frac -> Bool is
  fn (p : QPair) is
    qlift QPair QRel Bool
      (fn (q : QPair) is ileb (imul (qnum p) (qden q)) (imul (qnum q) (qden p)) end)
      (fn (q : QPair) (q' : QPair) (r : QRel q q') is leRespR p q q' r end)
  end
end

leF : Frac -> Frac -> Bool is
  qlift QPair QRel (Frac -> Bool) leFR
    (fn (p : QPair) (p' : QPair) (r : QRel p p') is
      fn (z : Frac) is
        qind QPair QRel (fn (w : Frac) is Eq Bool (leFR p w) (leFR p' w) end)
          (fn (q : QPair) is leRespL p p' q r end)
          z
      end
    end)
end

instance ordFrac   : Ord Frac   is mkOrd Frac leF (compareFromLe Frac leF) end

leReflF : (a : Frac) -> Le Frac ordFrac a a is
  fn (a : Frac) is
    qind QPair QRel (fn (w : Frac) is Eq Bool (leF w w) true end)
      (fn (p : QPair) is ilebReflP (imul (qnum p) (qden p)) end)
      a
  end
end

crossTransP : (p : QPair) -> (q : QPair) -> (r : QPair)
    -> Eq Bool (ileb (imul (qnum p) (qden q)) (imul (qnum q) (qden p))) true
    -> Eq Bool (ileb (imul (qnum q) (qden r)) (imul (qnum r) (qden q))) true
    -> Eq Bool (ileb (imul (qnum p) (qden r)) (imul (qnum r) (qden p))) true is
  fn (p : QPair) (q : QPair) (r : QPair)
     (h1 : Eq Bool (ileb (imul (qnum p) (qden q)) (imul (qnum q) (qden p))) true)
     (h2 : Eq Bool (ileb (imul (qnum q) (qden r)) (imul (qnum r) (qden q))) true) is
    let np : Int = qnum p in
    let dp : Int = qden p in
    let nq : Int = qnum q in
    let dq : Int = qden q in
    let nr : Int = qnum r in
    let dr : Int = qden r in
    let s1 : Eq Bool (ileb (imul (imul np dq) dr) (imul (imul nq dp) dr)) true =
      transEq Bool (ileb (imul (imul np dq) dr) (imul (imul nq dp) dr)) (ileb (imul np dq) (imul nq dp)) true
        (ilebMulPosR (imul np dq) (imul nq dp) (qdpred r))
        h1 in
    let s2raw : Eq Bool (ileb (imul (imul nq dr) dp) (imul (imul nr dq) dp)) true =
      transEq Bool (ileb (imul (imul nq dr) dp) (imul (imul nr dq) dp)) (ileb (imul nq dr) (imul nr dq)) true
        (ilebMulPosR (imul nq dr) (imul nr dq) (qdpred p))
        h2 in
    let s2 : Eq Bool (ileb (imul (imul nq dp) dr) (imul (imul nr dq) dp)) true =
      transEq Bool (ileb (imul (imul nq dp) dr) (imul (imul nr dq) dp)) (ileb (imul (imul nq dr) dp) (imul (imul nr dq) dp)) true
        (symEq Bool (ileb (imul (imul nq dr) dp) (imul (imul nr dq) dp)) (ileb (imul (imul nq dp) dr) (imul (imul nr dq) dp))
           (congIleb2 (imul (imul nq dr) dp) (imul (imul nq dp) dr) (imul (imul nr dq) dp) (imul (imul nr dq) dp)
              (imulSwap3R nq dr dp)
              (refl (imul (imul nr dq) dp))))
        s2raw in
    let s3 : Eq Bool (ileb (imul (imul np dq) dr) (imul (imul nr dq) dp)) true =
      ilebTransP (imul (imul np dq) dr) (imul (imul nq dp) dr) (imul (imul nr dq) dp) s1 s2 in
    let s4 : Eq Bool (ileb (imul (imul np dr) dq) (imul (imul nr dp) dq)) true =
      transEq Bool (ileb (imul (imul np dr) dq) (imul (imul nr dp) dq)) (ileb (imul (imul np dq) dr) (imul (imul nr dq) dp)) true
        (symEq Bool (ileb (imul (imul np dq) dr) (imul (imul nr dq) dp)) (ileb (imul (imul np dr) dq) (imul (imul nr dp) dq))
           (congIleb2 (imul (imul np dq) dr) (imul (imul np dr) dq) (imul (imul nr dq) dp) (imul (imul nr dp) dq)
              (imulSwap3R np dq dr)
              (imulSwap3R nr dq dp)))
        s3 in
    transEq Bool (ileb (imul np dr) (imul nr dp)) (ileb (imul (imul np dr) dq) (imul (imul nr dp) dq)) true
      (symEq Bool (ileb (imul (imul np dr) dq) (imul (imul nr dp) dq)) (ileb (imul np dr) (imul nr dp))
         (ilebMulPosR (imul np dr) (imul nr dp) (qdpred q)))
      s4
  end
end

leTransF : (a : Frac) -> (b : Frac) -> (c : Frac)
    -> Le Frac ordFrac a b -> Le Frac ordFrac b c -> Le Frac ordFrac a c is
  fn (a : Frac) (b : Frac) (c : Frac) (hab : Le Frac ordFrac a b) (hbc : Le Frac ordFrac b c) is
    qind QPair QRel
      (fn (wx : Frac) is (yy : Frac) -> (zz : Frac) -> Eq Bool (leF wx yy) true -> Eq Bool (leF yy zz) true -> Eq Bool (leF wx zz) true end)
      (fn (p : QPair) is
        fn (yy : Frac) is
          qind QPair QRel
            (fn (wy : Frac) is (zz : Frac) -> Eq Bool (leF (qin QPair QRel p) wy) true -> Eq Bool (leF wy zz) true -> Eq Bool (leF (qin QPair QRel p) zz) true end)
            (fn (q : QPair) is
              fn (zz : Frac) is
                qind QPair QRel
                  (fn (wz : Frac) is Eq Bool (leF (qin QPair QRel p) (qin QPair QRel q)) true -> Eq Bool (leF (qin QPair QRel q) wz) true -> Eq Bool (leF (qin QPair QRel p) wz) true end)
                  (fn (r : QPair) is
                    fn (g1 : Eq Bool (leF (qin QPair QRel p) (qin QPair QRel q)) true) (g2 : Eq Bool (leF (qin QPair QRel q) (qin QPair QRel r)) true) is
                      crossTransP p q r g1 g2
                    end
                   end)
                  zz
              end
            end)
            yy
        end
      end)
      a b c hab hbc
  end
end

leAntisymF : (a : Frac) -> (b : Frac)
    -> Le Frac ordFrac a b -> Le Frac ordFrac b a -> Eq Frac a b is
  fn (a : Frac) (b : Frac) (hab : Le Frac ordFrac a b) (hba : Le Frac ordFrac b a) is
    qind QPair QRel
      (fn (wx : Frac) is (yy : Frac) -> Eq Bool (leF wx yy) true -> Eq Bool (leF yy wx) true -> Eq Frac wx yy end)
      (fn (p : QPair) is
        fn (yy : Frac) is
          qind QPair QRel
            (fn (wy : Frac) is Eq Bool (leF (qin QPair QRel p) wy) true -> Eq Bool (leF wy (qin QPair QRel p)) true -> Eq Frac (qin QPair QRel p) wy end)
            (fn (q : QPair) is
              fn (g1 : Eq Bool (leF (qin QPair QRel p) (qin QPair QRel q)) true) (g2 : Eq Bool (leF (qin QPair QRel q) (qin QPair QRel p)) true) is
                qsound QPair QRel p q
                  (ilebAntisymP (imul (qnum p) (qden q)) (imul (qnum q) (qden p)) g1 g2)
              end
            end)
            yy
        end
      end)
      a b hab hba
  end
end

leTotalF : (a : Frac) -> (b : Frac)
    -> Eq Bool (or (leOf Frac ordFrac a b) (leOf Frac ordFrac b a)) true is
  fn (a : Frac) (b : Frac) is
    qind QPair QRel
      (fn (wx : Frac) is (yy : Frac) -> Eq Bool (or (leOf Frac ordFrac wx yy) (leOf Frac ordFrac yy wx)) true end)
      (fn (p : QPair) is
        fn (yy : Frac) is
          qind QPair QRel
            (fn (wy : Frac) is Eq Bool (or (leOf Frac ordFrac (qin QPair QRel p) wy) (leOf Frac ordFrac wy (qin QPair QRel p))) true end)
            (fn (q : QPair) is ilebTotalP (imul (qnum p) (qden q)) (imul (qnum q) (qden p)) end)
            yy
        end
      end)
      a b
  end
end

ordLawsFrac : OrdLaws Frac ordFrac is
  mkAnd ((a : Frac) -> Le Frac ordFrac a a)
    (And ((a : Frac) -> (b : Frac) -> (c : Frac) -> Le Frac ordFrac a b -> Le Frac ordFrac b c -> Le Frac ordFrac a c)
    (And ((a : Frac) -> (b : Frac) -> Le Frac ordFrac a b -> Le Frac ordFrac b a -> Eq Frac a b)
    (And ((a : Frac) -> (b : Frac) -> Eq Bool (or (leOf Frac ordFrac a b) (leOf Frac ordFrac b a)) true)
    (And ((a : Frac) -> (b : Frac) -> Eq Ordering (compareOf Frac ordFrac a b) eq -> Eq Frac a b)
         ((a : Frac) -> (b : Frac) -> Eq Ordering (compareOf Frac ordFrac a b) lt -> Le Frac ordFrac a b)))))
    leReflF
    (mkAnd ((a : Frac) -> (b : Frac) -> (c : Frac) -> Le Frac ordFrac a b -> Le Frac ordFrac b c -> Le Frac ordFrac a c)
      (And ((a : Frac) -> (b : Frac) -> Le Frac ordFrac a b -> Le Frac ordFrac b a -> Eq Frac a b)
      (And ((a : Frac) -> (b : Frac) -> Eq Bool (or (leOf Frac ordFrac a b) (leOf Frac ordFrac b a)) true)
      (And ((a : Frac) -> (b : Frac) -> Eq Ordering (compareOf Frac ordFrac a b) eq -> Eq Frac a b)
           ((a : Frac) -> (b : Frac) -> Eq Ordering (compareOf Frac ordFrac a b) lt -> Le Frac ordFrac a b))))
      leTransF
      (mkAnd ((a : Frac) -> (b : Frac) -> Le Frac ordFrac a b -> Le Frac ordFrac b a -> Eq Frac a b)
        (And ((a : Frac) -> (b : Frac) -> Eq Bool (or (leOf Frac ordFrac a b) (leOf Frac ordFrac b a)) true)
        (And ((a : Frac) -> (b : Frac) -> Eq Ordering (compareOf Frac ordFrac a b) eq -> Eq Frac a b)
             ((a : Frac) -> (b : Frac) -> Eq Ordering (compareOf Frac ordFrac a b) lt -> Le Frac ordFrac a b)))
        leAntisymF
        (mkAnd ((a : Frac) -> (b : Frac) -> Eq Bool (or (leOf Frac ordFrac a b) (leOf Frac ordFrac b a)) true)
          (And ((a : Frac) -> (b : Frac) -> Eq Ordering (compareOf Frac ordFrac a b) eq -> Eq Frac a b)
               ((a : Frac) -> (b : Frac) -> Eq Ordering (compareOf Frac ordFrac a b) lt -> Le Frac ordFrac a b))
          leTotalF
          (mkAnd ((a : Frac) -> (b : Frac) -> Eq Ordering (compareOf Frac ordFrac a b) eq -> Eq Frac a b)
                 ((a : Frac) -> (b : Frac) -> Eq Ordering (compareOf Frac ordFrac a b) lt -> Le Frac ordFrac a b)
            (fn (a : Frac) (b : Frac) (h : Eq Ordering (compareOf Frac ordFrac a b) eq) is
               let pr : And (Eq Bool (leF a b) true) (Eq Bool (leF b a) true) =
                 compareFromLeEq Frac leF a b h in
               leAntisymF a b (pr.1) (pr.2)
             end)
            (fn (a : Frac) (b : Frac) (h : Eq Ordering (compareOf Frac ordFrac a b) lt) is
               compareFromLeLt Frac leF a b h
             end)))))
end


-- ============================================================
-- THE ORDERED ALGEBRA BRIDGE. An ordered semiring / ring / field is an ops
-- instance PLUS an Ord PLUS the two order-compat laws, stated over the
-- erased Le view. AddMonoT: addition is monotone on the right. MulNonnegT:
-- a product of nonnegatives is nonnegative. The three law records nest by
-- inheritance -- OrderedRingLaws carries RingLaws alongside OrderedSemiring
-- Laws over the ring's embedded semiring (r.1), so the two compat laws are
-- stated once at the semiring rung. OrderedFieldLaws tops the ladder with
-- commutativity over the DivRing's semiring (d.1.1). Projections confirmed
-- against mkSemiring / mkRing / mkDivRing: add s.1, zero s.2.1, mul s.2.2.1.
-- ============================================================
AddMonoT : (A : U) -> Ord A -> (A -> A -> A) -> U is
  fn (A : U) (o : Ord A) (add : A -> A -> A) is
    (a : A) -> (b : A) -> (c : A) -> Le A o a b -> Le A o (add a c) (add b c)
  end
end

MulNonnegT : (A : U) -> Ord A -> (A -> A -> A) -> A -> U is
  fn (A : U) (o : Ord A) (mul : A -> A -> A) (z : A) is
    (a : A) -> (b : A) -> Le A o z a -> Le A o z b -> Le A o z (mul a b)
  end
end

OrderedSemiringLaws : (A : U) -> Semiring A -> Ord A -> U is
  fn (A : U) (s : Semiring A) (o : Ord A) is
    And (SemiringLaws A s)
    (And (OrdLaws A o)
    (And (AddMonoT A o (s.1))
         (MulNonnegT A o (s.2.2.1) (s.2.1))))
  end
end

OrderedRingLaws : (A : U) -> Ring A -> Ord A -> U is
  fn (A : U) (r : Ring A) (o : Ord A) is
    And (RingLaws A r) (OrderedSemiringLaws A (r.1) o)
  end
end

OrderedFieldLaws : (A : U) -> DivRing A -> Ord A -> (A -> U) -> U is
  fn (A : U) (d : DivRing A) (o : Ord A) (nz : A -> U) is
    And (OrderedRingLaws A (d.1) o) (CommLaws A (d.1.1))
  end
end


-- ------------------------------------------------------------
-- WHOLE ORDERED SEMIRING. Whole is a Semiring (no negation), so its top
-- rung is the ordered SEMIRING. addMonoWhole transports lebAddMono (add on
-- the LEFT) across addWComm to the right-addition form; mulNonnegWhole is
-- refl true (leb zero _ reduces to true, so Whole nonnegativity is
-- universal and the hypotheses are unused).
-- ------------------------------------------------------------
addMonoWhole : AddMonoT Whole ordWhole addW is
  fn (a : Whole) (b : Whole) (c : Whole) (h : Le Whole ordWhole a b) is
    subst Whole (addW c b) (addW b c) (addWComm c b)
      (fn (t : Whole) is Eq Bool (leb (addW a c) t) true end)
      (subst Whole (addW c a) (addW a c) (addWComm c a)
        (fn (s : Whole) is Eq Bool (leb s (addW c b)) true end)
        (lebAddMono c a b h))
  end
end

mulNonnegWhole : MulNonnegT Whole ordWhole mulW zero is
  fn (a : Whole) (b : Whole) (ha : Le Whole ordWhole zero a) (hb : Le Whole ordWhole zero b) is
    refl true
  end
end

orderedSemiringLawsWhole : OrderedSemiringLaws Whole semiringWhole ordWhole is
  mkAnd (SemiringLaws Whole semiringWhole)
    (And (OrdLaws Whole ordWhole)
    (And (AddMonoT Whole ordWhole (semiringWhole.1))
         (MulNonnegT Whole ordWhole (semiringWhole.2.2.1) (semiringWhole.2.1))))
    semiringLawsWhole
    (mkAnd (OrdLaws Whole ordWhole)
      (And (AddMonoT Whole ordWhole (semiringWhole.1))
           (MulNonnegT Whole ordWhole (semiringWhole.2.2.1) (semiringWhole.2.1)))
      ordLawsWhole
      (mkAnd (AddMonoT Whole ordWhole (semiringWhole.1))
             (MulNonnegT Whole ordWhole (semiringWhole.2.2.1) (semiringWhole.2.1))
        addMonoWhole
        mulNonnegWhole))
end


-- ------------------------------------------------------------
-- INT ORDERED RING. Int IS a Ring, so its rung is the ordered RING over the
-- embedded semiring ringInt.1. addMonoInt is the substantial slot: a sign-
-- case tree (nested IntElim on a, b, c) with the hypothesis a<=b carried in
-- the motive, so every reachable leaf's goal is a `... = true` and the
-- impossible sign combinations are ex-falso by boolDiscTF. The mixed-sign
-- iadd cases produce wsub (whole-minus-whole as a signed Int), handled by
-- the four helper lemmas below (built from lebPred + the two monus-
-- monotonicity facts); the same-sign leaves reduce to addMonoWhole.
-- mulNonnegInt forces both factors nonneg, then imul (nonneg)(nonneg) is
-- nonneg on the nose -- refl true. No cancellation anywhere.
-- ------------------------------------------------------------
lebPred : (x : Whole) -> (y : Whole) -> Eq Bool (leb x y) true
    -> Eq Bool (leb (pred x) (pred y)) true is
  fn (x : Whole) is
    case x of
    | zero -> fn (y : Whole) (h : Eq Bool true true) is refl true end
    | succ x2 -> fn (y : Whole) is
        case y of
        | zero -> fn (h : Eq Bool false true) is
            boolDiscTF (Eq Bool (leb (pred (succ x2)) (pred zero)) true)
              (symEq Bool false true h) end
        | succ y2 -> fn (h : Eq Bool (leb x2 y2) true) is h end
        end
      end
    end
  end
end

monusLeMono1 : (s : Whole) -> (m : Whole) -> (n : Whole)
    -> Eq Bool (leb m n) true -> Eq Bool (leb (subW m s) (subW n s)) true is
  fn (s : Whole) is
    case s of
    | zero -> fn (m : Whole) (n : Whole) (h : Eq Bool (leb m n) true) is h end
    | succ s2 with ih -> fn (m : Whole) (n : Whole) (h : Eq Bool (leb m n) true) is
        lebPred (subW m s2) (subW n s2) (ih m n h) end
    end
  end
end

ilebWsubMinuendMono : (s : Whole) -> (m : Whole) -> (n : Whole)
    -> Eq Bool (leb m n) true -> Eq Bool (ileb (wsub m s) (wsub n s)) true is
  fn (s : Whole) (m : Whole) (n : Whole) (h : Eq Bool (leb m n) true) is
    boolCaseEq (leb s m)
      (fn (g1 : Bool) is Eq Bool (ileb (wsub m s) (wsub n s)) true end)
      (fn (e1 : Eq Bool (leb s m) true) is
         boolCaseEq (leb s n)
           (fn (g2 : Bool) is Eq Bool (ileb (wsub m s) (wsub n s)) true end)
           (fn (e2 : Eq Bool (leb s n) true) is
              transEq Bool (ileb (wsub m s) (wsub n s))
                (ileb (nonneg (subW m s)) (nonneg (subW n s))) true
                (congIleb2 (wsub m s) (nonneg (subW m s)) (wsub n s) (nonneg (subW n s))
                   (wsubTrue m s e1) (wsubTrue n s e2))
                (monusLeMono1 s m n h)
            end)
           (fn (e2 : Eq Bool (leb s n) false) is
              boolDiscTF (Eq Bool (ileb (wsub m s) (wsub n s)) true)
                (transEq Bool true (leb s n) false
                   (symEq Bool (leb s n) true (lebTrans s m n e1 h)) e2)
            end)
       end)
      (fn (e1 : Eq Bool (leb s m) false) is
         boolCaseEq (leb s n)
           (fn (g2 : Bool) is Eq Bool (ileb (wsub m s) (wsub n s)) true end)
           (fn (e2 : Eq Bool (leb s n) true) is
              transEq Bool (ileb (wsub m s) (wsub n s))
                (ileb (negsucc (subW s (succ m))) (nonneg (subW n s))) true
                (congIleb2 (wsub m s) (negsucc (subW s (succ m))) (wsub n s) (nonneg (subW n s))
                   (wsubFalse m s e1) (wsubTrue n s e2))
                (refl true)
            end)
           (fn (e2 : Eq Bool (leb s n) false) is
              transEq Bool (ileb (wsub m s) (wsub n s))
                (ileb (negsucc (subW s (succ m))) (negsucc (subW s (succ n)))) true
                (congIleb2 (wsub m s) (negsucc (subW s (succ m))) (wsub n s) (negsucc (subW s (succ n)))
                   (wsubFalse m s e1) (wsubFalse n s e2))
                (monusLeMono2 s (succ m) (succ n) h)
            end)
       end)
  end
end

ilebWsubSubtrahendMono : (p : Whole) -> (sk : Whole) -> (sj : Whole)
    -> Eq Bool (leb sj sk) true -> Eq Bool (ileb (wsub p sk) (wsub p sj)) true is
  fn (p : Whole) (sk : Whole) (sj : Whole) (h : Eq Bool (leb sj sk) true) is
    boolCaseEq (leb sk p)
      (fn (g1 : Bool) is Eq Bool (ileb (wsub p sk) (wsub p sj)) true end)
      (fn (e1 : Eq Bool (leb sk p) true) is
         boolCaseEq (leb sj p)
           (fn (g2 : Bool) is Eq Bool (ileb (wsub p sk) (wsub p sj)) true end)
           (fn (e2 : Eq Bool (leb sj p) true) is
              transEq Bool (ileb (wsub p sk) (wsub p sj))
                (ileb (nonneg (subW p sk)) (nonneg (subW p sj))) true
                (congIleb2 (wsub p sk) (nonneg (subW p sk)) (wsub p sj) (nonneg (subW p sj))
                   (wsubTrue p sk e1) (wsubTrue p sj e2))
                (monusLeMono2 p sj sk h)
            end)
           (fn (e2 : Eq Bool (leb sj p) false) is
              boolDiscTF (Eq Bool (ileb (wsub p sk) (wsub p sj)) true)
                (transEq Bool true (leb sj p) false
                   (symEq Bool (leb sj p) true (lebTrans sj sk p h e1)) e2)
            end)
       end)
      (fn (e1 : Eq Bool (leb sk p) false) is
         boolCaseEq (leb sj p)
           (fn (g2 : Bool) is Eq Bool (ileb (wsub p sk) (wsub p sj)) true end)
           (fn (e2 : Eq Bool (leb sj p) true) is
              transEq Bool (ileb (wsub p sk) (wsub p sj))
                (ileb (negsucc (subW sk (succ p))) (nonneg (subW p sj))) true
                (congIleb2 (wsub p sk) (negsucc (subW sk (succ p))) (wsub p sj) (nonneg (subW p sj))
                   (wsubFalse p sk e1) (wsubTrue p sj e2))
                (refl true)
            end)
           (fn (e2 : Eq Bool (leb sj p) false) is
              transEq Bool (ileb (wsub p sk) (wsub p sj))
                (ileb (negsucc (subW sk (succ p))) (negsucc (subW sj (succ p)))) true
                (congIleb2 (wsub p sk) (negsucc (subW sk (succ p))) (wsub p sj) (negsucc (subW sj (succ p)))
                   (wsubFalse p sk e1) (wsubFalse p sj e2))
                (monusLeMono1 (succ p) sj sk h)
            end)
       end)
  end
end

ilebWsubNonnegR : (k : Whole) -> (n : Whole) -> (p : Whole)
    -> Eq Bool (ileb (wsub p (succ k)) (nonneg (addW n p))) true is
  fn (k : Whole) (n : Whole) (p : Whole) is
    boolCaseEq (leb (succ k) p)
      (fn (g1 : Bool) is Eq Bool (ileb (wsub p (succ k)) (nonneg (addW n p))) true end)
      (fn (e1 : Eq Bool (leb (succ k) p) true) is
         transEq Bool (ileb (wsub p (succ k)) (nonneg (addW n p)))
           (ileb (nonneg (subW p (succ k))) (nonneg (addW n p))) true
           (congIleb2 (wsub p (succ k)) (nonneg (subW p (succ k))) (nonneg (addW n p)) (nonneg (addW n p))
              (wsubTrue p (succ k) e1) (refl (nonneg (addW n p))))
           (lebTrans (subW p (succ k)) p (addW n p) (monusLe p (succ k)) (lteAddL n p))
       end)
      (fn (e1 : Eq Bool (leb (succ k) p) false) is
         transEq Bool (ileb (wsub p (succ k)) (nonneg (addW n p)))
           (ileb (negsucc (subW (succ k) (succ p))) (nonneg (addW n p))) true
           (congIleb2 (wsub p (succ k)) (negsucc (subW (succ k) (succ p))) (nonneg (addW n p)) (nonneg (addW n p))
              (wsubFalse p (succ k) e1) (refl (nonneg (addW n p))))
           (refl true)
       end)
  end
end

ilebNegsuccWsub : (k : Whole) -> (n : Whole) -> (q : Whole)
    -> Eq Bool (ileb (negsucc (succ (addW k q))) (wsub n (succ q))) true is
  fn (k : Whole) (n : Whole) (q : Whole) is
    boolCaseEq (leb (succ q) n)
      (fn (g1 : Bool) is Eq Bool (ileb (negsucc (succ (addW k q))) (wsub n (succ q))) true end)
      (fn (e1 : Eq Bool (leb (succ q) n) true) is
         transEq Bool (ileb (negsucc (succ (addW k q))) (wsub n (succ q)))
           (ileb (negsucc (succ (addW k q))) (nonneg (subW n (succ q)))) true
           (congIleb2 (negsucc (succ (addW k q))) (negsucc (succ (addW k q)))
              (wsub n (succ q)) (nonneg (subW n (succ q)))
              (refl (negsucc (succ (addW k q)))) (wsubTrue n (succ q) e1))
           (refl true)
       end)
      (fn (e1 : Eq Bool (leb (succ q) n) false) is
         transEq Bool (ileb (negsucc (succ (addW k q))) (wsub n (succ q)))
           (ileb (negsucc (succ (addW k q))) (negsucc (subW (succ q) (succ n)))) true
           (congIleb2 (negsucc (succ (addW k q))) (negsucc (succ (addW k q)))
              (wsub n (succ q)) (negsucc (subW (succ q) (succ n)))
              (refl (negsucc (succ (addW k q)))) (wsubFalse n (succ q) e1))
           (subst Whole (subW q n) (subW (succ q) (succ n))
              (symEq Whole (subW (succ q) (succ n)) (subW q n) (subWSucc q n))
              (fn (t : Whole) is Eq Bool (leb t (succ (addW k q))) true end)
              (lebTrans (subW q n) q (succ (addW k q))
                 (monusLe q n)
                 (lebTrans q (addW k q) (succ (addW k q)) (lteAddL k q) (lebSuccSelf (addW k q)))))
       end)
  end
end

addMonoInt : AddMonoT Int ordInt iadd is
  fn (a : Int) (b : Int) (c : Int) is
    IntElim
      (fn (wa : Int) is (wb : Int) -> Le Int ordInt wa wb
         -> Le Int ordInt (iadd wa c) (iadd wb c) end)
      (fn (m : Whole) is fn (wb : Int) is
         IntElim
           (fn (wb2 : Int) is Le Int ordInt (nonneg m) wb2
              -> Le Int ordInt (iadd (nonneg m) c) (iadd wb2 c) end)
           (fn (n : Whole) (h : Le Int ordInt (nonneg m) (nonneg n)) is
              IntElim
                (fn (wc : Int) is Le Int ordInt (iadd (nonneg m) wc) (iadd (nonneg n) wc) end)
                (fn (p : Whole) is addMonoWhole m n p h end)
                (fn (q : Whole) is ilebWsubMinuendMono (succ q) m n h end)
                c
            end)
           (fn (j : Whole) (h : Le Int ordInt (nonneg m) (negsucc j)) is
              boolDiscTF (Le Int ordInt (iadd (nonneg m) c) (iadd (negsucc j) c))
                (symEq Bool false true h)
            end)
           wb
       end end)
      (fn (k : Whole) is fn (wb : Int) is
         IntElim
           (fn (wb2 : Int) is Le Int ordInt (negsucc k) wb2
              -> Le Int ordInt (iadd (negsucc k) c) (iadd wb2 c) end)
           (fn (n : Whole) (h : Le Int ordInt (negsucc k) (nonneg n)) is
              IntElim
                (fn (wc : Int) is Le Int ordInt (iadd (negsucc k) wc) (iadd (nonneg n) wc) end)
                (fn (p : Whole) is ilebWsubNonnegR k n p end)
                (fn (q : Whole) is ilebNegsuccWsub k n q end)
                c
            end)
           (fn (j : Whole) (h : Le Int ordInt (negsucc k) (negsucc j)) is
              IntElim
                (fn (wc : Int) is Le Int ordInt (iadd (negsucc k) wc) (iadd (negsucc j) wc) end)
                (fn (p : Whole) is ilebWsubSubtrahendMono p (succ k) (succ j) h end)
                (fn (q : Whole) is addMonoWhole j k q h end)
                c
            end)
           wb
       end end)
      a
      b
  end
end

mulNonnegInt : MulNonnegT Int ordInt imul (nonneg zero) is
  fn (a : Int) (b : Int) is
    IntElim
      (fn (wa : Int) is Le Int ordInt (nonneg zero) wa
         -> Le Int ordInt (nonneg zero) b -> Le Int ordInt (nonneg zero) (imul wa b) end)
      (fn (x : Whole) is fn (hx : Le Int ordInt (nonneg zero) (nonneg x)) is
         IntElim
           (fn (wb : Int) is Le Int ordInt (nonneg zero) wb
              -> Le Int ordInt (nonneg zero) (imul (nonneg x) wb) end)
           (fn (y : Whole) (hy : Le Int ordInt (nonneg zero) (nonneg y)) is refl true end)
           (fn (j : Whole) (hy : Le Int ordInt (nonneg zero) (negsucc j)) is
              boolDiscTF (Le Int ordInt (nonneg zero) (imul (nonneg x) (negsucc j)))
                (symEq Bool false true hy)
            end)
           b
       end end)
      (fn (k : Whole) is fn (hx : Le Int ordInt (nonneg zero) (negsucc k)) is
         fn (hy : Le Int ordInt (nonneg zero) b) is
           boolDiscTF (Le Int ordInt (nonneg zero) (imul (negsucc k) b))
             (symEq Bool false true hx)
         end
       end end)
      a
  end
end

orderedSemiringLawsInt : OrderedSemiringLaws Int (ringInt.1) ordInt is
  mkAnd (SemiringLaws Int (ringInt.1))
    (And (OrdLaws Int ordInt)
    (And (AddMonoT Int ordInt iadd)
         (MulNonnegT Int ordInt imul (nonneg zero))))
    semiringLawsInt
    (mkAnd (OrdLaws Int ordInt)
      (And (AddMonoT Int ordInt iadd)
           (MulNonnegT Int ordInt imul (nonneg zero)))
      ordLawsInt
      (mkAnd (AddMonoT Int ordInt iadd)
             (MulNonnegT Int ordInt imul (nonneg zero))
        addMonoInt
        mulNonnegInt))
end

orderedRingLawsInt : OrderedRingLaws Int ringInt ordInt is
  mkAnd (RingLaws Int ringInt) (OrderedSemiringLaws Int (ringInt.1) ordInt)
    ringLawsInt orderedSemiringLawsInt
end


-- ------------------------------------------------------------
-- FRAC ORDERED FIELD -- THE DELIVERABLE (the tower's first ordered field).
-- Frac is a DivRing, so its rung is the ordered FIELD. The two compat laws
-- lift out of the quotient by qind to representatives, where leF is the Int
-- cross-comparison. mulNonnegF reduces to mulNonnegP (a product of two
-- nonnegative numerators, mulNonnegInt; the denominator is irrelevant to
-- sign). addMonoF reduces to crossAddMonoP: align the sum denominators
-- (qdenMul), distribute each numerator (idistribR), SCALE the hypothesis by
-- the positive dr*dr with ilebMulPosR, and re-attach the shared r-term with
-- addMonoInt. Positive-scaling monotonicity + addition throughout -- NOT
-- multiplicative cancellation, no gcd, no lowest terms. orderedFieldLawsFrac
-- composes with fieldLawsFrac for the full ordered-field story.
-- ------------------------------------------------------------
mulNonnegP : (p : QPair) -> (q : QPair)
    -> Eq Bool (ileb (nonneg zero) (imul (qnum p) (nonneg (succ zero)))) true
    -> Eq Bool (ileb (nonneg zero) (imul (qnum q) (nonneg (succ zero)))) true
    -> Eq Bool (ileb (nonneg zero) (imul (imul (qnum p) (qnum q)) (nonneg (succ zero)))) true is
  fn (p : QPair) (q : QPair)
     (hx : Eq Bool (ileb (nonneg zero) (imul (qnum p) (nonneg (succ zero)))) true)
     (hy : Eq Bool (ileb (nonneg zero) (imul (qnum q) (nonneg (succ zero)))) true) is
    let hp : Eq Bool (ileb (nonneg zero) (qnum p)) true =
      subst Int (imul (qnum p) (nonneg (succ zero))) (qnum p) (imulOneR (qnum p))
        (fn (z : Int) is Eq Bool (ileb (nonneg zero) z) true end) hx in
    let hq : Eq Bool (ileb (nonneg zero) (qnum q)) true =
      subst Int (imul (qnum q) (nonneg (succ zero))) (qnum q) (imulOneR (qnum q))
        (fn (z : Int) is Eq Bool (ileb (nonneg zero) z) true end) hy in
    let hpq : Eq Bool (ileb (nonneg zero) (imul (qnum p) (qnum q))) true =
      mulNonnegInt (qnum p) (qnum q) hp hq in
    subst Int (imul (qnum p) (qnum q)) (imul (imul (qnum p) (qnum q)) (nonneg (succ zero)))
      (symEq Int (imul (imul (qnum p) (qnum q)) (nonneg (succ zero))) (imul (qnum p) (qnum q))
         (imulOneR (imul (qnum p) (qnum q))))
      (fn (z : Int) is Eq Bool (ileb (nonneg zero) z) true end) hpq
  end
end

mulNonnegF : MulNonnegT Frac ordFrac mulF (fracOf zero) is
  fn (a : Frac) (b : Frac) is
    qind QPair QRel
      (fn (wa : Frac) is (yy : Frac) -> Eq Bool (leF (fracOf zero) wa) true -> Eq Bool (leF (fracOf zero) yy) true -> Eq Bool (leF (fracOf zero) (mulF wa yy)) true end)
      (fn (p : QPair) is
        fn (yy : Frac) is
          qind QPair QRel
            (fn (wy : Frac) is Eq Bool (leF (fracOf zero) (qin QPair QRel p)) true -> Eq Bool (leF (fracOf zero) wy) true -> Eq Bool (leF (fracOf zero) (mulF (qin QPair QRel p) wy)) true end)
            (fn (q : QPair) is
              fn (hx : Eq Bool (leF (fracOf zero) (qin QPair QRel p)) true)
                 (hy : Eq Bool (leF (fracOf zero) (qin QPair QRel q)) true) is
                mulNonnegP p q hx hy
              end
             end)
            yy
        end
      end)
      a b
  end
end

crossAddMonoP : (p : QPair) -> (q : QPair) -> (r : QPair)
    -> Eq Bool (leF (qin QPair QRel p) (qin QPair QRel q)) true
    -> Eq Bool (leF (addF (qin QPair QRel p) (qin QPair QRel r))
                    (addF (qin QPair QRel q) (qin QPair QRel r))) true is
  fn (p : QPair) (q : QPair) (r : QPair)
     (h : Eq Bool (ileb (imul (qnum p) (qden q)) (imul (qnum q) (qden p))) true) is
    let np : Int = qnum p in
    let dp : Int = qden p in
    let nq : Int = qnum q in
    let dq : Int = qden q in
    let nr : Int = qnum r in
    let dr : Int = qden r in
    let dri : Whole = qdpred r in
    let npr : Int = iadd (imul np dr) (imul nr dp) in
    let nqr : Int = iadd (imul nq dr) (imul nr dq) in
    let bigA : Int = imul (imul np dq) (imul dr dr) in
    let bigB : Int = imul (imul nq dp) (imul dr dr) in
    let y1 : Int = imul (imul nr dp) (imul dq dr) in
    let x1 : Int = imul (imul np dr) (imul dq dr) in
    let x2 : Int = imul (imul nq dr) (imul dp dr) in
    let y2 : Int = imul (imul nr dq) (imul dp dr) in
    let drdrEq : Eq Int (imul dr dr) (nonneg (succ (dmul dri dri))) =
      congNonneg (mulW (succ dri) (succ dri)) (succ (dmul dri dri)) (dmulSucc dri dri) in
    let scaledHyp0 : Eq Bool (ileb (imul (imul np dq) (nonneg (succ (dmul dri dri))))
                                   (imul (imul nq dp) (nonneg (succ (dmul dri dri))))) true =
      transEq Bool (ileb (imul (imul np dq) (nonneg (succ (dmul dri dri))))
                         (imul (imul nq dp) (nonneg (succ (dmul dri dri)))))
                   (ileb (imul np dq) (imul nq dp)) true
        (ilebMulPosR (imul np dq) (imul nq dp) (dmul dri dri))
        h in
    let scaledHyp : Eq Bool (ileb bigA bigB) true =
      transEq Bool (ileb bigA bigB)
                   (ileb (imul (imul np dq) (nonneg (succ (dmul dri dri))))
                         (imul (imul nq dp) (nonneg (succ (dmul dri dri))))) true
        (congIleb2 bigA (imul (imul np dq) (nonneg (succ (dmul dri dri))))
                   bigB (imul (imul nq dp) (nonneg (succ (dmul dri dri))))
           (congImulR (imul np dq) (imul dr dr) (nonneg (succ (dmul dri dri))) drdrEq)
           (congImulR (imul nq dp) (imul dr dr) (nonneg (succ (dmul dri dri))) drdrEq))
        scaledHyp0 in
    let distGoal : Eq Bool (ileb (iadd x1 y1) (iadd x2 y2)) true =
      transEq Bool (ileb (iadd x1 y1) (iadd x2 y2)) (ileb (iadd bigA y1) (iadd bigB y1)) true
        (congIleb2 (iadd x1 y1) (iadd bigA y1) (iadd x2 y2) (iadd bigB y1)
           (congIaddL x1 bigA y1 (imulInterchange np dr dq dr))
           (congIadd2 x2 bigB y2 y1 (imulInterchange nq dr dp dr) (imulInterchange nr dq dp dr)))
        (addMonoInt bigA bigB y1 scaledHyp) in
    transEq Bool
      (ileb (imul npr (nonneg (succ (dmul (qdpred q) dri))))
            (imul nqr (nonneg (succ (dmul (qdpred p) dri)))))
      (ileb (imul npr (imul dq dr)) (imul nqr (imul dp dr))) true
      (congIleb2 (imul npr (nonneg (succ (dmul (qdpred q) dri)))) (imul npr (imul dq dr))
                 (imul nqr (nonneg (succ (dmul (qdpred p) dri)))) (imul nqr (imul dp dr))
         (congImulR npr (nonneg (succ (dmul (qdpred q) dri))) (imul dq dr) (qdenMul q r))
         (congImulR nqr (nonneg (succ (dmul (qdpred p) dri))) (imul dp dr) (qdenMul p r)))
      (transEq Bool (ileb (imul npr (imul dq dr)) (imul nqr (imul dp dr)))
                    (ileb (iadd x1 y1) (iadd x2 y2)) true
        (congIleb2 (imul npr (imul dq dr)) (iadd x1 y1) (imul nqr (imul dp dr)) (iadd x2 y2)
           (idistribR (imul np dr) (imul nr dp) (imul dq dr))
           (idistribR (imul nq dr) (imul nr dq) (imul dp dr)))
        distGoal)
  end
end

addMonoF : AddMonoT Frac ordFrac addF is
  fn (a : Frac) (b : Frac) (c : Frac) is
    qind QPair QRel
      (fn (wa : Frac) is (yy : Frac) -> (zz : Frac) -> Eq Bool (leF wa yy) true
         -> Eq Bool (leF (addF wa zz) (addF yy zz)) true end)
      (fn (p : QPair) is
        fn (yy : Frac) is
          qind QPair QRel
            (fn (wy : Frac) is (zz : Frac) -> Eq Bool (leF (qin QPair QRel p) wy) true
               -> Eq Bool (leF (addF (qin QPair QRel p) zz) (addF wy zz)) true end)
            (fn (q : QPair) is
              fn (zz : Frac) is
                qind QPair QRel
                  (fn (wz : Frac) is Eq Bool (leF (qin QPair QRel p) (qin QPair QRel q)) true
                     -> Eq Bool (leF (addF (qin QPair QRel p) wz) (addF (qin QPair QRel q) wz)) true end)
                  (fn (r : QPair) is
                    fn (hpq : Eq Bool (leF (qin QPair QRel p) (qin QPair QRel q)) true) is
                      crossAddMonoP p q r hpq
                    end
                   end)
                  zz
              end
            end)
            yy
        end
      end)
      a b c
  end
end

orderedSemiringLawsFrac : OrderedSemiringLaws Frac (divRingFrac.1.1) ordFrac is
  mkAnd (SemiringLaws Frac (divRingFrac.1.1))
    (And (OrdLaws Frac ordFrac)
    (And (AddMonoT Frac ordFrac addF)
         (MulNonnegT Frac ordFrac mulF (fracOf zero))))
    semiringLawsFrac
    (mkAnd (OrdLaws Frac ordFrac)
      (And (AddMonoT Frac ordFrac addF)
           (MulNonnegT Frac ordFrac mulF (fracOf zero)))
      ordLawsFrac
      (mkAnd (AddMonoT Frac ordFrac addF)
             (MulNonnegT Frac ordFrac mulF (fracOf zero))
        addMonoF
        mulNonnegF))
end

orderedRingLawsFrac : OrderedRingLaws Frac (divRingFrac.1) ordFrac is
  mkAnd (RingLaws Frac (divRingFrac.1)) (OrderedSemiringLaws Frac (divRingFrac.1.1) ordFrac)
    ringLawsFrac orderedSemiringLawsFrac
end

orderedFieldLawsFrac : OrderedFieldLaws Frac divRingFrac ordFrac nzFrac is
  mkAnd (OrderedRingLaws Frac (divRingFrac.1) ordFrac) (CommLaws Frac (divRingFrac.1.1))
    orderedRingLawsFrac commLawsFrac
end


-- A closing exercise: the ordered structure's base comparison COMPUTES.
-- compareOf on the Int instance folds ileb's two directions into one
-- verdict; 1 sits above -1, so comparing (nonneg 1) with (negsucc 0) is gt.
main : Ordering is compareOf Int ordInt (nonneg (succ zero)) (negsucc zero) end
