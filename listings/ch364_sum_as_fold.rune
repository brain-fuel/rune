-- Chapter 364 — sum is a fold: sum xs = foldr natAdd 0 xs (proven tier).
--
-- The list sum recovered as the catamorphism over the additive monoid (natAdd, 0). By
-- induction on xs. Proof-only.
--
--   sumAsFold : (xs : NatList) -> Eq Nat (sum xs) (foldr Nat natAdd zero xs)

data Nat : U is
  zero : Nat
| succ : Nat -> Nat
end
builtin nat Nat zero succ

data NatList : U is
  nnil  : NatList
| ncons : Nat -> NatList -> NatList
end

-- (Eq / refl / subst are ambient, as in ch03.)

cong : (A : U) -> (B : U) -> (f : A -> B) -> (x : A) -> (y : A) -> Eq A x y -> Eq B (f x) (f y) is
  fn (A : U) (B : U) (f : A -> B) (x : A) (y : A) (p : Eq A x y) is
    subst A x y p (fn (z : A) is Eq B (f x) (f z) end) refl
  end
end

natAdd : Nat -> Nat -> Nat is
  fn (a : Nat) (b : Nat) is
    NatElim (fn (x : Nat) is Nat end) b (fn (k : Nat) (ih : Nat) is succ ih end) a
  end
end

foldr : (B : U) -> (Nat -> B -> B) -> B -> NatList -> B is
  fn (B : U) (f : Nat -> B -> B) (z : B) (xs : NatList) is
    NatListElim (fn (x : NatList) is B end)
      z
      (fn (h : Nat) (rest : NatList) (ih : B) is f h ih end)
      xs
  end
end

sum : NatList -> Nat is
  fn (xs : NatList) is
    NatListElim (fn (x : NatList) is Nat end)
      zero
      (fn (h : Nat) (rest : NatList) (ih : Nat) is natAdd h ih end)
      xs
  end
end

sumAsFold : (xs : NatList) -> Eq Nat (sum xs) (foldr Nat natAdd zero xs) is
  fn (xs : NatList) is
    NatListElim (fn (z : NatList) is Eq Nat (sum z) (foldr Nat natAdd zero z) end)
      refl
      (fn (h : Nat) (rest : NatList) (ih : Eq Nat (sum rest) (foldr Nat natAdd zero rest)) is
         cong Nat Nat (natAdd h) (sum rest) (foldr Nat natAdd zero rest) ih end)
      xs
  end
end
