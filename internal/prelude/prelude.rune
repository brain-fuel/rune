-- The REPL prelude: enough arithmetic for `1 + 1` to mean 2 at the prompt.
-- Everything here is ordinary surface rune — the same definitions as the
-- ch11 listing, no special status in the core. `rune repl --no-prelude`
-- starts a bare session (the book's discipline: nothing you didn't write).
--
-- The numeric tower. `Whole` is the FOUNDATION — the initial algebra {0,1,2,…}
-- with `zero`/`succ`, the type induction bottoms out on and the one bare
-- numerals bind to (so `0` has a type). `Nat` is the COUNTING numbers {1,2,3,…}
-- sitting one rung up (no zero), injected into `Whole` by `wholeOf`. `Int` and
-- `Rat` are the quotient libraries above (see the int/rational listings). The
-- calculator (`+ - * // %`, gcd) lives at `Whole`.

data Whole : U is
  zero : Whole
| succ : Whole -> Whole
end

builtin nat Whole zero succ

-- The Whole-level arithmetic kernels. These are NAMED (addW/mulW/subW) so the
-- operators `+`/`-`/`*` below can be OVERLOADED across the tower (Whole and the
-- signed fractions) by typeclass dispatch — `1 + 1` is Whole addition, `1/3 + 2/3`
-- is fraction addition, the SAME symbol. The kernels carry the bigint acceleration.

addW : Whole -> Whole -> Whole is
  fn (m : Whole) (n : Whole) is
    case m of
    | zero -> n
    | succ k with ih -> succ ih
    end
  end
end

-- Accelerate addition on closed literals: `4000 + 4000` takes one bigint step
-- instead of building a succ-chain. Registration runs a differential gate (the
-- unfolded body must equal bigint add on a battery of pairs), so this stays
-- kernel-sound; it fires ONLY when both arguments are NatLit.
builtin natAdd addW

mulW : Whole -> Whole -> Whole is
  fn (m : Whole) (n : Whole) is
    case m of
    | zero -> 0
    | succ k with ih -> addW ih n
    end
  end
end

-- Accelerate multiplication likewise — what makes `4000 * 4000` instant instead
-- of materialising 16 million succ nodes (and overflowing the stack at readback).
builtin natMul mulW

pred : Whole -> Whole is
  fn (n : Whole) is
    case n of
    | zero -> 0
    | succ k -> k
    end
  end
end

-- Truncated subtraction: m - n stops at zero (Whole has nothing below it).
subW : Whole -> Whole -> Whole is
  fn (m : Whole) (n : Whole) is
    case n of
    | zero -> m
    | succ k with ih -> pred ih
    end
  end
end

-- Accelerate truncated subtraction (saturating monus) on closed literals.
builtin natMonus subW

data Bool : U is
  true : Bool
| false : Bool
end

-- ====================================================================
-- THE ALGEBRAIC OPS LADDER (v4). Three Σ-record classes carrying OPERATIONS
-- ONLY: Semiring {add, zero, mul, one} -> Ring {+neg} -> DivRing {+recip}.
-- Laws live in SEPARATE records (SemiringLaws and friends, below), so a type
-- that can compute but not prove (IEEE754, later) still gets ops instances.
-- Superclass access is projection: a Ring contains its Semiring as .1.
-- POSITIONAL DISCIPLINE (the Num lesson): a class is identified by its
-- STRUCTURE, so two classes with identical field-type sequences collide.
-- Shapes here: Semiring A = Sig (A->A->A) (Sig A (Sig (A->A->A) A));
-- Ring A = Sig (Semiring A) (A->A); DivRing A = Sig (Ring A) (A->A) - all
-- pairwise distinct, gated by TestTowerClassHashesDistinct.
-- `recip` is TOTAL with the junk value recip zero = zero (Mathlib's move);
-- the true inverse law is guarded by a nonzero hypothesis laws-side.
-- ====================================================================
Semiring : U -> U is
  fn (A : U) is
    Sig (A -> A -> A) (fn (_add : A -> A -> A) is
      Sig A (fn (_zero : A) is
        Sig (A -> A -> A) (fn (_mul : A -> A -> A) is A end)
      end)
    end)
  end
end
mkSemiring : (A : U) -> (A -> A -> A) -> A -> (A -> A -> A) -> A -> Semiring A is
  fn (A : U) (a : A -> A -> A) (z : A) (m : A -> A -> A) (o : A) is
    Pair (A -> A -> A) (fn (_add : A -> A -> A) is
        Sig A (fn (_zero : A) is
          Sig (A -> A -> A) (fn (_mul : A -> A -> A) is A end)
        end)
      end)
      a
      (Pair A (fn (_zero : A) is
          Sig (A -> A -> A) (fn (_mul : A -> A -> A) is A end)
        end)
        z
        (Pair (A -> A -> A) (fn (_mul : A -> A -> A) is A end) m o))
  end
end

Ring : U -> U is
  fn (A : U) is Sig (Semiring A) (fn (_s : Semiring A) is A -> A end) end
end
mkRing : (A : U) -> Semiring A -> (A -> A) -> Ring A is
  fn (A : U) (s : Semiring A) (n : A -> A) is
    Pair (Semiring A) (fn (_s : Semiring A) is A -> A end) s n
  end
end

DivRing : U -> U is
  fn (A : U) is Sig (Ring A) (fn (_r : Ring A) is A -> A end) end
end
mkDivRing : (A : U) -> Ring A -> (A -> A) -> DivRing A is
  fn (A : U) (r : Ring A) (rc : A -> A) is
    Pair (Ring A) (fn (_r : Ring A) is A -> A end) r rc
  end
end

-- ====================================================================
-- ARITHMETIC DISPATCH. `+` and `*` are Semiring-constrained: the elaborator
-- resolves the dictionary from the argument TYPE (class = type family,
-- instance = registered value; see the ops-ladder banner above). Whole,
-- Int, and Frac each register a Semiring instance below at their rungs.
-- Subtraction is NOT here: ℕ is not closed under it (2 − 5 has no whole
-- answer), so `-` PROMOTES (Whole → Int) via the result-typed `SubR` class
-- below; `/` likewise promotes to Frac; `// %` are integer ops at Whole.
-- ====================================================================
instance semiringWhole : Semiring Whole is mkSemiring Whole addW zero mulW (succ zero) end

+ : {A : U} -> {d : Semiring A} -> A -> A -> A is
  fn {A : U} {d : Semiring A} (x : A) (y : A) is (d.1) x y end
end
* : {A : U} -> {d : Semiring A} -> A -> A -> A is
  fn {A : U} {d : Semiring A} (x : A) (y : A) is (d.2.2.1) x y end
end

-- ====================================================================
-- MAGMA / MONOID - the overloaded append `++` (and `mempty`), built on the SAME
-- Σ-record-class + instance-search pattern as `Semiring`/`+`. `++` is DISTINCT from the
-- numeric `+` (Raku's lesson: keep `+` arithmetic) and resolves to whatever instance
-- the argument type carries: String (packed `Bytes`, below) and List (in the listings).
-- `++` dispatches over `Magma` (a bare binary operation; a semigroup is a magma whose
-- op is PROVEN associative - the lawful record a later task adds below); a Monoid
-- adds an identity (`mempty`). `++` is right-associative and looser than `+`
-- (Haskell's `++`); GRAMMAR §3.
-- ====================================================================
Magma : U -> U is fn (A : U) is A -> A -> A end end
Monoid    : U -> U is fn (A : U) is Sig (A -> A -> A) (fn (_p : A -> A -> A) is A end) end end
mkMonoid : (A : U) -> (A -> A -> A) -> A -> Monoid A is
  fn (A : U) (a : A -> A -> A) (e : A) is
    Pair (A -> A -> A) (fn (_p : A -> A -> A) is A end) a e
  end
end

++ : {A : U} -> {d : Magma A} -> A -> A -> A is
  fn {A : U} {d : Magma A} (x : A) (y : A) is d x y end
end
mempty : {A : U} -> {d : Monoid A} -> A is fn {A : U} {d : Monoid A} is d.2 end end

-- Group: a monoid with an inverse operation. Nests Monoid the way Ring
-- nests Semiring (projection g.1 monoid, g.2 inv); structurally distinct
-- from Ring because the first component differs (Monoid A vs Semiring A).
-- Abelian-ness is a LAW (AbGroupLaws below), never ops-side.
Group : U -> U is
  fn (A : U) is Sig (Monoid A) (fn (_m : Monoid A) is A -> A end) end
end
mkGroup : (A : U) -> Monoid A -> (A -> A) -> Group A is
  fn (A : U) (m : Monoid A) (i : A -> A) is
    Pair (Monoid A) (fn (_m : Monoid A) is A -> A end) m i
  end
end

-- leb m n decides m <= n; recursion on m produces the comparison FUNCTION,
-- so the induction hypothesis is "compare against k" awaiting its argument.
leb : Whole -> Whole -> Bool is
  fn (m : Whole) is
    case m of
    | zero -> fn (n : Whole) is true end
    | succ k with ih -> fn (n : Whole) is
        case n of
        | zero -> false
        | succ j -> ih j
        end
      end
    end
  end
end

-- Equality plumbing built from `subst` (the sole Leibniz primitive; there is no
-- ambient `ap`/`cong`/`sym`/`trans`). These let the lemmas below rewrite under a
-- context and chain steps.
symEq : (A : U) -> (x : A) -> (y : A) -> Eq A x y -> Eq A y x is
  fn (A : U) (x : A) (y : A) (p : Eq A x y) is
    subst A x y p (fn (z : A) is Eq A z x end) (refl x)
  end
end
transEq : (A : U) -> (x : A) -> (y : A) -> (z : A) -> Eq A x y -> Eq A y z -> Eq A x z is
  fn (A : U) (x : A) (y : A) (z : A) (p : Eq A x y) (q : Eq A y z) is
    subst A y z q (fn (w : A) is Eq A x w end) p
  end
end

-- `isZero` is the depth-1 zero-test (compiles to an O(1) constructor dispatch, no
-- eliminator loop), complementary to `isPos`.
isZero : Whole -> Bool is
  fn (n : Whole) is case n of | zero -> true | succ k -> false end end
end

-- subW order lemmas (by induction; `subW` recurses on its SECOND arg).
-- subWZeroL: 0 - b truncates to 0.
subWZeroL : (b : Whole) -> Eq Whole (subW zero b) zero is
  fn (b : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (subW zero x) zero end)
      (refl zero)
      (fn (k : Whole) (ih : Eq Whole (subW zero k) zero) is
         subst Whole (subW zero k) zero ih
           (fn (z : Whole) is Eq Whole (subW zero (succ k)) (pred z) end)
           (refl (subW zero (succ k)))
       end)
      b
  end
end
-- subWSucc: cancelling one from both sides leaves the subtraction unchanged.
subWSucc : (a : Whole) -> (b : Whole) -> Eq Whole (subW (succ a) (succ b)) (subW a b) is
  fn (a : Whole) (b : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (subW (succ a) (succ x)) (subW a x) end)
      (refl a)
      (fn (k : Whole) (ih : Eq Whole (subW (succ a) (succ k)) (subW a k)) is
         subst Whole (subW (succ a) (succ k)) (subW a k) ih
           (fn (z : Whole) is Eq Whole (subW (succ a) (succ (succ k))) (pred z) end)
           (refl (subW (succ a) (succ (succ k))))
       end)
      b
  end
end

-- leW: the accel-friendly `<=`. `subW` is the kernel-accelerated native subtract
-- (O(1) on bignums) and `isZero` is depth-1, so `leW a b` is O(1) in COMPILED code
-- where `leb a b` is O(a) — `leb` recurses into a comparison FUNCTION the eager
-- NatElim codegen fully unrolls (catastrophic on packed-bignum-sized Wholes; fine
-- in the lazy kernel). Prefer `leW` for comparisons on values that deploy.
leW : Whole -> Whole -> Bool is
  fn (a : Whole) (b : Whole) is isZero (subW a b) end
end
-- ...and the certificate that the refactor is sound: leW agrees with leb pointwise
-- (double induction; leb recurses on the first arg, subW on the second).
lebEquiv : (a : Whole) -> (b : Whole) -> Eq Bool (leb a b) (leW a b) is
  fn (a : Whole) is
    WholeElim (fn (x : Whole) is (b : Whole) -> Eq Bool (leb x b) (isZero (subW x b)) end)
      (fn (b : Whole) is
         symEq Bool (isZero (subW zero b)) true
           (subst Whole zero (subW zero b) (symEq Whole (subW zero b) zero (subWZeroL b))
              (fn (z : Whole) is Eq Bool (isZero z) true end)
              (refl true))
       end)
      (fn (k : Whole) (ih : (b : Whole) -> Eq Bool (leb k b) (isZero (subW k b))) is
         fn (b : Whole) is
           WholeElim (fn (x : Whole) is Eq Bool (leb (succ k) x) (isZero (subW (succ k) x)) end)
             (refl false)
             (fn (j : Whole) (ihb : Eq Bool (leb (succ k) j) (isZero (subW (succ k) j))) is
                transEq Bool (leb k j) (isZero (subW k j)) (isZero (subW (succ k) (succ j)))
                  (ih j)
                  (symEq Bool (isZero (subW (succ k) (succ j))) (isZero (subW k j))
                     (subst Whole (subW (succ k) (succ j)) (subW k j) (subWSucc k j)
                        (fn (z : Whole) is Eq Bool (isZero (subW (succ k) (succ j))) (isZero z) end)
                        (refl (isZero (subW (succ k) (succ j))))))
              end)
             b
         end
       end)
      a
  end
end

-- Division and modulus by repeated subtraction, with the dividend as fuel:
-- each step removes at least one from the dividend, so the budget suffices
-- exactly. The flooring quotient of anything by zero is 0; n % 0 is n,
-- keeping DIV-LAW (a = (a // b) * b + a % b) true at b = 0 too
-- (ref_docs/rune-numeric-tower.md). `/` is exact division and lives at Rat.

divF : Whole -> Whole -> Whole -> Whole is
  fn (fuel : Whole) is
    case fuel of
    | zero -> fn (a : Whole) (b : Whole) is 0 end
    | succ f with ih -> fn (a : Whole) (b : Whole) is
        case b of
        | zero -> 0
        | succ k ->
            case leb b a of
            | true -> succ (ih (subW a b) b)
            | false -> 0
            end
        end
      end
    end
  end
end

modF : Whole -> Whole -> Whole -> Whole is
  fn (fuel : Whole) is
    case fuel of
    | zero -> fn (a : Whole) (b : Whole) is a end
    | succ f with ih -> fn (a : Whole) (b : Whole) is
        case b of
        | zero -> a
        | succ k ->
            case leb b a of
            | true -> ih (subW a b) b
            | false -> a
            end
        end
      end
    end
  end
end

// : Whole -> Whole -> Whole is
  fn (m : Whole) (n : Whole) is divF m m n end
end

% : Whole -> Whole -> Whole is
  fn (m : Whole) (n : Whole) is modF m m n end
end

-- Kernel-accelerate `//` and `%` on literals (C7 / R-NUM Decision 1): the
-- fuel-based bodies are correct but O(quotient); the accel makes division a
-- one-bigint-step op on compressed numerals, so it scales to the large literals
-- that packed-String `uncons` (n div/mod 256) and a real calculator need. Bridge
-- to the fuel body is refl; agreement is the differential-tested registration gate.
builtin natDiv //
builtin natMod %

-- Euclid. The second argument strictly decreases (a % b < b), so its
-- successor is budget enough.
gcdF : Whole -> Whole -> Whole -> Whole is
  fn (fuel : Whole) is
    case fuel of
    | zero -> fn (a : Whole) (b : Whole) is a end
    | succ f with ih -> fn (a : Whole) (b : Whole) is
        case b of
        | zero -> a
        | succ k -> ih b (a % b)
        end
      end
    end
  end
end

gcd : Whole -> Whole -> Whole is
  fn (a : Whole) (b : Whole) is gcdF (succ b) a b end
end

-- isPos decides nonzero-ness: false on zero, true on every successor. It is the
-- predicate that carves the counting numbers out of the wholes.
isPos : Whole -> Bool is
  fn (n : Whole) is
    case n of
    | zero -> false
    | succ k -> true
    end
  end
end

-- Nat: the counting numbers {1,2,3,…} as the POSITIVE wholes — a whole paired
-- with a proof it is nonzero. A bare Peano `data Nat is one | nsucc` would be
-- HASH-IDENTICAL to Whole (same shape, and identity is structure not names), so
-- the distinct type must have distinct structure: this Σ. `zero` cannot inhabit
-- it — that would need `Eq Bool false true`, which is uninhabited — so Nat is
-- zeroless by construction. `wholeOf` is the injection Nat ↪ Whole (= .1).
Nat : U is
  Sig Whole (fn (n : Whole) is Eq Bool (isPos n) true end)
end

-- one = 1, the least counting number; the proof is refl since isPos (succ zero)
-- computes to true.
one : Nat is
  Pair Whole (fn (n : Whole) is Eq Bool (isPos n) true end) (succ zero) (refl true)
end

-- nsucc steps a counting number up; the successor of anything is positive, so
-- the nonzero proof is refl regardless of the predecessor.
nsucc : Nat -> Nat is
  fn (k : Nat) is
    Pair Whole (fn (n : Whole) is Eq Bool (isPos n) true end) (succ (k.1)) (refl true)
  end
end

-- The injection up the tower: a counting number IS its underlying whole. Nat is
-- literally a subset of Whole, so wholeOf is the first projection; its image is
-- exactly the positives {1,2,3,…}.
wholeOf : Nat -> Whole is
  fn (k : Nat) is k.1 end
end

-- ====================================================================
-- THE FRAC RUNG lives BELOW the Int ring-law corpus now: Frac is a
-- QUOTIENT of Int-numerator pairs (Quot QPair QRel) and its qlift
-- respect proofs spend the ringLawsInt lemmas, so the whole rung is
-- defined after them (search "THE FRAC RUNG").
-- ====================================================================

-- ====================================================================
-- THE INT RUNG (ℤ).  Whole is not closed under subtraction, so `-` PROMOTES into
-- the signed integers. Int is JUNK-FREE: `nonneg n` denotes n and `negsucc k`
-- denotes -(k+1), so every constructor application is a distinct integer and
-- there is no representation outside the normalized image. The prior
-- sign+magnitude encoding needed a normalizing smart constructor because
-- `int true zero` and `int false zero` were TWO values denoting the same
-- integer zero, a negative-zero junk value that sat outside the smart
-- constructor's image and poisoned any law proved by pattern-matching the
-- representation (a case split on the raw constructor had to carry an extra
-- proof obligation identifying the two zeros). `intOf` injects a whole;
-- `builtin int` lets a bare numeral check at Int (so `(2-5) + 1` works, the
-- `1` becomes an Int).
-- ====================================================================
data Int : U is
  nonneg  : Whole -> Int
| negsucc : Whole -> Int
end
intOf : Whole -> Int is fn (n : Whole) is nonneg n end end
builtin int Int intOf
isign : Int -> Bool is
  fn (i : Int) is case i of | nonneg n -> false | negsucc k -> true end end
end
imag : Int -> Whole is
  fn (i : Int) is case i of | nonneg n -> n | negsucc k -> succ k end end
end
ineg : Int -> Int is
  fn (i : Int) is
    case i of
    | nonneg n -> case n of | zero -> nonneg zero | succ k -> negsucc k end
    | negsucc k -> nonneg (succ k)
    end
  end
end
-- THE PROMOTION: whole minus whole, as a signed integer.
wsub : Whole -> Whole -> Int is
  fn (a : Whole) (b : Whole) is
    case leb b a of
    | true -> nonneg (subW a b)
    | false -> negsucc (subW b (succ a))
    end
  end
end
iadd : Int -> Int -> Int is
  fn (x : Int) (y : Int) is
    case x of
    | nonneg a ->
        case y of
        | nonneg c -> nonneg (addW a c)
        | negsucc d -> wsub a (succ d)
        end
    | negsucc b ->
        case y of
        | nonneg c -> wsub c (succ b)
        | negsucc d -> negsucc (succ (addW b d))
        end
    end
  end
end
isub : Int -> Int -> Int is fn (x : Int) (y : Int) is iadd x (ineg y) end end
imul : Int -> Int -> Int is
  fn (x : Int) (y : Int) is
    case x of
    | nonneg a ->
        case y of
        | nonneg c -> nonneg (mulW a c)
        | negsucc d -> ineg (nonneg (mulW a (succ d)))
        end
    | negsucc b ->
        case y of
        | nonneg c -> ineg (nonneg (mulW (succ b) c))
        | negsucc d -> nonneg (mulW (succ b) (succ d))
        end
    end
  end
end
-- Int's full rung is a Ring (ℤ is not closed under reciprocal; division
-- promotes to Frac via divIF below).
ringInt : Ring Int is
  mkRing Int (mkSemiring Int iadd (nonneg zero) imul (nonneg (succ zero))) ineg
end
instance semiringInt : Semiring Int is ringInt.1 end

-- Int / Int division (divIF) climbs to Q; it is defined with the Frac
-- rung below.

-- Build a signed Int from a Bool sign + Whole magnitude, normalizing away
-- negative zero: for sites below that hold a sign and a magnitude apart
-- (a demotion from Frac, a parsed sign, a Binary encoder) rather than a
-- value already committed to nonneg/negsucc.
signOfMag : Bool -> Whole -> Int is
  fn (s : Bool) (m : Whole) is
    case s of
    | false -> nonneg m
    | true -> case m of | zero -> nonneg zero | succ k -> negsucc k end
    end
  end
end

-- ====================================================================
-- NEGATION, with PROMOTION.  Negating an unsigned `Whole` has no whole answer, so
-- `negate` PROMOTES Whole -> Int, exactly as `-` does (`0 - 3` is `-3 : Int`); Int
-- and Frac are already signed and stay put. Result-indexed like `SubR` (the result
-- R is a separate parameter keyed by the operand A), so a bare `-3` lands at Int and
-- `-1/3` at Frac. Prefix `-` desugars to `negate`.
-- ====================================================================
NegR : U -> U -> U is fn (R : U) (A : U) is A -> R end end
wneg : Whole -> Int is fn (n : Whole) is ineg (nonneg n) end end
instance negWhole : NegR Int  Whole is wneg end
instance negInt   : NegR Int  Int   is ineg end
negate : {R : U} -> {A : U} -> {d : NegR R A} -> A -> R is
  fn {R : U} {A : U} {d : NegR R A} (x : A) is d x end
end

-- ====================================================================
-- SUBTRACTION, with PROMOTION.  `SubR R A` is the RELATION "an A subtracts to an
-- R": its dictionary is just the operation `A -> A -> R`. Indexing the RESULT type
-- R as a separate parameter (keyed by A, the last argument) makes the instances
-- distinct AND lets the result type be a plain inferred type rather than a stuck
-- projection — so `(2 - 5) + 1` composes. Whole − Whole promotes to Int, Int − Int
-- stays Int, Frac − Frac stays Frac. `2 - 5` is `-3 : Int`, `5 - 2` is `3 : Int`,
-- `1/3 - 2/3` is `-1/3 : Frac`. Whole − Whole has no whole answer, so `-` will not
-- type-check at Whole — use `monus`/`minus` (below) for a whole result.
-- ====================================================================
SubR : U -> U -> U is fn (R : U) (A : U) is A -> A -> R end end
instance subWhole : SubR Int  Whole is wsub end
instance subInt   : SubR Int  Int   is isub end
- : {R : U} -> {A : U} -> {d : SubR R A} -> A -> A -> R is
  fn {R : U} {A : U} {d : SubR R A} (x : A) (y : A) is d x y end
end

-- ====================================================================
-- LAW STATEMENTS (v4). Reusable propositions over raw operations; the law
-- RECORDS chain them with a non-dependent And. Laws are SEPARATE from the
-- ops classes so proof-free carriers (IEEE754, later) still get ops.
-- ====================================================================
And : U -> U -> U is fn (P : U) (Q : U) is Sig P (fn (_p : P) is Q end) end end
mkAnd : (P : U) -> (Q : U) -> P -> Q -> And P Q is
  fn (P : U) (Q : U) (p : P) (q : Q) is Pair P (fn (_p : P) is Q end) p q end
end

AssocT : (A : U) -> (A -> A -> A) -> U is
  fn (A : U) (f : A -> A -> A) is (a : A) -> (b : A) -> (c : A) -> Eq A (f (f a b) c) (f a (f b c)) end
end
CommT : (A : U) -> (A -> A -> A) -> U is
  fn (A : U) (f : A -> A -> A) is (a : A) -> (b : A) -> Eq A (f a b) (f b a) end
end
IdLT : (A : U) -> (A -> A -> A) -> A -> U is
  fn (A : U) (f : A -> A -> A) (e : A) is (a : A) -> Eq A (f e a) a end
end
IdRT : (A : U) -> (A -> A -> A) -> A -> U is
  fn (A : U) (f : A -> A -> A) (e : A) is (a : A) -> Eq A (f a e) a end
end
DistribLT : (A : U) -> (A -> A -> A) -> (A -> A -> A) -> U is
  fn (A : U) (add : A -> A -> A) (mul : A -> A -> A) is
    (a : A) -> (b : A) -> (c : A) -> Eq A (mul a (add b c)) (add (mul a b) (mul a c))
  end
end
DistribRT : (A : U) -> (A -> A -> A) -> (A -> A -> A) -> U is
  fn (A : U) (add : A -> A -> A) (mul : A -> A -> A) is
    (a : A) -> (b : A) -> (c : A) -> Eq A (mul (add a b) c) (add (mul a c) (mul b c))
  end
end
AnnihLT : (A : U) -> (A -> A -> A) -> A -> U is
  fn (A : U) (mul : A -> A -> A) (z : A) is (a : A) -> Eq A (mul z a) z end
end
AnnihRT : (A : U) -> (A -> A -> A) -> A -> U is
  fn (A : U) (mul : A -> A -> A) (z : A) is (a : A) -> Eq A (mul a z) z end
end

-- The semiring laws over an ops instance: additive commutative monoid,
-- multiplicative monoid, distributivity both sides, zero annihilates.
SemiringLaws : (A : U) -> Semiring A -> U is
  fn (A : U) (s : Semiring A) is
    And (AssocT A (s.1))
    (And (CommT A (s.1))
    (And (IdLT A (s.1) (s.2.1))
    (And (IdRT A (s.1) (s.2.1))
    (And (AssocT A (s.2.2.1))
    (And (IdLT A (s.2.2.1) (s.2.2.2))
    (And (IdRT A (s.2.2.1) (s.2.2.2))
    (And (DistribLT A (s.1) (s.2.2.1))
    (And (DistribRT A (s.1) (s.2.2.1))
    (And (AnnihLT A (s.2.2.1) (s.2.1))
         (AnnihRT A (s.2.2.1) (s.2.1)))))))))))
  end
end

-- ====================================================================
-- WHOLE'S SEMIRING LAWS, machine-checked. Proven over the raw kernels addW/mulW
-- (which semiringWhole's projections compute to definitionally), by WholeElim
-- induction with subst/symEq/transEq plumbing, mirroring the subWZeroL/subWSucc
-- proofs above and ch107's Nat semiring. addW recurses on its FIRST argument;
-- mulW steps by `addW ih n` (ih FIRST; the operand order differs from ch107's
-- `add n ih`, so the mul proofs are adapted, not transcribed).
-- ====================================================================

-- Local congruence (there is no ambient cong): rewrite under a Whole context.
congW : (f : Whole -> Whole) -> (x : Whole) -> (y : Whole) -> Eq Whole x y -> Eq Whole (f x) (f y) is
  fn (f : Whole -> Whole) (x : Whole) (y : Whole) (p : Eq Whole x y) is
    subst Whole x y p (fn (z : Whole) is Eq Whole (f x) (f z) end) (refl (f x))
  end
end

-- addW is associative (induction on the first argument).
addWAssoc : AssocT Whole addW is
  fn (a : Whole) (b : Whole) (c : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (addW (addW x b) c) (addW x (addW b c)) end)
      (refl (addW b c))
      (fn (k : Whole) (ih : Eq Whole (addW (addW k b) c) (addW k (addW b c))) is
         subst Whole (addW (addW k b) c) (addW k (addW b c)) ih
           (fn (z : Whole) is Eq Whole (succ (addW (addW k b) c)) (succ z) end)
           (refl (succ (addW (addW k b) c)))
       end)
      a
  end
end

-- addW zero a = a definitionally (addW recurses on its first argument).
addWZeroL : IdLT Whole addW zero is fn (a : Whole) is refl a end end

-- addW a zero = a (induction on a; the recursion is stuck on a neutral first arg).
addWZeroR : IdRT Whole addW zero is
  fn (a : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (addW x zero) x end)
      (refl zero)
      (fn (k : Whole) (ih : Eq Whole (addW k zero) k) is
         subst Whole (addW k zero) k ih
           (fn (z : Whole) is Eq Whole (addW (succ k) zero) (succ z) end)
           (refl (addW (succ k) zero))
       end)
      a
  end
end

-- Pushing a successor out of the second argument (mirrors ch107's addSuccR).
addWSuccR : (m : Whole) -> (n : Whole) -> Eq Whole (addW m (succ n)) (succ (addW m n)) is
  fn (m : Whole) (n : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (addW x (succ n)) (succ (addW x n)) end)
      (refl (succ n))
      (fn (k : Whole) (ih : Eq Whole (addW k (succ n)) (succ (addW k n))) is
         subst Whole (addW k (succ n)) (succ (addW k n)) ih
           (fn (z : Whole) is Eq Whole (addW (succ k) (succ n)) (succ z) end)
           (refl (addW (succ k) (succ n)))
       end)
      m
  end
end

-- addW is commutative (induction on the first argument; needs addWZeroR + addWSuccR).
addWComm : CommT Whole addW is
  fn (a : Whole) (b : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (addW x b) (addW b x) end)
      (subst Whole (addW b zero) b (addWZeroR b)
         (fn (z : Whole) is Eq Whole z (addW b zero) end)
         (refl (addW b zero)))
      (fn (k : Whole) (ih : Eq Whole (addW k b) (addW b k)) is
         subst Whole (succ (addW b k)) (addW b (succ k))
           (subst Whole (addW b (succ k)) (succ (addW b k)) (addWSuccR b k)
              (fn (z : Whole) is Eq Whole z (addW b (succ k)) end)
              (refl (addW b (succ k))))
           (fn (z : Whole) is Eq Whole (succ (addW k b)) z end)
           (subst Whole (addW k b) (addW b k) ih
              (fn (z : Whole) is Eq Whole (succ (addW k b)) (succ z) end)
              (refl (succ (addW k b))))
       end)
      a
  end
end

-- A rearrangement workhorse: (x + y) + w = (x + w) + y (from assoc + comm).
addWSwapR : (x : Whole) -> (y : Whole) -> (w : Whole) -> Eq Whole (addW (addW x y) w) (addW (addW x w) y) is
  fn (x : Whole) (y : Whole) (w : Whole) is
    transEq Whole (addW (addW x y) w) (addW x (addW y w)) (addW (addW x w) y)
      (addWAssoc x y w)
      (transEq Whole (addW x (addW y w)) (addW x (addW w y)) (addW (addW x w) y)
         (congW (fn (t : Whole) is addW x t end) (addW y w) (addW w y) (addWComm y w))
         (symEq Whole (addW (addW x w) y) (addW x (addW w y)) (addWAssoc x w y)))
  end
end

-- (a + x) + succ y = (a + y) + succ x (assoc + succ-shift + comm); feeds mulWSuccR.
addWShiftSucc : (a : Whole) -> (x : Whole) -> (y : Whole)
  -> Eq Whole (addW (addW a x) (succ y)) (addW (addW a y) (succ x)) is
  fn (a : Whole) (x : Whole) (y : Whole) is
    transEq Whole (addW (addW a x) (succ y)) (addW a (addW x (succ y))) (addW (addW a y) (succ x))
      (addWAssoc a x (succ y))
      (transEq Whole (addW a (addW x (succ y))) (addW a (succ (addW y x))) (addW (addW a y) (succ x))
         (congW (fn (t : Whole) is addW a t end) (addW x (succ y)) (succ (addW y x))
            (transEq Whole (addW x (succ y)) (succ (addW x y)) (succ (addW y x))
               (addWSuccR x y)
               (congW (fn (t : Whole) is succ t end) (addW x y) (addW y x) (addWComm x y))))
         (transEq Whole (addW a (succ (addW y x))) (addW a (addW y (succ x))) (addW (addW a y) (succ x))
            (congW (fn (t : Whole) is addW a t end) (succ (addW y x)) (addW y (succ x))
               (symEq Whole (addW y (succ x)) (succ (addW y x)) (addWSuccR y x)))
            (symEq Whole (addW (addW a y) (succ x)) (addW a (addW y (succ x))) (addWAssoc a y (succ x)))))
  end
end

-- mul zero a = 0 definitionally (mulW's zero case returns 0).
mulWZeroL : AnnihLT Whole mulW zero is fn (a : Whole) is refl zero end end

-- mul a zero = 0 (induction on a; addWZeroR mops up the stuck `addW _ zero`).
mulWZeroR : AnnihRT Whole mulW zero is
  fn (a : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (mulW x zero) zero end)
      (refl zero)
      (fn (k : Whole) (ih : Eq Whole (mulW k zero) zero) is
         transEq Whole (mulW (succ k) zero) (mulW k zero) zero
           (addWZeroR (mulW k zero))
           ih
       end)
      a
  end
end

-- RIGHT distributivity: (a + b) * c = a*c + b*c (induction on a).
distribWR : DistribRT Whole addW mulW is
  fn (a : Whole) (b : Whole) (c : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (mulW (addW x b) c) (addW (mulW x c) (mulW b c)) end)
      (refl (mulW b c))
      (fn (k : Whole) (ih : Eq Whole (mulW (addW k b) c) (addW (mulW k c) (mulW b c))) is
         transEq Whole
           (addW (mulW (addW k b) c) c)
           (addW (addW (mulW k c) (mulW b c)) c)
           (addW (addW (mulW k c) c) (mulW b c))
           (congW (fn (t : Whole) is addW t c end) (mulW (addW k b) c) (addW (mulW k c) (mulW b c)) ih)
           (addWSwapR (mulW k c) (mulW b c) c)
       end)
      a
  end
end

-- Multiplicative successor-shift: mul n (succ m) = mul n m + n (induction on n).
mulWSuccR : (n : Whole) -> (m : Whole) -> Eq Whole (mulW n (succ m)) (addW (mulW n m) n) is
  fn (n : Whole) (m : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (mulW x (succ m)) (addW (mulW x m) x) end)
      (refl zero)
      (fn (k : Whole) (ih : Eq Whole (mulW k (succ m)) (addW (mulW k m) k)) is
         transEq Whole
           (addW (mulW k (succ m)) (succ m))
           (addW (addW (mulW k m) k) (succ m))
           (addW (addW (mulW k m) m) (succ k))
           (congW (fn (t : Whole) is addW t (succ m) end) (mulW k (succ m)) (addW (mulW k m) k) ih)
           (addWShiftSucc (mulW k m) k m)
       end)
      n
  end
end

-- mul is commutative (induction on the first argument; needs mulWZeroR + mulWSuccR).
-- Named for Task 4 (commLawsWhole) even though SemiringLaws omits it.
mulWComm : CommT Whole mulW is
  fn (a : Whole) (b : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (mulW x b) (mulW b x) end)
      (subst Whole (mulW b zero) zero (mulWZeroR b)
         (fn (z : Whole) is Eq Whole z (mulW b zero) end)
         (refl (mulW b zero)))
      (fn (k : Whole) (ih : Eq Whole (mulW k b) (mulW b k)) is
         transEq Whole (mulW (succ k) b) (addW (mulW b k) b) (mulW b (succ k))
           (congW (fn (t : Whole) is addW t b end) (mulW k b) (mulW b k) ih)
           (symEq Whole (mulW b (succ k)) (addW (mulW b k) b) (mulWSuccR b k))
       end)
      a
  end
end

-- mul is associative (induction on a; the step turns on distribWR + congruence).
mulWAssoc : AssocT Whole mulW is
  fn (a : Whole) (b : Whole) (c : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (mulW (mulW x b) c) (mulW x (mulW b c)) end)
      (refl zero)
      (fn (k : Whole) (ih : Eq Whole (mulW (mulW k b) c) (mulW k (mulW b c))) is
         transEq Whole
           (mulW (mulW (succ k) b) c)
           (addW (mulW (mulW k b) c) (mulW b c))
           (mulW (succ k) (mulW b c))
           (distribWR (mulW k b) b c)
           (congW (fn (t : Whole) is addW t (mulW b c) end) (mulW (mulW k b) c) (mulW k (mulW b c)) ih)
       end)
      a
  end
end

-- mul (succ zero) a = a definitionally: mul (succ zero) a = addW 0 a = a.
mulWOneL : IdLT Whole mulW (succ zero) is fn (a : Whole) is refl a end end

-- mul a (succ zero) = a (from mulWSuccR + mulWZeroR, no induction here).
mulWOneR : IdRT Whole mulW (succ zero) is
  fn (a : Whole) is
    transEq Whole (mulW a (succ zero)) (addW (mulW a zero) a) a
      (mulWSuccR a zero)
      (congW (fn (t : Whole) is addW t a end) (mulW a zero) zero (mulWZeroR a))
  end
end

-- LEFT distributivity: a * (b + c) = a*b + a*c (from mulWComm + distribWR).
distribWL : DistribLT Whole addW mulW is
  fn (a : Whole) (b : Whole) (c : Whole) is
    transEq Whole
      (mulW a (addW b c))
      (mulW (addW b c) a)
      (addW (mulW a b) (mulW a c))
      (mulWComm a (addW b c))
      (transEq Whole
         (mulW (addW b c) a)
         (addW (mulW b a) (mulW c a))
         (addW (mulW a b) (mulW a c))
         (distribWR b c a)
         (transEq Whole
            (addW (mulW b a) (mulW c a))
            (addW (mulW a b) (mulW c a))
            (addW (mulW a b) (mulW a c))
            (congW (fn (t : Whole) is addW t (mulW c a) end) (mulW b a) (mulW a b) (mulWComm b a))
            (congW (fn (t : Whole) is addW (mulW a b) t end) (mulW c a) (mulW a c) (mulWComm c a))))
  end
end

-- The assembled record. Stated over semiringWhole, whose projections compute to
-- addW/zero/mulW/(succ zero), so the raw-kernel lemmas check on the nose.
semiringLawsWhole : SemiringLaws Whole semiringWhole is
  mkAnd (AssocT Whole addW)
        (And (CommT Whole addW)
        (And (IdLT Whole addW zero)
        (And (IdRT Whole addW zero)
        (And (AssocT Whole mulW)
        (And (IdLT Whole mulW (succ zero))
        (And (IdRT Whole mulW (succ zero))
        (And (DistribLT Whole addW mulW)
        (And (DistribRT Whole addW mulW)
        (And (AnnihLT Whole mulW zero)
             (AnnihRT Whole mulW zero))))))))))
    addWAssoc
    (mkAnd (CommT Whole addW)
          (And (IdLT Whole addW zero)
          (And (IdRT Whole addW zero)
          (And (AssocT Whole mulW)
          (And (IdLT Whole mulW (succ zero))
          (And (IdRT Whole mulW (succ zero))
          (And (DistribLT Whole addW mulW)
          (And (DistribRT Whole addW mulW)
          (And (AnnihLT Whole mulW zero)
               (AnnihRT Whole mulW zero)))))))))
      addWComm
      (mkAnd (IdLT Whole addW zero)
            (And (IdRT Whole addW zero)
            (And (AssocT Whole mulW)
            (And (IdLT Whole mulW (succ zero))
            (And (IdRT Whole mulW (succ zero))
            (And (DistribLT Whole addW mulW)
            (And (DistribRT Whole addW mulW)
            (And (AnnihLT Whole mulW zero)
                 (AnnihRT Whole mulW zero))))))))
        addWZeroL
        (mkAnd (IdRT Whole addW zero)
              (And (AssocT Whole mulW)
              (And (IdLT Whole mulW (succ zero))
              (And (IdRT Whole mulW (succ zero))
              (And (DistribLT Whole addW mulW)
              (And (DistribRT Whole addW mulW)
              (And (AnnihLT Whole mulW zero)
                   (AnnihRT Whole mulW zero)))))))
          addWZeroR
          (mkAnd (AssocT Whole mulW)
                (And (IdLT Whole mulW (succ zero))
                (And (IdRT Whole mulW (succ zero))
                (And (DistribLT Whole addW mulW)
                (And (DistribRT Whole addW mulW)
                (And (AnnihLT Whole mulW zero)
                     (AnnihRT Whole mulW zero))))))
            mulWAssoc
            (mkAnd (IdLT Whole mulW (succ zero))
                  (And (IdRT Whole mulW (succ zero))
                  (And (DistribLT Whole addW mulW)
                  (And (DistribRT Whole addW mulW)
                  (And (AnnihLT Whole mulW zero)
                       (AnnihRT Whole mulW zero)))))
              mulWOneL
              (mkAnd (IdRT Whole mulW (succ zero))
                    (And (DistribLT Whole addW mulW)
                    (And (DistribRT Whole addW mulW)
                    (And (AnnihLT Whole mulW zero)
                         (AnnihRT Whole mulW zero))))
                mulWOneR
                (mkAnd (DistribLT Whole addW mulW)
                      (And (DistribRT Whole addW mulW)
                      (And (AnnihLT Whole mulW zero)
                           (AnnihRT Whole mulW zero)))
                  distribWL
                  (mkAnd (DistribRT Whole addW mulW)
                        (And (AnnihLT Whole mulW zero)
                             (AnnihRT Whole mulW zero))
                    distribWR
                    (mkAnd (AnnihLT Whole mulW zero)
                           (AnnihRT Whole mulW zero)
                      mulWZeroL
                      mulWZeroR)))))))))
end

-- ====================================================================
-- RING / DIVRING / COMM LAWS (v4, next rung). RingLaws layers additive
-- inverses onto SemiringLaws; DivRingLaws layers multiplicative inverses
-- (guarded by a nonzero PREDICATE, since the prelude has no ambient
-- negation type to state "nonzero" uniformly). Commutativity is its OWN
-- record: a commutative ring is Ring + RingLaws + CommLaws; a field is
-- DivRing + DivRingLaws + CommLaws; a Quaternion (later) is a DivRing
-- withOUT CommLaws. Whole's CommLaws instance is free from mulWComm.
-- ====================================================================
NegInvLT : (A : U) -> (A -> A -> A) -> (A -> A) -> A -> U is
  fn (A : U) (add : A -> A -> A) (neg : A -> A) (z : A) is (a : A) -> Eq A (add (neg a) a) z end
end
NegInvRT : (A : U) -> (A -> A -> A) -> (A -> A) -> A -> U is
  fn (A : U) (add : A -> A -> A) (neg : A -> A) (z : A) is (a : A) -> Eq A (add a (neg a)) z end
end
RecipInvLT : (A : U) -> (A -> A -> A) -> (A -> A) -> A -> (A -> U) -> U is
  fn (A : U) (mul : A -> A -> A) (rc : A -> A) (o : A) (nz : A -> U) is
    (x : A) -> nz x -> Eq A (mul (rc x) x) o
  end
end
RecipInvRT : (A : U) -> (A -> A -> A) -> (A -> A) -> A -> (A -> U) -> U is
  fn (A : U) (mul : A -> A -> A) (rc : A -> A) (o : A) (nz : A -> U) is
    (x : A) -> nz x -> Eq A (mul x (rc x)) o
  end
end

-- Ring laws = semiring laws over the embedded semiring + additive inverses.
RingLaws : (A : U) -> Ring A -> U is
  fn (A : U) (r : Ring A) is
    And (SemiringLaws A (r.1))
    (And (NegInvLT A (r.1.1) (r.2) (r.1.2.1))
         (NegInvRT A (r.1.1) (r.2) (r.1.2.1)))
  end
end

-- DivRing laws take a nonzero PREDICATE nz (each carrier states nonzeroness
-- its own way; the prelude has no ambient negation type). recip zero is junk
-- by convention, so the inverse laws are guarded by nz.
DivRingLaws : (A : U) -> DivRing A -> (A -> U) -> U is
  fn (A : U) (d : DivRing A) (nz : A -> U) is
    And (RingLaws A (d.1))
    (And (RecipInvLT A (d.1.1.2.2.1) (d.2) (d.1.1.2.2.2) nz)
         (RecipInvRT A (d.1.1.2.2.1) (d.2) (d.1.1.2.2.2) nz))
  end
end

-- Commutativity is its own record: a commutative ring is Ring + RingLaws +
-- CommLaws; a field is DivRing + DivRingLaws + CommLaws; Quaternion (later)
-- is a DivRing withOUT CommLaws. Whole's instance is free from mulWComm.
CommLaws : (A : U) -> Semiring A -> U is
  fn (A : U) (s : Semiring A) is CommT A (s.2.2.1) end
end
commLawsWhole : CommLaws Whole semiringWhole is mulWComm end

-- ====================================================================
-- THE LOWER LADDER (v4 full ladder). Laws for the append-family ops
-- shapes: a semigroup is a magma with associativity, a monoid adds the
-- identity laws, a commutative monoid adds commutativity. Whole sits on
-- the CommMonoid rung twice - under addition and under multiplication -
-- with every law already proven above. These are plain defs, not
-- instance-table entries: registering Magma Whole would make `++` mean
-- addition (the Raku lesson: keep `+` arithmetic, `++` append).
-- ====================================================================
-- (No witness or consumer yet: this is the lawful level the Magma rename
-- freed the name for; String's associativity candidate lives in the
-- listings over the rune-list view, not the packed carrier.)
SemigroupLaws : (A : U) -> Magma A -> U is
  fn (A : U) (m : Magma A) is AssocT A m end
end
MonoidLaws : (A : U) -> Monoid A -> U is
  fn (A : U) (d : Monoid A) is
    And (AssocT A (d.1)) (And (IdLT A (d.1) (d.2)) (IdRT A (d.1) (d.2)))
  end
end
CommMonoidLaws : (A : U) -> Monoid A -> U is
  fn (A : U) (d : Monoid A) is And (MonoidLaws A d) (CommT A (d.1)) end
end

monoidWholeAdd : Monoid Whole is mkMonoid Whole addW zero end
monoidWholeMul : Monoid Whole is mkMonoid Whole mulW (succ zero) end

commMonoidLawsWholeAdd : CommMonoidLaws Whole monoidWholeAdd is
  mkAnd (MonoidLaws Whole monoidWholeAdd) (CommT Whole addW)
    (mkAnd (AssocT Whole addW)
      (And (IdLT Whole addW zero) (IdRT Whole addW zero))
      addWAssoc
      (mkAnd (IdLT Whole addW zero) (IdRT Whole addW zero) addWZeroL addWZeroR))
    addWComm
end
commMonoidLawsWholeMul : CommMonoidLaws Whole monoidWholeMul is
  mkAnd (MonoidLaws Whole monoidWholeMul) (CommT Whole mulW)
    (mkAnd (AssocT Whole mulW)
      (And (IdLT Whole mulW (succ zero)) (IdRT Whole mulW (succ zero)))
      mulWAssoc
      (mkAnd (IdLT Whole mulW (succ zero)) (IdRT Whole mulW (succ zero)) mulWOneL mulWOneR))
    mulWComm
end

-- ====================================================================
-- THE UPPER LADDER (v4 full ladder). Group laws layer the two inverse
-- laws onto MonoidLaws; AbGroupLaws adds commutativity. The classical
-- top rungs are law bundles over the shipped ops shapes: a commutative
-- ring is Ring + RingLaws + CommLaws (over the embedded semiring), a
-- field is DivRing + DivRingLaws + CommLaws. These are plain defs, not
-- instance-table entries: this task ships no Group value.
-- ====================================================================

-- Group laws = monoid laws + the two inverse laws. NegInvLT/RT are
-- already generic in (op, inv, e), so they serve groups verbatim.
GroupLaws : (A : U) -> Group A -> U is
  fn (A : U) (g : Group A) is
    And (MonoidLaws A (g.1))
    (And (NegInvLT A (g.1.1) (g.2) (g.1.2))
         (NegInvRT A (g.1.1) (g.2) (g.1.2)))
  end
end
AbGroupLaws : (A : U) -> Group A -> U is
  fn (A : U) (g : Group A) is And (GroupLaws A g) (CommT A (g.1.1)) end
end

-- The classical top rungs as law bundles over the shipped ops shapes:
-- a commutative ring is a Ring whose multiplication commutes; a field is
-- a DivRing whose multiplication commutes.
CommRingLaws : (A : U) -> Ring A -> U is
  fn (A : U) (r : Ring A) is And (RingLaws A r) (CommLaws A (r.1)) end
end
FieldLaws : (A : U) -> DivRing A -> (A -> U) -> U is
  fn (A : U) (d : DivRing A) (nz : A -> U) is
    And (DivRingLaws A d nz) (CommLaws A (d.1.1))
  end
end

-- ====================================================================
-- THE LADDER'S EDGES. Every classical containment is a FUNCTION with a
-- proven law transport: a ring IS an abelian group under addition and a
-- monoid under multiplication. Transports are pure reassembly - project
-- the law out of the source And-chain, rebuild the target chain. When
-- Int's RingLaws land (deferred campaign), groupLawsOfRing instantly
-- yields Int's AbGroup; the bridges are written once, here.
-- ====================================================================
magmaOfMonoid : (A : U) -> Monoid A -> Magma A is
  fn (A : U) (d : Monoid A) is d.1 end
end
monoidOfGroup : (A : U) -> Group A -> Monoid A is
  fn (A : U) (g : Group A) is g.1 end
end
addMonoidOfSemiring : (A : U) -> Semiring A -> Monoid A is
  fn (A : U) (s : Semiring A) is mkMonoid A (s.1) (s.2.1) end
end
mulMonoidOfSemiring : (A : U) -> Semiring A -> Monoid A is
  fn (A : U) (s : Semiring A) is mkMonoid A (s.2.2.1) (s.2.2.2) end
end
groupOfRing : (A : U) -> Ring A -> Group A is
  fn (A : U) (r : Ring A) is mkGroup A (addMonoidOfSemiring A (r.1)) (r.2) end
end

-- Named slot extractors for the SemiringLaws And-chain (nicer than raw
-- .2.2... trails at every use site; the chain order is documented at the
-- record). Only the slots the transports need are named.
srlAddAssoc : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> AssocT A (s.1) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is l.1 end
end
srlAddComm : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> CommT A (s.1) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is l.2.1 end
end
srlAddZeroL : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> IdLT A (s.1) (s.2.1) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is l.2.2.1 end
end
srlAddZeroR : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> IdRT A (s.1) (s.2.1) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is l.2.2.2.1 end
end
srlMulAssoc : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> AssocT A (s.2.2.1) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is l.2.2.2.2.1 end
end
srlMulOneL : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> IdLT A (s.2.2.1) (s.2.2.2) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is l.2.2.2.2.2.1 end
end
srlMulOneR : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> IdRT A (s.2.2.1) (s.2.2.2) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is l.2.2.2.2.2.2.1 end
end

addCommMonoidLawsOfSemiring : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> CommMonoidLaws A (addMonoidOfSemiring A s) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is
    mkAnd (MonoidLaws A (addMonoidOfSemiring A s)) (CommT A (s.1))
      (mkAnd (AssocT A (s.1))
        (And (IdLT A (s.1) (s.2.1)) (IdRT A (s.1) (s.2.1)))
        (srlAddAssoc A s l)
        (mkAnd (IdLT A (s.1) (s.2.1)) (IdRT A (s.1) (s.2.1)) (srlAddZeroL A s l) (srlAddZeroR A s l)))
      (srlAddComm A s l)
  end
end
mulMonoidLawsOfSemiring : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> MonoidLaws A (mulMonoidOfSemiring A s) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is
    mkAnd (AssocT A (s.2.2.1))
      (And (IdLT A (s.2.2.1) (s.2.2.2)) (IdRT A (s.2.2.1) (s.2.2.2)))
      (srlMulAssoc A s l)
      (mkAnd (IdLT A (s.2.2.1) (s.2.2.2)) (IdRT A (s.2.2.1) (s.2.2.2)) (srlMulOneL A s l) (srlMulOneR A s l))
  end
end
groupLawsOfRing : (A : U) -> (r : Ring A) -> RingLaws A r -> GroupLaws A (groupOfRing A r) is
  fn (A : U) (r : Ring A) (l : RingLaws A r) is
    mkAnd (MonoidLaws A (addMonoidOfSemiring A (r.1)))
      (And (NegInvLT A (r.1.1) (r.2) (r.1.2.1)) (NegInvRT A (r.1.1) (r.2) (r.1.2.1)))
      (mkAnd (AssocT A (r.1.1))
        (And (IdLT A (r.1.1) (r.1.2.1)) (IdRT A (r.1.1) (r.1.2.1)))
        (srlAddAssoc A (r.1) (l.1))
        (mkAnd (IdLT A (r.1.1) (r.1.2.1)) (IdRT A (r.1.1) (r.1.2.1)) (srlAddZeroL A (r.1) (l.1)) (srlAddZeroR A (r.1) (l.1))))
      (mkAnd (NegInvLT A (r.1.1) (r.2) (r.1.2.1)) (NegInvRT A (r.1.1) (r.2) (r.1.2.1)) (l.2.1) (l.2.2))
  end
end
abGroupLawsOfRing : (A : U) -> (r : Ring A) -> RingLaws A r -> AbGroupLaws A (groupOfRing A r) is
  fn (A : U) (r : Ring A) (l : RingLaws A r) is
    mkAnd (GroupLaws A (groupOfRing A r)) (CommT A (r.1.1))
      (groupLawsOfRing A r l)
      (srlAddComm A (r.1) (l.1))
  end
end

-- ====================================================================
-- THE MONUS / ORDER LIBRARY + wsubEq (Int ring-laws campaign, Task 2).
-- The keystone `wsubEq` proves that `wsub` (the Whole-difference into Int)
-- respects cross-equal differences: a + d = c + b implies a - b = c - d as
-- signed integers. It is the transport lemma the Int ring laws stand on.
-- Everything here is machine-checked by WholeElim induction over the raw
-- kernels (leb recurses on its first arg, subW on its second, addW on its
-- first), with the shipped subst/symEq/transEq/congW plumbing.
-- ====================================================================

-- succ is injective: cancel a successor by congruence on `pred`
-- (pred (succ a) = a definitionally, so the congW result IS Eq Whole a b).
succInj : (a : Whole) -> (b : Whole) -> Eq Whole (succ a) (succ b) -> Eq Whole a b is
  fn (a : Whole) (b : Whole) (p : Eq Whole (succ a) (succ b)) is
    congW pred (succ a) (succ b) p
  end
end

-- EX-FALSO from a Bool absurdity (the idiom later tasks reuse). Given a proof
-- that `true = false`, ANY goal G follows: subst along the discriminant with a
-- Bool-CASE motive whose true-arm is trivially inhabited (Eq Bool true true,
-- by refl) and whose false-arm is G. `subst … (refl true)` transports the
-- true-arm witness to the false-arm, i.e. to G. This discharges impossible
-- case branches WITHOUT an Empty type.
boolDiscTF : (G : U) -> Eq Bool true false -> G is
  fn (G : U) (h : Eq Bool true false) is
    subst Bool true false h
      (fn (z : Bool) is
         case z of
         | true -> Eq Bool true true
         | false -> G
         end
       end)
      (refl true)
  end
end

-- Case on a Bool while RETAINING the discriminant equation. Ordinary BoolElim
-- forgets that the bound tag equals the scrutinee; here the motive is
-- `Eq Bool g x -> P x`, so applying the eliminated result to `refl g` hands
-- each arm a proof that the guard equals its tag. The order-transfer proofs
-- below need those equations to reduce `wsub` and to invoke `subWAddCancel`.
boolCaseEq : (g : Bool) -> (P : Bool -> U)
  -> (Eq Bool g true -> P true) -> (Eq Bool g false -> P false) -> P g is
  fn (g : Bool) (P : Bool -> U)
     (ht : Eq Bool g true -> P true) (hf : Eq Bool g false -> P false) is
    BoolElim (fn (x : Bool) is Eq Bool g x -> P x end) ht hf g (refl g)
  end
end

-- Congruence from Whole into Int through the two Int constructors (there is no
-- ambient cong across types; these lift a Whole equality onto nonneg/negsucc).
congNonneg : (x : Whole) -> (y : Whole) -> Eq Whole x y -> Eq Int (nonneg x) (nonneg y) is
  fn (x : Whole) (y : Whole) (p : Eq Whole x y) is
    subst Whole x y p (fn (z : Whole) is Eq Int (nonneg x) (nonneg z) end) (refl (nonneg x))
  end
end
congNegsucc : (x : Whole) -> (y : Whole) -> Eq Whole x y -> Eq Int (negsucc x) (negsucc y) is
  fn (x : Whole) (y : Whole) (p : Eq Whole x y) is
    subst Whole x y p (fn (z : Whole) is Eq Int (negsucc x) (negsucc z) end) (refl (negsucc x))
  end
end

-- COMPLETENESS of the decidable order: leb is total, so `leb a b = false`
-- forces `leb b a = true`. Double induction (leb recurses on the first arg);
-- the zero-vs-zero corner is impossible and discharged by boolDiscTF.
lebComplete : (a : Whole) -> (b : Whole) -> Eq Bool (leb a b) false -> Eq Bool (leb b a) true is
  fn (a : Whole) is
    WholeElim (fn (x : Whole) is (b : Whole) -> Eq Bool (leb x b) false -> Eq Bool (leb b x) true end)
      (fn (b : Whole) (h : Eq Bool (leb zero b) false) is
         boolDiscTF (Eq Bool (leb b zero) true) h end)
      (fn (k : Whole) (ih : (b : Whole) -> Eq Bool (leb k b) false -> Eq Bool (leb b k) true) is
         fn (b : Whole) is
           WholeElim (fn (y : Whole) is Eq Bool (leb (succ k) y) false -> Eq Bool (leb y (succ k)) true end)
             (fn (h : Eq Bool (leb (succ k) zero) false) is refl true end)
             (fn (j : Whole) (ihb : Eq Bool (leb (succ k) j) false -> Eq Bool (leb j (succ k)) true) is
                fn (h : Eq Bool (leb (succ k) (succ j)) false) is ih j h end end)
             b
         end end)
      a
  end
end

-- The monus cancellation lemma: when `b <= a`, adding `b` back to `a - b`
-- recovers `a`. Induction on the recursed variable `b` (subW steps on it,
-- addW steps on it); the a=zero-under-succ corner is impossible (b <= 0 with
-- b a successor) and is discharged by boolDiscTF. subWSucc peels the matched
-- successors so the induction hypothesis applies.
subWAddCancel : (a : Whole) -> (b : Whole) -> Eq Bool (leb b a) true -> Eq Whole (addW b (subW a b)) a is
  fn (a : Whole) (b : Whole) is
    WholeElim (fn (x : Whole) is (m : Whole) -> Eq Bool (leb x m) true -> Eq Whole (addW x (subW m x)) m end)
      (fn (m : Whole) (h : Eq Bool (leb zero m) true) is refl m end)
      (fn (k : Whole) (ih : (m : Whole) -> Eq Bool (leb k m) true -> Eq Whole (addW k (subW m k)) m) is
         fn (m : Whole) is
           WholeElim (fn (y : Whole) is Eq Bool (leb (succ k) y) true -> Eq Whole (addW (succ k) (subW y (succ k))) y end)
             (fn (h : Eq Bool (leb (succ k) zero) true) is
                boolDiscTF (Eq Whole (addW (succ k) (subW zero (succ k))) zero)
                  (symEq Bool (leb (succ k) zero) true h) end)
             (fn (j : Whole) (ihb : Eq Bool (leb (succ k) j) true -> Eq Whole (addW (succ k) (subW j (succ k))) j) is
                fn (h : Eq Bool (leb (succ k) (succ j)) true) is
                  congW (fn (t : Whole) is succ t end) (addW k (subW (succ j) (succ k))) j
                    (transEq Whole (addW k (subW (succ j) (succ k))) (addW k (subW j k)) j
                       (congW (fn (t : Whole) is addW k t end) (subW (succ j) (succ k)) (subW j k) (subWSucc j k))
                       (ih j h))
                end end)
             m
         end end)
      b
      a
  end
end

-- LEFT cancellation of addW: `k + a = k + b` implies `a = b`. Induction on the
-- prefix `k` (addW recurses on its first arg); each step strips one successor
-- with succInj and defers to the hypothesis.
addWCancelL : (k : Whole) -> (a : Whole) -> (b : Whole) -> Eq Whole (addW k a) (addW k b) -> Eq Whole a b is
  fn (k : Whole) (a : Whole) (b : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (addW x a) (addW x b) -> Eq Whole a b end)
      (fn (h : Eq Whole (addW zero a) (addW zero b)) is h end)
      (fn (n : Whole) (ih : Eq Whole (addW n a) (addW n b) -> Eq Whole a b) is
         fn (h : Eq Whole (addW (succ n) a) (addW (succ n) b)) is
           ih (succInj (addW n a) (addW n b) h)
         end end)
      k
  end
end

-- Order reflexivity through addition: m <= m + n, always. Induction on m (both
-- leb and addW recurse on their first arg, so the successor case reduces the
-- goal straight onto the hypothesis).
lebSelfAddR : (m : Whole) -> (n : Whole) -> Eq Bool (leb m (addW m n)) true is
  fn (m : Whole) (n : Whole) is
    WholeElim (fn (x : Whole) is Eq Bool (leb x (addW x n)) true end)
      (refl true)
      (fn (k : Whole) (ih : Eq Bool (leb k (addW k n)) true) is ih end)
      m
  end
end

-- STRICT completeness: `leb b a = false` (i.e. a < b) gives `leb (succ a) b`
-- = true (a + 1 <= b). Double induction mirroring lebComplete; the recursive
-- call sits in exactly one arm, the corners are refl / boolDiscTF.
lebComplStrict : (a : Whole) -> (b : Whole) -> Eq Bool (leb b a) false -> Eq Bool (leb (succ a) b) true is
  fn (a : Whole) (b : Whole) is
    WholeElim (fn (y : Whole) is (w : Whole) -> Eq Bool (leb y w) false -> Eq Bool (leb (succ w) y) true end)
      (fn (w : Whole) (h : Eq Bool (leb zero w) false) is
         boolDiscTF (Eq Bool (leb (succ w) zero) true) h end)
      (fn (j : Whole) (ih : (w : Whole) -> Eq Bool (leb j w) false -> Eq Bool (leb (succ w) j) true) is
         fn (w : Whole) is
           WholeElim (fn (x : Whole) is Eq Bool (leb (succ j) x) false -> Eq Bool (leb (succ x) (succ j)) true end)
             (fn (h : Eq Bool (leb (succ j) zero) false) is refl true end)
             (fn (i : Whole) (ihx : Eq Bool (leb (succ j) i) false -> Eq Bool (leb (succ i) (succ j)) true) is
                fn (h : Eq Bool (leb (succ j) (succ i)) false) is ih i h end end)
             w
         end end)
      b
      a
  end
end

-- ORDER TRANSFER (the mixed-branch discharger): from the cross-equality
-- a + d = c + b and `b <= a`, derive `d <= c`. Substituting a = b + (a - b)
-- and cancelling b turns the cross-equality into (a - b) + d = c, and
-- lebSelfAddR reads off d <= d + (a - b) = c.
orderTransfer : (a : Whole) -> (b : Whole) -> (c : Whole) -> (d : Whole)
  -> Eq Whole (addW a d) (addW c b) -> Eq Bool (leb b a) true -> Eq Bool (leb d c) true is
  fn (a : Whole) (b : Whole) (c : Whole) (d : Whole)
     (H : Eq Whole (addW a d) (addW c b)) (e1 : Eq Bool (leb b a) true) is
    let ba : Eq Whole (addW b (subW a b)) a = subWAddCancel a b e1 in
    let Hsub : Eq Whole (addW (addW b (subW a b)) d) (addW c b) =
      subst Whole a (addW b (subW a b)) (symEq Whole (addW b (subW a b)) a ba)
        (fn (z : Whole) is Eq Whole (addW z d) (addW c b) end) H in
    let step : Eq Whole (addW b (addW (subW a b) d)) (addW b c) =
      transEq Whole (addW b (addW (subW a b) d)) (addW (addW b (subW a b)) d) (addW b c)
        (symEq Whole (addW (addW b (subW a b)) d) (addW b (addW (subW a b) d)) (addWAssoc b (subW a b) d))
        (transEq Whole (addW (addW b (subW a b)) d) (addW c b) (addW b c) Hsub (addWComm c b)) in
    let rdc : Eq Whole (addW (subW a b) d) c = addWCancelL b (addW (subW a b) d) c step in
    let drc : Eq Whole (addW d (subW a b)) c =
      transEq Whole (addW d (subW a b)) (addW (subW a b) d) c (addWComm d (subW a b)) rdc in
    subst Whole (addW d (subW a b)) c drc (fn (z : Whole) is Eq Bool (leb d z) true end) (lebSelfAddR d (subW a b))
  end
end

-- The SAME-BRANCH compatibility cores. Both same-sign branches of wsubEq reduce
-- to a Whole equality of the two truncated differences; these package the addW
-- shuffle + subWAddCancel + addWCancelL argument once each.

-- Nonneg branch: b <= a and d <= c give (a - b) = (c - d).
subWCrossTrue : (a : Whole) -> (b : Whole) -> (c : Whole) -> (d : Whole)
  -> Eq Whole (addW a d) (addW c b)
  -> Eq Bool (leb b a) true -> Eq Bool (leb d c) true
  -> Eq Whole (subW a b) (subW c d) is
  fn (a : Whole) (b : Whole) (c : Whole) (d : Whole)
     (H : Eq Whole (addW a d) (addW c b))
     (e1 : Eq Bool (leb b a) true) (e2 : Eq Bool (leb d c) true) is
    let sac1 : Eq Whole (addW b (subW a b)) a = subWAddCancel a b e1 in
    let sac2 : Eq Whole (addW d (subW c d)) c = subWAddCancel c d e2 in
    let L1 : Eq Whole (addW (addW b d) (subW a b)) (addW a d) =
      transEq Whole (addW (addW b d) (subW a b)) (addW (addW b (subW a b)) d) (addW a d)
        (symEq Whole (addW (addW b (subW a b)) d) (addW (addW b d) (subW a b))
           (addWSwapR b (subW a b) d))
        (congW (fn (t : Whole) is addW t d end) (addW b (subW a b)) a sac1) in
    let R1 : Eq Whole (addW (addW b d) (subW c d)) (addW c b) =
      transEq Whole (addW (addW b d) (subW c d)) (addW (addW d b) (subW c d)) (addW c b)
        (congW (fn (t : Whole) is addW t (subW c d) end) (addW b d) (addW d b) (addWComm b d))
        (transEq Whole (addW (addW d b) (subW c d)) (addW (addW d (subW c d)) b) (addW c b)
           (symEq Whole (addW (addW d (subW c d)) b) (addW (addW d b) (subW c d))
              (addWSwapR d (subW c d) b))
           (congW (fn (t : Whole) is addW t b end) (addW d (subW c d)) c sac2)) in
    let E : Eq Whole (addW (addW b d) (subW a b)) (addW (addW b d) (subW c d)) =
      transEq Whole (addW (addW b d) (subW a b)) (addW a d) (addW (addW b d) (subW c d))
        L1
        (transEq Whole (addW a d) (addW c b) (addW (addW b d) (subW c d))
           H
           (symEq Whole (addW (addW b d) (subW c d)) (addW c b) R1)) in
    addWCancelL (addW b d) (subW a b) (subW c d) E
  end
end

-- Negsucc branch: leb b a = false and leb d c = false give
-- (b - succ a) = (d - succ c). subWAddCancel now fires at the shifted bound
-- (succ a <= b via lebComplStrict); one succInj strips the shared successor.
subWCrossFalse : (a : Whole) -> (b : Whole) -> (c : Whole) -> (d : Whole)
  -> Eq Whole (addW a d) (addW c b)
  -> Eq Bool (leb b a) false -> Eq Bool (leb d c) false
  -> Eq Whole (subW b (succ a)) (subW d (succ c)) is
  fn (a : Whole) (b : Whole) (c : Whole) (d : Whole)
     (H : Eq Whole (addW a d) (addW c b))
     (e1 : Eq Bool (leb b a) false) (e2 : Eq Bool (leb d c) false) is
    let sac1 : Eq Whole (addW (succ a) (subW b (succ a))) b =
      subWAddCancel b (succ a) (lebComplStrict a b e1) in
    let sac2 : Eq Whole (addW (succ c) (subW d (succ c))) d =
      subWAddCancel d (succ c) (lebComplStrict c d e2) in
    let H1 : Eq Whole (addW a (addW (succ c) (subW d (succ c)))) (addW c b) =
      subst Whole d (addW (succ c) (subW d (succ c)))
        (symEq Whole (addW (succ c) (subW d (succ c))) d sac2)
        (fn (z : Whole) is Eq Whole (addW a z) (addW c b) end) H in
    let Hb : Eq Whole (addW a (addW (succ c) (subW d (succ c)))) (addW c (addW (succ a) (subW b (succ a)))) =
      subst Whole b (addW (succ a) (subW b (succ a)))
        (symEq Whole (addW (succ a) (subW b (succ a))) b sac1)
        (fn (z : Whole) is Eq Whole (addW a (addW (succ c) (subW d (succ c)))) (addW c z) end) H1 in
    let Llhs : Eq Whole (addW a (addW (succ c) (subW d (succ c)))) (succ (addW (addW a c) (subW d (succ c)))) =
      transEq Whole (addW a (addW (succ c) (subW d (succ c)))) (succ (addW a (addW c (subW d (succ c))))) (succ (addW (addW a c) (subW d (succ c))))
        (addWSuccR a (addW c (subW d (succ c))))
        (congW (fn (t : Whole) is succ t end) (addW a (addW c (subW d (succ c)))) (addW (addW a c) (subW d (succ c)))
           (symEq Whole (addW (addW a c) (subW d (succ c))) (addW a (addW c (subW d (succ c))))
              (addWAssoc a c (subW d (succ c))))) in
    let Rrhs : Eq Whole (addW c (addW (succ a) (subW b (succ a)))) (succ (addW (addW a c) (subW b (succ a)))) =
      transEq Whole (addW c (addW (succ a) (subW b (succ a)))) (succ (addW c (addW a (subW b (succ a))))) (succ (addW (addW a c) (subW b (succ a))))
        (addWSuccR c (addW a (subW b (succ a))))
        (congW (fn (t : Whole) is succ t end) (addW c (addW a (subW b (succ a)))) (addW (addW a c) (subW b (succ a)))
           (transEq Whole (addW c (addW a (subW b (succ a)))) (addW (addW c a) (subW b (succ a))) (addW (addW a c) (subW b (succ a)))
              (symEq Whole (addW (addW c a) (subW b (succ a))) (addW c (addW a (subW b (succ a))))
                 (addWAssoc c a (subW b (succ a))))
              (congW (fn (t : Whole) is addW t (subW b (succ a)) end) (addW c a) (addW a c) (addWComm c a)))) in
    let succEq : Eq Whole (succ (addW (addW a c) (subW d (succ c)))) (succ (addW (addW a c) (subW b (succ a)))) =
      transEq Whole (succ (addW (addW a c) (subW d (succ c)))) (addW a (addW (succ c) (subW d (succ c)))) (succ (addW (addW a c) (subW b (succ a))))
        (symEq Whole (addW a (addW (succ c) (subW d (succ c)))) (succ (addW (addW a c) (subW d (succ c)))) Llhs)
        (transEq Whole (addW a (addW (succ c) (subW d (succ c)))) (addW c (addW (succ a) (subW b (succ a)))) (succ (addW (addW a c) (subW b (succ a))))
           Hb Rrhs) in
    symEq Whole (subW d (succ c)) (subW b (succ a))
      (addWCancelL (addW a c) (subW d (succ c)) (subW b (succ a))
         (succInj (addW (addW a c) (subW d (succ c))) (addW (addW a c) (subW b (succ a))) succEq))
  end
end

-- The guard-explicit form of wsub (its body with the discriminant abstracted),
-- so a proof can rewrite the guard by subst. `wsubG (leb b a) a b` is wsub a b
-- definitionally; feeding `true`/`false` collapses to the two branch values.
wsubG : Bool -> Whole -> Whole -> Int is
  fn (g : Bool) (a : Whole) (b : Whole) is
    case g of
    | true -> nonneg (subW a b)
    | false -> negsucc (subW b (succ a))
    end
  end
end
-- Branch-reduction lemmas: knowing the guard, wsub collapses to one arm.
wsubTrue : (a : Whole) -> (b : Whole) -> Eq Bool (leb b a) true -> Eq Int (wsub a b) (nonneg (subW a b)) is
  fn (a : Whole) (b : Whole) (e : Eq Bool (leb b a) true) is
    subst Bool true (leb b a) (symEq Bool (leb b a) true e)
      (fn (g : Bool) is Eq Int (wsubG g a b) (nonneg (subW a b)) end)
      (refl (nonneg (subW a b)))
  end
end
wsubFalse : (a : Whole) -> (b : Whole) -> Eq Bool (leb b a) false -> Eq Int (wsub a b) (negsucc (subW b (succ a))) is
  fn (a : Whole) (b : Whole) (e : Eq Bool (leb b a) false) is
    subst Bool false (leb b a) (symEq Bool (leb b a) false e)
      (fn (g : Bool) is Eq Int (wsubG g a b) (negsucc (subW b (succ a))) end)
      (refl (negsucc (subW b (succ a))))
  end
end

-- THE KEYSTONE. wsub respects cross-equal differences: a + d = c + b implies
-- wsub a b = wsub c d. Case-split (with the guard equations retained, via
-- boolCaseEq) on `leb b a` and `leb d c`. The two SAME-sign branches reduce to
-- a Whole equality via subWCrossTrue / subWCrossFalse and lift it onto the Int
-- constructor. The two MIXED branches are IMPOSSIBLE: orderTransfer moves one
-- branch's leb fact to the other side, collides with its assumption to make
-- `Eq Bool true false`, and boolDiscTF discharges the goal ex falso.
wsubEq : (a : Whole) -> (b : Whole) -> (c : Whole) -> (d : Whole)
  -> Eq Whole (addW a d) (addW c b) -> Eq Int (wsub a b) (wsub c d) is
  fn (a : Whole) (b : Whole) (c : Whole) (d : Whole) (H : Eq Whole (addW a d) (addW c b)) is
    boolCaseEq (leb b a)
      (fn (g1 : Bool) is Eq Int (wsub a b) (wsub c d) end)
      (fn (e1 : Eq Bool (leb b a) true) is
         boolCaseEq (leb d c)
           (fn (g2 : Bool) is Eq Int (wsub a b) (wsub c d) end)
           (fn (e2 : Eq Bool (leb d c) true) is
              transEq Int (wsub a b) (nonneg (subW a b)) (wsub c d)
                (wsubTrue a b e1)
                (transEq Int (nonneg (subW a b)) (nonneg (subW c d)) (wsub c d)
                   (congNonneg (subW a b) (subW c d) (subWCrossTrue a b c d H e1 e2))
                   (symEq Int (wsub c d) (nonneg (subW c d)) (wsubTrue c d e2)))
            end)
           (fn (e2 : Eq Bool (leb d c) false) is
              boolDiscTF (Eq Int (wsub a b) (wsub c d))
                (transEq Bool true (leb d c) false
                   (symEq Bool (leb d c) true (orderTransfer a b c d H e1)) e2)
            end)
       end)
      (fn (e1 : Eq Bool (leb b a) false) is
         boolCaseEq (leb d c)
           (fn (g2 : Bool) is Eq Int (wsub a b) (wsub c d) end)
           (fn (e2 : Eq Bool (leb d c) true) is
              boolDiscTF (Eq Int (wsub a b) (wsub c d))
                (transEq Bool true (leb b a) false
                   (symEq Bool (leb b a) true
                      (orderTransfer c d a b (symEq Whole (addW a d) (addW c b) H) e2))
                   e1)
            end)
           (fn (e2 : Eq Bool (leb d c) false) is
              transEq Int (wsub a b) (negsucc (subW b (succ a))) (wsub c d)
                (wsubFalse a b e1)
                (transEq Int (negsucc (subW b (succ a))) (negsucc (subW d (succ c))) (wsub c d)
                   (congNegsucc (subW b (succ a)) (subW d (succ c)) (subWCrossFalse a b c d H e1 e2))
                   (symEq Int (wsub c d) (negsucc (subW d (succ c))) (wsubFalse c d e2)))
            end)
       end)
  end
end

-- ====================================================================
-- THE DIFFERENCE-PAIR TRANSPORT SPECS (Int ring-laws campaign, Task 3).
-- Every Int op is rewritten as a `wsub` of Whole polynomials, so a ring law
-- reduces to Whole arithmetic under `wsubEq`. `posP`/`negP` split an Int into
-- the difference pair it denotes (x = posP x - negP x); `wsubRep` is that
-- representation, `wsubPosNeg` the cross-equality bridge, and the *Spec lemmas
-- transport each op. `iaddWsub`/`imulWsub` push a wsub through the op (chaining
-- the spec with wsubEq, cross-equality via wsubPosNeg, multiplied out over the
-- Whole semiring). Shape guide: ch107's pmulRespL/R over its own NatPair.
-- ====================================================================

-- The difference pair a junk-free Int denotes: nonneg n is n - 0, negsucc k is
-- 0 - (k+1). `posP` reads the nonneg part, `negP` the neg part.
posP : Int -> Whole is
  fn (x : Int) is case x of | nonneg n -> n | negsucc k -> zero end end
end
negP : Int -> Whole is
  fn (x : Int) is case x of | nonneg n -> zero | negsucc k -> succ k end end
end

-- Congruence into Int through both arguments of `wsub` (there is no ambient cong
-- across the Whole -> Whole -> Int shape); rewrites either or both differences.
congWsub2 : (x1 : Whole) -> (y1 : Whole) -> (x2 : Whole) -> (y2 : Whole)
  -> Eq Whole x1 y1 -> Eq Whole x2 y2 -> Eq Int (wsub x1 x2) (wsub y1 y2) is
  fn (x1 : Whole) (y1 : Whole) (x2 : Whole) (y2 : Whole)
     (p1 : Eq Whole x1 y1) (p2 : Eq Whole x2 y2) is
    subst Whole x1 y1 p1 (fn (z : Whole) is Eq Int (wsub x1 x2) (wsub z y2) end)
      (subst Whole x2 y2 p2 (fn (w : Whole) is Eq Int (wsub x1 x2) (wsub x1 w) end)
         (refl (wsub x1 x2)))
  end
end

-- The additive interchange law (x+y)+(u+v) = (x+u)+(y+v): pure associativity +
-- commutativity regrouping. The workhorse for the degree-2 cross-equalities.
addWInterchange : (x : Whole) -> (y : Whole) -> (u : Whole) -> (v : Whole)
  -> Eq Whole (addW (addW x y) (addW u v)) (addW (addW x u) (addW y v)) is
  fn (x : Whole) (y : Whole) (u : Whole) (v : Whole) is
    transEq Whole (addW (addW x y) (addW u v)) (addW x (addW y (addW u v))) (addW (addW x u) (addW y v))
      (addWAssoc x y (addW u v))
      (transEq Whole (addW x (addW y (addW u v))) (addW x (addW u (addW y v))) (addW (addW x u) (addW y v))
         (congW (fn (s : Whole) is addW x s end) (addW y (addW u v)) (addW u (addW y v))
            (transEq Whole (addW y (addW u v)) (addW (addW y u) v) (addW u (addW y v))
               (symEq Whole (addW (addW y u) v) (addW y (addW u v)) (addWAssoc y u v))
               (transEq Whole (addW (addW y u) v) (addW (addW u y) v) (addW u (addW y v))
                  (congW (fn (s : Whole) is addW s v end) (addW y u) (addW u y) (addWComm y u))
                  (addWAssoc u y v))))
         (symEq Whole (addW (addW x u) (addW y v)) (addW x (addW u (addW y v))) (addWAssoc x u (addW y v))))
  end
end

-- REPRESENTATION: wsub of an Int's own difference pair reconstructs it. Both
-- constructor cases compute (leb zero _ / subW _ zero / subW (succ k)(succ zero)).
wsubRep : (x : Int) -> Eq Int (wsub (posP x) (negP x)) x is
  fn (x : Int) is
    IntElim (fn (w : Int) is Eq Int (wsub (posP w) (negP w)) w end)
      (fn (n : Whole) is refl (nonneg n) end)
      (fn (k : Whole) is refl (negsucc k) end)
      x
  end
end

-- ineg of a nonneg is the wsub of the reversed difference (0 - m). Both branches
-- (zero / succ k) compute on the nose.
inegNonneg : (m : Whole) -> Eq Int (ineg (nonneg m)) (wsub zero m) is
  fn (m : Whole) is
    WholeElim (fn (w : Whole) is Eq Int (ineg (nonneg w)) (wsub zero w) end)
      (refl (nonneg zero))
      (fn (k : Whole) (ih : Eq Int (ineg (nonneg k)) (wsub zero k)) is refl (negsucc k) end)
      m
  end
end

-- THE CROSS-EQUALITY BRIDGE. The difference pair of `wsub p n` differs from
-- (p, n) by the wsub-choice, but the two pairs denote the same integer:
-- posP(wsub p n) + n = p + negP(wsub p n). Case on the guard `leb n p` with the
-- equation retained; subWAddCancel closes both branches (the strict shift
-- lebComplStrict feeds the false branch, addWSuccR lines up the successor).
wsubPosNeg : (p : Whole) -> (n : Whole)
  -> Eq Whole (addW (posP (wsub p n)) n) (addW p (negP (wsub p n))) is
  fn (p : Whole) (n : Whole) is
    boolCaseEq (leb n p)
      (fn (g : Bool) is Eq Whole (addW (posP (wsub p n)) n) (addW p (negP (wsub p n))) end)
      (fn (e1 : Eq Bool (leb n p) true) is
         subst Int (nonneg (subW p n)) (wsub p n)
           (symEq Int (wsub p n) (nonneg (subW p n)) (wsubTrue p n e1))
           (fn (w : Int) is Eq Whole (addW (posP w) n) (addW p (negP w)) end)
           (transEq Whole (addW (subW p n) n) (addW n (subW p n)) (addW p zero)
              (addWComm (subW p n) n)
              (transEq Whole (addW n (subW p n)) p (addW p zero)
                 (subWAddCancel p n e1)
                 (symEq Whole (addW p zero) p (addWZeroR p))))
       end)
      (fn (e2 : Eq Bool (leb n p) false) is
         subst Int (negsucc (subW n (succ p))) (wsub p n)
           (symEq Int (wsub p n) (negsucc (subW n (succ p))) (wsubFalse p n e2))
           (fn (w : Int) is Eq Whole (addW (posP w) n) (addW p (negP w)) end)
           (transEq Whole n (succ (addW p (subW n (succ p)))) (addW p (succ (subW n (succ p))))
              (symEq Whole (succ (addW p (subW n (succ p)))) n
                 (subWAddCancel n (succ p) (lebComplStrict p n e2)))
              (symEq Whole (addW p (succ (subW n (succ p)))) (succ (addW p (subW n (succ p))))
                 (addWSuccR p (subW n (succ p)))))
       end)
  end
end

-- iadd as a wsub of Whole polynomials. Four constructor cases: nonneg/nonneg is
-- refl (leb zero / subW _ zero / addW zero zero compute); the two mixed cases
-- each need one addWZeroR rewrite (the stuck addW _ zero); negsucc/negsucc uses
-- addWSuccR under a negsucc congruence.
iaddSpec : (x : Int) -> (y : Int)
  -> Eq Int (iadd x y) (wsub (addW (posP x) (posP y)) (addW (negP x) (negP y))) is
  fn (x : Int) (y : Int) is
    IntElim (fn (wx : Int) is Eq Int (iadd wx y) (wsub (addW (posP wx) (posP y)) (addW (negP wx) (negP y))) end)
      (fn (a : Whole) is
         IntElim (fn (wy : Int) is Eq Int (iadd (nonneg a) wy) (wsub (addW (posP (nonneg a)) (posP wy)) (addW (negP (nonneg a)) (negP wy))) end)
           (fn (c : Whole) is refl (nonneg (addW a c)) end)
           (fn (d : Whole) is
              congWsub2 a (addW a zero) (succ d) (succ d)
                (symEq Whole (addW a zero) a (addWZeroR a)) (refl (succ d))
            end)
           y
       end)
      (fn (b : Whole) is
         IntElim (fn (wy : Int) is Eq Int (iadd (negsucc b) wy) (wsub (addW (posP (negsucc b)) (posP wy)) (addW (negP (negsucc b)) (negP wy))) end)
           (fn (c : Whole) is
              congWsub2 c c (succ b) (addW (succ b) zero)
                (refl c)
                (congW (fn (t : Whole) is succ t end) b (addW b zero)
                   (symEq Whole (addW b zero) b (addWZeroR b)))
            end)
           (fn (d : Whole) is
              congNegsucc (succ (addW b d)) (addW b (succ d))
                (symEq Whole (addW b (succ d)) (succ (addW b d)) (addWSuccR b d))
            end)
           y
       end)
      x
  end
end

-- imul as a wsub of Whole polynomials (the signed-pair product laid out over the
-- two sign columns). Same-sign cases: rewrite the stuck addW _ zero / mulW _ zero
-- to reach nonneg. Mixed-sign cases go through inegNonneg (the product is a
-- negated nonneg, i.e. a `wsub zero _`).
imulSpec : (x : Int) -> (y : Int)
  -> Eq Int (imul x y)
       (wsub (addW (mulW (posP x) (posP y)) (mulW (negP x) (negP y)))
             (addW (mulW (posP x) (negP y)) (mulW (negP x) (posP y)))) is
  fn (x : Int) (y : Int) is
    IntElim (fn (wx : Int) is Eq Int (imul wx y)
              (wsub (addW (mulW (posP wx) (posP y)) (mulW (negP wx) (negP y)))
                    (addW (mulW (posP wx) (negP y)) (mulW (negP wx) (posP y)))) end)
      (fn (a : Whole) is
         IntElim (fn (wy : Int) is Eq Int (imul (nonneg a) wy)
                   (wsub (addW (mulW (posP (nonneg a)) (posP wy)) (mulW (negP (nonneg a)) (negP wy)))
                         (addW (mulW (posP (nonneg a)) (negP wy)) (mulW (negP (nonneg a)) (posP wy)))) end)
           (fn (c : Whole) is
              congWsub2 (mulW a c) (addW (mulW a c) zero) zero (addW (mulW a zero) zero)
                (symEq Whole (addW (mulW a c) zero) (mulW a c) (addWZeroR (mulW a c)))
                (symEq Whole (addW (mulW a zero) zero) zero
                   (transEq Whole (addW (mulW a zero) zero) (mulW a zero) zero
                      (addWZeroR (mulW a zero)) (mulWZeroR a)))
            end)
           (fn (d : Whole) is
              transEq Int (ineg (nonneg (mulW a (succ d)))) (wsub zero (mulW a (succ d)))
                (wsub (addW (mulW a zero) zero) (addW (mulW a (succ d)) zero))
                (inegNonneg (mulW a (succ d)))
                (congWsub2 zero (addW (mulW a zero) zero) (mulW a (succ d)) (addW (mulW a (succ d)) zero)
                   (symEq Whole (addW (mulW a zero) zero) zero
                      (transEq Whole (addW (mulW a zero) zero) (mulW a zero) zero
                         (addWZeroR (mulW a zero)) (mulWZeroR a)))
                   (symEq Whole (addW (mulW a (succ d)) zero) (mulW a (succ d)) (addWZeroR (mulW a (succ d)))))
            end)
           y
       end)
      (fn (b : Whole) is
         IntElim (fn (wy : Int) is Eq Int (imul (negsucc b) wy)
                   (wsub (addW (mulW (posP (negsucc b)) (posP wy)) (mulW (negP (negsucc b)) (negP wy)))
                         (addW (mulW (posP (negsucc b)) (negP wy)) (mulW (negP (negsucc b)) (posP wy)))) end)
           (fn (c : Whole) is
              transEq Int (ineg (nonneg (mulW (succ b) c))) (wsub zero (mulW (succ b) c))
                (wsub (mulW (succ b) zero) (mulW (succ b) c))
                (inegNonneg (mulW (succ b) c))
                (congWsub2 zero (mulW (succ b) zero) (mulW (succ b) c) (mulW (succ b) c)
                   (symEq Whole (mulW (succ b) zero) zero (mulWZeroR (succ b)))
                   (refl (mulW (succ b) c)))
            end)
           (fn (d : Whole) is
              congWsub2 (mulW (succ b) (succ d)) (mulW (succ b) (succ d)) zero (mulW (succ b) zero)
                (refl (mulW (succ b) (succ d)))
                (symEq Whole (mulW (succ b) zero) zero (mulWZeroR (succ b)))
            end)
           y
       end)
      x
  end
end

-- ineg as a wsub of the reversed difference. The nonneg case is exactly
-- inegNonneg; the negsucc case computes (leb zero / subW (succ k) zero).
inegSpec : (x : Int) -> Eq Int (ineg x) (wsub (negP x) (posP x)) is
  fn (x : Int) is
    IntElim (fn (w : Int) is Eq Int (ineg w) (wsub (negP w) (posP w)) end)
      (fn (n : Whole) is inegNonneg n end)
      (fn (k : Whole) is refl (nonneg (succ k)) end)
      x
  end
end

-- The degree-2 cross-equality (pmulRespL's shape over junk-free Int): given the
-- difference pairs (u,v) ~ (r,w) (u+w = r+v), the signed products by (s,t) agree
-- as differences. Both sides regroup to like-multiplier columns (distribWR) and
-- rewrite through the hypothesis; the additive shuffling is addWInterchange.
mulCrossIdent : (u : Whole) -> (v : Whole) -> (r : Whole) -> (w : Whole) -> (s : Whole) -> (t : Whole)
  -> Eq Whole (addW u w) (addW r v)
  -> Eq Whole (addW (addW (mulW u s) (mulW v t)) (addW (mulW r t) (mulW w s)))
              (addW (addW (mulW r s) (mulW w t)) (addW (mulW u t) (mulW v s))) is
  fn (u : Whole) (v : Whole) (r : Whole) (w : Whole) (s : Whole) (t : Whole)
     (hyp : Eq Whole (addW u w) (addW r v)) is
    let a1 : Whole = mulW u s in
    let a2 : Whole = mulW v t in
    let a3 : Whole = mulW r t in
    let a4 : Whole = mulW w s in
    let b1 : Whole = mulW r s in
    let b2 : Whole = mulW w t in
    let b3 : Whole = mulW u t in
    let b4 : Whole = mulW v s in
    let colPz : Eq Whole (addW a1 a4) (addW b1 b4)
      = transEq Whole (addW a1 a4) (mulW (addW u w) s) (addW b1 b4)
          (symEq Whole (mulW (addW u w) s) (addW a1 a4) (distribWR u w s))
          (transEq Whole (mulW (addW u w) s) (mulW (addW r v) s) (addW b1 b4)
             (congW (fn (zz : Whole) is mulW zz s end) (addW u w) (addW r v) hyp)
             (distribWR r v s)) in
    let vrEq : Eq Whole (addW v r) (addW w u)
      = transEq Whole (addW v r) (addW r v) (addW w u)
          (addWComm v r)
          (transEq Whole (addW r v) (addW u w) (addW w u)
             (symEq Whole (addW u w) (addW r v) hyp)
             (addWComm u w)) in
    let g2 : Eq Whole (addW a2 a3) (addW b2 b3)
      = transEq Whole (addW a2 a3) (mulW (addW v r) t) (addW b2 b3)
          (symEq Whole (mulW (addW v r) t) (addW a2 a3) (distribWR v r t))
          (transEq Whole (mulW (addW v r) t) (mulW (addW w u) t) (addW b2 b3)
             (congW (fn (zz : Whole) is mulW zz t end) (addW v r) (addW w u) vrEq)
             (distribWR w u t)) in
    let part1 : Eq Whole (addW (addW a1 a2) (addW a3 a4)) (addW (addW a1 a4) (addW a2 a3))
      = transEq Whole (addW (addW a1 a2) (addW a3 a4)) (addW (addW a1 a2) (addW a4 a3)) (addW (addW a1 a4) (addW a2 a3))
          (congW (fn (zz : Whole) is addW (addW a1 a2) zz end) (addW a3 a4) (addW a4 a3) (addWComm a3 a4))
          (addWInterchange a1 a2 a4 a3) in
    let part2 : Eq Whole (addW (addW a1 a4) (addW a2 a3)) (addW (addW b1 b4) (addW b2 b3))
      = transEq Whole (addW (addW a1 a4) (addW a2 a3)) (addW (addW b1 b4) (addW a2 a3)) (addW (addW b1 b4) (addW b2 b3))
          (congW (fn (zz : Whole) is addW zz (addW a2 a3) end) (addW a1 a4) (addW b1 b4) colPz)
          (congW (fn (zz : Whole) is addW (addW b1 b4) zz end) (addW a2 a3) (addW b2 b3) g2) in
    let part3 : Eq Whole (addW (addW b1 b4) (addW b2 b3)) (addW (addW b1 b2) (addW b3 b4))
      = transEq Whole (addW (addW b1 b4) (addW b2 b3)) (addW (addW b1 b2) (addW b4 b3)) (addW (addW b1 b2) (addW b3 b4))
          (addWInterchange b1 b4 b2 b3)
          (congW (fn (zz : Whole) is addW (addW b1 b2) zz end) (addW b4 b3) (addW b3 b4) (addWComm b4 b3)) in
    transEq Whole (addW (addW a1 a2) (addW a3 a4)) (addW (addW a1 a4) (addW a2 a3)) (addW (addW b1 b2) (addW b3 b4))
      part1
      (transEq Whole (addW (addW a1 a4) (addW a2 a3)) (addW (addW b1 b4) (addW b2 b3)) (addW (addW b1 b2) (addW b3 b4))
         part2 part3)
  end
end

-- PUSH a wsub through iadd: iadd (wsub p n) z = wsub (p + posP z) (n + negP z).
-- Chain iaddSpec at (wsub p n, z) with wsubEq; the cross-equality reduces
-- through wsubPosNeg (P0 + n = p + N0), regrouped by addWInterchange.
iaddWsub : (p : Whole) -> (n : Whole) -> (z : Int)
  -> Eq Int (iadd (wsub p n) z) (wsub (addW p (posP z)) (addW n (negP z))) is
  fn (p : Whole) (n : Whole) (z : Int) is
    let P0 : Whole = posP (wsub p n) in
    let N0 : Whole = negP (wsub p n) in
    let pz : Whole = posP z in
    let nz : Whole = negP z in
    let K : Eq Whole (addW P0 n) (addW p N0) = wsubPosNeg p n in
    let H : Eq Whole (addW (addW P0 pz) (addW n nz)) (addW (addW p pz) (addW N0 nz))
      = transEq Whole (addW (addW P0 pz) (addW n nz)) (addW (addW P0 n) (addW pz nz)) (addW (addW p pz) (addW N0 nz))
          (addWInterchange P0 pz n nz)
          (transEq Whole (addW (addW P0 n) (addW pz nz)) (addW (addW p N0) (addW pz nz)) (addW (addW p pz) (addW N0 nz))
             (congW (fn (zz : Whole) is addW zz (addW pz nz) end) (addW P0 n) (addW p N0) K)
             (symEq Whole (addW (addW p pz) (addW N0 nz)) (addW (addW p N0) (addW pz nz)) (addWInterchange p pz N0 nz))) in
    transEq Int (iadd (wsub p n) z)
      (wsub (addW P0 pz) (addW N0 nz)) (wsub (addW p pz) (addW n nz))
      (iaddSpec (wsub p n) z)
      (wsubEq (addW P0 pz) (addW N0 nz) (addW p pz) (addW n nz) H)
  end
end

-- PUSH a wsub through imul. Chain imulSpec at (wsub p n, z) with wsubEq; the
-- cross-equality is mulCrossIdent driven by wsubPosNeg (the degree-2 lift of the
-- difference-pair equality).
imulWsub : (p : Whole) -> (n : Whole) -> (z : Int)
  -> Eq Int (imul (wsub p n) z)
       (wsub (addW (mulW p (posP z)) (mulW n (negP z)))
             (addW (mulW p (negP z)) (mulW n (posP z)))) is
  fn (p : Whole) (n : Whole) (z : Int) is
    let P0 : Whole = posP (wsub p n) in
    let N0 : Whole = negP (wsub p n) in
    let pz : Whole = posP z in
    let nz : Whole = negP z in
    let K : Eq Whole (addW P0 n) (addW p N0) = wsubPosNeg p n in
    let H : Eq Whole (addW (addW (mulW P0 pz) (mulW N0 nz)) (addW (mulW p nz) (mulW n pz)))
                     (addW (addW (mulW p pz) (mulW n nz)) (addW (mulW P0 nz) (mulW N0 pz)))
      = mulCrossIdent P0 N0 p n pz nz K in
    transEq Int (imul (wsub p n) z)
      (wsub (addW (mulW P0 pz) (mulW N0 nz)) (addW (mulW P0 nz) (mulW N0 pz)))
      (wsub (addW (mulW p pz) (mulW n nz)) (addW (mulW p nz) (mulW n pz)))
      (imulSpec (wsub p n) z)
      (wsubEq (addW (mulW P0 pz) (mulW N0 nz)) (addW (mulW P0 nz) (mulW N0 pz))
              (addW (mulW p pz) (mulW n nz)) (addW (mulW p nz) (mulW n pz)) H)
  end
end

-- ====================================================================
-- THE INT RING LAWS (Int ring-laws campaign, Task 4). Each law reduces to
-- Whole arithmetic: rewrite every Int operand into `wsub` of a Whole pair
-- (via the *Spec lemmas), collapse nested ops with iaddWsub/imulWsub (and
-- the right/pair mirrors below), until each side is ONE `wsub` of a Whole
-- polynomial, then close with wsubEq (cross-equality) or congWsub2
-- (component-wise). The eight-term multiplicative-associativity shuffle is
-- packaged as `mulAssocCol` (ch107's pmulAssocFst over junk-free Int),
-- reused for both wsub columns with the e/f swap.
-- ====================================================================

-- Binary congruence on a Whole operation (there is no ambient cong2).
cong2W : (f : Whole -> Whole -> Whole) -> (x1 : Whole) -> (y1 : Whole) -> (x2 : Whole) -> (y2 : Whole)
  -> Eq Whole x1 y1 -> Eq Whole x2 y2 -> Eq Whole (f x1 x2) (f y1 y2) is
  fn (f : Whole -> Whole -> Whole) (x1 : Whole) (y1 : Whole) (x2 : Whole) (y2 : Whole)
     (p1 : Eq Whole x1 y1) (p2 : Eq Whole x2 y2) is
    transEq Whole (f x1 x2) (f y1 x2) (f y1 y2)
      (congW (fn (t : Whole) is f t x2 end) x1 y1 p1)
      (congW (fn (t : Whole) is f y1 t end) x2 y2 p2)
  end
end

-- Rewrite either operand of iadd/imul (subst under the op; no ambient cong
-- across the Int -> Int -> Int shape).
congIaddL : (x : Int) -> (x' : Int) -> (y : Int) -> Eq Int x x' -> Eq Int (iadd x y) (iadd x' y) is
  fn (x : Int) (x' : Int) (y : Int) (p : Eq Int x x') is
    subst Int x x' p (fn (z : Int) is Eq Int (iadd x y) (iadd z y) end) (refl (iadd x y))
  end
end
congIaddR : (x : Int) -> (y : Int) -> (y' : Int) -> Eq Int y y' -> Eq Int (iadd x y) (iadd x y') is
  fn (x : Int) (y : Int) (y' : Int) (p : Eq Int y y') is
    subst Int y y' p (fn (z : Int) is Eq Int (iadd x y) (iadd x z) end) (refl (iadd x y))
  end
end
congImulL : (x : Int) -> (x' : Int) -> (y : Int) -> Eq Int x x' -> Eq Int (imul x y) (imul x' y) is
  fn (x : Int) (x' : Int) (y : Int) (p : Eq Int x x') is
    subst Int x x' p (fn (z : Int) is Eq Int (imul x y) (imul z y) end) (refl (imul x y))
  end
end
congImulR : (x : Int) -> (y : Int) -> (y' : Int) -> Eq Int y y' -> Eq Int (imul x y) (imul x y') is
  fn (x : Int) (y : Int) (y' : Int) (p : Eq Int y y') is
    subst Int y y' p (fn (z : Int) is Eq Int (imul x y) (imul x z) end) (refl (imul x y))
  end
end

-- Right mirror of iaddWsub: push a wsub through the SECOND operand of iadd.
-- Same cross-equality (wsubPosNeg regrouped by addWInterchange), operands on
-- the other side.
iaddWsubR : (z : Int) -> (p : Whole) -> (n : Whole)
  -> Eq Int (iadd z (wsub p n)) (wsub (addW (posP z) p) (addW (negP z) n)) is
  fn (z : Int) (p : Whole) (n : Whole) is
    let P0 : Whole = posP (wsub p n) in
    let N0 : Whole = negP (wsub p n) in
    let pz : Whole = posP z in
    let nz : Whole = negP z in
    let K : Eq Whole (addW P0 n) (addW p N0) = wsubPosNeg p n in
    let H : Eq Whole (addW (addW pz P0) (addW nz n)) (addW (addW pz p) (addW nz N0))
      = transEq Whole (addW (addW pz P0) (addW nz n)) (addW (addW pz nz) (addW P0 n)) (addW (addW pz p) (addW nz N0))
          (addWInterchange pz P0 nz n)
          (transEq Whole (addW (addW pz nz) (addW P0 n)) (addW (addW pz nz) (addW p N0)) (addW (addW pz p) (addW nz N0))
             (congW (fn (zz : Whole) is addW (addW pz nz) zz end) (addW P0 n) (addW p N0) K)
             (symEq Whole (addW (addW pz p) (addW nz N0)) (addW (addW pz nz) (addW p N0)) (addWInterchange pz p nz N0))) in
    transEq Int (iadd z (wsub p n))
      (wsub (addW pz P0) (addW nz N0)) (wsub (addW pz p) (addW nz n))
      (iaddSpec z (wsub p n))
      (wsubEq (addW pz P0) (addW nz N0) (addW pz p) (addW nz n) H)
  end
end

-- Pair form of iaddWsub: iadd of two explicit wsubs collapses componentwise.
-- Chain iaddWsub (left literal) then resolve the right operand's posP/negP by
-- wsubPosNeg, regrouped by addWInterchange.
iaddWsub2 : (p1 : Whole) -> (n1 : Whole) -> (p2 : Whole) -> (n2 : Whole)
  -> Eq Int (iadd (wsub p1 n1) (wsub p2 n2)) (wsub (addW p1 p2) (addW n1 n2)) is
  fn (p1 : Whole) (n1 : Whole) (p2 : Whole) (n2 : Whole) is
    let Q0 : Whole = posP (wsub p2 n2) in
    let R0 : Whole = negP (wsub p2 n2) in
    let K2 : Eq Whole (addW Q0 n2) (addW p2 R0) = wsubPosNeg p2 n2 in
    let H : Eq Whole (addW (addW p1 Q0) (addW n1 n2)) (addW (addW p1 p2) (addW n1 R0))
      = transEq Whole (addW (addW p1 Q0) (addW n1 n2)) (addW (addW p1 n1) (addW Q0 n2)) (addW (addW p1 p2) (addW n1 R0))
          (addWInterchange p1 Q0 n1 n2)
          (transEq Whole (addW (addW p1 n1) (addW Q0 n2)) (addW (addW p1 n1) (addW p2 R0)) (addW (addW p1 p2) (addW n1 R0))
             (congW (fn (zz : Whole) is addW (addW p1 n1) zz end) (addW Q0 n2) (addW p2 R0) K2)
             (symEq Whole (addW (addW p1 p2) (addW n1 R0)) (addW (addW p1 n1) (addW p2 R0)) (addWInterchange p1 p2 n1 R0))) in
    transEq Int (iadd (wsub p1 n1) (wsub p2 n2))
      (wsub (addW p1 Q0) (addW n1 R0)) (wsub (addW p1 p2) (addW n1 n2))
      (iaddWsub p1 n1 (wsub p2 n2))
      (wsubEq (addW p1 Q0) (addW n1 R0) (addW p1 p2) (addW n1 n2) H)
  end
end

-- The eight-term multiplicative-associativity column (ch107's pmulAssocFst
-- shape). Both sides reduce to a1(ce+df) + b(cf+de): distribute (distribWR),
-- reassociate the triple products (mulWAssoc), interchange to a/b columns
-- (addWInterchange), contract (distribWL reversed), align the b-factor
-- (addWComm), and flip the multiplier order (mulWComm).
mulAssocCol : (a : Whole) -> (b : Whole) -> (c : Whole) -> (d : Whole) -> (e : Whole) -> (f : Whole)
  -> Eq Whole
       (addW (mulW (addW (mulW a c) (mulW b d)) e) (mulW (addW (mulW a d) (mulW b c)) f))
       (addW (mulW (addW (mulW c e) (mulW d f)) a) (mulW (addW (mulW c f) (mulW d e)) b)) is
  fn (a : Whole) (b : Whole) (c : Whole) (d : Whole) (e : Whole) (f : Whole) is
    let ace : Whole = mulW a (mulW c e) in
    let bde : Whole = mulW b (mulW d e) in
    let adf : Whole = mulW a (mulW d f) in
    let bcf : Whole = mulW b (mulW c f) in
    let canon : Whole = addW (mulW a (addW (mulW c e) (mulW d f))) (mulW b (addW (mulW c f) (mulW d e))) in
    let lhs2canon : Eq Whole
          (addW (mulW (addW (mulW a c) (mulW b d)) e) (mulW (addW (mulW a d) (mulW b c)) f))
          canon
      = transEq Whole
          (addW (mulW (addW (mulW a c) (mulW b d)) e) (mulW (addW (mulW a d) (mulW b c)) f))
          (addW (addW (mulW (mulW a c) e) (mulW (mulW b d) e)) (addW (mulW (mulW a d) f) (mulW (mulW b c) f)))
          canon
          (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
             (mulW (addW (mulW a c) (mulW b d)) e) (addW (mulW (mulW a c) e) (mulW (mulW b d) e))
             (mulW (addW (mulW a d) (mulW b c)) f) (addW (mulW (mulW a d) f) (mulW (mulW b c) f))
             (distribWR (mulW a c) (mulW b d) e)
             (distribWR (mulW a d) (mulW b c) f))
          (transEq Whole
             (addW (addW (mulW (mulW a c) e) (mulW (mulW b d) e)) (addW (mulW (mulW a d) f) (mulW (mulW b c) f)))
             (addW (addW ace bde) (addW adf bcf))
             canon
             (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
                (addW (mulW (mulW a c) e) (mulW (mulW b d) e)) (addW ace bde)
                (addW (mulW (mulW a d) f) (mulW (mulW b c) f)) (addW adf bcf)
                (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
                   (mulW (mulW a c) e) ace (mulW (mulW b d) e) bde
                   (mulWAssoc a c e) (mulWAssoc b d e))
                (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
                   (mulW (mulW a d) f) adf (mulW (mulW b c) f) bcf
                   (mulWAssoc a d f) (mulWAssoc b c f)))
             (transEq Whole
                (addW (addW ace bde) (addW adf bcf))
                (addW (addW ace adf) (addW bde bcf))
                canon
                (addWInterchange ace bde adf bcf)
                (transEq Whole
                   (addW (addW ace adf) (addW bde bcf))
                   (addW (mulW a (addW (mulW c e) (mulW d f))) (mulW b (addW (mulW d e) (mulW c f))))
                   canon
                   (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
                      (addW ace adf) (mulW a (addW (mulW c e) (mulW d f)))
                      (addW bde bcf) (mulW b (addW (mulW d e) (mulW c f)))
                      (symEq Whole (mulW a (addW (mulW c e) (mulW d f))) (addW ace adf) (distribWL a (mulW c e) (mulW d f)))
                      (symEq Whole (mulW b (addW (mulW d e) (mulW c f))) (addW bde bcf) (distribWL b (mulW d e) (mulW c f))))
                   (congW (fn (s : Whole) is addW (mulW a (addW (mulW c e) (mulW d f))) (mulW b s) end)
                      (addW (mulW d e) (mulW c f)) (addW (mulW c f) (mulW d e))
                      (addWComm (mulW d e) (mulW c f)))))) in
    transEq Whole
      (addW (mulW (addW (mulW a c) (mulW b d)) e) (mulW (addW (mulW a d) (mulW b c)) f))
      canon
      (addW (mulW (addW (mulW c e) (mulW d f)) a) (mulW (addW (mulW c f) (mulW d e)) b))
      lhs2canon
      (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
         (mulW a (addW (mulW c e) (mulW d f))) (mulW (addW (mulW c e) (mulW d f)) a)
         (mulW b (addW (mulW c f) (mulW d e))) (mulW (addW (mulW c f) (mulW d e)) b)
         (mulWComm a (addW (mulW c e) (mulW d f)))
         (mulWComm b (addW (mulW c f) (mulW d e))))
  end
end

-- THE THIRTEEN LAW LEMMAS + imulComm. Easy identities/annihilators first,
-- then commutativity, then associativity/distributivity, then the mul
-- associativity shuffle and the multiplicative identities.

-- iadd left/right zero: nonneg zero is the additive identity.
iaddZeroL : IdLT Int iadd (nonneg zero) is
  fn (a : Int) is
    transEq Int (iadd (nonneg zero) a) (wsub (posP a) (negP a)) a
      (iaddSpec (nonneg zero) a)
      (wsubRep a)
  end
end
iaddZeroR : IdRT Int iadd (nonneg zero) is
  fn (a : Int) is
    transEq Int (iadd a (nonneg zero)) (wsub (addW (posP a) zero) (addW (negP a) zero)) a
      (iaddSpec a (nonneg zero))
      (transEq Int (wsub (addW (posP a) zero) (addW (negP a) zero)) (wsub (posP a) (negP a)) a
         (congWsub2 (addW (posP a) zero) (posP a) (addW (negP a) zero) (negP a) (addWZeroR (posP a)) (addWZeroR (negP a)))
         (wsubRep a))
  end
end

-- imul left/right zero: nonneg zero annihilates.
imulZeroL : AnnihLT Int imul (nonneg zero) is
  fn (a : Int) is imulSpec (nonneg zero) a end
end
imulZeroR : AnnihRT Int imul (nonneg zero) is
  fn (a : Int) is
    transEq Int (imul a (nonneg zero))
      (wsub (addW (mulW (posP a) zero) (mulW (negP a) zero)) (addW (mulW (posP a) zero) (mulW (negP a) zero)))
      (nonneg zero)
      (imulSpec a (nonneg zero))
      (congWsub2 (addW (mulW (posP a) zero) (mulW (negP a) zero)) zero
                 (addW (mulW (posP a) zero) (mulW (negP a) zero)) zero
        (transEq Whole (addW (mulW (posP a) zero) (mulW (negP a) zero)) (mulW (negP a) zero) zero
           (congW (fn (t : Whole) is addW t (mulW (negP a) zero) end) (mulW (posP a) zero) zero (mulWZeroR (posP a)))
           (mulWZeroR (negP a)))
        (transEq Whole (addW (mulW (posP a) zero) (mulW (negP a) zero)) (mulW (negP a) zero) zero
           (congW (fn (t : Whole) is addW t (mulW (negP a) zero) end) (mulW (posP a) zero) zero (mulWZeroR (posP a)))
           (mulWZeroR (negP a))))
  end
end

-- Additive inverse: ineg a cancels a on both sides (to nonneg zero = wsub 0 0).
inegInvL : NegInvLT Int iadd ineg (nonneg zero) is
  fn (a : Int) is
    transEq Int (iadd (ineg a) a)
      (wsub (addW (negP a) (posP a)) (addW (posP a) (negP a)))
      (nonneg zero)
      (transEq Int (iadd (ineg a) a) (iadd (wsub (negP a) (posP a)) a) (wsub (addW (negP a) (posP a)) (addW (posP a) (negP a)))
         (congIaddL (ineg a) (wsub (negP a) (posP a)) a (inegSpec a))
         (iaddWsub (negP a) (posP a) a))
      (wsubEq (addW (negP a) (posP a)) (addW (posP a) (negP a)) zero zero
         (transEq Whole (addW (addW (negP a) (posP a)) zero) (addW (negP a) (posP a)) (addW (posP a) (negP a))
            (addWZeroR (addW (negP a) (posP a)))
            (addWComm (negP a) (posP a))))
  end
end
inegInvR : NegInvRT Int iadd ineg (nonneg zero) is
  fn (a : Int) is
    transEq Int (iadd a (ineg a))
      (wsub (addW (posP a) (negP a)) (addW (negP a) (posP a)))
      (nonneg zero)
      (transEq Int (iadd a (ineg a)) (iadd a (wsub (negP a) (posP a))) (wsub (addW (posP a) (negP a)) (addW (negP a) (posP a)))
         (congIaddR a (ineg a) (wsub (negP a) (posP a)) (inegSpec a))
         (iaddWsubR a (negP a) (posP a)))
      (wsubEq (addW (posP a) (negP a)) (addW (negP a) (posP a)) zero zero
         (transEq Whole (addW (addW (posP a) (negP a)) zero) (addW (posP a) (negP a)) (addW (negP a) (posP a))
            (addWZeroR (addW (posP a) (negP a)))
            (addWComm (posP a) (negP a))))
  end
end

-- iadd is commutative (component-wise addWComm on the two wsub columns).
iaddComm : CommT Int iadd is
  fn (a : Int) (b : Int) is
    transEq Int (iadd a b)
      (wsub (addW (posP a) (posP b)) (addW (negP a) (negP b)))
      (iadd b a)
      (iaddSpec a b)
      (transEq Int
         (wsub (addW (posP a) (posP b)) (addW (negP a) (negP b)))
         (wsub (addW (posP b) (posP a)) (addW (negP b) (negP a)))
         (iadd b a)
         (congWsub2 (addW (posP a) (posP b)) (addW (posP b) (posP a)) (addW (negP a) (negP b)) (addW (negP b) (negP a))
            (addWComm (posP a) (posP b)) (addWComm (negP a) (negP b)))
         (symEq Int (iadd b a) (wsub (addW (posP b) (posP a)) (addW (negP b) (negP a))) (iaddSpec b a)))
  end
end

-- imul is commutative (mulWComm on the eight products + a column swap).
imulComm : CommT Int imul is
  fn (a : Int) (b : Int) is
    transEq Int (imul a b)
      (wsub (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))))
      (imul b a)
      (imulSpec a b)
      (transEq Int
         (wsub (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))))
         (wsub (addW (mulW (posP b) (posP a)) (mulW (negP b) (negP a))) (addW (mulW (posP b) (negP a)) (mulW (negP b) (posP a))))
         (imul b a)
         (congWsub2
            (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (addW (mulW (posP b) (posP a)) (mulW (negP b) (negP a)))
            (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (addW (mulW (posP b) (negP a)) (mulW (negP b) (posP a)))
            (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
               (mulW (posP a) (posP b)) (mulW (posP b) (posP a)) (mulW (negP a) (negP b)) (mulW (negP b) (negP a))
               (mulWComm (posP a) (posP b)) (mulWComm (negP a) (negP b)))
            (transEq Whole
               (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b)))
               (addW (mulW (negP a) (posP b)) (mulW (posP a) (negP b)))
               (addW (mulW (posP b) (negP a)) (mulW (negP b) (posP a)))
               (addWComm (mulW (posP a) (negP b)) (mulW (negP a) (posP b)))
               (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
                  (mulW (negP a) (posP b)) (mulW (posP b) (negP a)) (mulW (posP a) (negP b)) (mulW (negP b) (posP a))
                  (mulWComm (negP a) (posP b)) (mulWComm (posP a) (negP b)))))
         (symEq Int (imul b a)
            (wsub (addW (mulW (posP b) (posP a)) (mulW (negP b) (negP a))) (addW (mulW (posP b) (negP a)) (mulW (negP b) (posP a))))
            (imulSpec b a)))
  end
end

-- Right mirror of imulWsub, via imulComm (avoids re-deriving mulCrossIdent on
-- the flipped multiplier column).
imulWsubR : (z : Int) -> (p : Whole) -> (n : Whole)
  -> Eq Int (imul z (wsub p n))
       (wsub (addW (mulW p (posP z)) (mulW n (negP z))) (addW (mulW p (negP z)) (mulW n (posP z)))) is
  fn (z : Int) (p : Whole) (n : Whole) is
    transEq Int (imul z (wsub p n)) (imul (wsub p n) z)
      (wsub (addW (mulW p (posP z)) (mulW n (negP z))) (addW (mulW p (negP z)) (mulW n (posP z))))
      (imulComm z (wsub p n))
      (imulWsub p n z)
  end
end

-- iadd is associative (collapse the inner op with iaddSpec, the outer with
-- iaddWsub/iaddWsubR; close with addWAssoc componentwise).
iaddAssoc : AssocT Int iadd is
  fn (a : Int) (b : Int) (c : Int) is
    transEq Int (iadd (iadd a b) c)
      (wsub (addW (addW (posP a) (posP b)) (posP c)) (addW (addW (negP a) (negP b)) (negP c)))
      (iadd a (iadd b c))
      (transEq Int (iadd (iadd a b) c)
         (iadd (wsub (addW (posP a) (posP b)) (addW (negP a) (negP b))) c)
         (wsub (addW (addW (posP a) (posP b)) (posP c)) (addW (addW (negP a) (negP b)) (negP c)))
         (congIaddL (iadd a b) (wsub (addW (posP a) (posP b)) (addW (negP a) (negP b))) c (iaddSpec a b))
         (iaddWsub (addW (posP a) (posP b)) (addW (negP a) (negP b)) c))
      (transEq Int
         (wsub (addW (addW (posP a) (posP b)) (posP c)) (addW (addW (negP a) (negP b)) (negP c)))
         (wsub (addW (posP a) (addW (posP b) (posP c))) (addW (negP a) (addW (negP b) (negP c))))
         (iadd a (iadd b c))
         (congWsub2 (addW (addW (posP a) (posP b)) (posP c)) (addW (posP a) (addW (posP b) (posP c)))
                    (addW (addW (negP a) (negP b)) (negP c)) (addW (negP a) (addW (negP b) (negP c)))
            (addWAssoc (posP a) (posP b) (posP c)) (addWAssoc (negP a) (negP b) (negP c)))
         (symEq Int (iadd a (iadd b c))
            (wsub (addW (posP a) (addW (posP b) (posP c))) (addW (negP a) (addW (negP b) (negP c))))
            (transEq Int (iadd a (iadd b c))
               (iadd a (wsub (addW (posP b) (posP c)) (addW (negP b) (negP c))))
               (wsub (addW (posP a) (addW (posP b) (posP c))) (addW (negP a) (addW (negP b) (negP c))))
               (congIaddR a (iadd b c) (wsub (addW (posP b) (posP c)) (addW (negP b) (negP c))) (iaddSpec b c))
               (iaddWsubR a (addW (posP b) (posP c)) (addW (negP b) (negP c))))))
  end
end

-- Right distributivity: (a + b) * c = a*c + b*c. Distribute each column
-- (distribWR) and interchange to the two-product columns.
idistribR : DistribRT Int iadd imul is
  fn (a : Int) (b : Int) (c : Int) is
    transEq Int (imul (iadd a b) c)
      (wsub (addW (mulW (addW (posP a) (posP b)) (posP c)) (mulW (addW (negP a) (negP b)) (negP c)))
            (addW (mulW (addW (posP a) (posP b)) (negP c)) (mulW (addW (negP a) (negP b)) (posP c))))
      (iadd (imul a c) (imul b c))
      (transEq Int (imul (iadd a b) c)
         (imul (wsub (addW (posP a) (posP b)) (addW (negP a) (negP b))) c)
         (wsub (addW (mulW (addW (posP a) (posP b)) (posP c)) (mulW (addW (negP a) (negP b)) (negP c)))
               (addW (mulW (addW (posP a) (posP b)) (negP c)) (mulW (addW (negP a) (negP b)) (posP c))))
         (congImulL (iadd a b) (wsub (addW (posP a) (posP b)) (addW (negP a) (negP b))) c (iaddSpec a b))
         (imulWsub (addW (posP a) (posP b)) (addW (negP a) (negP b)) c))
      (transEq Int
         (wsub (addW (mulW (addW (posP a) (posP b)) (posP c)) (mulW (addW (negP a) (negP b)) (negP c)))
               (addW (mulW (addW (posP a) (posP b)) (negP c)) (mulW (addW (negP a) (negP b)) (posP c))))
         (wsub (addW (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))))
               (addW (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))
         (iadd (imul a c) (imul b c))
         (congWsub2
            (addW (mulW (addW (posP a) (posP b)) (posP c)) (mulW (addW (negP a) (negP b)) (negP c)))
            (addW (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))))
            (addW (mulW (addW (posP a) (posP b)) (negP c)) (mulW (addW (negP a) (negP b)) (posP c)))
            (addW (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))))
            (transEq Whole
               (addW (mulW (addW (posP a) (posP b)) (posP c)) (mulW (addW (negP a) (negP b)) (negP c)))
               (addW (addW (mulW (posP a) (posP c)) (mulW (posP b) (posP c))) (addW (mulW (negP a) (negP c)) (mulW (negP b) (negP c))))
               (addW (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))))
               (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
                  (mulW (addW (posP a) (posP b)) (posP c)) (addW (mulW (posP a) (posP c)) (mulW (posP b) (posP c)))
                  (mulW (addW (negP a) (negP b)) (negP c)) (addW (mulW (negP a) (negP c)) (mulW (negP b) (negP c)))
                  (distribWR (posP a) (posP b) (posP c)) (distribWR (negP a) (negP b) (negP c)))
               (addWInterchange (mulW (posP a) (posP c)) (mulW (posP b) (posP c)) (mulW (negP a) (negP c)) (mulW (negP b) (negP c))))
            (transEq Whole
               (addW (mulW (addW (posP a) (posP b)) (negP c)) (mulW (addW (negP a) (negP b)) (posP c)))
               (addW (addW (mulW (posP a) (negP c)) (mulW (posP b) (negP c))) (addW (mulW (negP a) (posP c)) (mulW (negP b) (posP c))))
               (addW (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))))
               (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
                  (mulW (addW (posP a) (posP b)) (negP c)) (addW (mulW (posP a) (negP c)) (mulW (posP b) (negP c)))
                  (mulW (addW (negP a) (negP b)) (posP c)) (addW (mulW (negP a) (posP c)) (mulW (negP b) (posP c)))
                  (distribWR (posP a) (posP b) (negP c)) (distribWR (negP a) (negP b) (posP c)))
               (addWInterchange (mulW (posP a) (negP c)) (mulW (posP b) (negP c)) (mulW (negP a) (posP c)) (mulW (negP b) (posP c)))))
         (symEq Int (iadd (imul a c) (imul b c))
            (wsub (addW (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))))
                  (addW (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))
            (transEq Int (iadd (imul a c) (imul b c))
               (iadd (wsub (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c)))) (imul b c))
               (wsub (addW (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))))
                     (addW (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))
               (congIaddL (imul a c) (wsub (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c)))) (imul b c) (imulSpec a c))
               (transEq Int
                  (iadd (wsub (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c)))) (imul b c))
                  (iadd (wsub (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c))))
                        (wsub (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))
                  (wsub (addW (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))))
                        (addW (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))
                  (congIaddR (wsub (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c)))) (imul b c) (wsub (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))) (imulSpec b c))
                  (iaddWsub2 (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c)))
                             (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))))))))
  end
end

-- Left distributivity: a * (b + c) = a*b + a*c, via imulComm + idistribR.
idistribL : DistribLT Int iadd imul is
  fn (a : Int) (b : Int) (c : Int) is
    transEq Int (imul a (iadd b c)) (imul (iadd b c) a) (iadd (imul a b) (imul a c))
      (imulComm a (iadd b c))
      (transEq Int (imul (iadd b c) a) (iadd (imul b a) (imul c a)) (iadd (imul a b) (imul a c))
         (idistribR b c a)
         (transEq Int (iadd (imul b a) (imul c a)) (iadd (imul a b) (imul c a)) (iadd (imul a b) (imul a c))
            (congIaddL (imul b a) (imul a b) (imul c a) (imulComm b a))
            (congIaddR (imul a b) (imul c a) (imul a c) (imulComm c a))))
  end
end

-- imul is associative: the eight-term shuffle via mulAssocCol on each column
-- (the neg column reuses mulAssocCol with the c-factors e/f swapped + addWComm).
imulAssoc : AssocT Int imul is
  fn (a : Int) (b : Int) (c : Int) is
    transEq Int (imul (imul a b) c)
      (wsub (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (posP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (negP c)))
            (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (negP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (posP c))))
      (imul a (imul b c))
      (transEq Int (imul (imul a b) c)
         (imul (wsub (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b)))) c)
         (wsub (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (posP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (negP c)))
               (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (negP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (posP c))))
         (congImulL (imul a b) (wsub (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b)))) c (imulSpec a b))
         (imulWsub (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) c))
      (transEq Int
         (wsub (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (posP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (negP c)))
               (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (negP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (posP c))))
         (wsub (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (posP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (negP a)))
               (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a))))
         (imul a (imul b c))
         (congWsub2
            (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (posP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (negP c)))
            (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (posP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (negP a)))
            (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (negP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (posP c)))
            (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a)))
            (mulAssocCol (posP a) (negP a) (posP b) (negP b) (posP c) (negP c))
            (transEq Whole
               (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (negP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (posP c)))
               (addW (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a)) (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)))
               (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a)))
               (mulAssocCol (posP a) (negP a) (posP b) (negP b) (negP c) (posP c))
               (addWComm (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a)) (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)))))
         (symEq Int (imul a (imul b c))
            (wsub (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (posP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (negP a)))
                  (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a))))
            (transEq Int (imul a (imul b c))
               (imul a (wsub (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))
               (wsub (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (posP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (negP a)))
                     (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a))))
               (congImulR a (imul b c) (wsub (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))) (imulSpec b c))
               (imulWsubR a (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))))
  end
end

-- Multiplicative identities: nonneg (succ zero) is the unit on both sides.
imulOneL : IdLT Int imul (nonneg (succ zero)) is
  fn (a : Int) is
    transEq Int (imul (nonneg (succ zero)) a)
      (wsub (addW (posP a) zero) (addW (negP a) zero))
      a
      (imulSpec (nonneg (succ zero)) a)
      (transEq Int (wsub (addW (posP a) zero) (addW (negP a) zero)) (wsub (posP a) (negP a)) a
         (congWsub2 (addW (posP a) zero) (posP a) (addW (negP a) zero) (negP a) (addWZeroR (posP a)) (addWZeroR (negP a)))
         (wsubRep a))
  end
end
imulOneR : IdRT Int imul (nonneg (succ zero)) is
  fn (a : Int) is
    transEq Int (imul a (nonneg (succ zero)))
      (wsub (addW (posP a) zero) (addW (negP a) zero))
      a
      (imulWsubR a (succ zero) zero)
      (transEq Int (wsub (addW (posP a) zero) (addW (negP a) zero)) (wsub (posP a) (negP a)) a
         (congWsub2 (addW (posP a) zero) (posP a) (addW (negP a) zero) (negP a) (addWZeroR (posP a)) (addWZeroR (negP a)))
         (wsubRep a))
  end
end

-- ====================================================================
-- THE ASSEMBLED INT LAW RECORDS. semiringLawsInt is the 11-slot chain over
-- ringInt.1 (same shape as semiringLawsWhole); ringLawsInt layers the two
-- additive-inverse laws; commLawsInt is imulComm; commRingLawsInt bundles
-- them; abGroupLawsInt cashes the 1b bridge (abGroupLawsOfRing) in ONE line -
-- Int IS an abelian group under addition, for free from RingLaws.
-- ====================================================================
semiringLawsInt : SemiringLaws Int (ringInt.1) is
  mkAnd (AssocT Int iadd)
        (And (CommT Int iadd)
        (And (IdLT Int iadd (nonneg zero))
        (And (IdRT Int iadd (nonneg zero))
        (And (AssocT Int imul)
        (And (IdLT Int imul (nonneg (succ zero)))
        (And (IdRT Int imul (nonneg (succ zero)))
        (And (DistribLT Int iadd imul)
        (And (DistribRT Int iadd imul)
        (And (AnnihLT Int imul (nonneg zero))
             (AnnihRT Int imul (nonneg zero)))))))))))
    iaddAssoc
    (mkAnd (CommT Int iadd)
          (And (IdLT Int iadd (nonneg zero))
          (And (IdRT Int iadd (nonneg zero))
          (And (AssocT Int imul)
          (And (IdLT Int imul (nonneg (succ zero)))
          (And (IdRT Int imul (nonneg (succ zero)))
          (And (DistribLT Int iadd imul)
          (And (DistribRT Int iadd imul)
          (And (AnnihLT Int imul (nonneg zero))
               (AnnihRT Int imul (nonneg zero))))))))))
      iaddComm
      (mkAnd (IdLT Int iadd (nonneg zero))
            (And (IdRT Int iadd (nonneg zero))
            (And (AssocT Int imul)
            (And (IdLT Int imul (nonneg (succ zero)))
            (And (IdRT Int imul (nonneg (succ zero)))
            (And (DistribLT Int iadd imul)
            (And (DistribRT Int iadd imul)
            (And (AnnihLT Int imul (nonneg zero))
                 (AnnihRT Int imul (nonneg zero)))))))))
        iaddZeroL
        (mkAnd (IdRT Int iadd (nonneg zero))
              (And (AssocT Int imul)
              (And (IdLT Int imul (nonneg (succ zero)))
              (And (IdRT Int imul (nonneg (succ zero)))
              (And (DistribLT Int iadd imul)
              (And (DistribRT Int iadd imul)
              (And (AnnihLT Int imul (nonneg zero))
                   (AnnihRT Int imul (nonneg zero))))))))
          iaddZeroR
          (mkAnd (AssocT Int imul)
                (And (IdLT Int imul (nonneg (succ zero)))
                (And (IdRT Int imul (nonneg (succ zero)))
                (And (DistribLT Int iadd imul)
                (And (DistribRT Int iadd imul)
                (And (AnnihLT Int imul (nonneg zero))
                     (AnnihRT Int imul (nonneg zero)))))))
            imulAssoc
            (mkAnd (IdLT Int imul (nonneg (succ zero)))
                  (And (IdRT Int imul (nonneg (succ zero)))
                  (And (DistribLT Int iadd imul)
                  (And (DistribRT Int iadd imul)
                  (And (AnnihLT Int imul (nonneg zero))
                       (AnnihRT Int imul (nonneg zero))))))
              imulOneL
              (mkAnd (IdRT Int imul (nonneg (succ zero)))
                    (And (DistribLT Int iadd imul)
                    (And (DistribRT Int iadd imul)
                    (And (AnnihLT Int imul (nonneg zero))
                         (AnnihRT Int imul (nonneg zero)))))
                imulOneR
                (mkAnd (DistribLT Int iadd imul)
                      (And (DistribRT Int iadd imul)
                      (And (AnnihLT Int imul (nonneg zero))
                           (AnnihRT Int imul (nonneg zero))))
                  idistribL
                  (mkAnd (DistribRT Int iadd imul)
                        (And (AnnihLT Int imul (nonneg zero))
                             (AnnihRT Int imul (nonneg zero)))
                    idistribR
                    (mkAnd (AnnihLT Int imul (nonneg zero))
                           (AnnihRT Int imul (nonneg zero))
                      imulZeroL
                      imulZeroR)))))))))
end

ringLawsInt : RingLaws Int ringInt is
  mkAnd (SemiringLaws Int (ringInt.1))
    (And (NegInvLT Int iadd ineg (nonneg zero)) (NegInvRT Int iadd ineg (nonneg zero)))
    semiringLawsInt
    (mkAnd (NegInvLT Int iadd ineg (nonneg zero)) (NegInvRT Int iadd ineg (nonneg zero))
      inegInvL inegInvR)
end

commLawsInt : CommLaws Int semiringInt is imulComm end

commRingLawsInt : CommRingLaws Int ringInt is
  mkAnd (RingLaws Int ringInt) (CommLaws Int (ringInt.1)) ringLawsInt commLawsInt
end

abGroupLawsInt : AbGroupLaws Int (groupOfRing Int ringInt) is
  abGroupLawsOfRing Int ringInt ringLawsInt
end

-- ====================================================================
-- THE FRAC RUNG (Q), RE-FOUNDED AS A QUOTIENT (v4 Frac field laws, Plan A).
-- A rational is an UNREDUCED pair: the numerator a signed Int, the
-- denominator succ-encoded so it is positive BY CONSTRUCTION (qpair i d
-- denotes i / (d+1); no zero-denominator state exists). Frac is the
-- quotient of these pairs by cross-multiplication over Int, and the ops
-- act on representatives UNREDUCED, lifted by qlift with respect proofs
-- whose content is pure Int ring algebra (the corpus above); no gcd fact
-- is ever proven. Canonical display is COMPUTATIONAL, not propositional:
-- the REPL's Go fold reduces num/den by gcd at print time, and reduceQ
-- below is its rune-side mirror, a plain function that is never the
-- subject of a proof. Show/Binary instances for Frac are REMOVED in
-- Plan A: any string rendering out of the quotient needs a respect proof
-- that IS lowest-terms uniqueness, exactly the number theory the
-- quotient route exists to avoid (Plan B revisits via to_radix).
-- ====================================================================
data QPair : U is qpair : Int -> Whole -> QPair end
qnum   : QPair -> Int   is fn (p : QPair) is case p of | qpair i d -> i end end end
qdpred : QPair -> Whole is fn (p : QPair) is case p of | qpair i d -> d end end end

-- The denominator as a positive Int: qden (qpair i d) = d+1.
qden : QPair -> Int is fn (p : QPair) is nonneg (succ (qdpred p)) end end

-- Cross-multiplication: (i1 / sd1) ~ (i2 / sd2) iff i1*sd2 = i2*sd1 in
-- Int. Eq Int lands in Prop, so QRel is Prop-valued (the relation sort
-- the Quot builtin takes).
QRel : QPair -> QPair -> Prop is
  fn (p : QPair) (q : QPair) is
    Eq Int (imul (qnum p) (qden q)) (imul (qnum q) (qden p))
  end
end
Frac : U is Quot QPair QRel end

-- A bare numeral at Frac is the whole-valued fraction n/1.
fracOf : Whole -> Frac is fn (n : Whole) is qin QPair QRel (qpair (nonneg n) zero) end end
builtin rat Frac fracOf

-- The product-denominator INDEX: succ (dmul d1 d2) = (d1+1)*(d2+1). The
-- formula addW (mulW d1 (succ d2)) d2 puts the correspondence one
-- addWSuccR away (dmulSucc), because mulW (succ d1) (succ d2) computes
-- to addW (mulW d1 (succ d2)) (succ d2) on the nose.
dmul : Whole -> Whole -> Whole is
  fn (a : Whole) (b : Whole) is addW (mulW a (succ b)) b end
end
dmulSucc : (a : Whole) -> (b : Whole) -> Eq Whole (mulW (succ a) (succ b)) (succ (dmul a b)) is
  fn (a : Whole) (b : Whole) is addWSuccR (mulW a (succ b)) b end
end

-- Raw ops on representatives, UNREDUCED. rawAdd cross-multiplies onto
-- the product denominator, rawMul is componentwise, rawNeg negates the
-- numerator, rawRecip swaps numerator and denominator (the sign stays on
-- the numerator; recip of a zero numerator is the junk value 0/1, the
-- ops-ladder convention).
rawMul : QPair -> QPair -> QPair is
  fn (p : QPair) (q : QPair) is
    qpair (imul (qnum p) (qnum q)) (dmul (qdpred p) (qdpred q))
  end
end
rawAdd : QPair -> QPair -> QPair is
  fn (p : QPair) (q : QPair) is
    qpair (iadd (imul (qnum p) (qden q)) (imul (qnum q) (qden p))) (dmul (qdpred p) (qdpred q))
  end
end
rawNeg : QPair -> QPair is
  fn (p : QPair) is qpair (ineg (qnum p)) (qdpred p) end
end
-- rawRecip factors through a numerator-explicit worker so the respect
-- proof can eliminate on the numerator with the goal computing.
rawRecipOn : Int -> Whole -> QPair is
  fn (i : Int) (d : Whole) is
    case i of
    | nonneg n ->
        case n of
        | zero -> qpair (nonneg zero) zero
        | succ k -> qpair (nonneg (succ d)) k
        end
    | negsucc k -> qpair (negsucc d) k
    end
  end
end
rawRecip : QPair -> QPair is fn (p : QPair) is rawRecipOn (qnum p) (qdpred p) end end

-- General congruence across types (subst under any function; congW and
-- the congIadd/congImul family above are its monomorphic instances).
congE : (A : U) -> (B : U) -> (f : A -> B) -> (x : A) -> (y : A) -> Eq A x y -> Eq B (f x) (f y) is
  fn (A : U) (B : U) (f : A -> B) (x : A) (y : A) (p : Eq A x y) is
    subst A x y p (fn (z : A) is Eq B (f x) (f z) end) (refl (f x))
  end
end
congIadd2 : (x1 : Int) -> (y1 : Int) -> (x2 : Int) -> (y2 : Int)
  -> Eq Int x1 y1 -> Eq Int x2 y2 -> Eq Int (iadd x1 x2) (iadd y1 y2) is
  fn (x1 : Int) (y1 : Int) (x2 : Int) (y2 : Int) (p : Eq Int x1 y1) (q : Eq Int x2 y2) is
    transEq Int (iadd x1 x2) (iadd y1 x2) (iadd y1 y2)
      (congIaddL x1 y1 x2 p)
      (congIaddR y1 x2 y2 q)
  end
end

-- The commutative-ring 4-factor regrouping (a*b)*(c*d) = (a*c)*(b*d),
-- the workhorse of every cross-multiplication respect proof (ch116's
-- zmulInterchange one rung down; our Int is canonical data).
imulInterchange : (a : Int) -> (b : Int) -> (c : Int) -> (d : Int)
  -> Eq Int (imul (imul a b) (imul c d)) (imul (imul a c) (imul b d)) is
  fn (a : Int) (b : Int) (c : Int) (d : Int) is
    transEq Int (imul (imul a b) (imul c d)) (imul a (imul b (imul c d))) (imul (imul a c) (imul b d))
      (imulAssoc a b (imul c d))
      (transEq Int (imul a (imul b (imul c d))) (imul a (imul (imul b c) d)) (imul (imul a c) (imul b d))
         (congImulR a (imul b (imul c d)) (imul (imul b c) d)
            (symEq Int (imul (imul b c) d) (imul b (imul c d)) (imulAssoc b c d)))
         (transEq Int (imul a (imul (imul b c) d)) (imul a (imul (imul c b) d)) (imul (imul a c) (imul b d))
            (congImulR a (imul (imul b c) d) (imul (imul c b) d)
               (congImulL (imul b c) (imul c b) d (imulComm b c)))
            (transEq Int (imul a (imul (imul c b) d)) (imul a (imul c (imul b d))) (imul (imul a c) (imul b d))
               (congImulR a (imul (imul c b) d) (imul c (imul b d)) (imulAssoc c b d))
               (symEq Int (imul (imul a c) (imul b d)) (imul a (imul c (imul b d))) (imulAssoc a c (imul b d))))))
  end
end

-- The denominator homomorphism: qden (rawMul p q) = qden p * qden q.
-- rawAdd shares the same denominator index, so this one lemma serves the
-- addition respect proofs too (the types are definitionally equal).
qdenMul : (p : QPair) -> (q : QPair) -> Eq Int (qden (rawMul p q)) (imul (qden p) (qden q)) is
  fn (p : QPair) (q : QPair) is
    symEq Int (imul (qden p) (qden q)) (qden (rawMul p q))
      (congNonneg (mulW (succ (qdpred p)) (succ (qdpred q))) (succ (dmul (qdpred p) (qdpred q)))
         (dmulSucc (qdpred p) (qdpred q)))
  end
end

-- WELL-DEFINEDNESS of rawMul: cross-multiplication regrouping via
-- imulInterchange, the hypothesis applied in the aligned factor (the
-- ch116 qmulRespL/R shapes over canonical Int).
mulRespR : (p : QPair) -> (q : QPair) -> (q' : QPair) -> QRel q q' -> QRel (rawMul p q) (rawMul p q') is
  fn (p : QPair) (q : QPair) (q' : QPair) (h : QRel q q') is
    let np : Int = qnum p in
    let nq : Int = qnum q in
    let nq' : Int = qnum q' in
    let dp : Int = qden p in
    let dq : Int = qden q in
    let dq' : Int = qden q' in
    transEq Int
      (imul (imul np nq) (qden (rawMul p q')))
      (imul (imul np nq) (imul dp dq'))
      (imul (imul np nq') (qden (rawMul p q)))
      (congImulR (imul np nq) (qden (rawMul p q')) (imul dp dq') (qdenMul p q'))
      (transEq Int
         (imul (imul np nq) (imul dp dq'))
         (imul (imul np dp) (imul nq dq'))
         (imul (imul np nq') (qden (rawMul p q)))
         (imulInterchange np nq dp dq')
         (transEq Int
            (imul (imul np dp) (imul nq dq'))
            (imul (imul np dp) (imul nq' dq))
            (imul (imul np nq') (qden (rawMul p q)))
            (congImulR (imul np dp) (imul nq dq') (imul nq' dq) h)
            (transEq Int
               (imul (imul np dp) (imul nq' dq))
               (imul (imul np nq') (imul dp dq))
               (imul (imul np nq') (qden (rawMul p q)))
               (symEq Int (imul (imul np nq') (imul dp dq)) (imul (imul np dp) (imul nq' dq)) (imulInterchange np nq' dp dq))
               (congImulR (imul np nq') (imul dp dq) (qden (rawMul p q)) (symEq Int (qden (rawMul p q)) (imul dp dq) (qdenMul p q))))))
  end
end
mulRespL : (p : QPair) -> (p' : QPair) -> (q : QPair) -> QRel p p' -> QRel (rawMul p q) (rawMul p' q) is
  fn (p : QPair) (p' : QPair) (q : QPair) (h : QRel p p') is
    let np : Int = qnum p in
    let np' : Int = qnum p' in
    let nq : Int = qnum q in
    let dp : Int = qden p in
    let dp' : Int = qden p' in
    let dq : Int = qden q in
    transEq Int
      (imul (imul np nq) (qden (rawMul p' q)))
      (imul (imul np nq) (imul dp' dq))
      (imul (imul np' nq) (qden (rawMul p q)))
      (congImulR (imul np nq) (qden (rawMul p' q)) (imul dp' dq) (qdenMul p' q))
      (transEq Int
         (imul (imul np nq) (imul dp' dq))
         (imul (imul np dp') (imul nq dq))
         (imul (imul np' nq) (qden (rawMul p q)))
         (imulInterchange np nq dp' dq)
         (transEq Int
            (imul (imul np dp') (imul nq dq))
            (imul (imul np' dp) (imul nq dq))
            (imul (imul np' nq) (qden (rawMul p q)))
            (congImulL (imul np dp') (imul np' dp) (imul nq dq) h)
            (transEq Int
               (imul (imul np' dp) (imul nq dq))
               (imul (imul np' nq) (imul dp dq))
               (imul (imul np' nq) (qden (rawMul p q)))
               (symEq Int (imul (imul np' nq) (imul dp dq)) (imul (imul np' dp) (imul nq dq)) (imulInterchange np' nq dp dq))
               (congImulR (imul np' nq) (imul dp dq) (qden (rawMul p q)) (symEq Int (qden (rawMul p q)) (imul dp dq) (qdenMul p q))))))
  end
end

-- Lift rawMul through QRel, twice (the ch113/ch108 double-qlift pattern;
-- Eq at a function type funext-reduces to the pointwise Pi, so the outer
-- respect witness is a function into a qind).
mulFR : QPair -> Frac -> Frac is
  fn (p : QPair) is
    qlift QPair QRel Frac
      (fn (q : QPair) is qin QPair QRel (rawMul p q) end)
      (fn (q : QPair) (q' : QPair) (r : QRel q q') is
        qsound QPair QRel (rawMul p q) (rawMul p q') (mulRespR p q q' r)
      end)
  end
end
mulF : Frac -> Frac -> Frac is
  qlift QPair QRel (Frac -> Frac) mulFR
    (fn (p : QPair) (p' : QPair) (r : QRel p p') is
      fn (z : Frac) is
        qind QPair QRel (fn (w : Frac) is Eq Frac (mulFR p w) (mulFR p' w) end)
          (fn (q : QPair) is
            qsound QPair QRel (rawMul p q) (rawMul p' q) (mulRespL p p' q r)
          end)
          z
      end
    end)
end

-- WELL-DEFINEDNESS of rawAdd: distribute the sum numerator over the
-- product denominator (idistribR), fix each summand by interchange (the
-- hypothesis lands in the aligned factor), and reassemble.
addRespR : (p : QPair) -> (q : QPair) -> (q' : QPair) -> QRel q q' -> QRel (rawAdd p q) (rawAdd p q') is
  fn (p : QPair) (q : QPair) (q' : QPair) (h : QRel q q') is
    let np : Int = qnum p in
    let nq : Int = qnum q in
    let nq' : Int = qnum q' in
    let dp : Int = qden p in
    let dq : Int = qden q in
    let dq' : Int = qden q' in
    let n1 : Int = iadd (imul np dq) (imul nq dp) in
    let n2 : Int = iadd (imul np dq') (imul nq' dp) in
    let term1 : Eq Int (imul (imul np dq) (imul dp dq')) (imul (imul np dq') (imul dp dq)) =
      transEq Int (imul (imul np dq) (imul dp dq')) (imul (imul np dp) (imul dq dq')) (imul (imul np dq') (imul dp dq))
        (imulInterchange np dq dp dq')
        (transEq Int (imul (imul np dp) (imul dq dq')) (imul (imul np dp) (imul dq' dq)) (imul (imul np dq') (imul dp dq))
           (congImulR (imul np dp) (imul dq dq') (imul dq' dq) (imulComm dq dq'))
           (symEq Int (imul (imul np dq') (imul dp dq)) (imul (imul np dp) (imul dq' dq)) (imulInterchange np dq' dp dq))) in
    let term2 : Eq Int (imul (imul nq dp) (imul dp dq')) (imul (imul nq' dp) (imul dp dq)) =
      transEq Int (imul (imul nq dp) (imul dp dq')) (imul (imul nq dp) (imul dq' dp)) (imul (imul nq' dp) (imul dp dq))
        (congImulR (imul nq dp) (imul dp dq') (imul dq' dp) (imulComm dp dq'))
        (transEq Int (imul (imul nq dp) (imul dq' dp)) (imul (imul nq dq') (imul dp dp)) (imul (imul nq' dp) (imul dp dq))
           (imulInterchange nq dp dq' dp)
           (transEq Int (imul (imul nq dq') (imul dp dp)) (imul (imul nq' dq) (imul dp dp)) (imul (imul nq' dp) (imul dp dq))
              (congImulL (imul nq dq') (imul nq' dq) (imul dp dp) h)
              (transEq Int (imul (imul nq' dq) (imul dp dp)) (imul (imul nq' dp) (imul dq dp)) (imul (imul nq' dp) (imul dp dq))
                 (symEq Int (imul (imul nq' dp) (imul dq dp)) (imul (imul nq' dq) (imul dp dp)) (imulInterchange nq' dp dq dp))
                 (congImulR (imul nq' dp) (imul dq dp) (imul dp dq) (imulComm dq dp))))) in
    transEq Int
      (imul n1 (qden (rawAdd p q')))
      (imul n1 (imul dp dq'))
      (imul n2 (qden (rawAdd p q)))
      (congImulR n1 (qden (rawAdd p q')) (imul dp dq') (qdenMul p q'))
      (transEq Int
         (imul n1 (imul dp dq'))
         (iadd (imul (imul np dq) (imul dp dq')) (imul (imul nq dp) (imul dp dq')))
         (imul n2 (qden (rawAdd p q)))
         (idistribR (imul np dq) (imul nq dp) (imul dp dq'))
         (transEq Int
            (iadd (imul (imul np dq) (imul dp dq')) (imul (imul nq dp) (imul dp dq')))
            (iadd (imul (imul np dq') (imul dp dq)) (imul (imul nq' dp) (imul dp dq)))
            (imul n2 (qden (rawAdd p q)))
            (congIadd2
               (imul (imul np dq) (imul dp dq')) (imul (imul np dq') (imul dp dq))
               (imul (imul nq dp) (imul dp dq')) (imul (imul nq' dp) (imul dp dq))
               term1 term2)
            (transEq Int
               (iadd (imul (imul np dq') (imul dp dq)) (imul (imul nq' dp) (imul dp dq)))
               (imul n2 (imul dp dq))
               (imul n2 (qden (rawAdd p q)))
               (symEq Int (imul n2 (imul dp dq)) (iadd (imul (imul np dq') (imul dp dq)) (imul (imul nq' dp) (imul dp dq)))
                  (idistribR (imul np dq') (imul nq' dp) (imul dp dq)))
               (congImulR n2 (imul dp dq) (qden (rawAdd p q)) (symEq Int (qden (rawAdd p q)) (imul dp dq) (qdenMul p q))))))
  end
end
addRespL : (p : QPair) -> (p' : QPair) -> (q : QPair) -> QRel p p' -> QRel (rawAdd p q) (rawAdd p' q) is
  fn (p : QPair) (p' : QPair) (q : QPair) (h : QRel p p') is
    let np : Int = qnum p in
    let np' : Int = qnum p' in
    let nq : Int = qnum q in
    let dp : Int = qden p in
    let dp' : Int = qden p' in
    let dq : Int = qden q in
    let n1 : Int = iadd (imul np dq) (imul nq dp) in
    let n2 : Int = iadd (imul np' dq) (imul nq dp') in
    let term1 : Eq Int (imul (imul np dq) (imul dp' dq)) (imul (imul np' dq) (imul dp dq)) =
      transEq Int (imul (imul np dq) (imul dp' dq)) (imul (imul np dp') (imul dq dq)) (imul (imul np' dq) (imul dp dq))
        (imulInterchange np dq dp' dq)
        (transEq Int (imul (imul np dp') (imul dq dq)) (imul (imul np' dp) (imul dq dq)) (imul (imul np' dq) (imul dp dq))
           (congImulL (imul np dp') (imul np' dp) (imul dq dq) h)
           (symEq Int (imul (imul np' dq) (imul dp dq)) (imul (imul np' dp) (imul dq dq)) (imulInterchange np' dq dp dq))) in
    transEq Int
      (imul n1 (qden (rawAdd p' q)))
      (imul n1 (imul dp' dq))
      (imul n2 (qden (rawAdd p q)))
      (congImulR n1 (qden (rawAdd p' q)) (imul dp' dq) (qdenMul p' q))
      (transEq Int
         (imul n1 (imul dp' dq))
         (iadd (imul (imul np dq) (imul dp' dq)) (imul (imul nq dp) (imul dp' dq)))
         (imul n2 (qden (rawAdd p q)))
         (idistribR (imul np dq) (imul nq dp) (imul dp' dq))
         (transEq Int
            (iadd (imul (imul np dq) (imul dp' dq)) (imul (imul nq dp) (imul dp' dq)))
            (iadd (imul (imul np' dq) (imul dp dq)) (imul (imul nq dp') (imul dp dq)))
            (imul n2 (qden (rawAdd p q)))
            (congIadd2
               (imul (imul np dq) (imul dp' dq)) (imul (imul np' dq) (imul dp dq))
               (imul (imul nq dp) (imul dp' dq)) (imul (imul nq dp') (imul dp dq))
               term1
               (imulInterchange nq dp dp' dq))
            (transEq Int
               (iadd (imul (imul np' dq) (imul dp dq)) (imul (imul nq dp') (imul dp dq)))
               (imul n2 (imul dp dq))
               (imul n2 (qden (rawAdd p q)))
               (symEq Int (imul n2 (imul dp dq)) (iadd (imul (imul np' dq) (imul dp dq)) (imul (imul nq dp') (imul dp dq)))
                  (idistribR (imul np' dq) (imul nq dp') (imul dp dq)))
               (congImulR n2 (imul dp dq) (qden (rawAdd p q)) (symEq Int (qden (rawAdd p q)) (imul dp dq) (qdenMul p q))))))
  end
end
addFR : QPair -> Frac -> Frac is
  fn (p : QPair) is
    qlift QPair QRel Frac
      (fn (q : QPair) is qin QPair QRel (rawAdd p q) end)
      (fn (q : QPair) (q' : QPair) (r : QRel q q') is
        qsound QPair QRel (rawAdd p q) (rawAdd p q') (addRespR p q q' r)
      end)
  end
end
addF : Frac -> Frac -> Frac is
  qlift QPair QRel (Frac -> Frac) addFR
    (fn (p : QPair) (p' : QPair) (r : QRel p p') is
      fn (z : Frac) is
        qind QPair QRel (fn (w : Frac) is Eq Frac (addFR p w) (addFR p' w) end)
          (fn (q : QPair) is
            qsound QPair QRel (rawAdd p q) (rawAdd p' q) (addRespL p p' q r)
          end)
          z
      end
    end)
end

-- NEGATION respects QRel because ineg pulls out of imul (inegImul, a
-- direct constructor-case fact on junk-free Int: four arms are refl, two
-- fold a double negation via inegInvol).
inegInvol : (x : Int) -> Eq Int (ineg (ineg x)) x is
  fn (x : Int) is
    IntElim (fn (w : Int) is Eq Int (ineg (ineg w)) w end)
      (fn (n : Whole) is
        WholeElim (fn (m : Whole) is Eq Int (ineg (ineg (nonneg m))) (nonneg m) end)
          (refl (nonneg zero))
          (fn (k : Whole) (ih : Eq Int (ineg (ineg (nonneg k))) (nonneg k)) is refl (nonneg (succ k)) end)
          n
      end)
      (fn (k : Whole) is refl (negsucc k) end)
      x
  end
end
inegImul : (a : Int) -> (b : Int) -> Eq Int (imul (ineg a) b) (ineg (imul a b)) is
  fn (a : Int) (b : Int) is
    IntElim (fn (w : Int) is Eq Int (imul (ineg w) b) (ineg (imul w b)) end)
      (fn (n : Whole) is
        WholeElim (fn (m : Whole) is Eq Int (imul (ineg (nonneg m)) b) (ineg (imul (nonneg m) b)) end)
          (IntElim (fn (w2 : Int) is Eq Int (imul (ineg (nonneg zero)) w2) (ineg (imul (nonneg zero) w2)) end)
             (fn (c : Whole) is refl (nonneg zero) end)
             (fn (d : Whole) is refl (nonneg zero) end)
             b)
          (fn (k : Whole) (ih : Eq Int (imul (ineg (nonneg k)) b) (ineg (imul (nonneg k) b))) is
             IntElim (fn (w2 : Int) is Eq Int (imul (ineg (nonneg (succ k))) w2) (ineg (imul (nonneg (succ k)) w2)) end)
               (fn (c : Whole) is refl (ineg (nonneg (mulW (succ k) c))) end)
               (fn (d : Whole) is
                  symEq Int (ineg (ineg (nonneg (mulW (succ k) (succ d))))) (nonneg (mulW (succ k) (succ d)))
                    (inegInvol (nonneg (mulW (succ k) (succ d))))
                end)
               b
           end)
          n
      end)
      (fn (k : Whole) is
        IntElim (fn (w2 : Int) is Eq Int (imul (ineg (negsucc k)) w2) (ineg (imul (negsucc k) w2)) end)
          (fn (c : Whole) is
             symEq Int (ineg (ineg (nonneg (mulW (succ k) c)))) (nonneg (mulW (succ k) c))
               (inegInvol (nonneg (mulW (succ k) c)))
           end)
          (fn (d : Whole) is refl (ineg (nonneg (mulW (succ k) (succ d)))) end)
          b
      end)
      a
  end
end
negResp : (p : QPair) -> (p' : QPair) -> QRel p p' -> QRel (rawNeg p) (rawNeg p') is
  fn (p : QPair) (p' : QPair) (h : QRel p p') is
    transEq Int (imul (ineg (qnum p)) (qden p')) (ineg (imul (qnum p) (qden p'))) (imul (ineg (qnum p')) (qden p))
      (inegImul (qnum p) (qden p'))
      (transEq Int (ineg (imul (qnum p) (qden p'))) (ineg (imul (qnum p') (qden p))) (imul (ineg (qnum p')) (qden p))
         (congE Int Int ineg (imul (qnum p) (qden p')) (imul (qnum p') (qden p)) h)
         (symEq Int (imul (ineg (qnum p')) (qden p)) (ineg (imul (qnum p') (qden p))) (inegImul (qnum p') (qden p))))
  end
end
fnegate : Frac -> Frac is
  qlift QPair QRel Frac
    (fn (p : QPair) is qin QPair QRel (rawNeg p) end)
    (fn (p : QPair) (p' : QPair) (r : QRel p p') is
      qsound QPair QRel (rawNeg p) (rawNeg p') (negResp p p' r)
    end)
end

-- RECIPROCAL respects QRel. The correlated case split: equal cross
-- products force the two numerators to share sign and zeroness, so the
-- four mixed arms are impossible (discharged by transporting isign or
-- the zero test along the hypothesis into boolDiscTF) and the two live
-- arms are one imulComm swap (positive) or one dmul rewrite (negative).
mulSuccPos : (a : Whole) -> (b : Whole) -> Eq Bool (isZero (mulW (succ a) (succ b))) false is
  fn (a : Whole) (b : Whole) is
    congE Whole Bool isZero (mulW (succ a) (succ b)) (succ (dmul a b)) (dmulSucc a b)
  end
end
negMulSS : (a : Whole) -> (b : Whole) -> Eq Int (imul (negsucc a) (nonneg (succ b))) (negsucc (dmul a b)) is
  fn (a : Whole) (b : Whole) is
    congE Whole Int (fn (w : Whole) is ineg (nonneg w) end) (mulW (succ a) (succ b)) (succ (dmul a b)) (dmulSucc a b)
  end
end
recipRespOn : (d : Whole) -> (d' : Whole) -> (i : Int) -> (i' : Int)
  -> Eq Int (imul i (nonneg (succ d'))) (imul i' (nonneg (succ d)))
  -> QRel (rawRecipOn i d) (rawRecipOn i' d') is
  fn (d : Whole) (d' : Whole) (i : Int) is
    IntElim (fn (w : Int) is
        (i' : Int) -> Eq Int (imul w (nonneg (succ d'))) (imul i' (nonneg (succ d)))
        -> QRel (rawRecipOn w d) (rawRecipOn i' d') end)
      (fn (n : Whole) is
        WholeElim (fn (m : Whole) is
            (i' : Int) -> Eq Int (imul (nonneg m) (nonneg (succ d'))) (imul i' (nonneg (succ d)))
            -> QRel (rawRecipOn (nonneg m) d) (rawRecipOn i' d') end)
          (fn (i' : Int) is
            IntElim (fn (w' : Int) is
                Eq Int (imul (nonneg zero) (nonneg (succ d'))) (imul w' (nonneg (succ d)))
                -> QRel (qpair (nonneg zero) zero) (rawRecipOn w' d') end)
              (fn (m' : Whole) is
                WholeElim (fn (mm : Whole) is
                    Eq Int (imul (nonneg zero) (nonneg (succ d'))) (imul (nonneg mm) (nonneg (succ d)))
                    -> QRel (qpair (nonneg zero) zero) (rawRecipOn (nonneg mm) d') end)
                  (fn (h2 : Eq Int (imul (nonneg zero) (nonneg (succ d'))) (imul (nonneg zero) (nonneg (succ d)))) is
                     refl (nonneg zero)
                   end)
                  (fn (j : Whole) (ihj : Eq Int (imul (nonneg zero) (nonneg (succ d'))) (imul (nonneg j) (nonneg (succ d))) -> QRel (qpair (nonneg zero) zero) (rawRecipOn (nonneg j) d')) is
                     fn (h2 : Eq Int (imul (nonneg zero) (nonneg (succ d'))) (imul (nonneg (succ j)) (nonneg (succ d)))) is
                       boolDiscTF (QRel (qpair (nonneg zero) zero) (rawRecipOn (nonneg (succ j)) d'))
                         (transEq Bool true (isZero (mulW (succ j) (succ d))) false
                            (congE Int Bool (fn (z : Int) is isZero (imag z) end)
                               (imul (nonneg zero) (nonneg (succ d'))) (imul (nonneg (succ j)) (nonneg (succ d))) h2)
                            (mulSuccPos j d))
                     end
                   end)
                  m'
               end)
              (fn (k' : Whole) is
                fn (h2 : Eq Int (imul (nonneg zero) (nonneg (succ d'))) (imul (negsucc k') (nonneg (succ d)))) is
                  boolDiscTF (QRel (qpair (nonneg zero) zero) (rawRecipOn (negsucc k') d'))
                    (symEq Bool false true
                       (congE Int Bool isign
                          (imul (nonneg zero) (nonneg (succ d'))) (negsucc (dmul k' d))
                          (transEq Int (imul (nonneg zero) (nonneg (succ d'))) (imul (negsucc k') (nonneg (succ d))) (negsucc (dmul k' d))
                             h2 (negMulSS k' d))))
                end
               end)
              i'
           end)
          (fn (k : Whole) (ihk : (i' : Int) -> Eq Int (imul (nonneg k) (nonneg (succ d'))) (imul i' (nonneg (succ d))) -> QRel (rawRecipOn (nonneg k) d) (rawRecipOn i' d')) is
            fn (i' : Int) is
              IntElim (fn (w' : Int) is
                  Eq Int (imul (nonneg (succ k)) (nonneg (succ d'))) (imul w' (nonneg (succ d)))
                  -> QRel (qpair (nonneg (succ d)) k) (rawRecipOn w' d') end)
                (fn (m' : Whole) is
                  WholeElim (fn (mm : Whole) is
                      Eq Int (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (nonneg mm) (nonneg (succ d)))
                      -> QRel (qpair (nonneg (succ d)) k) (rawRecipOn (nonneg mm) d') end)
                    (fn (h2 : Eq Int (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (nonneg zero) (nonneg (succ d)))) is
                       boolDiscTF (QRel (qpair (nonneg (succ d)) k) (rawRecipOn (nonneg zero) d'))
                         (transEq Bool true (isZero (mulW (succ k) (succ d'))) false
                            (symEq Bool (isZero (mulW (succ k) (succ d'))) true
                               (congE Int Bool (fn (z : Int) is isZero (imag z) end)
                                  (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (nonneg zero) (nonneg (succ d))) h2))
                            (mulSuccPos k d'))
                     end)
                    (fn (j : Whole) (ihj : Eq Int (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (nonneg j) (nonneg (succ d))) -> QRel (qpair (nonneg (succ d)) k) (rawRecipOn (nonneg j) d')) is
                       fn (h2 : Eq Int (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (nonneg (succ j)) (nonneg (succ d)))) is
                         transEq Int (imul (nonneg (succ d)) (nonneg (succ j))) (imul (nonneg (succ j)) (nonneg (succ d))) (imul (nonneg (succ d')) (nonneg (succ k)))
                           (imulComm (nonneg (succ d)) (nonneg (succ j)))
                           (transEq Int (imul (nonneg (succ j)) (nonneg (succ d))) (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (nonneg (succ d')) (nonneg (succ k)))
                              (symEq Int (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (nonneg (succ j)) (nonneg (succ d))) h2)
                              (imulComm (nonneg (succ k)) (nonneg (succ d'))))
                       end
                     end)
                    m'
                 end)
                (fn (k' : Whole) is
                  fn (h2 : Eq Int (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (negsucc k') (nonneg (succ d)))) is
                    boolDiscTF (QRel (qpair (nonneg (succ d)) k) (rawRecipOn (negsucc k') d'))
                      (symEq Bool false true
                         (congE Int Bool isign
                            (imul (nonneg (succ k)) (nonneg (succ d'))) (negsucc (dmul k' d))
                            (transEq Int (imul (nonneg (succ k)) (nonneg (succ d'))) (imul (negsucc k') (nonneg (succ d))) (negsucc (dmul k' d))
                               h2 (negMulSS k' d))))
                  end
                 end)
                i'
            end
           end)
          n
       end)
      (fn (k : Whole) is
        fn (i' : Int) is
          IntElim (fn (w' : Int) is
              Eq Int (imul (negsucc k) (nonneg (succ d'))) (imul w' (nonneg (succ d)))
              -> QRel (qpair (negsucc d) k) (rawRecipOn w' d') end)
            (fn (m' : Whole) is
              WholeElim (fn (mm : Whole) is
                  Eq Int (imul (negsucc k) (nonneg (succ d'))) (imul (nonneg mm) (nonneg (succ d)))
                  -> QRel (qpair (negsucc d) k) (rawRecipOn (nonneg mm) d') end)
                (fn (h2 : Eq Int (imul (negsucc k) (nonneg (succ d'))) (imul (nonneg zero) (nonneg (succ d)))) is
                   boolDiscTF (QRel (qpair (negsucc d) k) (rawRecipOn (nonneg zero) d'))
                     (congE Int Bool isign (negsucc (dmul k d')) (imul (nonneg zero) (nonneg (succ d)))
                        (transEq Int (negsucc (dmul k d')) (imul (negsucc k) (nonneg (succ d'))) (imul (nonneg zero) (nonneg (succ d)))
                           (symEq Int (imul (negsucc k) (nonneg (succ d'))) (negsucc (dmul k d')) (negMulSS k d'))
                           h2))
                 end)
                (fn (j : Whole) (ihj : Eq Int (imul (negsucc k) (nonneg (succ d'))) (imul (nonneg j) (nonneg (succ d))) -> QRel (qpair (negsucc d) k) (rawRecipOn (nonneg j) d')) is
                   fn (h2 : Eq Int (imul (negsucc k) (nonneg (succ d'))) (imul (nonneg (succ j)) (nonneg (succ d)))) is
                     boolDiscTF (QRel (qpair (negsucc d) k) (rawRecipOn (nonneg (succ j)) d'))
                       (congE Int Bool isign (negsucc (dmul k d')) (imul (nonneg (succ j)) (nonneg (succ d)))
                          (transEq Int (negsucc (dmul k d')) (imul (negsucc k) (nonneg (succ d'))) (imul (nonneg (succ j)) (nonneg (succ d)))
                             (symEq Int (imul (negsucc k) (nonneg (succ d'))) (negsucc (dmul k d')) (negMulSS k d'))
                             h2))
                   end
                 end)
                m'
             end)
            (fn (k' : Whole) is
              fn (h2 : Eq Int (imul (negsucc k) (nonneg (succ d'))) (imul (negsucc k') (nonneg (succ d)))) is
                let hA : Eq Int (negsucc (dmul k d')) (negsucc (dmul k' d)) =
                  transEq Int (negsucc (dmul k d')) (imul (negsucc k) (nonneg (succ d'))) (negsucc (dmul k' d))
                    (symEq Int (imul (negsucc k) (nonneg (succ d'))) (negsucc (dmul k d')) (negMulSS k d'))
                    (transEq Int (imul (negsucc k) (nonneg (succ d'))) (imul (negsucc k') (nonneg (succ d))) (negsucc (dmul k' d))
                       h2 (negMulSS k' d)) in
                let hW : Eq Whole (succ (dmul k d')) (succ (dmul k' d)) =
                  congE Int Whole imag (negsucc (dmul k d')) (negsucc (dmul k' d)) hA in
                let hM : Eq Whole (mulW (succ k) (succ d')) (mulW (succ k') (succ d)) =
                  transEq Whole (mulW (succ k) (succ d')) (succ (dmul k d')) (mulW (succ k') (succ d))
                    (dmulSucc k d')
                    (transEq Whole (succ (dmul k d')) (succ (dmul k' d)) (mulW (succ k') (succ d))
                       hW
                       (symEq Whole (mulW (succ k') (succ d)) (succ (dmul k' d)) (dmulSucc k' d))) in
                let hswap : Eq Whole (mulW (succ d) (succ k')) (mulW (succ d') (succ k)) =
                  transEq Whole (mulW (succ d) (succ k')) (mulW (succ k') (succ d)) (mulW (succ d') (succ k))
                    (mulWComm (succ d) (succ k'))
                    (transEq Whole (mulW (succ k') (succ d)) (mulW (succ k) (succ d')) (mulW (succ d') (succ k))
                       (symEq Whole (mulW (succ k) (succ d')) (mulW (succ k') (succ d)) hM)
                       (mulWComm (succ k) (succ d'))) in
                congE Whole Int (fn (w : Whole) is ineg (nonneg w) end)
                  (mulW (succ d) (succ k')) (mulW (succ d') (succ k)) hswap
              end
             end)
            i'
        end
       end)
      i
  end
end
recipResp : (p : QPair) -> (p' : QPair) -> QRel p p' -> QRel (rawRecip p) (rawRecip p') is
  fn (p : QPair) (p' : QPair) (h : QRel p p') is
    recipRespOn (qdpred p) (qdpred p') (qnum p) (qnum p') h
  end
end
recipF : Frac -> Frac is
  qlift QPair QRel Frac
    (fn (p : QPair) is qin QPair QRel (rawRecip p) end)
    (fn (p : QPair) (p' : QPair) (r : QRel p p') is
      qsound QPair QRel (rawRecip p) (rawRecip p') (recipResp p p' r)
    end)
end

-- The derived family: subtraction is addition of the negation, division
-- is multiplication by the reciprocal.
subF : Frac -> Frac -> Frac is fn (x : Frac) (y : Frac) is addF x (fnegate y) end end
divF : Frac -> Frac -> Frac is fn (x : Frac) (y : Frac) is mulF x (recipF y) end end

-- Division of two wholes PROMOTES to Q, exactly as subtraction promotes
-- to Z; a zero divisor yields the junk value 0/1 (denominators are
-- positive by construction, so no n/0 state exists to display).
divWF : Whole -> Whole -> Frac is
  fn (a : Whole) (b : Whole) is
    case b of
    | zero -> fracOf zero
    | succ k -> qin QPair QRel (qpair (nonneg a) k)
    end
  end
end
-- Int / Int climbs to Q the same way: a negative divisor moves its sign
-- onto the numerator (x / -(k+1) = -x / (k+1)).
divIF : Int -> Int -> Frac is
  fn (x : Int) (y : Int) is
    case y of
    | nonneg m ->
        case m of
        | zero -> fracOf zero
        | succ k -> qin QPair QRel (qpair x k)
        end
    | negsucc k -> qin QPair QRel (qpair (ineg x) k)
    end
  end
end

-- reduceQ: the COMPUTATIONAL lowest-terms reduction on representatives
-- (gcd used as a plain function). It is the rune-side mirror of the Go
-- display fold and is never the subject of a proof; the fallback arms
-- are unreachable (g divides both parts and the denominator is
-- positive) but keep it total without any divisibility fact.
reduceQ : QPair -> QPair is
  fn (p : QPair) is
    case qnum p of
    | nonneg n ->
        let den : Whole = succ (qdpred p) in
        let g : Whole = gcd n den in
        case den // g of
        | zero -> p
        | succ d2 -> qpair (nonneg (n // g)) d2
        end
    | negsucc k ->
        let den : Whole = succ (qdpred p) in
        let g : Whole = gcd (succ k) den in
        case den // g of
        | zero -> p
        | succ d2 ->
            case (succ k) // g of
            | zero -> p
            | succ m2 -> qpair (negsucc m2) d2
            end
        end
    end
  end
end

-- DIVISION, with PROMOTION. `Div A` is the class "an A divides (by an A)
-- to a Frac"; its dictionary is the operation `A -> A -> Frac`. The
-- result is ALWAYS Frac, so it is keyed by the single operand type A, a
-- DISTINCT structure from `SubR R A`. Whole / Whole, Int / Int, and
-- Frac / Frac all land at Frac; a bound Whole result divides just like a
-- numeral literal does (`$3 / 5` = `16/5`).
Div : U -> U is fn (A : U) is A -> A -> Frac end end
instance divWhole : Div Whole is divWF end
instance divFrac  : Div Frac  is divF end
instance divInt   : Div Int   is divIF end
/ : {A : U} -> {d : Div A} -> A -> A -> Frac is
  fn {A : U} {d : Div A} (x : A) (y : A) is d x y end
end

-- The Frac instances of the promoting negate / subtract (the NegR / SubR
-- classes above).
instance negFrac : NegR Frac Frac is fnegate end
instance subFrac : SubR Frac Frac is subF end

-- Frac's full rung is a DivRing over the lifted ops.
divRingFrac : DivRing Frac is
  mkDivRing Frac
    (mkRing Frac (mkSemiring Frac addF (fracOf zero) mulF (fracOf (succ zero))) fnegate)
    recipF
end
instance semiringFrac : Semiring Frac is divRingFrac.1.1 end

-- ====================================================================
-- THE TOWER GRAPH (v4). Named injections up the tower with homomorphism
-- certificates. Edges: wholeOf (Nat -> Whole, the projection, above),
-- intOf (Whole -> Int), fracOf (Whole -> Frac), ratOfInt (Int -> Frac).
-- The intOf edge preserves + * 1, now DIRECTLY BY REFL: intOf commutes with
-- iadd/imul on the nose because iadd/imul on two `nonneg` values compute
-- straight to `nonneg` of the Whole result, no normalizing step in between.
-- (Under the old sign+magnitude Int this triangle needed a normalization
-- lemma certifying that the smart constructor's minus-zero normalization
-- was a no-op on an already-non-negative magnitude; junk-free Int has no
-- such lemma to state because it has no such junk to normalize away.) The
-- Frac edges' homomorphisms need gcd/reduce theory and ship with the Frac
-- laws campaign. The triangle ratOfInt . intOf = fracOf is DEFINITIONAL
-- (both sides are frac false n 1).
-- ====================================================================
ratOfInt : Int -> Frac is
  fn (i : Int) is qin QPair QRel (qpair i zero) end
end

intOfAdd : (a : Whole) -> (b : Whole) -> Eq Int (iadd (intOf a) (intOf b)) (intOf (addW a b)) is
  fn (a : Whole) (b : Whole) is refl (nonneg (addW a b)) end
end
intOfMul : (a : Whole) -> (b : Whole) -> Eq Int (imul (intOf a) (intOf b)) (intOf (mulW a b)) is
  fn (a : Whole) (b : Whole) is refl (nonneg (mulW a b)) end
end
intOfOne : Eq Int (intOf (succ zero)) (nonneg (succ zero)) is refl (nonneg (succ zero)) end

-- The commuting triangle, by refl: both sides compute to qin (qpair (nonneg n) zero).
ratOfIntOf : (n : Whole) -> Eq Frac (ratOfInt (intOf n)) (fracOf n) is
  fn (n : Whole) is refl (fracOf n) end
end

-- ====================================================================
-- PROVABLY-WHOLE subtraction.  When `b <= a` is in hand, a − b stays a Whole, no
-- promotion: the proof is part of the TYPE. `monus` is the unconditional truncating
-- whole subtraction (floors at 0) for when underflow is acceptable.
-- ====================================================================
Leq : Whole -> Whole -> U is fn (a : Whole) (b : Whole) is Eq Bool (leb a b) true end end
minus : (a : Whole) -> (b : Whole) -> Leq b a -> Whole is
  fn (a : Whole) (b : Whole) (_pf : Leq b a) is subW a b end
end
monus : Whole -> Whole -> Whole is fn (a : Whole) (b : Whole) is subW a b end end

-- ====================================================================
-- DIVISION, DEFENDED.  ℕ is not closed under division either; the fraction builder
-- `/` climbs to ℚ. But x/0 is undefined at every rung, so a CHECKED division
-- returns a Result: `ok` the (reduced) quotient, or `err` on a zero divisor.
-- ====================================================================
data Result : U -> U -> U is
  ok  : (A : U) -> (E : U) -> A -> Result A E
| err : (A : U) -> (E : U) -> E -> Result A E
end

-- ArithErr — a DISCRIMINATED UNION of the ways an arithmetic operation can fail,
-- each variant CARRYING the operands that explain it (the Idris2 / Lean4 / Haskell
-- spirit: an error is structured DATA, not a string). The human-readable message is
-- the Show boundary — here the REPL's pretty-printer, which folds each variant to a
-- sentence (`divByZero 7 0` -> "cannot divide 7 by 0"), so the operands need not be
-- re-parsed out of a baked f-string. Room is left for further faults: add a
-- constructor and a renderer arm. `divByZero a b` covers the `b = (1-1)` case — the
-- zero denominator is carried, whatever expression produced it.
data ArithErr : U is
  divByZero   : Whole -> Whole -> ArithErr   -- a / 0  — carries (numerator, denominator)
| notIntegral : Frac  -> ArithErr            -- demotion of a value with denominator > 1
| negative    : Frac  -> ArithErr            -- demotion of a negative value to Whole / Nat
| notCounting : Frac  -> ArithErr            -- demotion of zero to a counting number (Nat)
end

divChecked : Whole -> Whole -> Result Frac ArithErr is
  fn (a : Whole) (b : Whole) is
    case b of
    | zero   -> err Frac ArithErr (divByZero a b)
    | succ k -> ok Frac ArithErr (qin QPair QRel (qpair (nonneg a) k))
    end
  end
end

powTen : Whole -> Whole is
  fn (n : Whole) is case n of | zero -> 1 | succ k with ih -> 10 * ih end end
end

data WList : U is wnil : WList | wcons : Whole -> WList -> WList end

eqW : Whole -> Whole -> Bool is
  fn (m : Whole) is
    case m of
    | zero -> fn (n : Whole) is case n of | zero -> true | succ j -> false end end
    | succ k with ih -> fn (n : Whole) is case n of | zero -> false | succ j -> ih j end end
    end
  end
end

-- The low `count` digits of v, most significant first, zero-padded (the rounded
-- fractional part). digitsOf 2 75 = [7,5]; digitsOf 2 5 = [0,5].
digitsOf : Whole -> Whole -> WList is
  fn (count : Whole) is
    case count of
    | zero -> fn (v : Whole) is wnil end
    | succ k with ih -> fn (v : Whole) is wcons ((v // powTen k) % 10) (ih v) end
    end
  end
end

-- The EXACT decimal of a fraction: sign, integer part, fractional digits, where
-- the repetend begins, and whether it terminates. `rdec false 0 [7,5] _ true` is
-- 0.75; `rdec true 0 [3] 0 false` is -0.{3}; `rdec false 0 [1,6] 1 false` is 0.1{6}.
data RDec : U is rdec : Bool -> Whole -> WList -> Whole -> Bool -> RDec end

-- Number of decimal digits of a whole (q < 10 has 1).
numDigits : Whole -> Whole -> Whole is
  fn (cap : Whole) is
    case cap of
    | zero -> fn (q : Whole) is 1 end
    | succ c with ih -> fn (q : Whole) is
        case leb 10 q of | false -> 1 | true -> succ (ih (q // 10)) end
      end
    end
  end
end

-- The fractional expansion produced by cycle-detecting long division: the digits,
-- where the repetend begins, and whether it terminates (no repetend).
data FBody : U is fbody : WList -> Whole -> Bool -> FBody end
fbDigits : FBody -> WList is fn (b : FBody) is case b of | fbody d r t -> d end end end
fbRep    : FBody -> Whole is fn (b : FBody) is case b of | fbody d r t -> r end end end
fbTerm   : FBody -> Bool  is fn (b : FBody) is case b of | fbody d r t -> t end end end

-- Append at the end: the seen-remainders list grows in position order.
wsnoc : WList -> Whole -> WList is
  fn (xs : WList) (x : Whole) is
    case xs of
    | wnil -> wcons x wnil
    | wcons h t with ih -> wcons h ih
    end
  end
end
wmember : Whole -> WList -> Bool is
  fn (x : Whole) (xs : WList) is
    case xs of
    | wnil -> false
    | wcons h t with ih -> case eqW x h of | true -> true | false -> ih end
    end
  end
end
windex : Whole -> WList -> Whole is
  fn (x : Whole) (xs : WList) is
    case xs of
    | wnil -> 0
    | wcons h t with ih -> case eqW x h of | true -> 0 | false -> succ ih end
    end
  end
end

-- The WHOLE fuelled flooring division + the proof-friendly remainder the ported
-- to_radix PROOFS reason about (ch203).  `qdivF` is a private copy of the base
-- `divF` (the name is SHADOWED by the Frac division below).  `cmul` is ch203's
-- multiplication (add-on-the-LEFT: cmul (succ k) n = n + k*n), the reduction every
-- ported mul lemma needs (the prelude's `mulW` is the mirror, (k*n)+n).  `qdiv` = //
-- by value; `qmod a b` = a - (a//b)*b DEFINITIONALLY (not the fuel-based `%`).
cmul : Whole -> Whole -> Whole is
  fn (m : Whole) (n : Whole) is
    case m of
    | zero -> 0
    | succ k with ih -> addW n ih
    end
  end
end
qdivF : Whole -> Whole -> Whole -> Whole is
  fn (fuel : Whole) is
    case fuel of
    | zero -> fn (a : Whole) (b : Whole) is 0 end
    | succ f with ih -> fn (a : Whole) (b : Whole) is
        case b of
        | zero -> 0
        | succ k ->
            case leb b a of
            | true  -> succ (ih (subW a b) b)
            | false -> 0
            end
        end
      end
    end
  end
end
qdiv : Whole -> Whole -> Whole is fn (m : Whole) (n : Whole) is qdivF m m n end end
qmod : Whole -> Whole -> Whole is fn (a : Whole) (b : Whole) is subW a (cmul (qdiv a b) b) end end

-- Long division with cycle detection. fuel bounds the loop (a cycle appears within
-- `den` steps by pigeonhole); seen records remainders in position order so a recur
-- gives the repetend's start.  Uses cmul/qdiv/qmod so the expand-respects proofs
-- unfold it structurally.
expand : Whole -> Whole -> Whole -> WList -> FBody is
  fn (den : Whole) (fuel : Whole) is
    case fuel of
    | zero -> fn (rem : Whole) (seen : WList) is fbody wnil 0 true end
    | succ fl with ih -> fn (rem : Whole) (seen : WList) is
        case rem of
        | zero -> fbody wnil 0 true
        | succ rp ->
            case wmember rem seen of
            | true  -> fbody wnil (windex rem seen) false
            | false ->
                let r10  : Whole = cmul rem 10 in
                let rest : FBody = ih (qmod r10 den) (wsnoc seen rem) in
                fbody (wcons (qdiv r10 den) (fbDigits rest)) (fbRep rest) (fbTerm rest)
            end
        end
      end
    end
  end
end

-- ============================================================================
-- TASK 2: the to_radix pipeline + demotion trio, re-founded on the quotient Frac.
-- Ported from listings/ch203_rational_canonical.rune: toRadixRep+toRadixRespects
-- (class-invariance of the decimal expansion) and floorRep+floorUnique lift onto
-- Frac by qlift.  ch203's Z is a QUOTIENT integer; ours is canonical data Int, so
-- every Z-respect step collapses to direct Int algebra (the imag/isign bridges
-- below).  The pure Whole division + expand number theory ports over ch203's mul
-- (= cmul, add-on-left; the prelude's mulW is the mirror), lemmas verbatim.
-- ============================================================================

-- --- equality combinators + base arithmetic + order + division + expand (ch203) ---
cong : {A : U} -> {B : U} -> (f : A -> B) -> {x : A} -> {y : A} -> Eq A x y -> Eq B (f x) (f y) is
  fn {A : U} {B : U} (f : A -> B) {x : A} {y : A} (p : Eq A x y) is
    subst A x y p (fn (z : A) is Eq B (f x) (f z) end) refl
  end
end

sym : {A : U} -> {x : A} -> {y : A} -> Eq A x y -> Eq A y x is
  fn {A : U} {x : A} {y : A} (p : Eq A x y) is
    subst A x y p (fn (z : A) is Eq A z x end) refl
  end
end

trans : {A : U} -> {x : A} -> {y : A} -> {z : A} -> Eq A x y -> Eq A y z -> Eq A x z is
  fn {A : U} {x : A} {y : A} {z : A} (p : Eq A x y) (q : Eq A y z) is
    subst A y z q (fn (w : A) is Eq A x w end) p
  end
end

-- ============================================================================
-- The Whole SEMIRING lemmas (ch63 / ch81), redeclared verbatim.
-- ============================================================================

addZeroR : (n : Whole) -> Eq Whole (addW n zero) n is
  fn (n : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (addW x zero) x end)
      (refl zero)
      (fn (k : Whole) (ih : Eq Whole (addW k zero) k) is
         subst Whole (addW k zero) k ih
           (fn (z : Whole) is Eq Whole (addW (succ k) zero) (succ z) end)
           (refl (addW (succ k) zero))
       end)
      n
  end
end

addSuccR : (n : Whole) -> (m : Whole) -> Eq Whole (addW n (succ m)) (succ (addW n m)) is
  fn (n : Whole) (m : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (addW x (succ m)) (succ (addW x m)) end)
      (refl (succ m))
      (fn (k : Whole) (ih : Eq Whole (addW k (succ m)) (succ (addW k m))) is
         subst Whole (addW k (succ m)) (succ (addW k m)) ih
           (fn (z : Whole) is Eq Whole (addW (succ k) (succ m)) (succ z) end)
           (refl (addW (succ k) (succ m)))
       end)
      n
  end
end

addAssoc : (a : Whole) -> (b : Whole) -> (c : Whole)
   -> Eq Whole (addW (addW a b) c) (addW a (addW b c)) is
  fn (a : Whole) (b : Whole) (c : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (addW (addW x b) c) (addW x (addW b c)) end)
      (refl (addW b c))
      (fn (k : Whole) (ih : Eq Whole (addW (addW k b) c) (addW k (addW b c))) is
         subst Whole (addW (addW k b) c) (addW k (addW b c)) ih
           (fn (z : Whole) is Eq Whole (succ (addW (addW k b) c)) (succ z) end)
           (refl (succ (addW (addW k b) c)))
       end)
      a
  end
end

addComm : (n : Whole) -> (m : Whole) -> Eq Whole (addW n m) (addW m n) is
  fn (n : Whole) (m : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (addW x m) (addW m x) end)
      (subst Whole (addW m zero) m (addZeroR m)
         (fn (z : Whole) is Eq Whole z (addW m zero) end)
         (refl (addW m zero)))
      (fn (k : Whole) (ih : Eq Whole (addW k m) (addW m k)) is
         subst Whole (succ (addW m k)) (addW m (succ k))
           (subst Whole (addW m (succ k)) (succ (addW m k)) (addSuccR m k)
              (fn (z : Whole) is Eq Whole z (addW m (succ k)) end)
              (refl (addW m (succ k))))
           (fn (z : Whole) is Eq Whole (succ (addW k m)) z end)
           (subst Whole (addW k m) (addW m k) ih
              (fn (z : Whole) is Eq Whole (succ (addW k m)) (succ z) end)
              (refl (succ (addW k m))))
       end)
      n
  end
end

mulZeroR : (n : Whole) -> Eq Whole (cmul n zero) zero is
  fn (n : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (cmul x zero) zero end)
      (refl zero)
      (fn (k : Whole) (ih : Eq Whole (cmul k zero) zero) is ih end)
      n
  end
end

-- RIGHT DISTRIBUTIVITY: (a + b) * c = a*c + b*c (ch63).

mulDistR : (a : Whole) -> (b : Whole) -> (c : Whole)
   -> Eq Whole (cmul (addW a b) c) (addW (cmul a c) (cmul b c)) is
  fn (a : Whole) (b : Whole) (c : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (cmul (addW x b) c) (addW (cmul x c) (cmul b c)) end)
      (refl (cmul b c))
      (fn (k : Whole) (ih : Eq Whole (cmul (addW k b) c) (addW (cmul k c) (cmul b c))) is
         subst Whole
           (addW c (addW (cmul k c) (cmul b c)))
           (addW (addW c (cmul k c)) (cmul b c))
           (subst Whole
              (addW (addW c (cmul k c)) (cmul b c))
              (addW c (addW (cmul k c) (cmul b c)))
              (addAssoc c (cmul k c) (cmul b c))
              (fn (z : Whole) is Eq Whole z (addW (addW c (cmul k c)) (cmul b c)) end)
              (refl (addW (addW c (cmul k c)) (cmul b c))))
           (fn (z : Whole) is Eq Whole (addW c (cmul (addW k b) c)) z end)
           (subst Whole (cmul (addW k b) c) (addW (cmul k c) (cmul b c)) ih
              (fn (z : Whole) is Eq Whole (addW c (cmul (addW k b) c)) (addW c z) end)
              (refl (addW c (cmul (addW k b) c))))
       end)
      a
  end
end

-- MULTIPLICATIVE SUCCESSOR-SHIFT: cmul n (succ m) = addW (cmul n m) n (ch81).

mulSuccR : (n : Whole) -> (m : Whole) -> Eq Whole (cmul n (succ m)) (addW (cmul n m) n) is
  fn (n : Whole) (m : Whole) is
    WholeElim
      (fn (x : Whole) is Eq Whole (cmul x (succ m)) (addW (cmul x m) x) end)
      (refl zero)
      (fn (k : Whole) (ih : Eq Whole (cmul k (succ m)) (addW (cmul k m) k)) is
         subst Whole
           (succ (addW (addW m (cmul k m)) k))
           (addW (addW m (cmul k m)) (succ k))
           (subst Whole
              (addW (addW m (cmul k m)) (succ k))
              (succ (addW (addW m (cmul k m)) k))
              (addSuccR (addW m (cmul k m)) k)
              (fn (z : Whole) is Eq Whole z (addW (addW m (cmul k m)) (succ k)) end)
              (refl (addW (addW m (cmul k m)) (succ k))))
           (fn (z : Whole) is Eq Whole (cmul (succ k) (succ m)) z end)
           (subst Whole
              (addW m (addW (cmul k m) k))
              (addW (addW m (cmul k m)) k)
              (subst Whole
                 (addW (addW m (cmul k m)) k)
                 (addW m (addW (cmul k m) k))
                 (addAssoc m (cmul k m) k)
                 (fn (z : Whole) is Eq Whole z (addW (addW m (cmul k m)) k) end)
                 (refl (addW (addW m (cmul k m)) k)))
              (fn (z : Whole) is Eq Whole (cmul (succ k) (succ m)) (succ z) end)
              (subst Whole
                 (cmul k (succ m))
                 (addW (cmul k m) k)
                 ih
                 (fn (z : Whole) is Eq Whole (cmul (succ k) (succ m)) (succ (addW m z)) end)
                 (refl (cmul (succ k) (succ m)))))
       end)
      n
  end
end

-- COMMUTATIVITY of Whole cmul (ch81), by induction on m.

mulComm : (m : Whole) -> (n : Whole) -> Eq Whole (cmul m n) (cmul n m) is
  fn (m : Whole) (n : Whole) is
    WholeElim
      (fn (x : Whole) is Eq Whole (cmul x n) (cmul n x) end)
      (subst Whole (cmul n zero) zero (mulZeroR n)
         (fn (z : Whole) is Eq Whole z (cmul n zero) end)
         (refl (cmul n zero)))
      (fn (k : Whole) (ih : Eq Whole (cmul k n) (cmul n k)) is
         subst Whole
           (addW (cmul n k) n)
           (cmul n (succ k))
           (subst Whole
              (cmul n (succ k))
              (addW (cmul n k) n)
              (mulSuccR n k)
              (fn (z : Whole) is Eq Whole z (cmul n (succ k)) end)
              (refl (cmul n (succ k))))
           (fn (z : Whole) is Eq Whole (cmul (succ k) n) z end)
           (subst Whole
              (cmul n k)
              (cmul k n)
              (subst Whole (cmul k n) (cmul n k) ih
                 (fn (z : Whole) is Eq Whole z (cmul k n) end)
                 (refl (cmul k n)))
              (fn (z : Whole) is Eq Whole (addW n z) (addW (cmul n k) n) end)
              (addComm n (cmul n k)))
       end)
      m
  end
end

-- LEFT DISTRIBUTIVITY: a * (b + c) = a*b + a*c, derived from mulComm + mulDistR.

mulOneR : (n : Whole) -> Eq Whole (cmul n (succ zero)) n is
  fn (n : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (cmul x (succ zero)) x end)
      (refl zero)
      (fn (k : Whole) (ih : Eq Whole (cmul k (succ zero)) k) is
         cong succ ih
       end)
      n
  end
end

-- MUL ASSOCIATIVITY: (a * b) * c = a * (b * c) (ch81 sibling), by induction on a.
--   (succ k * b) * c = (b + k*b) * c           [def]
--                    = b*c + (k*b)*c           [mulDistR]
--                    = b*c + k*(b*c)           [IH]
--                    = (succ k) * (b*c)         [def]

mulAssoc : (a : Whole) -> (b : Whole) -> (c : Whole)
   -> Eq Whole (cmul (cmul a b) c) (cmul a (cmul b c)) is
  fn (a : Whole) (b : Whole) (c : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (cmul (cmul x b) c) (cmul x (cmul b c)) end)
      (refl zero)
      (fn (k : Whole) (ih : Eq Whole (cmul (cmul k b) c) (cmul k (cmul b c))) is
         trans (mulDistR b (cmul k b) c)
           (cong (fn (s : Whole) is addW (cmul b c) s end) ih)
       end)
      a
  end
end

-- ============================================================================
-- ch07/ch103/ch105 ℤ infrastructure, redeclared verbatim.
-- ============================================================================

cong2 : {A : U} -> {B : U} -> {C : U} -> (f : A -> B -> C)
     -> {x : A} -> {y : A} -> {u : B} -> {v : B}
     -> Eq A x y -> Eq B u v -> Eq C (f x u) (f y v) is
  fn {A : U} {B : U} {C : U} (f : A -> B -> C)
     {x : A} {y : A} {u : B} {v : B} (p : Eq A x y) (q : Eq B u v) is
    trans (cong (fn (z : A) is f z u end) p) (cong (fn (z : B) is f y z end) q)
  end
end

or : Bool -> Bool -> Bool is
  fn (a : Bool) (b : Bool) is
    BoolElim (fn (x : Bool) is Bool end) true b a
  end
end

-- REFLEXIVITY of leb (ch65).

lteRefl : (n : Whole) -> Eq Bool (leb n n) true is
  fn (n : Whole) is
    WholeElim (fn (x : Whole) is Eq Bool (leb x x) true end)
      (refl true)
      (fn (k : Whole) (ih : Eq Bool (leb k k) true) is ih end)
      n
  end
end

-- ABSURDITY from `false = true`: any leb equation (ch80 idiom).

lteAbsurd : (a : Whole) -> (c : Whole) -> Eq Bool false true -> Eq Bool (leb a c) true is
  fn (a : Whole) (c : Whole) (h : Eq Bool false true) is
    subst Bool false true h
      (fn (z : Bool) is
         case z of
         | true  -> Eq Bool (leb a c) true
         | false -> Eq Bool true true
         end
       end)
      (refl true)
  end
end

-- ABSURDITY from `false = true`: any Whole equation (ch82 idiom).

lteAbsurdNat : (a : Whole) -> (b : Whole) -> Eq Bool false true -> Eq Whole a b is
  fn (a : Whole) (b : Whole) (h : Eq Bool false true) is
    subst Bool false true h
      (fn (z : Bool) is
         case z of
         | true  -> Eq Whole a b
         | false -> Eq Whole a a
         end
       end)
      (refl a)
  end
end

-- TRANSITIVITY of leb (ch80, verbatim).

lteTrans : (a : Whole) -> (b : Whole) -> (c : Whole)
   -> Eq Bool (leb a b) true -> Eq Bool (leb b c) true -> Eq Bool (leb a c) true is
  fn (a : Whole) is
    WholeElim
      (fn (x : Whole) is
         (b : Whole) -> (c : Whole)
           -> Eq Bool (leb x b) true -> Eq Bool (leb b c) true
           -> Eq Bool (leb x c) true end)
      (fn (b : Whole) (c : Whole)
          (hab : Eq Bool (leb zero b) true) (hbc : Eq Bool (leb b c) true) is
         refl true end)
      (fn (a' : Whole)
          (ih : (b : Whole) -> (c : Whole)
                  -> Eq Bool (leb a' b) true -> Eq Bool (leb b c) true
                  -> Eq Bool (leb a' c) true) is
         fn (b : Whole) is
           WholeElim
             (fn (y : Whole) is
                (c : Whole)
                  -> Eq Bool (leb (succ a') y) true -> Eq Bool (leb y c) true
                  -> Eq Bool (leb (succ a') c) true end)
             (fn (c : Whole)
                 (hab : Eq Bool false true) (hbc : Eq Bool (leb zero c) true) is
                lteAbsurd (succ a') c hab end)
             (fn (b' : Whole)
                 (ihb : (c : Whole)
                          -> Eq Bool (leb (succ a') b') true
                          -> Eq Bool (leb b' c) true
                          -> Eq Bool (leb (succ a') c) true) is
                fn (c : Whole) is
                  WholeElim
                    (fn (z : Whole) is
                       Eq Bool (leb (succ a') (succ b')) true
                         -> Eq Bool (leb (succ b') z) true
                         -> Eq Bool (leb (succ a') z) true end)
                    (fn (hab : Eq Bool (leb a' b') true)
                        (hbc : Eq Bool false true) is
                       lteAbsurd (succ a') zero hbc end)
                    (fn (c' : Whole)
                        (ihc : Eq Bool (leb (succ a') (succ b')) true
                                 -> Eq Bool (leb (succ b') c') true
                                 -> Eq Bool (leb (succ a') c') true) is
                       fn (hab : Eq Bool (leb a' b') true)
                          (hbc : Eq Bool (leb b' c') true) is
                         ih b' c' hab hbc end
                     end)
                    c
                end
              end)
             b
         end
       end)
      a
  end
end

-- ANTISYMMETRY of leb (ch82, verbatim).

lteAntisym : (a : Whole) -> (b : Whole)
   -> Eq Bool (leb a b) true -> Eq Bool (leb b a) true -> Eq Whole a b is
  fn (a : Whole) is
    WholeElim
      (fn (x : Whole) is
         (b : Whole)
           -> Eq Bool (leb x b) true -> Eq Bool (leb b x) true
           -> Eq Whole x b end)
      (fn (b : Whole) is
         WholeElim
           (fn (y : Whole) is
              Eq Bool (leb zero y) true -> Eq Bool (leb y zero) true
                -> Eq Whole zero y end)
           (fn (hab : Eq Bool (leb zero zero) true)
               (hba : Eq Bool (leb zero zero) true) is
              refl zero end)
           (fn (b' : Whole)
               (ihb : Eq Bool (leb zero b') true -> Eq Bool (leb b' zero) true
                        -> Eq Whole zero b') is
              fn (hab : Eq Bool (leb zero (succ b')) true)
                 (hba : Eq Bool false true) is
                lteAbsurdNat zero (succ b') hba end
            end)
           b
       end)
      (fn (a' : Whole)
          (ih : (b : Whole)
                  -> Eq Bool (leb a' b) true -> Eq Bool (leb b a') true
                  -> Eq Whole a' b) is
         fn (b : Whole) is
           WholeElim
             (fn (y : Whole) is
                Eq Bool (leb (succ a') y) true -> Eq Bool (leb y (succ a')) true
                  -> Eq Whole (succ a') y end)
             (fn (hab : Eq Bool false true)
                 (hba : Eq Bool (leb zero (succ a')) true) is
                lteAbsurdNat (succ a') zero hab end)
             (fn (b' : Whole)
                 (ihb : Eq Bool (leb (succ a') b') true
                          -> Eq Bool (leb b' (succ a')) true
                          -> Eq Whole (succ a') b') is
                fn (hab : Eq Bool (leb a' b') true)
                   (hba : Eq Bool (leb b' a') true) is
                  subst Whole a' b' (ih b' hab hba)
                    (fn (z : Whole) is Eq Whole (succ a') (succ z) end)
                    (refl (succ a'))
                end
              end)
             b
         end
       end)
      a
  end
end

-- TOTALITY of leb (ch83, verbatim).

lteAddCancelL : (k : Whole) -> (x : Whole) -> (y : Whole)
   -> Eq Bool (leb (addW k x) (addW k y)) (leb x y) is
  fn (k : Whole) (x : Whole) (y : Whole) is
    WholeElim (fn (z : Whole) is Eq Bool (leb (addW z x) (addW z y)) (leb x y) end)
      (refl (leb x y))
      (fn (j : Whole) (ih : Eq Bool (leb (addW j x) (addW j y)) (leb x y)) is ih end)
      k
  end
end

-- RIGHT CANCELLATION:  leb (x + k) (y + k) = leb x y.  Convert each side to the
-- left-cancellation form with addComm, then apply lteAddCancelL.

lteMulPos : (n : Whole) -> (x : Whole) -> (y : Whole)
   -> Eq Bool (leb (cmul x (succ n)) (cmul y (succ n))) (leb x y) is
  fn (n : Whole) (x : Whole) is
    WholeElim
      (fn (w : Whole) is
         (y : Whole) -> Eq Bool (leb (cmul w (succ n)) (cmul y (succ n))) (leb w y) end)
      -- x = 0: leb 0 (cmul y k) = true = leb 0 y.
      (fn (y : Whole) is refl true end)
      -- x = succ x', IH at x'.
      (fn (x' : Whole)
          (ih : (y : Whole) -> Eq Bool (leb (cmul x' (succ n)) (cmul y (succ n))) (leb x' y)) is
         fn (y : Whole) is
           WholeElim
             (fn (w : Whole) is
                Eq Bool (leb (cmul (succ x') (succ n)) (cmul w (succ n))) (leb (succ x') w) end)
             -- y = 0: cmul (succ x') (succ n) = succ(...), leb (succ _) 0 = false = leb (succ x') 0.
             (refl false)
             -- y = succ y': common (succ n) cancels via lteAddCancelL, then IH.
             (fn (y' : Whole)
                 (ihy : Eq Bool (leb (cmul (succ x') (succ n)) (cmul y' (succ n))) (leb (succ x') y')) is
                -- cmul (succ x')(succ n) = addW (succ n) (cmul x' (succ n)) def.,
                -- cmul (succ y')(succ n) = addW (succ n) (cmul y' (succ n)) def.,
                -- so the goal is leb (addW (succ n)(x'·k)) (addW (succ n)(y'·k)) = leb (succ x')(succ y'),
                -- and leb (succ x')(succ y') = leb x' y' def.
                trans (lteAddCancelL (succ n) (cmul x' (succ n)) (cmul y' (succ n)))
                  (ih y')
              end)
             y
         end
       end)
      x
  end
end

-- ----------------------------------------------------------------------------
-- ℤ ORDER INVARIANCE UNDER A POSITIVE MULTIPLIER, at the REPRESENTATIVE level.
-- Multiplying both ℤ-sides (as reps) by a positive embedded nat (succ m, 0) leaves
-- zleP unchanged.  pmul p (sm,0) has rep (a·sm + b·0, a·0 + b·sm); after mulZeroR the
-- cross sum (a·sm + d·sm) factors (mulDistR) to (a+d)·sm, and lteMulPos cancels sm.
-- ----------------------------------------------------------------------------

-- the simplification fst(pmul p k) + snd(pmul q k) = (fst p + snd q) · succ m,
-- where k = (succ m, 0).

zeroMonus : (b : Whole) -> Eq Whole (monus zero b) zero is
  fn (b : Whole) is
    case b of
    | zero -> refl zero
    | succ k with ih -> cong pred ih
    end
  end
end

monusSuccSucc : (b : Whole) -> (a : Whole) -> Eq Whole (monus (succ a) (succ b)) (monus a b) is
  fn (b : Whole) is
    case b of
    | zero -> fn (a : Whole) is refl a end
    | succ k with ih -> fn (a : Whole) is cong pred (ih a) end
    end
  end
end

monusAddCancel : (d : Whole) -> (a : Whole) -> Eq Whole (monus (addW a d) d) a is
  fn (d : Whole) is
    case d of
    | zero -> fn (a : Whole) is addZeroR a end
    | succ k with ih -> fn (a : Whole) is
        calc monus (addW a (succ k)) (succ k)
          = monus (succ (addW a k)) (succ k) by cong (fn (s : Whole) is monus s (succ k) end) (addSuccR a k)
          = monus (addW a k) k               by monusSuccSucc k (addW a k)
          = a                               by ih a
        end
      end
    end
  end
end

succInj : {a : Whole} -> {b : Whole} -> Eq Whole (succ a) (succ b) -> Eq Whole a b is
  fn {a : Whole} {b : Whole} (p : Eq Whole (succ a) (succ b)) is cong pred p end
end

-- The workhorse: equal differences have equal monuses (ch12), glyph-free.

qmagNum : QPair -> Whole is fn (p : QPair) is imag (qnum p) end end

qmagDen : QPair -> Whole is fn (p : QPair) is succ (qdpred p) end end

qsign   : QPair -> Bool is fn (p : QPair) is isign (qnum p) end end

toRadixRep : QPair -> RDec is
  fn (p : QPair) is
    let body : FBody =
      expand (qmagDen p) (succ (qmagDen p)) (qmod (qmagNum p) (qmagDen p)) wnil in
    rdec (qsign p) (qdiv (qmagNum p) (qmagDen p)) (fbDigits body) (fbRep body) (fbTerm body)
  end
end

-- ----------------------------------------------------------------------------
-- Certificates: the repeating decimal COMPUTES through the canonical rep.
-- A QPair (qpair (intOf n) d) denotes n / succ d.
-- ----------------------------------------------------------------------------

-- 3/4 = 0.75  (terminating): qpair (intOf 3) 3 is 3 / succ 3 = 3/4.

monusAddInv : (b : Whole) -> (a : Whole) -> Eq Bool (leb b a) true -> Eq Whole (addW (monus a b) b) a is
  fn (b : Whole) is
    case b of
    | zero -> fn (a : Whole) (h : Eq Bool true true) is addZeroR (monus a zero) end
    | succ k with ih -> fn (a : Whole) is
        case a of
        | zero -> fn (h : Eq Bool false true) is lteAbsurdNat (addW (monus zero (succ k)) (succ k)) zero h end
        | succ j -> fn (h : Eq Bool (leb k j) true) is
            calc addW (monus (succ j) (succ k)) (succ k)
              = addW (monus j k) (succ k) by cong (fn (s : Whole) is addW s (succ k) end) (monusSuccSucc k j)
              = succ (addW (monus j k) k)  by addSuccR (monus j k) k
              = succ j                    by cong succ (ih j h)
            end
          end
        end
      end
    end
  end
end

-- addW (succ c) x = succ (addW c x).  addW recurses on its 2nd arg, so the leading
-- successor does not peel definitionally; prove it by induction on x.

addSuccL : (c : Whole) -> (x : Whole) -> Eq Whole (addW (succ c) x) (succ (addW c x)) is
  fn (c : Whole) (x : Whole) is
    WholeElim (fn (z : Whole) is Eq Whole (addW (succ c) z) (succ (addW c z)) end)
      (trans (addZeroR (succ c)) (cong succ (sym (addZeroR c))))
      (fn (k : Whole) (ih : Eq Whole (addW (succ c) k) (succ (addW c k))) is
         trans (addSuccR (succ c) k)
           (trans (cong succ ih) (cong succ (sym (addSuccR c k)))) end)
      x
  end
end

-- leb is monotone under a common left summand: x ≤ y ⟹ c+x ≤ c+y.  Induction on c.

lebAddMono : (c : Whole) -> (x : Whole) -> (y : Whole) -> Eq Bool (leb x y) true
    -> Eq Bool (leb (addW c x) (addW c y)) true is
  fn (c : Whole) is
    case c of
    | zero -> fn (x : Whole) (y : Whole) (h : Eq Bool (leb x y) true) is h end
    | succ d with ih -> fn (x : Whole) (y : Whole) (h : Eq Bool (leb x y) true) is
        subst Whole (succ (addW d x)) (addW (succ d) x) (sym (addSuccL d x))
          (fn (s : Whole) is Eq Bool (leb s (addW (succ d) y)) true end)
          (subst Whole (succ (addW d y)) (addW (succ d) y) (sym (addSuccL d y))
            (fn (t : Whole) is Eq Bool (leb (succ (addW d x)) t) true end)
            (ih x y h))
      end
    end
  end
end

-- b ≤ a  and  x ≤ a−b   ⟹   b+x ≤ a.   (monotonicity + monusAddInv.)

lebAddMonus : (a : Whole) -> (b : Whole) -> (x : Whole)
    -> Eq Bool (leb b a) true -> Eq Bool (leb x (monus a b)) true
    -> Eq Bool (leb (addW b x) a) true is
  fn (a : Whole) (b : Whole) (x : Whole) (hba : Eq Bool (leb b a) true)
     (hx : Eq Bool (leb x (monus a b)) true) is
    subst Whole (addW b (monus a b)) a (trans (addComm b (monus a b)) (monusAddInv b a hba))
      (fn (s : Whole) is Eq Bool (leb (addW b x) s) true end)
      (lebAddMono b x (monus a b) hx)
  end
end

-- The divisor step under a known boolean: case on the value `lv` of `leb (succ k) a`
-- WITH its defining equation, so qdivF's branch reduces and the true branch carries
-- `leb (succ k) a = true` to feed lebAddMonus.  `q'` is the recursive quotient.

divStepMulLe : (a : Whole) -> (k : Whole) -> (q' : Whole)
    -> Eq Bool (leb (cmul q' (succ k)) (monus a (succ k))) true
    -> (lv : Bool) -> Eq Bool (leb (succ k) a) lv
    -> Eq Bool (leb (cmul (BoolElim (fn (w : Bool) is Whole end) (succ q') zero lv) (succ k)) a) true is
  fn (a : Whole) (k : Whole) (q' : Whole)
     (hrec : Eq Bool (leb (cmul q' (succ k)) (monus a (succ k))) true) (lv : Bool) is
    case lv of
    | true  -> fn (h : Eq Bool (leb (succ k) a) true) is
        -- BoolElim ... true = succ q'; cmul (succ q') (succ k) = (succ k) + cmul q' (succ k).
        lebAddMonus a (succ k) (cmul q' (succ k)) h hrec
      end
    | false -> fn (h : Eq Bool (leb (succ k) a) false) is
        -- BoolElim ... false = zero; cmul 0 (succ k) = 0; leb 0 a = true.
        refl true
      end
    end
  end
end

-- The fuelled quotient times the divisor never exceeds the dividend:
-- (qdivF f a b)·b ≤ a, for ANY fuel.  Induction on fuel; the recursive call's
-- bound (on a−b) lifts back to a via divStepMulLe.

divFMulLe : (f : Whole) -> (a : Whole) -> (b : Whole) -> Eq Bool (leb (cmul (qdivF f a b) b) a) true is
  fn (f : Whole) is
    case f of
    | zero -> fn (a : Whole) (b : Whole) is refl true end
    | succ g with ih -> fn (a : Whole) (b : Whole) is
        case b of
        | zero -> refl true
        | succ k ->
            divStepMulLe a k (qdivF g (monus a (succ k)) (succ k))
              (ih (monus a (succ k)) (succ k))
              (leb (succ k) a) (refl (leb (succ k) a))
        end
      end
    end
  end
end

-- Specialise to qdiv (fuel = the dividend): (qdiv a b)·b ≤ a.

divMulLe : (a : Whole) -> (b : Whole) -> Eq Bool (leb (cmul (qdiv a b) b) a) true is
  fn (a : Whole) (b : Whole) is divFMulLe a a b end
end

-- THE DIVISION LAW (F-convention):  (qdiv a b)·b + qmod a b = a.
-- qmod a b = a − (qdiv a b)·b, and (qdiv a b)·b ≤ a (divMulLe), so adding the
-- remainder back recovers a (monusAddInv, commuted).

divLaw : (a : Whole) -> (b : Whole)
    -> Eq Whole (addW (cmul (qdiv a b) b) (qmod a b)) a is
  fn (a : Whole) (b : Whole) is
    trans (addComm (cmul (qdiv a b) b) (qmod a b))
      (monusAddInv (cmul (qdiv a b) b) a (divMulLe a b))
  end
end

-- Strict order (ported from ch13), case-based like leb.

ltb : Whole -> Whole -> Bool is
  fn (m : Whole) is
    case m of
    | zero -> fn (n : Whole) is case n of | zero -> false | succ j -> true end end
    | succ k with ih -> fn (n : Whole) is case n of | zero -> false | succ j -> ih j end end
    end
  end
end

ltbZero : (r : Whole) -> Eq Bool (ltb r zero) false is
  fn (r : Whole) is case r of | zero -> refl false | succ k -> refl false end end
end

Lt : Whole -> Whole -> Prop is fn (a : Whole) (b : Whole) is Eq Bool (ltb a b) true end end

-- monus over a sum:  a − (b + c) = (a − b) − c.   Induction on c (addW recurses there).

monusAdd : (a : Whole) -> (b : Whole) -> (c : Whole)
    -> Eq Whole (monus a (addW b c)) (monus (monus a b) c) is
  fn (a : Whole) (b : Whole) (c : Whole) is
    WholeElim (fn (z : Whole) is Eq Whole (monus a (addW b z)) (monus (monus a b) z) end)
      (cong (fn (s : Whole) is monus a s end) (addZeroR b))
      (fn (k : Whole) (ih : Eq Whole (monus a (addW b k)) (monus (monus a b) k)) is
         trans (cong (fn (s : Whole) is monus a s end) (addSuccR b k))
           (cong pred ih) end)
      c
  end
end

-- leb is transitive (induction on the first argument; same shape as lteTrans).

lebTrans : (a : Whole) -> (b : Whole) -> (c : Whole)
    -> Eq Bool (leb a b) true -> Eq Bool (leb b c) true -> Eq Bool (leb a c) true is
  fn (a : Whole) is
    case a of
    | zero -> fn (b : Whole) (c : Whole) (hab : Eq Bool true true) (hbc : Eq Bool (leb b c) true) is
        refl true end
    | succ a2 with ih -> fn (b : Whole) is
        case b of
        | zero -> fn (c : Whole) (hab : Eq Bool false true) (hbc : Eq Bool (leb zero c) true) is
            lteAbsurd (succ a2) c hab end
        | succ b2 -> fn (c : Whole) is
            case c of
            | zero -> fn (hab : Eq Bool (leb a2 b2) true) (hbc : Eq Bool false true) is
                lteAbsurd (succ a2) zero hbc end
            | succ c2 -> fn (hab : Eq Bool (leb a2 b2) true) (hbc : Eq Bool (leb b2 c2) true) is
                ih b2 c2 hab hbc end
            end
          end
        end
      end
    end
  end
end

-- leb is reflexive (induction on the argument).

lebRefl : (a : Whole) -> Eq Bool (leb a a) true is
  fn (a : Whole) is
    case a of
    | zero -> refl true
    | succ k with ih -> ih
    end
  end
end
-- a ≤ succ a (induction on a).

lebSuccSelf : (a : Whole) -> Eq Bool (leb a (succ a)) true is
  fn (a : Whole) is
    case a of
    | zero -> refl true
    | succ k with ih -> ih
    end
  end
end
-- a − d ≤ a always.   Induction on a; chains via lebTrans and lebSuccSelf.

monusLe : (a : Whole) -> (d : Whole) -> Eq Bool (leb (monus a d) a) true is
  fn (a : Whole) is
    case a of
    | zero -> fn (d : Whole) is
        subst Whole zero (monus zero d) (sym (zeroMonus d))
          (fn (s : Whole) is Eq Bool (leb s zero) true end) (refl true) end
    | succ a2 with ih -> fn (d : Whole) is
        case d of
        | zero -> lebRefl (succ a2)
        | succ d2 ->
            subst Whole (monus a2 d2) (monus (succ a2) (succ d2)) (sym (monusSuccSucc d2 a2))
              (fn (s : Whole) is Eq Bool (leb s (succ a2)) true end)
              (lebTrans (monus a2 d2) a2 (succ a2) (ih d2) (lebSuccSelf a2))
        end
      end
    end
  end
end

-- monus is antitone in its subtrahend:  c ≤ d  ⟹  a−d ≤ a−c.   Induction on a.

monusLeMono2 : (a : Whole) -> (c : Whole) -> (d : Whole)
    -> Eq Bool (leb c d) true -> Eq Bool (leb (monus a d) (monus a c)) true is
  fn (a : Whole) is
    case a of
    | zero -> fn (c : Whole) (d : Whole) (h : Eq Bool (leb c d) true) is
        subst Whole zero (monus zero d) (sym (zeroMonus d))
          (fn (s : Whole) is Eq Bool (leb s (monus zero c)) true end)
          (subst Whole zero (monus zero c) (sym (zeroMonus c))
            (fn (t : Whole) is Eq Bool (leb zero t) true end) (refl true)) end
    | succ a2 with ih -> fn (c : Whole) is
        case c of
        | zero -> fn (d : Whole) (h : Eq Bool true true) is
            -- monus (succ a2) zero = succ a2 (def. monus zero-case); monusLe closes it.
            monusLe (succ a2) d end
        | succ c2 -> fn (d : Whole) is
            case d of
            | zero -> fn (h : Eq Bool (leb (succ c2) zero) true) is
                subst Bool false true h
                  (fn (z : Bool) is case z of
                     | true  -> Eq Bool (leb (monus (succ a2) zero) (monus (succ a2) (succ c2))) true
                     | false -> Eq Bool true true end end)
                  (refl true) end
            | succ d2 -> fn (h : Eq Bool (leb c2 d2) true) is
                subst Whole (monus a2 d2) (monus (succ a2) (succ d2)) (sym (monusSuccSucc d2 a2))
                  (fn (s : Whole) is Eq Bool (leb s (monus (succ a2) (succ c2))) true end)
                  (subst Whole (monus a2 c2) (monus (succ a2) (succ c2)) (sym (monusSuccSucc c2 a2))
                    (fn (t : Whole) is Eq Bool (leb (monus a2 d2) t) true end)
                    (ih c2 d2 h)) end
            end
          end
        end
      end
    end
  end
end

-- From false = true, any Bool-equation goal (the leb-flavoured absurdity).

boolAbsurd : (x : Whole) -> (y : Whole) -> Eq Bool false true -> Eq Bool (leb x y) true is
  fn (x : Whole) (y : Whole) (h : Eq Bool false true) is
    subst Bool false true h
      (fn (z : Bool) is case z of
         | true  -> Eq Bool (leb x y) true
         | false -> Eq Bool true true end end)
      (refl true)
  end
end

-- a ≤ succ g  ⟹  pred a ≤ g.   Case on a (no induction; succ-case is leb-definitional).

predLebFuel : (a : Whole) -> (g : Whole) -> Eq Bool (leb a (succ g)) true -> Eq Bool (leb (pred a) g) true is
  fn (a : Whole) is
    case a of
    | zero -> fn (g : Whole) (h : Eq Bool true true) is refl true end
    | succ j -> fn (g : Whole) (h : Eq Bool (leb j g) true) is h end
    end
  end
end

-- monus a 1 = pred a (monus succ-case then zero-case; definitional).

predIsMonusOne : (a : Whole) -> Eq Whole (monus a (succ zero)) (pred a) is
  fn (a : Whole) is refl (pred a) end
end

-- FUEL DESCENT:  succ b0 ≤ a  and  a ≤ succ g   ⟹   a − succ b0 ≤ g.
-- a−(succ b0) ≤ a−1 = pred a (monusLeMono2, succ 0 ≤ succ b0), and pred a ≤ g.

lebMonusFuel : (a : Whole) -> (b0 : Whole) -> (g : Whole)
    -> Eq Bool (leb (succ b0) a) true -> Eq Bool (leb a (succ g)) true
    -> Eq Bool (leb (monus a (succ b0)) g) true is
  fn (a : Whole) (b0 : Whole) (g : Whole)
     (hba : Eq Bool (leb (succ b0) a) true) (hfuel : Eq Bool (leb a (succ g)) true) is
    lebTrans (monus a (succ b0)) (pred a) g
      (subst Whole (monus a (succ zero)) (pred a) (predIsMonusOne a)
        (fn (s : Whole) is Eq Bool (leb (monus a (succ b0)) s) true end)
        (monusLeMono2 a (succ zero) (succ b0) (refl true)))
      (predLebFuel a g hfuel)
  end
end

-- leb (succ b0) a = false  ⟹  a < succ b0  (the false branch of the divisor test
-- gives the remainder-is-the-dividend bound).   Induction on b0, a varying.

lebFalseLt : (b0 : Whole) -> (a : Whole)
    -> Eq Bool (leb (succ b0) a) false -> Eq Bool (ltb a (succ b0)) true is
  fn (b0 : Whole) is
    case b0 of
    | zero -> fn (a : Whole) is
        case a of
        | zero -> fn (h : Eq Bool false false) is refl true end
        | succ j -> fn (h : Eq Bool true false) is
            subst Bool true false h
              (fn (z : Bool) is case z of
                 | true  -> Eq Bool true true
                 | false -> Eq Bool (ltb (succ j) (succ zero)) true end end)
              (refl true) end
        end
      end
    | succ b1 with ih -> fn (a : Whole) is
        case a of
        | zero -> fn (h : Eq Bool false false) is refl true end
        | succ j -> fn (h : Eq Bool (leb (succ b1) j) false) is ih j h end
        end
      end
    end
  end
end

-- The remainder step under a known boolean lv = leb (succ b0) a, WITH its equation.
-- true:  rem = (a − succ b0) − q'·(succ b0) = the recursive remainder  (< succ b0 by hrec).
-- false: rem = a,  a < succ b0  by lebFalseLt.

remStepLt : (a : Whole) -> (b0 : Whole) -> (q' : Whole)
    -> (Eq Bool (leb (succ b0) a) true
        -> Lt (monus (monus a (succ b0)) (cmul q' (succ b0))) (succ b0))
    -> (lv : Bool) -> Eq Bool (leb (succ b0) a) lv
    -> Lt (monus a (cmul (BoolElim (fn (w : Bool) is Whole end) (succ q') zero lv) (succ b0))) (succ b0) is
  fn (a : Whole) (b0 : Whole) (q' : Whole)
     (hrec : Eq Bool (leb (succ b0) a) true
        -> Lt (monus (monus a (succ b0)) (cmul q' (succ b0))) (succ b0)) (lv : Bool) is
    case lv of
    | true  -> fn (h : Eq Bool (leb (succ b0) a) true) is
        -- cmul (succ q') (succ b0) = (succ b0) + q'·(succ b0); monusAdd splits the subtraction.
        subst Whole (monus (monus a (succ b0)) (cmul q' (succ b0)))
                  (monus a (addW (succ b0) (cmul q' (succ b0))))
          (sym (monusAdd a (succ b0) (cmul q' (succ b0))))
          (fn (s : Whole) is Lt s (succ b0) end)
          (hrec h)
      end
    | false -> fn (h : Eq Bool (leb (succ b0) a) false) is
        -- BoolElim ... false = 0; cmul 0 (succ b0) = 0; monus a 0 = a; a < succ b0.
        lebFalseLt b0 a h
      end
    end
  end
end

-- The fuelled remainder is bounded WHEN the fuel covers the dividend (leb a f).

remLtFuel : (f : Whole) -> (a : Whole) -> (b0 : Whole) -> Eq Bool (leb a f) true
    -> Lt (monus a (cmul (qdivF f a (succ b0)) (succ b0))) (succ b0) is
  fn (f : Whole) is
    case f of
    | zero -> fn (a : Whole) is
        case a of
        | zero -> fn (b0 : Whole) (hf : Eq Bool true true) is refl true end
        | succ j -> fn (b0 : Whole) (hf : Eq Bool false true) is
            subst Bool false true hf
              (fn (z : Bool) is case z of
                 | true  -> Lt (monus (succ j) (cmul (qdivF zero (succ j) (succ b0)) (succ b0))) (succ b0)
                 | false -> Eq Bool true true end end)
              (refl true) end
        end
      end
    | succ g with ih -> fn (a : Whole) (b0 : Whole) (hf : Eq Bool (leb a (succ g)) true) is
        remStepLt a b0 (qdivF g (monus a (succ b0)) (succ b0))
          (fn (h : Eq Bool (leb (succ b0) a) true) is
             ih (monus a (succ b0)) b0 (lebMonusFuel a b0 g h hf) end)
          (leb (succ b0) a) (refl (leb (succ b0) a))
      end
    end
  end
end

-- REMAINDER BOUND:  qmod a (succ b0) < succ b0.   qmod unfolds to the fuelled
-- remainder with fuel = a, and leb a a (lebRefl) discharges the fuel precondition.

remBound : (a : Whole) -> (b0 : Whole) -> Lt (qmod a (succ b0)) (succ b0) is
  fn (a : Whole) (b0 : Whole) is remLtFuel a a b0 (lebRefl a) end
end

-- Bool discriminators (ported from ch13).

trueNotFalse : {P : U} -> Eq Bool true false -> P is
  fn {P : U} (h : Eq Bool true false) is
    subst Bool true false h (fn (z : Bool) is case z of | true -> P | false -> P end end)
      (subst Bool false true (sym h) (fn (z : Bool) is case z of | true -> P | false -> P -> P end end)
        (fn (p : P) is p end))
  end
end

falseNotTrue : {P : U} -> Eq Bool false true -> P is
  fn {P : U} (h : Eq Bool false true) is trueNotFalse (sym h) end
end

-- addW cancels on the right (ported from ch13's addCancelR; addW recurses on 2nd arg).

addCancelR : (z : Whole) -> (x : Whole) -> (y : Whole) -> Eq Whole (addW x z) (addW y z) -> Eq Whole x y is
  fn (z : Whole) is
    case z of
    | zero -> fn (x : Whole) (y : Whole) (r : Eq Whole (addW x zero) (addW y zero)) is
        trans (sym (addZeroR x)) (trans r (addZeroR y)) end
    | succ k with ih -> fn (x : Whole) (y : Whole) (r : Eq Whole (addW x (succ k)) (addW y (succ k))) is
        ih x y (succInj (trans (sym (addSuccR x k)) (trans r (addSuccR y k)))) end
    end
  end
end
-- addW cancels on the left (via commutation to addCancelR).

addCancelL : (c : Whole) -> (x : Whole) -> (y : Whole) -> Eq Whole (addW c x) (addW c y) -> Eq Whole x y is
  fn (c : Whole) (x : Whole) (y : Whole) (r : Eq Whole (addW c x) (addW c y)) is
    addCancelR c x y (trans (addComm x c) (trans r (addComm c y)))
  end
end

-- (x + b) + y is never < b (ported from ch13's notLtMidB), glyph-free.

notLtMidB : (x : Whole) -> (b : Whole) -> (y : Whole) -> Eq Bool (ltb (addW (addW x b) y) b) false is
  fn (x : Whole) (b : Whole) is
    case b of
    | zero -> fn (y : Whole) is ltbZero (addW (addW x zero) y) end
    | succ b2 with ih -> fn (y : Whole) is
        subst Whole (succ (addW (addW x b2) y)) (addW (addW x (succ b2)) y)
          (sym (cong (fn (w : Whole) is addW w y end) (addSuccR x b2)))
          (fn (z : Whole) is Eq Bool (ltb z (succ b2)) false end)
          (ih y)
      end
    end
  end
end
-- (xx + b) + r = (xx + r) + b   (ported from ch13's midComm), glyph-free.

midComm : (xx : Whole) -> (b : Whole) -> (r : Whole) -> Eq Whole (addW (addW xx b) r) (addW (addW xx r) b) is
  fn (xx : Whole) (b : Whole) (r : Whole) is
    trans (addAssoc xx b r) (trans (cong (fn (w : Whole) is addW xx w end) (addComm b r)) (sym (addAssoc xx r b)))
  end
end

-- addW zero r = r  (addW recurses on its 2nd arg, so this needs induction on r).

addZeroL : (r : Whole) -> Eq Whole (addW zero r) r is
  fn (r : Whole) is
    WholeElim (fn (z : Whole) is Eq Whole (addW zero z) z end)
      (refl zero)
      (fn (k : Whole) (ih : Eq Whole (addW zero k) k) is
         trans (addSuccR zero k) (cong succ ih) end)
      r
  end
end

-- QUOTIENT UNIQUENESS (ported from ch13's divUnique; ch203's cmul puts the divisor
-- on the LEFT — cmul (succ q) b = addW b (cmul q b) — so the leading b cancels via
-- addCancelL, and the cross-case contradiction reuses notLtMidB after an addComm.)

divUnique : (b : Whole) -> (q1 : Whole) -> (q2 : Whole) -> (r1 : Whole) -> (r2 : Whole)
    -> Lt r1 b -> Lt r2 b
    -> Eq Whole (addW (cmul q1 b) r1) (addW (cmul q2 b) r2) -> Eq Whole q1 q2 is
  fn (b : Whole) (q1 : Whole) is
    case q1 of
    | zero -> fn (q2 : Whole) is
        case q2 of
        | zero -> fn (r1 : Whole) (r2 : Whole) (b1 : Lt r1 b) (b2 : Lt r2 b)
            (h : Eq Whole (addW zero r1) (addW zero r2)) is refl zero end
        | succ q2b -> fn (r1 : Whole) (r2 : Whole) (b1 : Lt r1 b) (b2 : Lt r2 b)
            (h : Eq Whole (addW zero r1) (addW (addW b (cmul q2b b)) r2)) is
            -- r1 < b but r1 = (b + q2b·b) + r2 ≥ b: contradiction.
            trueNotFalse (trans (sym b1)
              (trans (cong (fn (z : Whole) is ltb z b end)
                       (trans (sym (addZeroL r1))
                         (trans h (cong (fn (w : Whole) is addW w r2 end) (addComm b (cmul q2b b))))))
                (notLtMidB (cmul q2b b) b r2)))
          end
        end
      end
    | succ q1b with ih -> fn (q2 : Whole) is
        case q2 of
        | zero -> fn (r1 : Whole) (r2 : Whole) (b1 : Lt r1 b) (b2 : Lt r2 b)
            (h : Eq Whole (addW (addW b (cmul q1b b)) r1) (addW zero r2)) is
            trueNotFalse (trans (sym b2)
              (trans (cong (fn (z : Whole) is ltb z b end)
                       (trans (sym (addZeroL r2))
                         (trans (sym h) (cong (fn (w : Whole) is addW w r1 end) (addComm b (cmul q1b b))))))
                (notLtMidB (cmul q1b b) b r1)))
          end
        | succ q2b -> fn (r1 : Whole) (r2 : Whole) (b1 : Lt r1 b) (b2 : Lt r2 b)
            (h : Eq Whole (addW (addW b (cmul q1b b)) r1) (addW (addW b (cmul q2b b)) r2)) is
            -- cancel the leading b: addAssoc reveals addW b (addW (q·b) r), then addCancelL.
            cong succ (ih q2b r1 r2 b1 b2
              (addCancelL b (addW (cmul q1b b) r1) (addW (cmul q2b b) r2)
                (trans (sym (addAssoc b (cmul q1b b) r1))
                  (trans h (addAssoc b (cmul q2b b) r2)))))
          end
        end
      end
    end
  end
end

-- ltb a s = leb (succ a) s   (ported from ch13's ltLeSucc).

ltLeSucc : (a : Whole) -> (s : Whole) -> Eq Bool (ltb a s) (leb (succ a) s) is
  fn (a : Whole) is
    case a of
    | zero -> fn (s : Whole) is case s of | zero -> refl false | succ s2 -> refl true end end
    | succ a2 with ih -> fn (s : Whole) is case s of | zero -> refl false | succ s2 -> ih s2 end end
    end
  end
end
-- ltb x (x + succ m) = true   (ported from ch13's ltbAddSucc; addW recurses on 2nd arg,
-- and ltb on the first, so we induct on x and peel both via addSuccL is not needed —
-- x + succ m has a succ head after addSuccR, lining ltb's succ/succ recursion up).

ltbAddSucc : (x : Whole) -> (m : Whole) -> Eq Bool (ltb x (addW x (succ m))) true is
  fn (x : Whole) is
    case x of
    | zero -> fn (m : Whole) is
        -- ltb 0 (addW 0 (succ m)); addW 0 (succ m) = succ (addW 0 m) is succ-headed.
        subst Whole (succ (addW zero m)) (addW zero (succ m)) (sym (addSuccR zero m))
          (fn (z : Whole) is Eq Bool (ltb zero z) true end) (refl true) end
    | succ x2 with ih -> fn (m : Whole) is
        -- ltb (succ x2) (addW (succ x2) (succ m)); rewrite the bound to succ (addW x2 (succ m)).
        subst Whole (succ (addW x2 (succ m))) (addW (succ x2) (succ m)) (sym (addSuccL x2 (succ m)))
          (fn (z : Whole) is Eq Bool (ltb (succ x2) z) true end) (ih m) end
    end
  end
end

-- STRICT MONOTONICITY of scaling:  r < b  ⟹  r·(succ k) < b·(succ k).
-- b = (b−succ r) + succ r (monusAddInv); distribute over (succ k); reassociate so the
-- bound is r·(succ k) + succ M, then ltbAddSucc.

mulLtMono : (r : Whole) -> (b : Whole) -> (k : Whole)
    -> Lt r b -> Lt (cmul r (succ k)) (cmul b (succ k)) is
  fn (r : Whole) (b : Whole) (k : Whole) (lt : Lt r b) is
    let lesr : Eq Bool (leb (succ r) b) true =
      subst Bool (ltb r b) (leb (succ r) b) (ltLeSucc r b) (fn (z : Bool) is Eq Bool z true end) lt in
    let g : Whole = monus b (succ r) in
    let bEq : Eq Whole (addW g (succ r)) b = monusAddInv (succ r) b lesr in
    -- cmul b (succ k) = cmul (addW g (succ r)) (succ k) = g·k' + (succ k + r·k'), reassociated
    -- to r·k' + succ (g·k' + k).
    let A : Whole = cmul g (succ k) in
    let B : Whole = cmul r (succ k) in
    let boundEq : Eq Whole (cmul b (succ k)) (addW B (succ (addW A k))) =
      trans (cong (fn (s : Whole) is cmul s (succ k) end) (sym bEq))
        (trans (mulDistR g (succ r) (succ k))
          (trans (cong (fn (s : Whole) is addW A s end) (refl (addW (succ k) B)))
            (trans (cong (fn (s : Whole) is addW A s end) (addSuccL k B))
              (trans (addSuccR A (addW k B))
                (trans (cong succ (sym (addAssoc A k B)))
                  (trans (cong succ (addComm (addW A k) B))
                    (sym (addSuccR B (addW A k))))))))) in
    subst Whole (addW B (succ (addW A k))) (cmul b (succ k)) (sym boundEq)
      (fn (z : Whole) is Eq Bool (ltb B z) true end)
      (ltbAddSucc B (addW A k))
  end
end

-- qdiv x 0 = 0  (case on x; both qdivF clauses with b=0 return 0).

natDivZero : (x : Whole) -> Eq Whole (qdiv x zero) zero is
  fn (x : Whole) is case x of | zero -> refl zero | succ j -> refl zero end end
end

-- cmul (succ b0) (succ k) is succ-headed:  = succ (k + b0·(succ k)).
-- cmul (succ b0) c = addW c (cmul b0 c) = addW (succ k) (cmul b0 (succ k)) = succ (k + …).

mulSuccPosForm : (b0 : Whole) -> (k : Whole)
    -> Eq Whole (cmul (succ b0) (succ k)) (succ (addW k (cmul b0 (succ k)))) is
  fn (b0 : Whole) (k : Whole) is addSuccL k (cmul b0 (succ k)) end
end

-- SCALED DIVISION LAW:  q·(b·k') + r·k' = a·k'   (q=qdiv a b, r=qmod a b, b=succ b0,
-- k'=succ k).  Multiply divLaw by k' (mulDistR), then mulAssoc on the quotient term.

scaledDivLaw : (a : Whole) -> (b0 : Whole) -> (k : Whole)
    -> Eq Whole (addW (cmul (qdiv a (succ b0)) (cmul (succ b0) (succ k)))
                   (cmul (qmod a (succ b0)) (succ k)))
              (cmul a (succ k)) is
  fn (a : Whole) (b0 : Whole) (k : Whole) is
    trans (cong (fn (s : Whole) is addW s (cmul (qmod a (succ b0)) (succ k)) end)
             (sym (mulAssoc (qdiv a (succ b0)) (succ b0) (succ k))))
      (trans (sym (mulDistR (cmul (qdiv a (succ b0)) (succ b0)) (qmod a (succ b0)) (succ k)))
        (cong (fn (s : Whole) is cmul s (succ k) end) (divLaw a (succ b0))))
  end
end

-- remBound transported along a proof that the modulus is succ-headed.

remBoundGen : (x : Whole) -> (b : Whole) -> (b0 : Whole) -> Eq Whole b (succ b0)
    -> Lt (qmod x b) b is
  fn (x : Whole) (b : Whole) (b0 : Whole) (hb : Eq Whole b (succ b0)) is
    subst Whole (succ b0) b (sym hb)
      (fn (z : Whole) is Lt (qmod x z) z end)
      (remBound x b0)
  end
end

-- DIVISION RESPECTS SCALING:  (a·k') // (b·k') = a // b.   b=0 collapses both to 0;
-- b=succ b0 invokes divUnique on the scaled division (two presentations of a·k'),
-- the remainders bounded by remBoundGen and mulLtMono.

natDivScale : (a : Whole) -> (b : Whole) -> (k : Whole)
    -> Eq Whole (qdiv (cmul a (succ k)) (cmul b (succ k))) (qdiv a b) is
  fn (a : Whole) (b : Whole) (k : Whole) is
    case b of
    | zero -> trans (natDivZero (cmul a (succ k))) (sym (natDivZero a))
    | succ b0 ->
        let kp : Whole = succ k in
        let bp : Whole = succ b0 in
        let bigB : Whole = cmul bp kp in
        let q : Whole = qdiv a bp in
        let r : Whole = qmod a bp in
        let Q : Whole = qdiv (cmul a kp) bigB in
        let R : Whole = qmod (cmul a kp) bigB in
        -- bigB is succ-headed (mulSuccPosForm) ⇒ R < bigB.
        let ltR : Lt R bigB =
          remBoundGen (cmul a kp) bigB (addW k (cmul b0 kp)) (mulSuccPosForm b0 k) in
        -- r < bp (remBound), scaled ⇒ r·kp < bp·kp = bigB.
        let ltRr : Lt (cmul r kp) bigB = mulLtMono r bp k (remBound a b0) in
        -- two presentations of a·kp: scaled divLaw vs divLaw of the scaled division.
        let hEq : Eq Whole (addW (cmul Q bigB) R) (addW (cmul q bigB) (cmul r kp)) =
          trans (divLaw (cmul a kp) bigB) (sym (scaledDivLaw a b0 k)) in
        divUnique bigB Q q R (cmul r kp) ltR ltRr hEq
    end
  end
end

-- qmod x 0 = x.   qmod x 0 = x − (qdiv x 0)·0 = x − 0 = x  (mulZeroR, monus zero-case).

natModZero : (x : Whole) -> Eq Whole (qmod x zero) x is
  fn (x : Whole) is
    trans (cong (fn (s : Whole) is monus x s end) (mulZeroR (qdiv x zero)))
      (refl x)
  end
end

-- REMAINDER RESPECTS SCALING:  (a·k') % (b·k') = (a % b)·k'.   b=0 collapses both to a·k';
-- b=succ b0: divUnique gave Q=q, so cancelling q·(b·k') in the two presentations of a·k'
-- (hEq) leaves R = r·k'.

natModScale : (a : Whole) -> (b : Whole) -> (k : Whole)
    -> Eq Whole (qmod (cmul a (succ k)) (cmul b (succ k))) (cmul (qmod a b) (succ k)) is
  fn (a : Whole) (b : Whole) (k : Whole) is
    case b of
    | zero -> trans (natModZero (cmul a (succ k)))
        (sym (cong (fn (s : Whole) is cmul s (succ k) end) (natModZero a)))
    | succ b0 ->
        let kp : Whole = succ k in
        let bp : Whole = succ b0 in
        let bigB : Whole = cmul bp kp in
        let q : Whole = qdiv a bp in
        let r : Whole = qmod a bp in
        let Q : Whole = qdiv (cmul a kp) bigB in
        let R : Whole = qmod (cmul a kp) bigB in
        let qQ : Eq Whole Q q = natDivScale a bp k in
        let hEq : Eq Whole (addW (cmul Q bigB) R) (addW (cmul q bigB) (cmul r kp)) =
          trans (divLaw (cmul a kp) bigB) (sym (scaledDivLaw a b0 k)) in
        -- rewrite Q to q in hEq, then cancel cmul q bigB on the left.
        addCancelL (cmul q bigB) R (cmul r kp)
          (subst Whole Q q qQ (fn (z : Whole) is Eq Whole (addW (cmul z bigB) R) (addW (cmul q bigB) (cmul r kp)) end) hEq)
    end
  end
end

-- floorUniqueGeneral: EQUAL FRACTIONS HAVE EQUAL FLOORS.  If a / succ b0 and
-- c / succ d0 are the same rational (cross-multiplication a·succ d0 = c·succ b0),
-- their flooring quotients agree.  The Euclidean-uniqueness payoff at Whole: expand
-- both by divLaw against the COMMON denominator (succ b0)·(succ d0), bound the two
-- remainders (cmul ra d, cmul rc b) below it, and divUnique forces the quotients
-- equal.  This is exactly what makes each decimal DIGIT a function of the rational
-- value — the engine of the to_radix respect proof.

floorUniqueGeneral : (b0 : Whole) -> (d0 : Whole) -> (a : Whole) -> (c : Whole)
    -> Eq Whole (cmul a (succ d0)) (cmul c (succ b0))
    -> Eq Whole (qdiv a (succ b0)) (qdiv c (succ d0)) is
  fn (b0 : Whole) (d0 : Whole) (a : Whole) (c : Whole)
     (hyp : Eq Whole (cmul a (succ d0)) (cmul c (succ b0))) is
    let b  : Whole = succ b0 in
    let d  : Whole = succ d0 in
    let qa : Whole = qdiv a b in
    let ra : Whole = qmod a b in
    let qc : Whole = qdiv c d in
    let rc : Whole = qmod c d in
    let bd : Whole = cmul b d in
    let lhsEq : Eq Whole (addW (cmul qa bd) (cmul ra d)) (cmul a d) =
      trans (cong (fn (s : Whole) is addW s (cmul ra d) end) (sym (mulAssoc qa b d)))
        (trans (sym (mulDistR (cmul qa b) ra d))
          (cong (fn (s : Whole) is cmul s d end) (divLaw a b))) in
    let rhsEq : Eq Whole (addW (cmul qc bd) (cmul rc b)) (cmul c b) =
      trans (cong (fn (s : Whole) is addW s (cmul rc b) end)
              (sym (trans (mulAssoc qc d b)
                     (cong (fn (s : Whole) is cmul qc s end) (mulComm d b)))))
        (trans (sym (mulDistR (cmul qc d) rc b))
          (cong (fn (s : Whole) is cmul s b end) (divLaw c d))) in
    let keyEq : Eq Whole (addW (cmul qa bd) (cmul ra d)) (addW (cmul qc bd) (cmul rc b)) =
      trans lhsEq (trans hyp (sym rhsEq)) in
    let bound1 : Lt (cmul ra d) bd = mulLtMono ra b d0 (remBound a b0) in
    let bound2 : Lt (cmul rc b) bd =
      subst Whole (cmul d b) bd (mulComm d b)
        (fn (s : Whole) is Lt (cmul rc b) s end)
        (mulLtMono rc d b0 (remBound c d0)) in
    divUnique bd qa qc (cmul ra d) (cmul rc b) bound1 bound2 keyEq
  end
end

-- ============================================================================
-- APPENDED Int-level lemmas (imag / sign laws).
-- ============================================================================

-- monus n zero = n.  Definitional: monus scrutinizes its SECOND argument, so
-- monus m zero ~> m by ι; refl suffices.

monusZeroR : (n : Whole) -> Eq Whole (monus n zero) n is
  fn (n : Whole) is refl n end
end

-- |intOf n| = n.  obs (intOf n) = canon (npair n zero) = npair (monus n zero)
-- (monus zero n) = npair n zero; imag = addW n zero = n.

predMul : (x : Whole) -> (n : Whole) -> Eq Whole (cmul (pred x) n) (monus (cmul x n) n) is
  fn (x : Whole) (n : Whole) is
    case x of
    | zero -> sym (zeroMonus n)
    | succ k ->
        sym (trans (cong (fn (s : Whole) is monus s n end) (addComm n (cmul k n)))
                   (monusAddCancel n (cmul k n)))
    end
  end
end

-- RIGHT-distribution of multiplication over truncated subtraction:
-- (a − b)·n = a·n − b·n.  TRUE even with underflow (a<b ⇒ both sides 0, since
-- cmul is order-preserving), but the naive "(a−b)+(c−d) = (a+c)−(b+d)" step is
-- FALSE truncated, so the proof inducts on b through predMul, never splitting the
-- monus pair.  Step: monus a (succ k) ≡ pred (monus a k); predMul peels the n,
-- the IH rewrites, monusAdd re-nests, addComm aligns.

mulMonusDistR : (a : Whole) -> (n : Whole) -> (b : Whole)
    -> Eq Whole (cmul (monus a b) n) (monus (cmul a n) (cmul b n)) is
  fn (a : Whole) (n : Whole) (b : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (cmul (monus a x) n) (monus (cmul a n) (cmul x n)) end)
      (refl (cmul a n))
      (fn (k : Whole) (ih : Eq Whole (cmul (monus a k) n) (monus (cmul a n) (cmul k n))) is
        trans (predMul (monus a k) n)
          (trans (cong (fn (s : Whole) is monus s n end) ih)
            (trans (sym (monusAdd (cmul a n) (cmul k n) n))
              (cong (fn (s : Whole) is monus (cmul a n) s end)
                    (addComm (cmul k n) n))))
      end)
      b
  end
end

-- THE SIGN-BRIDGE (non-negative case): |m · intOf n| = |m| · n.  The full
-- multiplicativity of imag needs a four-way sign split; here the SECOND factor
-- is a genuine natural (intOf n, never negative), and that is all the to_radix
-- respect proof needs (it multiplies a numerator by a positive denominator
-- zden q = intOf (succ (qdpred q))).  qind drops m to a representative (a, b);
-- then imul (qin (a,b)) (intOf n) ≡ qin (a·n + b·0, a·0 + b·n), whose canon-abs
-- is addW (monus (a·n)(b·n)) (monus (b·n)(a·n)) once the 0-products clear — and
-- |m|·n = (|a−b|)·n distributes to exactly that pair via mulMonusDistR (twice).

-- --- CANONICAL-INT BRIDGES (replacing ch203's quotient-Z natAbs/sign lemmas) ---
-- ============================================================================
-- CANONICAL-INT BRIDGES.  ch203's Z is a QUOTIENT integer, so its natAbs/sign
-- multiplicativity needed qind + canon/obs reasoning.  Our Int is CANONICAL
-- data (nonneg/negsucc), so these bridges are direct constructor algebra.
-- The Int ops (imul) are built on the prelude's `mulW`; the ported division/
-- expand proofs run on `cmul` (ch203's mul, add-on-the-left); mulWEqCmul is the
-- one lemma that crosses between them.
-- ============================================================================

-- mulW and cmul compute the same product, add-arguments reversed (mulW is
-- (k*n)+n, cmul is n+(k*n)); equal by addComm.  The bridge the Int-abs lemmas need.
mulWEqCmul : (a : Whole) -> (b : Whole) -> Eq Whole (mulW a b) (cmul a b) is
  fn (a : Whole) (b : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (mulW x b) (cmul x b) end)
      (refl 0)
      (fn (k : Whole) (ih : Eq Whole (mulW k b) (cmul k b)) is
         trans (cong (fn (z : Whole) is addW z b end) ih)
               (addWComm (cmul k b) b)
       end)
      a
  end
end

-- |intOf n| = n  (intOf n = nonneg n; imag reads the magnitude off the constructor).
natAbsZfrom : (n : Whole) -> Eq Whole (imag (intOf n)) n is
  fn (n : Whole) is refl n end
end

-- |ineg (nonneg X)| = X  (ineg on a nonneg is nonneg 0 / negsucc, imag recovers X).
imagInegNonneg : (X : Whole) -> Eq Whole (imag (ineg (nonneg X))) X is
  fn (X : Whole) is
    case X of
    | zero   -> refl zero
    | succ k -> refl (succ k)
    end
  end
end

-- MULTIPLICATIVITY OF |.| on canonical Int, landing in cmul: |a * b| = |a| * |b|.
-- Four-way case; imul is mulW-based, so each arm bridges mulW -> cmul via mulWEqCmul
-- (mixed-sign arms first pass through imagInegNonneg).
imagMul : (a : Int) -> (b : Int) -> Eq Whole (imag (imul a b)) (cmul (imag a) (imag b)) is
  fn (a : Int) (b : Int) is
    case a of
    | nonneg x ->
        case b of
        | nonneg y  -> mulWEqCmul x y
        | negsucc d -> trans (imagInegNonneg (mulW x (succ d))) (mulWEqCmul x (succ d))
        end
    | negsucc c ->
        case b of
        | nonneg y  -> trans (imagInegNonneg (mulW (succ c) y)) (mulWEqCmul (succ c) y)
        | negsucc d -> mulWEqCmul (succ c) (succ d)
        end
    end
  end
end

-- THE SIGN-BRIDGE (non-negative case): |m * intOf n| = |m| * n.  imagMul then the
-- trivial |intOf n| = n.  (ch203's natAbsMulZfrom, shrunk to canonical Int.)
natAbsMulZfrom : (m : Int) -> (n : Whole)
    -> Eq Whole (imag (imul m (intOf n))) (cmul (imag m) n) is
  fn (m : Int) (n : Whole) is
    trans (imagMul m (intOf n))
          (cong (fn (w : Whole) is cmul (imag m) w end) (natAbsZfrom n))
  end
end

-- THE SIGN-BRIDGE for the sign bit: sign (m * intOf (succ n)) = sign m.  A positive
-- factor never flips the sign.  nonneg stays nonneg; negsucc times a positive is
-- ineg of a positive product = negsucc (dmulSucc makes the product a succ).
isNegZMulZfromSucc : (m : Int) -> (n : Whole)
    -> Eq Bool (isign (imul m (intOf (succ n)))) (isign m) is
  fn (m : Int) (n : Whole) is
    case m of
    | nonneg x -> refl false
    | negsucc c ->
        subst Whole (succ (dmul c n)) (mulW (succ c) (succ n)) (sym (dmulSucc c n))
          (fn (w : Whole) is Eq Bool (isign (ineg (nonneg w))) true end)
          (refl true)
    end
  end
end

-- --- respect lemmas + expand cross-invariance + floor + toRadix well-definedness ---
intPartResp : (p : QPair) -> (q : QPair) -> QRel p q
    -> Eq Whole (qdiv (qmagNum p) (qmagDen p)) (qdiv (qmagNum q) (qmagDen q)) is
  fn (p : QPair) (q : QPair) (h : QRel p q) is
    floorUniqueGeneral (qdpred p) (qdpred q) (qmagNum p) (qmagNum q)
      (trans (sym (natAbsMulZfrom (qnum p) (succ (qdpred q))))
        (trans (cong imag h)
               (natAbsMulZfrom (qnum q) (succ (qdpred p)))))
  end
end

-- MULTIPLYING BY A POSITIVE PRESERVES ZERO-NESS (the Bool-sign engine).  The
-- nonzero-test  case _ of zero->false | succ->true  agrees on  x  and  x·(succ n):
-- x=0 ⇒ cmul 0 (succ n) ≡ 0 (cmul recurses on its first arg), both false; x=succ j ⇒
-- cmul (succ j)(succ n) ≡ succ (…) (addW recurses on succ n's head), both true.  This
-- is the sign analogue of monusZeroR for imag — a positive factor never flips a
-- nonzero magnitude to zero or back.

nzMulSucc : (x : Whole) -> (n : Whole)
    -> Eq Bool (case (cmul x (succ n)) of | zero -> false | succ k -> true end)
               (case x of | zero -> false | succ k -> true end) is
  fn (x : Whole) (n : Whole) is
    case x of
    | zero -> refl false
    | succ j -> refl true
    end
  end
end

-- THE SIGN-BRIDGE (non-negative case): isign (m · intOf (succ n)) = isign m.  Dual
-- of natAbsMulZfrom for the sign rather than the magnitude.  qind drops m to (a, b);
-- then the negative part of m · intOf (succ n) is  snd (canon (pmul (a,b)(succ n, 0)))
-- = monus (a·0 + b·(succ n)) (a·(succ n) + b·0), whose 0-products clear (snz/feq) to
-- monus (b·(succ n)) (a·(succ n)) = (b−a)·(succ n)  (mulMonusDistR).  isign m itself
-- is  case (monus b a) of …,  so the goal is exactly nzMulSucc (monus b a) n: scaling
-- the negative part b−a by the positive (succ n) cannot change whether it is zero.

signResp : (p : QPair) -> (q : QPair) -> QRel p q
    -> Eq Bool (qsign p) (qsign q) is
  fn (p : QPair) (q : QPair) (h : QRel p q) is
    trans (sym (isNegZMulZfromSucc (qnum p) (qdpred q)))
      (trans (cong isign h)
             (isNegZMulZfromSucc (qnum q) (qdpred p)))
  end
end

-- ============================================================================
-- RUNG 3 (fractional digits) — foundations.
-- ============================================================================

-- CANCELLATION of a positive multiplier:  x·(succ k) = y·(succ k)  ⟹  x = y.
-- The equality gives leb both ways on the products; lteMulPos strips the common
-- (succ k) from each, and lteAntisym pins x = y.  The Whole injectivity that lets a
-- cross-equality  rem_p·den_q = rem_q·den_p  be cancelled to compare remainders.

mulRightCancel : (k : Whole) -> (x : Whole) -> (y : Whole)
    -> Eq Whole (cmul x (succ k)) (cmul y (succ k)) -> Eq Whole x y is
  fn (k : Whole) (x : Whole) (y : Whole) (h : Eq Whole (cmul x (succ k)) (cmul y (succ k))) is
    let lexy : Eq Bool (leb (cmul x (succ k)) (cmul y (succ k))) true =
      subst Whole (cmul x (succ k)) (cmul y (succ k)) h
        (fn (z : Whole) is Eq Bool (leb (cmul x (succ k)) z) true end)
        (lteRefl (cmul x (succ k))) in
    let leyx : Eq Bool (leb (cmul y (succ k)) (cmul x (succ k))) true =
      subst Whole (cmul x (succ k)) (cmul y (succ k)) h
        (fn (z : Whole) is Eq Bool (leb z (cmul x (succ k))) true end)
        (lteRefl (cmul x (succ k))) in
    lteAntisym x y
      (trans (sym (lteMulPos k x y)) lexy)
      (trans (sym (lteMulPos k y x)) leyx)
  end
end

-- eqW is REFLEXIVE:  eqW n n = true.  succ/succ reduces to the recursive call by ι.

eqWRefl : (n : Whole) -> Eq Bool (eqW n n) true is
  fn (n : Whole) is
    WholeElim (fn (x : Whole) is Eq Bool (eqW x x) true end)
      (refl true)
      (fn (k : Whole) (ih : Eq Bool (eqW k k) true) is ih end)
      n
  end
end

-- eqW is COMPLETE:  x = y  ⟹  eqW x y = true.  Transport eqWRefl along the equality.

eqWComplete : (x : Whole) -> (y : Whole) -> Eq Whole x y -> Eq Bool (eqW x y) true is
  fn (x : Whole) (y : Whole) (h : Eq Whole x y) is
    subst Whole x y h (fn (z : Whole) is Eq Bool (eqW x z) true end) (eqWRefl x)
  end
end

-- eqW is SOUND:  eqW x y = true  ⟹  x = y.  Double induction; the mismatched-head
-- branches discharge an absurd  false = true  via lteAbsurdNat, the succ/succ branch
-- recurses (eqW (succ k)(succ u) ≡ eqW k u) and re-applies succ.

eqWSound : (x : Whole) -> (y : Whole) -> Eq Bool (eqW x y) true -> Eq Whole x y is
  fn (x : Whole) is
    WholeElim (fn (w : Whole) is (y : Whole) -> Eq Bool (eqW w y) true -> Eq Whole w y end)
      (fn (y : Whole) is
        WholeElim (fn (u : Whole) is Eq Bool (eqW zero u) true -> Eq Whole zero u end)
          (fn (h : Eq Bool (eqW zero zero) true) is refl zero end)
          (fn (u' : Whole) (ihu : Eq Bool (eqW zero u') true -> Eq Whole zero u') is
            fn (h : Eq Bool (eqW zero (succ u')) true) is
              lteAbsurdNat zero (succ u') h end
          end)
          y
      end)
      (fn (k : Whole) (ih : (y : Whole) -> Eq Bool (eqW k y) true -> Eq Whole k y) is
        fn (y : Whole) is
          WholeElim (fn (u : Whole) is Eq Bool (eqW (succ k) u) true -> Eq Whole (succ k) u end)
            (fn (h : Eq Bool (eqW (succ k) zero) true) is
              lteAbsurdNat (succ k) zero h end)
            (fn (u' : Whole) (ihu : Eq Bool (eqW (succ k) u') true -> Eq Whole (succ k) u') is
              fn (h : Eq Bool (eqW (succ k) (succ u')) true) is
                cong (fn (z : Whole) is succ z end) (ih u' h) end
            end)
            y
        end
      end)
      x
  end
end

-- Boolean conjunction:  and true b = b, and false b = false.

and : Bool -> Bool -> Bool is
  fn (a : Bool) (b : Bool) is BoolElim (fn (x : Bool) is Bool end) b false a end
end

-- BOOL EXTENSIONALITY:  two bools sharing the same truth value are equal.  The
-- p=true case syms f (refl true); the p=false case splits q — true contradicts via
-- g (refl true), false is refl.  The decidable bridge: it turns a biconditional on
-- nonzero-tests into an actual Bool equality.

boolTrueIff : (p : Bool) -> (q : Bool)
    -> (Eq Bool p true -> Eq Bool q true)
    -> (Eq Bool q true -> Eq Bool p true)
    -> Eq Bool p q is
  fn (p : Bool) (q : Bool)
     (f : Eq Bool p true -> Eq Bool q true)
     (g : Eq Bool q true -> Eq Bool p true) is
    BoolElim
      (fn (b : Bool) is
         (Eq Bool b true -> Eq Bool q true)
           -> (Eq Bool q true -> Eq Bool b true)
           -> Eq Bool b q end)
      (fn (f1 : Eq Bool true true -> Eq Bool q true)
          (g1 : Eq Bool q true -> Eq Bool true true) is
         sym (f1 (refl true)) end)
      (fn (f0 : Eq Bool false true -> Eq Bool q true)
          (g0 : Eq Bool q true -> Eq Bool false true) is
         BoolElim
           (fn (c : Bool) is (Eq Bool c true -> Eq Bool false true) -> Eq Bool false c end)
           (fn (g0t : Eq Bool true true -> Eq Bool false true) is g0t (refl true) end)
           (fn (g0f : Eq Bool false true -> Eq Bool false true) is refl false end)
           q g0 end)
      p f g
  end
end

-- eqW RESPECTS CROSS-EQUALITY:  if rP·sd = rQ·sb and x·sd = y·sb (sb = succ b0,
-- sd = succ d0), then eqW rP x = eqW rQ y.  Each direction: decode one eqW to a Whole
-- equality (eqWSound), transport it across the two cross-products and cancel the
-- positive factor (mulRightCancel) to get the other Whole equality, re-encode
-- (eqWComplete); boolTrueIff glues the directions.  This is what makes the cycle
-- detector see the SAME recurrences in two equivalent long divisions even though the
-- recorded remainders differ.

eqWCross : (b0 : Whole) -> (d0 : Whole) -> (rP : Whole) -> (rQ : Whole) -> (x : Whole) -> (y : Whole)
    -> Eq Whole (cmul rP (succ d0)) (cmul rQ (succ b0))
    -> Eq Whole (cmul x (succ d0)) (cmul y (succ b0))
    -> Eq Bool (eqW rP x) (eqW rQ y) is
  fn (b0 : Whole) (d0 : Whole) (rP : Whole) (rQ : Whole) (x : Whole) (y : Whole)
     (hr : Eq Whole (cmul rP (succ d0)) (cmul rQ (succ b0)))
     (hx : Eq Whole (cmul x (succ d0)) (cmul y (succ b0))) is
    boolTrueIff (eqW rP x) (eqW rQ y)
      (fn (e : Eq Bool (eqW rP x) true) is
         let hpx : Eq Whole rP x = eqWSound rP x e in
         let hqy : Eq Whole rQ y =
           mulRightCancel b0 rQ y
             (trans (sym hr)
               (trans (cong (fn (z : Whole) is cmul z (succ d0) end) hpx) hx)) in
         eqWComplete rQ y hqy end)
      (fn (e : Eq Bool (eqW rQ y) true) is
         let hqy : Eq Whole rQ y = eqWSound rQ y e in
         let hpx : Eq Whole rP x =
           mulRightCancel d0 rP x
             (trans hr
               (trans (cong (fn (z : Whole) is cmul z (succ b0) end) hqy) (sym hx))) in
         eqWComplete rP x hpx end)
  end
end

-- EX FALSO from a disjoint Bool equation:  false = true entails anything.  The motive
-- is C at true and the inhabited (Eq Bool false false) at false; subst along the
-- false=true proof ships refl into C.

boolDisjoint : (C : U) -> Eq Bool false true -> C is
  fn (C : U) (h : Eq Bool false true) is
    subst Bool false true h
      (fn (z : Bool) is
         case z of
         | true  -> C
         | false -> Eq Bool false false
         end
       end)
      (refl false)
  end
end

-- Projections of a true conjunction.  and false _ ≡ false, so a false left factor
-- makes the whole thing a false = true absurdity (boolDisjoint for the right one).

andTrueL : (a : Bool) -> (b : Bool) -> Eq Bool (and a b) true -> Eq Bool a true is
  fn (a : Bool) (b : Bool) (h : Eq Bool (and a b) true) is
    BoolElim (fn (x : Bool) is (Eq Bool (and x b) true -> Eq Bool x true) end)
      (fn (h1 : Eq Bool (and true b) true) is refl true end)
      (fn (h0 : Eq Bool (and false b) true) is h0 end)
      a h
  end
end

andTrueR : (a : Bool) -> (b : Bool) -> Eq Bool (and a b) true -> Eq Bool b true is
  fn (a : Bool) (b : Bool) (h : Eq Bool (and a b) true) is
    BoolElim (fn (x : Bool) is (Eq Bool (and x b) true -> Eq Bool b true) end)
      (fn (h1 : Eq Bool (and true b) true) is h1 end)
      (fn (h0 : Eq Bool (and false b) true) is boolDisjoint (Eq Bool b true) h0 end)
      a h
  end
end

-- THE SEEN-LIST CORRESPONDENCE.  wcrossB b0 d0 sP sQ = true means the two recorded
-- remainder lists have equal length and position-wise cross-equal entries
-- (sP[i]·(succ d0) = sQ[i]·(succ b0)), checked by eqW on the cross-products.
-- Structural on sP; the mismatched-length cases are false.

wcrossB : Whole -> Whole -> WList -> WList -> Bool is
  fn (b0 : Whole) (d0 : Whole) (sP : WList) is
    WListElim (fn (w : WList) is WList -> Bool end)
      (fn (sQ : WList) is case sQ of | wnil -> true | wcons y ys -> false end end)
      (fn (x : Whole) (xs : WList) (ih : WList -> Bool) is
         fn (sQ : WList) is
           case sQ of
           | wnil -> false
           | wcons y ys -> and (eqW (cmul x (succ d0)) (cmul y (succ b0))) (ih ys)
           end
         end
       end)
      sP
  end
end

-- MEMBERSHIP RESPECTS THE CORRESPONDENCE.  Under wcrossB and a cross-equal current
-- remainder, the cycle detector reports the same hit/miss in both expansions.  The
-- head comparison agrees by eqWCross; the tails recurse; cong2 rebuilds the case.

wmemberCross : (b0 : Whole) -> (d0 : Whole) -> (sP : WList) -> (sQ : WList)
    -> Eq Bool (wcrossB b0 d0 sP sQ) true
    -> (rP : Whole) -> (rQ : Whole)
    -> Eq Whole (cmul rP (succ d0)) (cmul rQ (succ b0))
    -> Eq Bool (wmember rP sP) (wmember rQ sQ) is
  fn (b0 : Whole) (d0 : Whole) (sP : WList) is
    WListElim
      (fn (w : WList) is
         (sQ : WList) -> Eq Bool (wcrossB b0 d0 w sQ) true
           -> (rP : Whole) -> (rQ : Whole)
           -> Eq Whole (cmul rP (succ d0)) (cmul rQ (succ b0))
           -> Eq Bool (wmember rP w) (wmember rQ sQ) end)
      (fn (sQ : WList) is
         case sQ of
         | wnil ->
             fn (h : Eq Bool (wcrossB b0 d0 wnil wnil) true) (rP : Whole) (rQ : Whole)
                (hc : Eq Whole (cmul rP (succ d0)) (cmul rQ (succ b0))) is refl false end
         | wcons y ys ->
             fn (h : Eq Bool (wcrossB b0 d0 wnil (wcons y ys)) true) (rP : Whole) (rQ : Whole)
                (hc : Eq Whole (cmul rP (succ d0)) (cmul rQ (succ b0))) is
               boolDisjoint (Eq Bool (wmember rP wnil) (wmember rQ (wcons y ys))) h end
         end
       end)
      (fn (x : Whole) (xs : WList)
          (ih : (sQ : WList) -> Eq Bool (wcrossB b0 d0 xs sQ) true -> (rP : Whole) -> (rQ : Whole)
                  -> Eq Whole (cmul rP (succ d0)) (cmul rQ (succ b0))
                  -> Eq Bool (wmember rP xs) (wmember rQ sQ)) is
         fn (sQ : WList) is
           case sQ of
           | wnil ->
               fn (h : Eq Bool (wcrossB b0 d0 (wcons x xs) wnil) true) (rP : Whole) (rQ : Whole)
                  (hc : Eq Whole (cmul rP (succ d0)) (cmul rQ (succ b0))) is
                 boolDisjoint (Eq Bool (wmember rP (wcons x xs)) (wmember rQ wnil)) h end
           | wcons y ys ->
               fn (h : Eq Bool (wcrossB b0 d0 (wcons x xs) (wcons y ys)) true) (rP : Whole) (rQ : Whole)
                  (hc : Eq Whole (cmul rP (succ d0)) (cmul rQ (succ b0))) is
                 let hxy : Eq Whole (cmul x (succ d0)) (cmul y (succ b0)) =
                   eqWSound (cmul x (succ d0)) (cmul y (succ b0))
                     (andTrueL (eqW (cmul x (succ d0)) (cmul y (succ b0)))
                               (wcrossB b0 d0 xs ys) h) in
                 let hTail : Eq Bool (wcrossB b0 d0 xs ys) true =
                   andTrueR (eqW (cmul x (succ d0)) (cmul y (succ b0)))
                            (wcrossB b0 d0 xs ys) h in
                 let hEqW : Eq Bool (eqW rP x) (eqW rQ y) =
                   eqWCross b0 d0 rP rQ x y hc hxy in
                 let ihTail : Eq Bool (wmember rP xs) (wmember rQ ys) =
                   ih ys hTail rP rQ hc in
                 cong2 (fn (sc : Bool) (fb : Bool) is
                          BoolElim (fn (w : Bool) is Bool end) true fb sc end)
                   hEqW ihTail end
           end
         end
       end)
      sP
  end
end

-- THE RECURRENCE INDEX RESPECTS THE CORRESPONDENCE.  Same structure as wmemberCross
-- but the false-branch carries succ of the recursive index, so the repetend's start
-- position is identical in both expansions.

windexCross : (b0 : Whole) -> (d0 : Whole) -> (sP : WList) -> (sQ : WList)
    -> Eq Bool (wcrossB b0 d0 sP sQ) true
    -> (rP : Whole) -> (rQ : Whole)
    -> Eq Whole (cmul rP (succ d0)) (cmul rQ (succ b0))
    -> Eq Whole (windex rP sP) (windex rQ sQ) is
  fn (b0 : Whole) (d0 : Whole) (sP : WList) is
    WListElim
      (fn (w : WList) is
         (sQ : WList) -> Eq Bool (wcrossB b0 d0 w sQ) true
           -> (rP : Whole) -> (rQ : Whole)
           -> Eq Whole (cmul rP (succ d0)) (cmul rQ (succ b0))
           -> Eq Whole (windex rP w) (windex rQ sQ) end)
      (fn (sQ : WList) is
         case sQ of
         | wnil ->
             fn (h : Eq Bool (wcrossB b0 d0 wnil wnil) true) (rP : Whole) (rQ : Whole)
                (hc : Eq Whole (cmul rP (succ d0)) (cmul rQ (succ b0))) is refl zero end
         | wcons y ys ->
             fn (h : Eq Bool (wcrossB b0 d0 wnil (wcons y ys)) true) (rP : Whole) (rQ : Whole)
                (hc : Eq Whole (cmul rP (succ d0)) (cmul rQ (succ b0))) is
               boolDisjoint (Eq Whole (windex rP wnil) (windex rQ (wcons y ys))) h end
         end
       end)
      (fn (x : Whole) (xs : WList)
          (ih : (sQ : WList) -> Eq Bool (wcrossB b0 d0 xs sQ) true -> (rP : Whole) -> (rQ : Whole)
                  -> Eq Whole (cmul rP (succ d0)) (cmul rQ (succ b0))
                  -> Eq Whole (windex rP xs) (windex rQ sQ)) is
         fn (sQ : WList) is
           case sQ of
           | wnil ->
               fn (h : Eq Bool (wcrossB b0 d0 (wcons x xs) wnil) true) (rP : Whole) (rQ : Whole)
                  (hc : Eq Whole (cmul rP (succ d0)) (cmul rQ (succ b0))) is
                 boolDisjoint (Eq Whole (windex rP (wcons x xs)) (windex rQ wnil)) h end
           | wcons y ys ->
               fn (h : Eq Bool (wcrossB b0 d0 (wcons x xs) (wcons y ys)) true) (rP : Whole) (rQ : Whole)
                  (hc : Eq Whole (cmul rP (succ d0)) (cmul rQ (succ b0))) is
                 let hxy : Eq Whole (cmul x (succ d0)) (cmul y (succ b0)) =
                   eqWSound (cmul x (succ d0)) (cmul y (succ b0))
                     (andTrueL (eqW (cmul x (succ d0)) (cmul y (succ b0)))
                               (wcrossB b0 d0 xs ys) h) in
                 let hTail : Eq Bool (wcrossB b0 d0 xs ys) true =
                   andTrueR (eqW (cmul x (succ d0)) (cmul y (succ b0)))
                            (wcrossB b0 d0 xs ys) h in
                 let hEqW : Eq Bool (eqW rP x) (eqW rQ y) =
                   eqWCross b0 d0 rP rQ x y hc hxy in
                 let ihTail : Eq Whole (windex rP xs) (windex rQ ys) =
                   ih ys hTail rP rQ hc in
                 cong2 (fn (sc : Bool) (t : Whole) is
                          BoolElim (fn (w : Bool) is Whole end) zero (succ t) sc end)
                   hEqW ihTail end
           end
         end
       end)
      sP
  end
end

-- ============================================================================
-- RUNG 3 — the per-step cross-equality is preserved through the long division.
-- ============================================================================

-- a=true and b=true give and a b = true (and true b ≡ b).

andBoth : (a : Bool) -> (b : Bool) -> Eq Bool a true -> Eq Bool b true -> Eq Bool (and a b) true is
  fn (a : Bool) (b : Bool) (ha : Eq Bool a true) (hb : Eq Bool b true) is
    trans (cong (fn (z : Bool) is and z b end) ha) hb
  end
end

-- Scaling the cross-equality by the radix 10:  remP·sd = remQ·sb  ⟹
-- (remP·10)·sd = (remQ·10)·sb.  Reassociate so the shared 10 floats to the outside.

mul10Cross : (b0 : Whole) -> (d0 : Whole) -> (remP : Whole) -> (remQ : Whole)
    -> Eq Whole (cmul remP (succ d0)) (cmul remQ (succ b0))
    -> Eq Whole (cmul (cmul remP 10) (succ d0)) (cmul (cmul remQ 10) (succ b0)) is
  fn (b0 : Whole) (d0 : Whole) (remP : Whole) (remQ : Whole)
     (hr : Eq Whole (cmul remP (succ d0)) (cmul remQ (succ b0))) is
    trans (mulAssoc remP 10 (succ d0))
      (trans (cong (fn (z : Whole) is cmul remP z end) (mulComm 10 (succ d0)))
        (trans (sym (mulAssoc remP (succ d0) 10))
          (trans (cong (fn (z : Whole) is cmul z 10 end) hr)
            (trans (mulAssoc remQ (succ b0) 10)
              (trans (cong (fn (z : Whole) is cmul remQ z end) (mulComm (succ b0) 10))
                (sym (mulAssoc remQ 10 (succ b0))))))))
  end
end

-- THE REMAINDER STAYS CROSS-EQUAL.  If a·sd = c·sb then the long-division remainders
-- satisfy (a % sb)·sd = (c % sd)·sb.  qmod x m = x − (x//m)·m; distribute ·sd / ·sb
-- over the monus (mulMonusDistR), equate the minuends by hypothesis and the quotient
-- terms via floorUniqueGeneral (the floors agree) plus a commute of sb·sd.

natModCrossStep : (b0 : Whole) -> (d0 : Whole) -> (a : Whole) -> (c : Whole)
    -> Eq Whole (cmul a (succ d0)) (cmul c (succ b0))
    -> Eq Whole (cmul (qmod a (succ b0)) (succ d0)) (cmul (qmod c (succ d0)) (succ b0)) is
  fn (b0 : Whole) (d0 : Whole) (a : Whole) (c : Whole)
     (hyp : Eq Whole (cmul a (succ d0)) (cmul c (succ b0))) is
    let qa : Whole = qdiv a (succ b0) in
    let qc : Whole = qdiv c (succ d0) in
    let hq : Eq Whole qa qc = floorUniqueGeneral b0 d0 a c hyp in
    let midEq : Eq Whole (cmul (cmul qa (succ b0)) (succ d0)) (cmul (cmul qc (succ d0)) (succ b0)) =
      trans (mulAssoc qa (succ b0) (succ d0))
        (trans (cong2 (fn (u : Whole) (v : Whole) is cmul u v end) hq (mulComm (succ b0) (succ d0)))
               (sym (mulAssoc qc (succ d0) (succ b0)))) in
    calc cmul (qmod a (succ b0)) (succ d0)
      = cmul (monus a (cmul qa (succ b0))) (succ d0)
          by refl (cmul (qmod a (succ b0)) (succ d0))
      = monus (cmul a (succ d0)) (cmul (cmul qa (succ b0)) (succ d0))
          by mulMonusDistR a (succ d0) (cmul qa (succ b0))
      = monus (cmul c (succ b0)) (cmul (cmul qc (succ d0)) (succ b0))
          by cong2 (fn (u : Whole) (v : Whole) is monus u v end) hyp midEq
      = cmul (monus c (cmul qc (succ d0))) (succ b0)
          by sym (mulMonusDistR c (succ b0) (cmul qc (succ d0)))
      = cmul (qmod c (succ d0)) (succ b0)
          by refl (cmul (qmod c (succ d0)) (succ b0))
    end
  end
end

-- APPENDING CROSS-EQUAL REMAINDERS PRESERVES THE CORRESPONDENCE.  wsnoc appends at the
-- tail, so the induction walks both lists down to their (corresponding) ends and snocs
-- the new cross-equal pair (eqWComplete on the scaled equality); andBoth re-knits.

wcrossSnoc : (b0 : Whole) -> (d0 : Whole) -> (seenP : WList) -> (seenQ : WList)
    -> (remP : Whole) -> (remQ : Whole)
    -> Eq Bool (wcrossB b0 d0 seenP seenQ) true
    -> Eq Whole (cmul remP (succ d0)) (cmul remQ (succ b0))
    -> Eq Bool (wcrossB b0 d0 (wsnoc seenP remP) (wsnoc seenQ remQ)) true is
  fn (b0 : Whole) (d0 : Whole) (seenP : WList) is
    WListElim
      (fn (w : WList) is
         (seenQ : WList) -> (remP : Whole) -> (remQ : Whole)
           -> Eq Bool (wcrossB b0 d0 w seenQ) true
           -> Eq Whole (cmul remP (succ d0)) (cmul remQ (succ b0))
           -> Eq Bool (wcrossB b0 d0 (wsnoc w remP) (wsnoc seenQ remQ)) true end)
      (fn (seenQ : WList) is
         case seenQ of
         | wnil ->
             fn (remP : Whole) (remQ : Whole)
                (hw : Eq Bool (wcrossB b0 d0 wnil wnil) true)
                (hr : Eq Whole (cmul remP (succ d0)) (cmul remQ (succ b0))) is
               cong (fn (z : Bool) is and z true end)
                 (eqWComplete (cmul remP (succ d0)) (cmul remQ (succ b0)) hr) end
         | wcons y ys ->
             fn (remP : Whole) (remQ : Whole)
                (hw : Eq Bool (wcrossB b0 d0 wnil (wcons y ys)) true)
                (hr : Eq Whole (cmul remP (succ d0)) (cmul remQ (succ b0))) is
               boolDisjoint
                 (Eq Bool (wcrossB b0 d0 (wsnoc wnil remP) (wsnoc (wcons y ys) remQ)) true) hw end
         end
       end)
      (fn (x : Whole) (xs : WList)
          (ih : (seenQ : WList) -> (remP : Whole) -> (remQ : Whole)
                  -> Eq Bool (wcrossB b0 d0 xs seenQ) true
                  -> Eq Whole (cmul remP (succ d0)) (cmul remQ (succ b0))
                  -> Eq Bool (wcrossB b0 d0 (wsnoc xs remP) (wsnoc seenQ remQ)) true) is
         fn (seenQ : WList) is
           case seenQ of
           | wnil ->
               fn (remP : Whole) (remQ : Whole)
                  (hw : Eq Bool (wcrossB b0 d0 (wcons x xs) wnil) true)
                  (hr : Eq Whole (cmul remP (succ d0)) (cmul remQ (succ b0))) is
                 boolDisjoint
                   (Eq Bool (wcrossB b0 d0 (wsnoc (wcons x xs) remP) (wsnoc wnil remQ)) true) hw end
           | wcons y ys ->
               fn (remP : Whole) (remQ : Whole)
                  (hw : Eq Bool (wcrossB b0 d0 (wcons x xs) (wcons y ys)) true)
                  (hr : Eq Whole (cmul remP (succ d0)) (cmul remQ (succ b0))) is
                 andBoth (eqW (cmul x (succ d0)) (cmul y (succ b0)))
                   (wcrossB b0 d0 (wsnoc xs remP) (wsnoc ys remQ))
                   (andTrueL (eqW (cmul x (succ d0)) (cmul y (succ b0))) (wcrossB b0 d0 xs ys) hw)
                   (ih ys remP remQ
                      (andTrueR (eqW (cmul x (succ d0)) (cmul y (succ b0))) (wcrossB b0 d0 xs ys) hw)
                      hr) end
           end
         end
       end)
      seenP
  end
end

-- ============================================================================
-- RUNG 3 — the lockstep:  equal fuel + cross-equal state ⟹ equal FBody.
-- ============================================================================

-- Ex falso for a successor equal to zero (succ-headed terms never equal zero).

succNotZero : (C : U) -> (n : Whole) -> Eq Whole (succ n) zero -> C is
  fn (C : U) (n : Whole) (h : Eq Whole (succ n) zero) is
    subst Whole (succ n) zero h
      (fn (z : Whole) is case z of | zero -> C | succ k -> Eq Whole zero zero end end)
      (refl zero)
  end
end

-- THE LOCKSTEP.  With the SAME fuel, two long divisions whose current remainders are
-- cross-equal (remP·sd = remQ·sb) and whose seen-lists correspond (wcrossB) emit the
-- SAME FBody.  Induction on fuel; the per-step case structure mirrors expand:
--   * fuel 0           — both hit the floor fbody wnil 0 true (refl);
--   * rem 0 / rem 0    — both terminate (refl); the mixed 0/succ corners are impossible
--                        by succNotZero on the cross-equality;
--   * succ / succ      — wmemberCross aligns the cycle test, windexCross the repetend
--                        index (true branch), and on the false branch the digit agrees
--                        (floorUniqueGeneral), the next remainder stays cross-equal
--                        (natModCrossStep ∘ mul10Cross), the seen-lists stay corresponding
--                        (wcrossSnoc), so the IH equates the recursive tails.

expandCross : (b0 : Whole) -> (d0 : Whole) -> (fuel : Whole)
    -> (remP : Whole) -> (remQ : Whole) -> (seenP : WList) -> (seenQ : WList)
    -> Eq Whole (cmul remP (succ d0)) (cmul remQ (succ b0))
    -> Eq Bool (wcrossB b0 d0 seenP seenQ) true
    -> Eq FBody (expand (succ b0) fuel remP seenP) (expand (succ d0) fuel remQ seenQ) is
  fn (b0 : Whole) (d0 : Whole) is
    WholeElim
      (fn (f : Whole) is
         (remP : Whole) -> (remQ : Whole) -> (seenP : WList) -> (seenQ : WList)
           -> Eq Whole (cmul remP (succ d0)) (cmul remQ (succ b0))
           -> Eq Bool (wcrossB b0 d0 seenP seenQ) true
           -> Eq FBody (expand (succ b0) f remP seenP) (expand (succ d0) f remQ seenQ) end)
      (fn (remP : Whole) (remQ : Whole) (seenP : WList) (seenQ : WList)
          (hcross : Eq Whole (cmul remP (succ d0)) (cmul remQ (succ b0)))
          (hwcross : Eq Bool (wcrossB b0 d0 seenP seenQ) true) is
         refl (fbody wnil zero true) end)
      (fn (fl : Whole)
          (ih : (remP : Whole) -> (remQ : Whole) -> (seenP : WList) -> (seenQ : WList)
                  -> Eq Whole (cmul remP (succ d0)) (cmul remQ (succ b0))
                  -> Eq Bool (wcrossB b0 d0 seenP seenQ) true
                  -> Eq FBody (expand (succ b0) fl remP seenP) (expand (succ d0) fl remQ seenQ)) is
         fn (remP : Whole) (remQ : Whole) (seenP : WList) (seenQ : WList) is
           case remP of
           | zero ->
               case remQ of
               | zero ->
                   fn (hcross : Eq Whole (cmul zero (succ d0)) (cmul zero (succ b0)))
                      (hwcross : Eq Bool (wcrossB b0 d0 seenP seenQ) true) is
                     refl (fbody wnil zero true) end
               | succ rq ->
                   fn (hcross : Eq Whole (cmul zero (succ d0)) (cmul (succ rq) (succ b0)))
                      (hwcross : Eq Bool (wcrossB b0 d0 seenP seenQ) true) is
                     succNotZero
                       (Eq FBody (expand (succ b0) (succ fl) zero seenP)
                                 (expand (succ d0) (succ fl) (succ rq) seenQ))
                       (addW b0 (cmul rq (succ b0))) (sym hcross) end
               end
           | succ rp ->
               case remQ of
               | zero ->
                   fn (hcross : Eq Whole (cmul (succ rp) (succ d0)) (cmul zero (succ b0)))
                      (hwcross : Eq Bool (wcrossB b0 d0 seenP seenQ) true) is
                     succNotZero
                       (Eq FBody (expand (succ b0) (succ fl) (succ rp) seenP)
                                 (expand (succ d0) (succ fl) zero seenQ))
                       (addW d0 (cmul rp (succ d0))) hcross end
               | succ rq ->
                   fn (hcross : Eq Whole (cmul (succ rp) (succ d0)) (cmul (succ rq) (succ b0)))
                      (hwcross : Eq Bool (wcrossB b0 d0 seenP seenQ) true) is
                     let hmem : Eq Bool (wmember (succ rp) seenP) (wmember (succ rq) seenQ) =
                       wmemberCross b0 d0 seenP seenQ hwcross (succ rp) (succ rq) hcross in
                     let hidx : Eq Whole (windex (succ rp) seenP) (windex (succ rq) seenQ) =
                       windexCross b0 d0 seenP seenQ hwcross (succ rp) (succ rq) hcross in
                     let htrue : Eq FBody (fbody wnil (windex (succ rp) seenP) false)
                                          (fbody wnil (windex (succ rq) seenQ) false) =
                       cong (fn (i : Whole) is fbody wnil i false end) hidx in
                     let hr10 : Eq Whole (cmul (cmul (succ rp) 10) (succ d0))
                                       (cmul (cmul (succ rq) 10) (succ b0)) =
                       mul10Cross b0 d0 (succ rp) (succ rq) hcross in
                     let hdigit : Eq Whole (qdiv (cmul (succ rp) 10) (succ b0))
                                         (qdiv (cmul (succ rq) 10) (succ d0)) =
                       floorUniqueGeneral b0 d0 (cmul (succ rp) 10) (cmul (succ rq) 10) hr10 in
                     let hnext : Eq Whole (cmul (qmod (cmul (succ rp) 10) (succ b0)) (succ d0))
                                        (cmul (qmod (cmul (succ rq) 10) (succ d0)) (succ b0)) =
                       natModCrossStep b0 d0 (cmul (succ rp) 10) (cmul (succ rq) 10) hr10 in
                     let hsnoc : Eq Bool
                         (wcrossB b0 d0 (wsnoc seenP (succ rp)) (wsnoc seenQ (succ rq))) true =
                       wcrossSnoc b0 d0 seenP seenQ (succ rp) (succ rq) hwcross hcross in
                     let ihRest : Eq FBody
                         (expand (succ b0) fl (qmod (cmul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp)))
                         (expand (succ d0) fl (qmod (cmul (succ rq) 10) (succ d0)) (wsnoc seenQ (succ rq))) =
                       ih (qmod (cmul (succ rp) 10) (succ b0)) (qmod (cmul (succ rq) 10) (succ d0))
                          (wsnoc seenP (succ rp)) (wsnoc seenQ (succ rq)) hnext hsnoc in
                     let arg1Eq : Eq WList
                         (wcons (qdiv (cmul (succ rp) 10) (succ b0))
                                (fbDigits (expand (succ b0) fl (qmod (cmul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp)))))
                         (wcons (qdiv (cmul (succ rq) 10) (succ d0))
                                (fbDigits (expand (succ d0) fl (qmod (cmul (succ rq) 10) (succ d0)) (wsnoc seenQ (succ rq))))) =
                       cong2 (fn (d : Whole) (ds : WList) is wcons d ds end)
                         hdigit (cong (fn (b : FBody) is fbDigits b end) ihRest) in
                     let hfalse : Eq FBody
                         (fbody (wcons (qdiv (cmul (succ rp) 10) (succ b0))
                                       (fbDigits (expand (succ b0) fl (qmod (cmul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp)))))
                                (fbRep (expand (succ b0) fl (qmod (cmul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp))))
                                (fbTerm (expand (succ b0) fl (qmod (cmul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp)))))
                         (fbody (wcons (qdiv (cmul (succ rq) 10) (succ d0))
                                       (fbDigits (expand (succ d0) fl (qmod (cmul (succ rq) 10) (succ d0)) (wsnoc seenQ (succ rq)))))
                                (fbRep (expand (succ d0) fl (qmod (cmul (succ rq) 10) (succ d0)) (wsnoc seenQ (succ rq))))
                                (fbTerm (expand (succ d0) fl (qmod (cmul (succ rq) 10) (succ d0)) (wsnoc seenQ (succ rq))))) =
                       trans
                         (cong (fn (a : WList) is
                                  fbody a
                                    (fbRep (expand (succ b0) fl (qmod (cmul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp))))
                                    (fbTerm (expand (succ b0) fl (qmod (cmul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp)))) end)
                               arg1Eq)
                         (cong2 (fn (r : Whole) (t : Bool) is
                                   fbody (wcons (qdiv (cmul (succ rq) 10) (succ d0))
                                                (fbDigits (expand (succ d0) fl (qmod (cmul (succ rq) 10) (succ d0)) (wsnoc seenQ (succ rq)))))
                                         r t end)
                            (cong (fn (b : FBody) is fbRep b end) ihRest)
                            (cong (fn (b : FBody) is fbTerm b end) ihRest)) in
                     trans
                       (cong (fn (sc : Bool) is
                                BoolElim (fn (w : Bool) is FBody end)
                                  (fbody wnil (windex (succ rp) seenP) false)
                                  (fbody (wcons (qdiv (cmul (succ rp) 10) (succ b0))
                                                (fbDigits (expand (succ b0) fl (qmod (cmul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp)))))
                                         (fbRep (expand (succ b0) fl (qmod (cmul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp))))
                                         (fbTerm (expand (succ b0) fl (qmod (cmul (succ rp) 10) (succ b0)) (wsnoc seenP (succ rp)))))
                                  sc end)
                             hmem)
                       (cong2 (fn (tb : FBody) (fb : FBody) is
                                 BoolElim (fn (w : Bool) is FBody end) tb fb
                                   (wmember (succ rq) seenQ) end)
                          htrue hfalse) end
               end
           end
         end
       end)
  end
end

-- ============================================================================
-- RUNG 3 — fuel sufficiency (pigeonhole).  List infrastructure first.
-- ============================================================================

-- Boolean negation and its reflection.

notB : Bool -> Bool is fn (b : Bool) is BoolElim (fn (x : Bool) is Bool end) false true b end end

notTrueIsFalse : (b : Bool) -> Eq Bool (notB b) true -> Eq Bool b false is
  fn (b : Bool) is
    BoolElim (fn (x : Bool) is (Eq Bool (notB x) true -> Eq Bool x false) end)
      (fn (h : Eq Bool (notB true) true) is boolDisjoint (Eq Bool true false) h end)
      (fn (h : Eq Bool (notB false) true) is refl false end)
      b
  end
end

falseIsNotTrue : (b : Bool) -> Eq Bool b false -> Eq Bool (notB b) true is
  fn (b : Bool) (h : Eq Bool b false) is
    subst Bool false b (sym h) (fn (z : Bool) is Eq Bool (notB z) true end) (refl true)
  end
end

-- Length, all-below-N, no-duplicates, and first-occurrence deletion on WList.

wlen : WList -> Whole is
  fn (xs : WList) is
    WListElim (fn (w : WList) is Whole end) zero
      (fn (h : Whole) (t : WList) (ih : Whole) is succ ih end) xs
  end
end

allLt : Whole -> WList -> Bool is
  fn (n : Whole) (xs : WList) is
    WListElim (fn (w : WList) is Bool end) true
      (fn (h : Whole) (t : WList) (ih : Bool) is and (ltb h n) ih end) xs
  end
end

noDupW : WList -> Bool is
  fn (xs : WList) is
    WListElim (fn (w : WList) is Bool end) true
      (fn (h : Whole) (t : WList) (ih : Bool) is and (notB (wmember h t)) ih end) xs
  end
end

wdelete : Whole -> WList -> WList is
  fn (x : Whole) (xs : WList) is
    WListElim (fn (w : WList) is WList end) wnil
      (fn (h : Whole) (t : WList) (ih : WList) is
         case eqW x h of | true -> t | false -> wcons h ih end
       end)
      xs
  end
end

-- eqW is symmetric (as a Bool equation): decode/recode each direction.

eqWSym : (a : Whole) -> (b : Whole) -> Eq Bool (eqW a b) (eqW b a) is
  fn (a : Whole) (b : Whole) is
    boolTrueIff (eqW a b) (eqW b a)
      (fn (e : Eq Bool (eqW a b) true) is eqWComplete b a (sym (eqWSound a b e)) end)
      (fn (e : Eq Bool (eqW b a) true) is eqWComplete a b (sym (eqWSound b a e)) end)
  end
end

-- leb n (succ n) and monotone weakening of the bound.

lteSuccSelf : (n : Whole) -> Eq Bool (leb n (succ n)) true is
  fn (n : Whole) is
    WholeElim (fn (x : Whole) is Eq Bool (leb x (succ x)) true end)
      (refl true)
      (fn (k : Whole) (ih : Eq Bool (leb k (succ k)) true) is ih end)
      n
  end
end

lteSuccR : (a : Whole) -> (b : Whole) -> Eq Bool (leb a b) true -> Eq Bool (leb a (succ b)) true is
  fn (a : Whole) (b : Whole) (h : Eq Bool (leb a b) true) is
    lteTrans a b (succ b) h (lteSuccSelf b)
  end
end

-- x < succ d and x ≠ d ⟹ x < d.  Double induction; mismatched corners are absurd.

ltSuccNe : (h : Whole) -> (d : Whole) -> Eq Bool (ltb h (succ d)) true -> Eq Bool (eqW h d) false
    -> Eq Bool (ltb h d) true is
  fn (h : Whole) is
    WholeElim (fn (x : Whole) is
        (d : Whole) -> Eq Bool (ltb x (succ d)) true -> Eq Bool (eqW x d) false
          -> Eq Bool (ltb x d) true end)
      (fn (d : Whole) is
         case d of
         | zero -> fn (hlt : Eq Bool (ltb zero (succ zero)) true) (hne : Eq Bool (eqW zero zero) false) is
             boolDisjoint (Eq Bool (ltb zero zero) true) (trans (sym hne) (eqWRefl zero)) end
         | succ d' -> fn (hlt : Eq Bool (ltb zero (succ (succ d'))) true) (hne : Eq Bool (eqW zero (succ d')) false) is
             refl true end
         end
       end)
      (fn (k : Whole) (ih : (d : Whole) -> Eq Bool (ltb k (succ d)) true -> Eq Bool (eqW k d) false
                            -> Eq Bool (ltb k d) true) is
         fn (d : Whole) is
           case d of
           | zero -> fn (hlt : Eq Bool (ltb (succ k) (succ zero)) true) (hne : Eq Bool (eqW (succ k) zero) false) is
               boolDisjoint (Eq Bool (ltb (succ k) zero) true) (trans (sym (ltbZero k)) hlt) end
           | succ d' -> fn (hlt : Eq Bool (ltb (succ k) (succ (succ d'))) true) (hne : Eq Bool (eqW (succ k) (succ d')) false) is
               ih d' hlt hne end
           end
         end
       end)
      h
  end
end

-- or-projections (wmember (wcons h t) ≡ or (eqW _ h) (wmember _ t)).

orFalseL : (a : Bool) -> (b : Bool) -> Eq Bool (or a b) false -> Eq Bool a false is
  fn (a : Bool) (b : Bool) (h : Eq Bool (or a b) false) is
    BoolElim (fn (x : Bool) is (Eq Bool (or x b) false -> Eq Bool x false) end)
      (fn (h1 : Eq Bool (or true b) false) is h1 end)
      (fn (h0 : Eq Bool (or false b) false) is refl false end)
      a h
  end
end

orFalseR : (a : Bool) -> (b : Bool) -> Eq Bool (or a b) false -> Eq Bool b false is
  fn (a : Bool) (b : Bool) (h : Eq Bool (or a b) false) is
    BoolElim (fn (x : Bool) is (Eq Bool (or x b) false -> Eq Bool b false) end)
      (fn (h1 : Eq Bool (or true b) false) is boolDisjoint (Eq Bool b false) (sym h1) end)
      (fn (h0 : Eq Bool (or false b) false) is h0 end)
      a h
  end
end

orBothFalse : (a : Bool) -> (b : Bool) -> Eq Bool a false -> Eq Bool b false -> Eq Bool (or a b) false is
  fn (a : Bool) (b : Bool) (ha : Eq Bool a false) (hb : Eq Bool b false) is
    trans (cong (fn (z : Bool) is or z b end) ha) hb
  end
end

orTrueR : (a : Bool) -> (b : Bool) -> Eq Bool (or a b) true -> Eq Bool a false -> Eq Bool b true is
  fn (a : Bool) (b : Bool) (h : Eq Bool (or a b) true) (ha : Eq Bool a false) is
    trans (sym (cong (fn (z : Bool) is or z b end) ha)) h
  end
end

-- Deletion never introduces a member:  h ∉ t  ⟹  h ∉ wdelete x t.

notMemberDelete : (hh : Whole) -> (x : Whole) -> (t : WList)
    -> Eq Bool (wmember hh t) false -> Eq Bool (wmember hh (wdelete x t)) false is
  fn (hh : Whole) (x : Whole) (t : WList) is
    WListElim (fn (w : WList) is (Eq Bool (wmember hh w) false -> Eq Bool (wmember hh (wdelete x w)) false) end)
      (fn (h0 : Eq Bool (wmember hh wnil) false) is refl false end)
      (fn (e : Whole) (t' : WList)
          (ih : Eq Bool (wmember hh t') false -> Eq Bool (wmember hh (wdelete x t')) false) is
         fn (hm : Eq Bool (wmember hh (wcons e t')) false) is
           BoolElim
             (fn (z : Bool) is
                Eq Bool (wmember hh (case z of | true -> t' | false -> wcons e (wdelete x t') end)) false end)
             (orFalseR (eqW hh e) (wmember hh t') hm)
             (orBothFalse (eqW hh e) (wmember hh (wdelete x t'))
                (orFalseL (eqW hh e) (wmember hh t') hm)
                (ih (orFalseR (eqW hh e) (wmember hh t') hm)))
             (eqW x e)
         end
       end)
      t
  end
end

-- allLt weakening:  all entries < succ d and d absent  ⟹  all entries < d.

allLtWeaken : (d : Whole) -> (xs : WList)
    -> Eq Bool (allLt (succ d) xs) true -> Eq Bool (wmember d xs) false
    -> Eq Bool (allLt d xs) true is
  fn (d : Whole) (xs : WList) is
    WListElim (fn (w : WList) is
        (Eq Bool (allLt (succ d) w) true -> Eq Bool (wmember d w) false -> Eq Bool (allLt d w) true) end)
      (fn (hal : Eq Bool (allLt (succ d) wnil) true) (hm : Eq Bool (wmember d wnil) false) is refl true end)
      (fn (h : Whole) (t : WList)
          (ih : Eq Bool (allLt (succ d) t) true -> Eq Bool (wmember d t) false -> Eq Bool (allLt d t) true) is
         fn (hal : Eq Bool (allLt (succ d) (wcons h t)) true) (hm : Eq Bool (wmember d (wcons h t)) false) is
           andBoth (ltb h d) (allLt d t)
             (ltSuccNe h d
                (andTrueL (ltb h (succ d)) (allLt (succ d) t) hal)
                (trans (eqWSym h d) (orFalseL (eqW d h) (wmember d t) hm)))
             (ih (andTrueR (ltb h (succ d)) (allLt (succ d) t) hal)
                 (orFalseR (eqW d h) (wmember d t) hm))
         end
       end)
      xs
  end
end

-- Deletion preserves the all-below-N bound (entries only removed).

deleteAllLt : (n : Whole) -> (x : Whole) -> (xs : WList)
    -> Eq Bool (allLt n xs) true -> Eq Bool (allLt n (wdelete x xs)) true is
  fn (n : Whole) (x : Whole) (xs : WList) is
    WListElim (fn (w : WList) is (Eq Bool (allLt n w) true -> Eq Bool (allLt n (wdelete x w)) true) end)
      (fn (h0 : Eq Bool (allLt n wnil) true) is refl true end)
      (fn (h : Whole) (t : WList)
          (ih : Eq Bool (allLt n t) true -> Eq Bool (allLt n (wdelete x t)) true) is
         fn (hal : Eq Bool (allLt n (wcons h t)) true) is
           BoolElim
             (fn (z : Bool) is
                Eq Bool (allLt n (case z of | true -> t | false -> wcons h (wdelete x t) end)) true end)
             (andTrueR (ltb h n) (allLt n t) hal)
             (andBoth (ltb h n) (allLt n (wdelete x t))
                (andTrueL (ltb h n) (allLt n t) hal)
                (ih (andTrueR (ltb h n) (allLt n t) hal)))
             (eqW x h)
         end
       end)
      xs
  end
end

-- Deletion preserves no-duplicates.

deleteNoDup : (x : Whole) -> (xs : WList)
    -> Eq Bool (noDupW xs) true -> Eq Bool (noDupW (wdelete x xs)) true is
  fn (x : Whole) (xs : WList) is
    WListElim (fn (w : WList) is (Eq Bool (noDupW w) true -> Eq Bool (noDupW (wdelete x w)) true) end)
      (fn (h0 : Eq Bool (noDupW wnil) true) is refl true end)
      (fn (h : Whole) (t : WList)
          (ih : Eq Bool (noDupW t) true -> Eq Bool (noDupW (wdelete x t)) true) is
         fn (hnd : Eq Bool (noDupW (wcons h t)) true) is
           BoolElim
             (fn (z : Bool) is
                Eq Bool (noDupW (case z of | true -> t | false -> wcons h (wdelete x t) end)) true end)
             (andTrueR (notB (wmember h t)) (noDupW t) hnd)
             (andBoth (notB (wmember h (wdelete x t))) (noDupW (wdelete x t))
                (falseIsNotTrue (wmember h (wdelete x t))
                   (notMemberDelete h x t
                      (notTrueIsFalse (wmember h t)
                         (andTrueL (notB (wmember h t)) (noDupW t) hnd))))
                (ih (andTrueR (notB (wmember h t)) (noDupW t) hnd)))
             (eqW x h)
         end
       end)
      xs
  end
end

-- Deleting a member drops the length by one.

wlenDeleteMember : (x : Whole) -> (xs : WList)
    -> Eq Bool (wmember x xs) true -> Eq Whole (wlen xs) (succ (wlen (wdelete x xs))) is
  fn (x : Whole) (xs : WList) is
    WListElim (fn (w : WList) is (Eq Bool (wmember x w) true -> Eq Whole (wlen w) (succ (wlen (wdelete x w)))) end)
      (fn (h0 : Eq Bool (wmember x wnil) true) is boolDisjoint (Eq Whole (wlen wnil) (succ (wlen (wdelete x wnil)))) h0 end)
      (fn (h : Whole) (t : WList)
          (ih : Eq Bool (wmember x t) true -> Eq Whole (wlen t) (succ (wlen (wdelete x t)))) is
         fn (hm : Eq Bool (wmember x (wcons h t)) true) is
           BoolElim
             (fn (z : Bool) is
                (Eq Bool (eqW x h) z
                   -> Eq Whole (wlen (wcons h t)) (succ (wlen (wdelete x (wcons h t))))) end)
             (fn (ev : Eq Bool (eqW x h) true) is
                subst Bool true (eqW x h) (sym ev)
                  (fn (z : Bool) is
                     Eq Whole (wlen (wcons h t))
                       (succ (wlen (case z of | true -> t | false -> wcons h (wdelete x t) end))) end)
                  (refl (succ (wlen t))) end)
             (fn (ev : Eq Bool (eqW x h) false) is
                subst Bool false (eqW x h) (sym ev)
                  (fn (z : Bool) is
                     Eq Whole (wlen (wcons h t))
                       (succ (wlen (case z of | true -> t | false -> wcons h (wdelete x t) end))) end)
                  (cong (fn (n : Whole) is succ n end)
                     (ih (orTrueR (eqW x h) (wmember x t) hm ev))) end)
             (eqW x h)
             (refl (eqW x h))
         end
       end)
      xs
  end
end

-- Deleting the target leaves it absent (given no duplicates).

deleteRemovesMember : (x : Whole) -> (xs : WList)
    -> Eq Bool (noDupW xs) true -> Eq Bool (wmember x (wdelete x xs)) false is
  fn (x : Whole) (xs : WList) is
    WListElim (fn (w : WList) is (Eq Bool (noDupW w) true -> Eq Bool (wmember x (wdelete x w)) false) end)
      (fn (h0 : Eq Bool (noDupW wnil) true) is refl false end)
      (fn (h : Whole) (t : WList)
          (ih : Eq Bool (noDupW t) true -> Eq Bool (wmember x (wdelete x t)) false) is
         fn (hnd : Eq Bool (noDupW (wcons h t)) true) is
           BoolElim
             (fn (z : Bool) is
                (Eq Bool (eqW x h) z -> Eq Bool (wmember x (wdelete x (wcons h t))) false) end)
             (fn (ev : Eq Bool (eqW x h) true) is
                subst Bool true (eqW x h) (sym ev)
                  (fn (z : Bool) is
                     Eq Bool (wmember x (case z of | true -> t | false -> wcons h (wdelete x t) end)) false end)
                  (subst Whole h x (sym (eqWSound x h ev))
                     (fn (w : Whole) is Eq Bool (wmember w t) false end)
                     (notTrueIsFalse (wmember h t)
                        (andTrueL (notB (wmember h t)) (noDupW t) hnd))) end)
             (fn (ev : Eq Bool (eqW x h) false) is
                subst Bool false (eqW x h) (sym ev)
                  (fn (z : Bool) is
                     Eq Bool (wmember x (case z of | true -> t | false -> wcons h (wdelete x t) end)) false end)
                  (orBothFalse (eqW x h) (wmember x (wdelete x t)) ev
                     (ih (andTrueR (notB (wmember h t)) (noDupW t) hnd))) end)
             (eqW x h)
             (refl (eqW x h))
         end
       end)
      xs
  end
end

-- THE PIGEONHOLE.  A duplicate-free WList whose entries are all < den has length
-- ≤ den.  Induction on den: at den = 0 nothing is < 0 so the list is empty; at
-- succ d, either d is absent (weaken the bound and recurse) or present (delete it —
-- length drops by one, no-dup/bound/absence are preserved — recurse at d).

lenBound : (den : Whole) -> (xs : WList)
    -> Eq Bool (noDupW xs) true -> Eq Bool (allLt den xs) true
    -> Eq Bool (leb (wlen xs) den) true is
  fn (den : Whole) is
    WholeElim
      (fn (n : Whole) is
         (xs : WList) -> Eq Bool (noDupW xs) true -> Eq Bool (allLt n xs) true
           -> Eq Bool (leb (wlen xs) n) true end)
      (fn (xs : WList) is
         case xs of
         | wnil -> fn (hnd : Eq Bool (noDupW wnil) true) (hal : Eq Bool (allLt zero wnil) true) is
             refl true end
         | wcons h t -> fn (hnd : Eq Bool (noDupW (wcons h t)) true) (hal : Eq Bool (allLt zero (wcons h t)) true) is
             boolDisjoint (Eq Bool (leb (wlen (wcons h t)) zero) true)
               (trans (sym (ltbZero h)) (andTrueL (ltb h zero) (allLt zero t) hal)) end
         end
       end)
      (fn (d : Whole)
          (ih : (xs : WList) -> Eq Bool (noDupW xs) true -> Eq Bool (allLt d xs) true
                  -> Eq Bool (leb (wlen xs) d) true) is
         fn (xs : WList) (hnd : Eq Bool (noDupW xs) true) (hal : Eq Bool (allLt (succ d) xs) true) is
           BoolElim
             (fn (z : Bool) is
                (Eq Bool (wmember d xs) z -> Eq Bool (leb (wlen xs) (succ d)) true) end)
             (fn (ev : Eq Bool (wmember d xs) true) is
                subst Whole (succ (wlen (wdelete d xs))) (wlen xs)
                  (sym (wlenDeleteMember d xs ev))
                  (fn (m : Whole) is Eq Bool (leb m (succ d)) true end)
                  (ih (wdelete d xs)
                     (deleteNoDup d xs hnd)
                     (allLtWeaken d (wdelete d xs)
                        (deleteAllLt (succ d) d xs hal)
                        (deleteRemovesMember d xs hnd))) end)
             (fn (ev : Eq Bool (wmember d xs) false) is
                lteSuccR (wlen xs) d
                  (ih xs hnd (allLtWeaken d xs hal ev)) end)
             (wmember d xs)
             (refl (wmember d xs))
         end
       end)
      den
  end
end

-- or laws + snoc algebra for threading the no-dup invariant through expand's wsnoc.

orFalseRight : (b : Bool) -> Eq Bool (or b false) b is
  fn (b : Bool) is
    BoolElim (fn (x : Bool) is Eq Bool (or x false) x end) (refl true) (refl false) b
  end
end

orAssoc : (a : Bool) -> (b : Bool) -> (c : Bool) -> Eq Bool (or a (or b c)) (or (or a b) c) is
  fn (a : Bool) (b : Bool) (c : Bool) is
    BoolElim (fn (x : Bool) is Eq Bool (or x (or b c)) (or (or x b) c) end)
      (refl true) (refl (or b c)) a
  end
end

memberSnoc : (a : Whole) -> (y : Whole) -> (t : WList)
    -> Eq Bool (wmember a (wsnoc t y)) (or (wmember a t) (eqW a y)) is
  fn (a : Whole) (y : Whole) (t : WList) is
    WListElim (fn (w : WList) is Eq Bool (wmember a (wsnoc w y)) (or (wmember a w) (eqW a y)) end)
      (orFalseRight (eqW a y))
      (fn (h : Whole) (t' : WList) (ih : Eq Bool (wmember a (wsnoc t' y)) (or (wmember a t') (eqW a y))) is
         trans (cong (fn (z : Bool) is or (eqW a h) z end) ih)
               (orAssoc (eqW a h) (wmember a t') (eqW a y)) end)
      t
  end
end

wlenSnoc : (y : Whole) -> (xs : WList) -> Eq Whole (wlen (wsnoc xs y)) (succ (wlen xs)) is
  fn (y : Whole) (xs : WList) is
    WListElim (fn (w : WList) is Eq Whole (wlen (wsnoc w y)) (succ (wlen w)) end)
      (refl (succ zero))
      (fn (h : Whole) (t : WList) (ih : Eq Whole (wlen (wsnoc t y)) (succ (wlen t))) is
         cong (fn (n : Whole) is succ n end) ih end)
      xs
  end
end

allLtSnoc : (n : Whole) -> (y : Whole) -> (xs : WList)
    -> Eq Bool (allLt n xs) true -> Eq Bool (ltb y n) true -> Eq Bool (allLt n (wsnoc xs y)) true is
  fn (n : Whole) (y : Whole) (xs : WList) is
    WListElim (fn (w : WList) is
        (Eq Bool (allLt n w) true -> Eq Bool (ltb y n) true -> Eq Bool (allLt n (wsnoc w y)) true) end)
      (fn (hal : Eq Bool (allLt n wnil) true) (hy : Eq Bool (ltb y n) true) is
         andBoth (ltb y n) true hy (refl true) end)
      (fn (h : Whole) (t : WList)
          (ih : Eq Bool (allLt n t) true -> Eq Bool (ltb y n) true -> Eq Bool (allLt n (wsnoc t y)) true) is
         fn (hal : Eq Bool (allLt n (wcons h t)) true) (hy : Eq Bool (ltb y n) true) is
           andBoth (ltb h n) (allLt n (wsnoc t y))
             (andTrueL (ltb h n) (allLt n t) hal)
             (ih (andTrueR (ltb h n) (allLt n t) hal) hy) end
         end)
      xs
  end
end

noDupSnoc : (y : Whole) -> (xs : WList)
    -> Eq Bool (noDupW xs) true -> Eq Bool (wmember y xs) false -> Eq Bool (noDupW (wsnoc xs y)) true is
  fn (y : Whole) (xs : WList) is
    WListElim (fn (w : WList) is
        (Eq Bool (noDupW w) true -> Eq Bool (wmember y w) false -> Eq Bool (noDupW (wsnoc w y)) true) end)
      (fn (hnd : Eq Bool (noDupW wnil) true) (hm : Eq Bool (wmember y wnil) false) is
         andBoth (notB (wmember y wnil)) (noDupW wnil)
           (falseIsNotTrue (wmember y wnil) (refl false)) (refl true) end)
      (fn (h : Whole) (t : WList)
          (ih : Eq Bool (noDupW t) true -> Eq Bool (wmember y t) false -> Eq Bool (noDupW (wsnoc t y)) true) is
         fn (hnd : Eq Bool (noDupW (wcons h t)) true) (hm : Eq Bool (wmember y (wcons h t)) false) is
           andBoth (notB (wmember h (wsnoc t y))) (noDupW (wsnoc t y))
             (falseIsNotTrue (wmember h (wsnoc t y))
                (trans (memberSnoc h y t)
                   (orBothFalse (wmember h t) (eqW h y)
                      (notTrueIsFalse (wmember h t)
                         (andTrueL (notB (wmember h t)) (noDupW t) hnd))
                      (trans (eqWSym h y) (orFalseL (eqW y h) (wmember y t) hm)))))
             (ih (andTrueR (notB (wmember h t)) (noDupW t) hnd)
                 (orFalseR (eqW y h) (wmember y t) hm)) end
         end)
      xs
  end
end

lteSuccSelfFalse : (n : Whole) -> Eq Bool (leb (succ n) n) false is
  fn (n : Whole) is
    WholeElim (fn (x : Whole) is Eq Bool (leb (succ x) x) false end)
      (refl false)
      (fn (k : Whole) (ih : Eq Bool (leb (succ k) k) false) is ih end)
      n
  end
end

-- FUEL SUFFICIENCY.  Two same-denominator long divisions with DIFFERENT fuels agree,
-- provided both fuels cover the remaining capacity (cap = den − |seen|).  Induction on
-- cap, threading the seen-list invariants (no-dup, all < den, exact capacity, rem in
-- range).  At cap 0 the seen-list is full: any unseen nonzero rem would make
-- (wcons rem seen) a distinct list of length den+1 bounded by den — impossible by
-- lenBound — so wmember fires and both terminate identically; otherwise the floor is
-- never reached.  At cap > 0 the cycle test aligns the two (same scrutinee), the digit
-- is identical, and the IH (one less capacity, one less fuel each) closes the tails.

expandFuelStable : (b0 : Whole) -> (cap : Whole) -> (rem : Whole) -> (seen : WList) -> (F : Whole) -> (G : Whole)
    -> Eq Bool (noDupW seen) true
    -> Eq Bool (allLt (succ b0) seen) true
    -> Eq Whole (addW (wlen seen) cap) (succ b0)
    -> Eq Bool (ltb rem (succ b0)) true
    -> Eq Bool (leb (succ cap) F) true
    -> Eq Bool (leb (succ cap) G) true
    -> Eq FBody (expand (succ b0) F rem seen) (expand (succ b0) G rem seen) is
  fn (b0 : Whole) (cap : Whole) is
    WholeElim
      (fn (c : Whole) is
         (rem : Whole) -> (seen : WList) -> (F : Whole) -> (G : Whole)
           -> Eq Bool (noDupW seen) true
           -> Eq Bool (allLt (succ b0) seen) true
           -> Eq Whole (addW (wlen seen) c) (succ b0)
           -> Eq Bool (ltb rem (succ b0)) true
           -> Eq Bool (leb (succ c) F) true
           -> Eq Bool (leb (succ c) G) true
           -> Eq FBody (expand (succ b0) F rem seen) (expand (succ b0) G rem seen) end)
      (fn (rem : Whole) (seen : WList) (F : Whole) (G : Whole)
          (hnd : Eq Bool (noDupW seen) true) (hal : Eq Bool (allLt (succ b0) seen) true)
          (hcap : Eq Whole (addW (wlen seen) zero) (succ b0)) (hrem : Eq Bool (ltb rem (succ b0)) true) is
         case F of
         | zero -> fn (hF : Eq Bool (leb (succ zero) zero) true) (hG : Eq Bool (leb (succ zero) G) true) is
             boolDisjoint (Eq FBody (expand (succ b0) zero rem seen) (expand (succ b0) G rem seen)) hF end
         | succ F' ->
             case G of
             | zero -> fn (hF : Eq Bool (leb (succ zero) (succ F')) true) (hG : Eq Bool (leb (succ zero) zero) true) is
                 boolDisjoint (Eq FBody (expand (succ b0) (succ F') rem seen) (expand (succ b0) zero rem seen)) hG end
             | succ G' -> fn (hF : Eq Bool (leb (succ zero) (succ F')) true) (hG : Eq Bool (leb (succ zero) (succ G')) true) is
                 WholeElim (fn (rv : Whole) is (Eq Bool (ltb rv (succ b0)) true
                            -> Eq FBody (expand (succ b0) (succ F') rv seen) (expand (succ b0) (succ G') rv seen)) end)
                   (fn (hrem0 : Eq Bool (ltb zero (succ b0)) true) is refl (fbody wnil zero true) end)
                   (fn (rp : Whole) (ihr : Eq Bool (ltb rp (succ b0)) true
                          -> Eq FBody (expand (succ b0) (succ F') rp seen) (expand (succ b0) (succ G') rp seen))
                       (hrem1 : Eq Bool (ltb (succ rp) (succ b0)) true) is
                     let hlen : Eq Whole (wlen seen) (succ b0) = trans (sym (addZeroR (wlen seen))) hcap in
                     let dec : Whole = qdiv (cmul (succ rp) 10) (succ b0) in
                     let nxt : Whole = qmod (cmul (succ rp) 10) (succ b0) in
                     let snc : WList = wsnoc seen (succ rp) in
                     let hfull : Eq Bool (wmember (succ rp) seen) true =
                       BoolElim (fn (z : Bool) is (Eq Bool (wmember (succ rp) seen) z -> Eq Bool (wmember (succ rp) seen) true) end)
                         (fn (ev : Eq Bool (wmember (succ rp) seen) true) is ev end)
                         (fn (ev : Eq Bool (wmember (succ rp) seen) false) is
                            boolDisjoint (Eq Bool (wmember (succ rp) seen) true)
                              (trans (sym (lteSuccSelfFalse (succ b0)))
                                 (subst Whole (wlen seen) (succ b0) hlen
                                    (fn (m : Whole) is Eq Bool (leb (succ m) (succ b0)) true end)
                                    (lenBound (succ b0) (wcons (succ rp) seen)
                                       (andBoth (notB (wmember (succ rp) seen)) (noDupW seen)
                                          (falseIsNotTrue (wmember (succ rp) seen) ev) hnd)
                                       (andBoth (ltb (succ rp) (succ b0)) (allLt (succ b0) seen) hrem1 hal)))) end)
                         (wmember (succ rp) seen) (refl (wmember (succ rp) seen)) in
                     trans
                       (cong (fn (sc : Bool) is BoolElim (fn (w : Bool) is FBody end)
                                (fbody wnil (windex (succ rp) seen) false)
                                (fbody (wcons dec (fbDigits (expand (succ b0) F' nxt snc)))
                                       (fbRep (expand (succ b0) F' nxt snc)) (fbTerm (expand (succ b0) F' nxt snc)))
                                sc end) hfull)
                       (sym (cong (fn (sc : Bool) is BoolElim (fn (w : Bool) is FBody end)
                                (fbody wnil (windex (succ rp) seen) false)
                                (fbody (wcons dec (fbDigits (expand (succ b0) G' nxt snc)))
                                       (fbRep (expand (succ b0) G' nxt snc)) (fbTerm (expand (succ b0) G' nxt snc)))
                                sc end) hfull)) end)
                   rem hrem end
             end
         end
       end)
      (fn (cap0 : Whole)
          (ih : (rem : Whole) -> (seen : WList) -> (F : Whole) -> (G : Whole)
                  -> Eq Bool (noDupW seen) true -> Eq Bool (allLt (succ b0) seen) true
                  -> Eq Whole (addW (wlen seen) cap0) (succ b0) -> Eq Bool (ltb rem (succ b0)) true
                  -> Eq Bool (leb (succ cap0) F) true -> Eq Bool (leb (succ cap0) G) true
                  -> Eq FBody (expand (succ b0) F rem seen) (expand (succ b0) G rem seen)) is
         fn (rem : Whole) (seen : WList) (F : Whole) (G : Whole)
            (hnd : Eq Bool (noDupW seen) true) (hal : Eq Bool (allLt (succ b0) seen) true)
            (hcap : Eq Whole (addW (wlen seen) (succ cap0)) (succ b0)) (hrem : Eq Bool (ltb rem (succ b0)) true) is
           case F of
           | zero -> fn (hF : Eq Bool (leb (succ (succ cap0)) zero) true) (hG : Eq Bool (leb (succ (succ cap0)) G) true) is
               boolDisjoint (Eq FBody (expand (succ b0) zero rem seen) (expand (succ b0) G rem seen)) hF end
           | succ F' ->
               case G of
               | zero -> fn (hF : Eq Bool (leb (succ (succ cap0)) (succ F')) true) (hG : Eq Bool (leb (succ (succ cap0)) zero) true) is
                   boolDisjoint (Eq FBody (expand (succ b0) (succ F') rem seen) (expand (succ b0) zero rem seen)) hG end
               | succ G' -> fn (hF : Eq Bool (leb (succ (succ cap0)) (succ F')) true) (hG : Eq Bool (leb (succ (succ cap0)) (succ G')) true) is
                   WholeElim (fn (rv : Whole) is (Eq Bool (ltb rv (succ b0)) true
                              -> Eq FBody (expand (succ b0) (succ F') rv seen) (expand (succ b0) (succ G') rv seen)) end)
                     (fn (hrem0 : Eq Bool (ltb zero (succ b0)) true) is refl (fbody wnil zero true) end)
                     (fn (rp : Whole) (ihr : Eq Bool (ltb rp (succ b0)) true
                            -> Eq FBody (expand (succ b0) (succ F') rp seen) (expand (succ b0) (succ G') rp seen))
                         (hrem1 : Eq Bool (ltb (succ rp) (succ b0)) true) is
                       let dec : Whole = qdiv (cmul (succ rp) 10) (succ b0) in
                       let nxt : Whole = qmod (cmul (succ rp) 10) (succ b0) in
                       let snc : WList = wsnoc seen (succ rp) in
                       BoolElim (fn (z : Bool) is (Eq Bool (wmember (succ rp) seen) z -> Eq FBody (expand (succ b0) (succ F') (succ rp) seen) (expand (succ b0) (succ G') (succ rp) seen)) end)
                         (fn (ev : Eq Bool (wmember (succ rp) seen) true) is
                            trans
                              (cong (fn (sc : Bool) is BoolElim (fn (w : Bool) is FBody end)
                                       (fbody wnil (windex (succ rp) seen) false)
                                       (fbody (wcons dec (fbDigits (expand (succ b0) F' nxt snc)))
                                              (fbRep (expand (succ b0) F' nxt snc)) (fbTerm (expand (succ b0) F' nxt snc)))
                                       sc end) ev)
                              (sym (cong (fn (sc : Bool) is BoolElim (fn (w : Bool) is FBody end)
                                       (fbody wnil (windex (succ rp) seen) false)
                                       (fbody (wcons dec (fbDigits (expand (succ b0) G' nxt snc)))
                                              (fbRep (expand (succ b0) G' nxt snc)) (fbTerm (expand (succ b0) G' nxt snc)))
                                       sc end) ev)) end)
                         (fn (ev : Eq Bool (wmember (succ rp) seen) false) is
                            let ihres : Eq FBody (expand (succ b0) F' nxt snc) (expand (succ b0) G' nxt snc) =
                              ih nxt snc F' G'
                                (noDupSnoc (succ rp) seen hnd ev)
                                (allLtSnoc (succ b0) (succ rp) seen hal hrem1)
                                (trans (cong (fn (m : Whole) is addW m cap0 end) (wlenSnoc (succ rp) seen))
                                   (trans (sym (addSuccR (wlen seen) cap0)) hcap))
                                (remBound (cmul (succ rp) 10) b0)
                                hF hG in
                            cong (fn (fb : FBody) is BoolElim (fn (w : Bool) is FBody end)
                                     (fbody wnil (windex (succ rp) seen) false) fb (wmember (succ rp) seen) end)
                              (trans
                                 (cong (fn (a : WList) is
                                          fbody (wcons dec a)
                                            (fbRep (expand (succ b0) F' nxt snc)) (fbTerm (expand (succ b0) F' nxt snc)) end)
                                       (cong (fn (bb : FBody) is fbDigits bb end) ihres))
                                 (cong2 (fn (r : Whole) (tb : Bool) is
                                           fbody (wcons dec (fbDigits (expand (succ b0) G' nxt snc))) r tb end)
                                    (cong (fn (bb : FBody) is fbRep bb end) ihres)
                                    (cong (fn (bb : FBody) is fbTerm bb end) ihres))) end)
                         (wmember (succ rp) seen) (refl (wmember (succ rp) seen)) end)
                     rem hrem end
               end
           end
         end
       end)
      cap
  end
end

-- ============================================================================
-- RUNG 3 assembled + THE QLIFT.  toRadixRep respects QRel; lift it onto Q.
-- ============================================================================

lteAddR : (a : Whole) -> (b : Whole) -> Eq Bool (leb a (addW a b)) true is
  fn (a : Whole) (b : Whole) is
    WholeElim (fn (x : Whole) is Eq Bool (leb x (addW x b)) true end)
      (refl true)
      (fn (k : Whole) (ih : Eq Bool (leb k (addW k b)) true) is ih end)
      a
  end
end

lteAddL : (a : Whole) -> (b : Whole) -> Eq Bool (leb b (addW a b)) true is
  fn (a : Whole) (b : Whole) is
    subst Whole (addW b a) (addW a b) (addComm b a)
      (fn (z : Whole) is Eq Bool (leb b z) true end) (lteAddR b a)
  end
end

-- MAGNITUDE CROSS-PRODUCT.  QRel-related QPairs satisfy |num p|·den q = |num q|·den p
-- (the non-negative-factor bridge applied to both sides of the ℤ cross-multiplication).

magCross : (p : QPair) -> (q : QPair) -> QRel p q
    -> Eq Whole (cmul (qmagNum p) (qmagDen q)) (cmul (qmagNum q) (qmagDen p)) is
  fn (p : QPair) (q : QPair) (h : QRel p q) is
    trans (sym (natAbsMulZfrom (qnum p) (succ (qdpred q))))
      (trans (cong imag h)
             (natAbsMulZfrom (qnum q) (succ (qdpred p))))
  end
end

-- FRACTIONAL EXPANSION RESPECTS QRel (rung 3, assembled).  Align both representatives'
-- own fuels to a common large fuel (expandFuelStable, both sufficient), then equate the
-- two expansions at that fuel (expandCross); the initial remainders are cross-equal by
-- natModCrossStep on magCross.

bodyResp : (p : QPair) -> (q : QPair) -> QRel p q
    -> Eq FBody
         (expand (qmagDen p) (succ (qmagDen p)) (qmod (qmagNum p) (qmagDen p)) wnil)
         (expand (qmagDen q) (succ (qmagDen q)) (qmod (qmagNum q) (qmagDen q)) wnil) is
  fn (p : QPair) (q : QPair) (h : QRel p q) is
    let remP : Whole = qmod (qmagNum p) (qmagDen p) in
    let remQ : Whole = qmod (qmagNum q) (qmagDen q) in
    let big : Whole = addW (succ (succ (qdpred p))) (succ (succ (qdpred q))) in
    let crossEq : Eq Whole (cmul remP (succ (qdpred q))) (cmul remQ (succ (qdpred p))) =
      natModCrossStep (qdpred p) (qdpred q) (qmagNum p) (qmagNum q) (magCross p q h) in
    trans
      (expandFuelStable (qdpred p) (succ (qdpred p)) remP wnil (succ (succ (qdpred p))) big
         (refl true) (refl true) (refl (succ (qdpred p))) (remBound (qmagNum p) (qdpred p))
         (lteRefl (succ (succ (qdpred p))))
         (lteAddR (succ (succ (qdpred p))) (succ (succ (qdpred q)))))
      (trans
         (expandCross (qdpred p) (qdpred q) big remP remQ wnil wnil crossEq (refl true))
         (sym
            (expandFuelStable (qdpred q) (succ (qdpred q)) remQ wnil (succ (succ (qdpred q))) big
               (refl true) (refl true) (refl (succ (qdpred q))) (remBound (qmagNum q) (qdpred q))
               (lteRefl (succ (succ (qdpred q))))
               (lteAddL (succ (succ (qdpred p))) (succ (succ (qdpred q)))))))
  end
end

-- THE WELL-DEFINEDNESS: toRadixRep is constant on each QRel class — equal sign
-- (signResp), equal integer part (intPartResp), equal fractional body (bodyResp).

toRadixRespects : (p : QPair) -> (q : QPair) -> QRel p q
    -> Eq RDec (toRadixRep p) (toRadixRep q) is
  fn (p : QPair) (q : QPair) (h : QRel p q) is
    trans (cong (fn (s : Bool) is
                  rdec s (qdiv (qmagNum p) (qmagDen p))
                    (fbDigits (expand (qmagDen p) (succ (qmagDen p)) (qmod (qmagNum p) (qmagDen p)) wnil))
                    (fbRep (expand (qmagDen p) (succ (qmagDen p)) (qmod (qmagNum p) (qmagDen p)) wnil))
                    (fbTerm (expand (qmagDen p) (succ (qmagDen p)) (qmod (qmagNum p) (qmagDen p)) wnil)) end)
                (signResp p q h))
      (trans (cong (fn (i : Whole) is
                     rdec (qsign q) i
                       (fbDigits (expand (qmagDen p) (succ (qmagDen p)) (qmod (qmagNum p) (qmagDen p)) wnil))
                       (fbRep (expand (qmagDen p) (succ (qmagDen p)) (qmod (qmagNum p) (qmagDen p)) wnil))
                       (fbTerm (expand (qmagDen p) (succ (qmagDen p)) (qmod (qmagNum p) (qmagDen p)) wnil)) end)
                   (intPartResp p q h))
        (trans (cong (fn (d : WList) is
                       rdec (qsign q) (qdiv (qmagNum q) (qmagDen q)) d
                         (fbRep (expand (qmagDen p) (succ (qmagDen p)) (qmod (qmagNum p) (qmagDen p)) wnil))
                         (fbTerm (expand (qmagDen p) (succ (qmagDen p)) (qmod (qmagNum p) (qmagDen p)) wnil)) end)
                     (cong (fn (bb : FBody) is fbDigits bb end) (bodyResp p q h)))
          (trans (cong (fn (r : Whole) is
                         rdec (qsign q) (qdiv (qmagNum q) (qmagDen q))
                           (fbDigits (expand (qmagDen q) (succ (qmagDen q)) (qmod (qmagNum q) (qmagDen q)) wnil))
                           r
                           (fbTerm (expand (qmagDen p) (succ (qmagDen p)) (qmod (qmagNum p) (qmagDen p)) wnil)) end)
                       (cong (fn (bb : FBody) is fbRep bb end) (bodyResp p q h)))
            (cong (fn (t : Bool) is
                    rdec (qsign q) (qdiv (qmagNum q) (qmagDen q))
                      (fbDigits (expand (qmagDen q) (succ (qmagDen q)) (qmod (qmagNum q) (qmagDen q)) wnil))
                      (fbRep (expand (qmagDen q) (succ (qmagDen q)) (qmod (qmagNum q) (qmagDen q)) wnil))
                      t end)
                  (cong (fn (bb : FBody) is fbTerm bb end) (bodyResp p q h))))))
  end
end

-- THE DECIMAL OF A RATIONAL, on Q itself — the qlift of toRadixRep through QRel.

nzNat : Whole -> Bool is
  fn (t : Whole) is case t of | zero -> false | succ k -> true end end
end

-- does the denominator NOT divide the numerator (is there a nonzero remainder)?

nzMod : Whole -> Whole -> Bool is
  fn (a : Whole) (b : Whole) is nzNat (qmod a b) end
end

-- assemble the signed floor from (sign, magnitude floor, has-remainder):
--   non-negative          -> +q
--   negative, divides      -> -q          (exact: floor is the negation)
--   negative, has rem      -> -(q+1)      (round toward -infinity)

mkFloor : Bool -> Whole -> Bool -> Int is
  fn (s : Bool) (q : Whole) (nz : Bool) is
    case s of
    | false -> intOf q
    | true ->
        case nz of
        | false -> ineg (intOf q)
        | true  -> ineg (intOf (succ q))
        end
    end
  end
end

-- the floor of a QPair representative.

floorRep : QPair -> Int is
  fn (p : QPair) is
    mkFloor (qsign p) (qdiv (qmagNum p) (qmagDen p)) (nzMod (qmagNum p) (qmagDen p))
  end
end

-- the magnitude cross-product the respect proofs share: QRel (cross-mult in Int),
-- |.|'d through natAbsMulZfrom, becomes the Whole cross-product on |num| and den.
-- (Same bridge intPartResp/signResp use; named here for reuse by modIndResp.)

modIndResp : (p : QPair) -> (q : QPair) -> QRel p q
    -> Eq Bool (nzMod (qmagNum p) (qmagDen p)) (nzMod (qmagNum q) (qmagDen q)) is
  fn (p : QPair) (q : QPair) (h : QRel p q) is
    trans (sym (nzMulSucc (qmod (qmagNum p) (qmagDen p)) (qdpred q)))
      (trans (cong nzNat
                (natModCrossStep (qdpred p) (qdpred q) (qmagNum p) (qmagNum q) (magCross p q h)))
             (nzMulSucc (qmod (qmagNum q) (qmagDen q)) (qdpred p)))
  end
end

-- FLOOR IS WELL-DEFINED ON THE QUOTIENT: QRel-related representatives have the
-- SAME floor.  floorRep factors through mkFloor in three slots, each respecting
-- QRel, so three substitutions (sign, magnitude floor, has-remainder) rewrite
-- the representative p into q.  This is ch13's floorUnique on the canonical Q.

floorUnique : (p : QPair) -> (q : QPair) -> QRel p q
    -> Eq Int (floorRep p) (floorRep q) is
  fn (p : QPair) (q : QPair) (h : QRel p q) is
    subst Bool (qsign p) (qsign q) (signResp p q h)
      (fn (s : Bool) is
         Eq Int (floorRep p)
              (mkFloor s (qdiv (qmagNum q) (qmagDen q)) (nzMod (qmagNum q) (qmagDen q))) end)
      (subst Whole (qdiv (qmagNum p) (qmagDen p)) (qdiv (qmagNum q) (qmagDen q)) (intPartResp p q h)
        (fn (n : Whole) is
           Eq Int (floorRep p) (mkFloor (qsign p) n (nzMod (qmagNum q) (qmagDen q))) end)
        (subst Bool (nzMod (qmagNum p) (qmagDen p)) (nzMod (qmagNum q) (qmagDen q)) (modIndResp p q h)
          (fn (b : Bool) is
             Eq Int (floorRep p) (mkFloor (qsign p) (qdiv (qmagNum p) (qmagDen p)) b) end)
          (refl (floorRep p))))
  end
end

-- THE FLOOR ON Q: the lift of floorRep along floorUnique.  floorQ (qin p) computes
-- to floorRep p, and floorUnique is the proof obligation qlift demands.

-- ============================================================================
-- THE DECIMAL OF A RATIONAL, on Frac itself — the qlift of toRadixRep through
-- QRel (well-definedness = toRadixRespects: the expansion is class-invariant).
-- ============================================================================
to_radix : Frac -> RDec is
  qlift QPair QRel RDec toRadixRep toRadixRespects
end

-- THE FLOOR ON Frac: the qlift of floorRep along floorUnique (round toward -inf).
floorQ : Frac -> Int is qlift QPair QRel Int floorRep floorUnique end

-- ----------------------------------------------------------------------------
-- SIGNIFICANT-FIGURE ROUNDING, re-lifted as PURE POST-FUNCTIONS of the already-
-- lifted to_radix output.  A pure function of a lifted observer respects QRel for
-- free — no second respect proof.  The RDec digit stream is read repetend-aware.
-- ----------------------------------------------------------------------------

-- the i-th element of a WList (0-indexed), 0 past the end.
wnth : WList -> Whole -> Whole is
  fn (xs : WList) is
    case xs of
    | wnil -> fn (i : Whole) is 0 end
    | wcons h t with ih -> fn (i : Whole) is
        case i of | zero -> h | succ j -> ih j end
      end
    end
  end
end

-- the i-th fractional digit of an RDec, expanding the repetend for a repeating
-- decimal and reading 0 past the end of a terminating one.
digitAt : RDec -> Whole -> Whole is
  fn (d : RDec) (i : Whole) is
    case d of
    | rdec s ip ds rep term ->
        case leb (wlen ds) i of
        | false -> wnth ds i
        | true  ->
            case term of
            | true  -> 0
            | false -> wnth ds (addW rep ((subW i rep) % (subW (wlen ds) rep)))
            end
        end
    end
  end
end

-- the integer formed by the first n fractional digits (d0..d(n-1)), MSB first.
firstND : RDec -> Whole -> Whole is
  fn (d : RDec) (n : Whole) is
    WholeElim (fn (k : Whole) is Whole end)
      0
      (fn (k : Whole) (ih : Whole) is addW (mulW ih 10) (digitAt d k) end)
      n
  end
end

-- round the exact decimal of f to n places (round half up), as a terminating RDec:
-- m = |int|·10^n + firstNDigits + carry; formatted exactly as the old longDiv path.
to_radix_sigplace : Whole -> Frac -> RDec is
  fn (n : Whole) (f : Frac) is
    let d : RDec = to_radix f in
    case d of
    | rdec s ip ds rep term ->
        let firstn : Whole = firstND d n in
        let bump   : Whole = case leb 5 (digitAt d n) of | true -> 1 | false -> 0 end in
        let m      : Whole = addW (mulW ip (powTen n)) (addW firstn bump) in
        rdec s (m // powTen n) (digitsOf n (m % powTen n)) 0 true
    end
  end
end

-- leading zeros of the fractional part (for |f| < 1 significant-figure counting).
leadZ : WList -> Whole is
  fn (ds : WList) is
    case ds of
    | wnil -> 0
    | wcons h t with ih -> case h of | zero -> succ ih | succ k -> 0 end
    end
  end
end

-- decimal places for s SIGNIFICANT FIGURES, read off the lifted decimal: for
-- |f| >= 1, s - (integer digits); for |f| < 1, s + (leading zeros after the point).
sigPlacesR : Whole -> RDec -> Whole is
  fn (s : Whole) (d : RDec) is
    case d of
    | rdec sg ip ds rep term ->
        case leb 1 ip of
        | true  -> subW s (numDigits 64 ip)
        | false -> addW s (leadZ ds)
        end
    end
  end
end

to_radix_sigfig : Whole -> Frac -> RDec is
  fn (s : Whole) (f : Frac) is to_radix_sigplace (sigPlacesR s (to_radix f)) f end
end

-- ============================================================================
-- DEMOTION, checked — REBUILT on the LIFTED observers.  Climbing the tower is
-- implicit; coming back DOWN is a deliberate, checked descent.  A Frac is integral
-- iff its exact decimal has NO fractional digits (empty digit list); its integer
-- value is then floorQ (exact for an integral value).  toWhole/toNat additionally
-- reject a negative (and toNat a zero).  Error strings/values are UNCHANGED: each
-- err carries the original Frac, which the printer gcd-reduces for display.
-- ============================================================================

-- the fractional digits of a Frac's exact decimal.
rdecDigits : RDec -> WList is fn (d : RDec) is case d of | rdec s ip ds rep term -> ds end end end

-- a Frac is integral iff its exact decimal terminates immediately (no digits).
isIntegralF : Frac -> Bool is
  fn (f : Frac) is
    case rdecDigits (to_radix f) of
    | wnil       -> true
    | wcons h t  -> false
    end
  end
end

toInt : Frac -> Result Int ArithErr is
  fn (f : Frac) is
    case isIntegralF f of
    | false -> err Int ArithErr (notIntegral f)
    | true  -> ok Int ArithErr (floorQ f)
    end
  end
end

toWhole : Frac -> Result Whole ArithErr is
  fn (f : Frac) is
    case isIntegralF f of
    | false -> err Whole ArithErr (notIntegral f)
    | true  ->
        case floorQ f of
        | nonneg n  -> ok Whole ArithErr n
        | negsucc k -> err Whole ArithErr (negative f)
        end
    end
  end
end

toNat : Frac -> Result Nat ArithErr is
  fn (f : Frac) is
    case isIntegralF f of
    | false -> err Nat ArithErr (notIntegral f)
    | true  ->
        case floorQ f of
        | nonneg n ->
            case n of
            | zero   -> err Nat ArithErr (notCounting f)
            | succ k -> ok Nat ArithErr
                (Pair Whole (fn (m : Whole) is Eq Bool (isPos m) true end) (succ k) (refl true))
            end
        | negsucc k -> err Nat ArithErr (negative f)
        end
    end
  end
end

-- ====================================================================
-- Packed binary strings + total numeric parsing (D1 + B4 + the goal).
-- `Bytes` is "Haskell's binary thing only better": a String is a SINGLE Whole
-- (a bignum) packing the UTF-8 bytes — NOT a [Char] cons-list. The first byte is
-- least-significant and a 0x01 SENTINEL caps the top, so the length is recoverable
-- (leading-NUL bytes survive) and `uncons` is O(1): head = code % 256, tail =
-- code // 256, and the string is exhausted when code <= 1 (sentinel only). A
-- literal `"3/4"` desugars (surface) to `bytes <packed>`, so strings COMPUTE in
-- the kernel — these parsers run in the REPL, no host needed. The `// %` accel
-- (above) keeps uncons one bigint step.
-- ====================================================================

data Bytes : U is bytes : Whole -> Bytes end
String : U is Bytes end

codeOf : Bytes -> Whole is fn (s : Bytes) is case s of | bytes n -> n end end end

-- exhausted when only the sentinel (or less) remains. Uses `leW` (not `leb`): the
-- packed `code` is a bignum, and `leb (codeOf s) 1` unrolls O(code) in compiled code
-- (see leW/lebEquiv above). `leW _ 1` is O(1) and `lebEquiv` certifies it = leb.
strNull : Bytes -> Bool  is fn (s : Bytes) is leW (codeOf s) 1 end end
-- the first byte (its UTF-8 code), or the sentinel value on an empty string.
strHead : Bytes -> Whole is fn (s : Bytes) is codeOf s % 256 end end
-- drop the first byte.
strTail : Bytes -> Bytes is fn (s : Bytes) is bytes (codeOf s // 256) end end

andB : Bool -> Bool -> Bool is fn (a : Bool) (b : Bool) is case a of | true -> b | false -> false end end end

-- prepend a byte `c` (0 <= c < 256) to a string: the new packed code is `c + 256*n`
-- (the bytes shift up one place, the sentinel rides along). O(1) via the accel ops;
-- verified against the existing accessors: strHead (c+256n) = c, strTail = bytes n,
-- and c+256n >= 256 > 1 so it is never null.
strCons : Whole -> Bytes -> Bytes is
  fn (c : Whole) (s : Bytes) is bytes (addW c (mulW 256 (codeOf s))) end
end

-- byte length and concatenation are structural recursion on FUEL (byte count), NEVER on
-- the packed code (~256^length — a code-sized recursion OOMs the eager codegen, the leb
-- lesson). The loops early-return at the sentinel, so runtime is O(length); `strFuel` is
-- only a safety bound far past any practical string.
strFuel : Whole is 1048576 end

strLenGo : Whole -> Whole -> Bytes -> Whole is
  fn (fuel : Whole) is
    WholeElim (fn (k : Whole) is Whole -> Bytes -> Whole end)
      (fn (acc : Whole) (s : Bytes) is acc end)
      (fn (f : Whole) (ih : Whole -> Bytes -> Whole) is
        fn (acc : Whole) (s : Bytes) is
          case strNull s of
          | true  -> acc
          | false -> ih (addW acc 1) (strTail s)
          end
        end
      end)
      fuel
  end
end
strLen : Bytes -> Whole is fn (s : Bytes) is strLenGo strFuel 0 s end end

strAppGo : Whole -> Bytes -> Bytes -> Bytes is
  fn (fuel : Whole) is
    WholeElim (fn (k : Whole) is Bytes -> Bytes -> Bytes end)
      (fn (s : Bytes) (t : Bytes) is t end)
      (fn (f : Whole) (ih : Bytes -> Bytes -> Bytes) is
        fn (s : Bytes) (t : Bytes) is
          case strNull s of
          | true  -> t
          | false -> strCons (strHead s) (ih (strTail s) t)
          end
        end
      end)
      fuel
  end
end
-- concatenation: cons each byte of `s` onto `t`. Fuel is exactly `strLen s` (a literal
-- for a closed string, so the loop runs exactly length-of-s times).
strApp : Bytes -> Bytes -> Bytes is fn (s : Bytes) (t : Bytes) is strAppGo (strLen s) s t end end

-- decidable string equality: the codes are equal (each <= the other). Uses subW/isZero
-- (O(1) accel), NOT leb (which is O(code) in compiled code). Sound because the sentinel
-- makes the packed encoding injective.
strEq : Bytes -> Bytes -> Bool is
  fn (a : Bytes) (b : Bytes) is
    andB (isZero (subW (codeOf a) (codeOf b))) (isZero (subW (codeOf b) (codeOf a)))
  end
end

-- String is a Magma and a Monoid under concatenation (identity = the empty string,
-- packed code 1). So `++` works on string literals. Associativity is proven in the
-- listings over the rune-list view (ch438 sappAssoc), not yet as a SemigroupLaws
-- value over this packed Bytes instance.
instance magmaBytes : Magma Bytes is strApp end
instance monoidBytes    : Monoid Bytes is mkMonoid Bytes strApp (bytes 1) end

eqW  : Whole -> Whole -> Bool is fn (a : Whole) (b : Whole) is andB (leb a b) (leb b a) end end
-- a byte is an ASCII decimal digit iff 48 ('0') <= c <= 57 ('9').
isDigitB : Whole -> Bool is fn (c : Whole) is andB (leb 48 c) (leb c 57) end end

-- the ways a parse can fail (D1: total, a value you must case on — never a crash).
data ParseErr : U is
  emptyStr  : ParseErr     -- nothing to parse
| notNumber : ParseErr     -- a byte that is not a digit / sign / slash
| badDenom  : ParseErr     -- a rational with denominator 0
| tooLong   : ParseErr     -- exceeded the parse fuel (a >256-byte token)
end

-- the digit loop: total structural recursion on FUEL (a generous fixed bound, far
-- past any real numeral), recursing into a FUNCTION type so the accumulator + the
-- remaining string thread through. Computes in the REPL (no `partial`, which would
-- stay neutral). 256 bytes of digits is astronomically more than any CLI number.
digitsGo : Whole -> Whole -> Bytes -> Result Whole ParseErr is
  fn (fuel : Whole) is
    WholeElim (fn (k : Whole) is Whole -> Bytes -> Result Whole ParseErr end)
      (fn (acc : Whole) (s : Bytes) is err Whole ParseErr tooLong end)
      (fn (f : Whole) (ih : Whole -> Bytes -> Result Whole ParseErr) is
        fn (acc : Whole) (s : Bytes) is
          case strNull s of
          | true  -> ok Whole ParseErr acc
          | false ->
              case isDigitB (strHead s) of
              | true  -> ih (addW (mulW acc 10) (subW (strHead s) 48)) (strTail s)
              | false -> err Whole ParseErr notNumber
              end
          end
        end
      end)
      fuel
  end
end

-- a Whole from the command line: a non-empty run of digits.
parseWhole : String -> Result Whole ParseErr is
  fn (s : String) is
    case strNull s of
    | true  -> err Whole ParseErr emptyStr
    | false -> digitsGo 256 0 s
    end
  end
end

resWtoI : Result Whole ParseErr -> Bool -> Result Int ParseErr is
  fn (r : Result Whole ParseErr) (sgn : Bool) is
    ResultElim Whole ParseErr (fn (x : Result Whole ParseErr) is Result Int ParseErr end)
      (fn (w : Whole) is ok Int ParseErr (signOfMag sgn w) end)
      (fn (e : ParseErr) is err Int ParseErr e end)
      r
  end
end

-- an Int: an optional leading '-' (byte 45) then a non-empty digit run.
parseInt : String -> Result Int ParseErr is
  fn (s : String) is
    case strNull s of
    | true  -> err Int ParseErr emptyStr
    | false ->
        case eqW (strHead s) 45 of
        | true  ->
            case strNull (strTail s) of
            | true  -> err Int ParseErr notNumber
            | false -> resWtoI (digitsGo 256 0 (strTail s)) true
            end
        | false -> resWtoI (digitsGo 256 0 s) false
        end
    end
  end
end



-- ====================================================================
-- Binary: encode/decode between a value and its packed-Bytes rendering — the
-- "both" half of the goal (a serialization class, like Data.Binary, ONLY BETTER:
-- decode is TOTAL, returning Result, never a partial crashing `get`). The textual
-- parsers above ARE the decoders; the encoders render back to the same packed
-- Bytes, so `decode (encode x)` round-trips (computing on concretes; see the
-- rt* lemmas).
-- ====================================================================

-- prepend one byte (its UTF-8 code) onto a packed string: the new least-sig byte.
strCons : Whole -> Bytes -> Bytes is
  fn (b : Whole) (s : Bytes) is bytes (addW b (mulW 256 (codeOf s))) end
end

-- concatenate packed strings (s1's bytes, in order, then s2's). Fuel-bounded total
-- recursion on s1, recursing into the standard cons fold.
strAppGo : Whole -> Bytes -> Bytes -> Bytes is
  fn (fuel : Whole) is
    WholeElim (fn (k : Whole) is Bytes -> Bytes -> Bytes end)
      (fn (s1 : Bytes) (s2 : Bytes) is s2 end)
      (fn (f : Whole) (ih : Bytes -> Bytes -> Bytes) is
        fn (s1 : Bytes) (s2 : Bytes) is
          case strNull s1 of
          | true  -> s2
          | false -> strCons (strHead s1) (ih (strTail s1) s2)
          end
        end
      end)
      fuel
  end
end
strApp : Bytes -> Bytes -> Bytes is fn (s1 : Bytes) (s2 : Bytes) is strAppGo 256 s1 s2 end end

-- render a Whole to its decimal Bytes. Peel the least-significant digit (n % 10)
-- and PREPEND it (strCons), so the digits land most-significant-first; fuel-bounded.
encodeWholeGo : Whole -> Whole -> Bytes -> Bytes is
  fn (fuel : Whole) is
    WholeElim (fn (k : Whole) is Whole -> Bytes -> Bytes end)
      (fn (n : Whole) (acc : Bytes) is acc end)
      (fn (f : Whole) (ih : Whole -> Bytes -> Bytes) is
        fn (n : Whole) (acc : Bytes) is
          case eqW n 0 of
          | true  -> acc
          | false -> ih (n // 10) (strCons (addW 48 (n % 10)) acc)
          end
        end
      end)
      fuel
  end
end
encodeWhole : Whole -> Bytes is
  fn (n : Whole) is
    case eqW n 0 of
    | true  -> strCons 48 (bytes 1)       -- "0"
    | false -> encodeWholeGo 256 n (bytes 1)
    end
  end
end

-- render an Int: a '-' (byte 45) prefix when negative, else the magnitude.
encodeInt : Int -> Bytes is
  fn (i : Int) is
    case isign i of
    | true  -> strCons 45 (encodeWhole (imag i))
    | false -> encodeWhole (imag i)
    end
  end
end


-- the Binary class (a Σ-record: an encoder + a TOTAL decoder), one instance per
-- tower rung. `encode`/`decode` dispatch on the resolved instance.
Binary : U -> U is
  fn (A : U) is Sig (A -> Bytes) (fn (_e : A -> Bytes) is Bytes -> Result A ParseErr end) end
end
mkBinary : (A : U) -> (A -> Bytes) -> (Bytes -> Result A ParseErr) -> Binary A is
  fn (A : U) (e : A -> Bytes) (d : Bytes -> Result A ParseErr) is
    Pair (A -> Bytes) (fn (_e : A -> Bytes) is Bytes -> Result A ParseErr end) e d
  end
end
instance binWhole : Binary Whole is mkBinary Whole encodeWhole parseWhole end
instance binInt   : Binary Int   is mkBinary Int   encodeInt   parseInt   end

encode : {A : U} -> {d : Binary A} -> A -> Bytes is
  fn {A : U} {d : Binary A} (x : A) is (d.1) x end
end
decode : {A : U} -> {d : Binary A} -> Bytes -> Result A ParseErr is
  fn {A : U} {d : Binary A} (s : Bytes) is (d.2) s end
end

-- round-trip witnesses (decode after encode): the "only better" guarantee, shown
-- COMPUTING on concrete values (the encoders/parsers reduce, so these are refl).
roundWhole : Whole -> Result Whole ParseErr is fn (n : Whole) is parseWhole (encodeWhole n) end end
roundInt   : Int   -> Result Int   ParseErr is fn (i : Int)   is parseInt   (encodeInt   i) end end

-- Proof-carrying round-trips: decode-after-encode is the identity, MACHINE-CHECKED
-- by refl (it computes) — the "only better than a partial read" guarantee, on
-- concrete values; and a malformed token decodes to exactly the right error, not a
-- crash. These elaborate at prelude load, so they are a standing regression gate.
rtWhole : Eq (Result Whole ParseErr) (roundWhole 42) (ok Whole ParseErr 42) is
  refl (ok Whole ParseErr 42)
end
rtInt : Eq (Result Int ParseErr) (roundInt (negsucc 4)) (ok Int ParseErr (negsucc 4)) is
  refl (ok Int ParseErr (negsucc 4))
end
rtBad : Eq (Result Whole ParseErr) (parseWhole "9z") (err Whole ParseErr notNumber) is
  refl (err Whole ParseErr notNumber)
end

-- ====================================================================
-- UNICODE: explicit levels (Rust-style). The DEFAULT level is BYTES — `strLen`/
-- `strHead` above are UTF-8 bytes, matching the packed representation. This section
-- adds the RUNE (codepoint) level: `runeLen` counts Unicode scalar values by skipping
-- UTF-8 continuation bytes (0x80..0xBF), so `runeLen "é" = 1` while `strLen "é" = 2`.
-- (GRAPHEME clusters — the user-perceived-character level — need Unicode tables and are
-- future work; PARKING-LOT.) Fuel-bounded by byte length, never the packed code.
-- ====================================================================

-- a byte is a UTF-8 CONTINUATION byte iff 128 <= b <= 191 (it is not a scalar's leader).
isCont : Whole -> Bool is fn (c : Whole) is andB (leW 128 c) (leW c 191) end end

runeLenGo : Whole -> Whole -> Bytes -> Whole is
  fn (fuel : Whole) is
    WholeElim (fn (k : Whole) is Whole -> Bytes -> Whole end)
      (fn (acc : Whole) (s : Bytes) is acc end)
      (fn (f : Whole) (ih : Whole -> Bytes -> Whole) is
        fn (acc : Whole) (s : Bytes) is
          case strNull s of
          | true  -> acc
          | false ->
              case isCont (strHead s) of
              | true  -> ih acc (strTail s)
              | false -> ih (addW acc 1) (strTail s)
              end
          end
        end
      end)
      fuel
  end
end
-- codepoint length: the number of Unicode scalar values (leading bytes) in the string.
runeLen : Bytes -> Whole is fn (s : Bytes) is runeLenGo strFuel 0 s end end

-- ====================================================================
-- SHOW: render any value to a string, the basis of string interpolation `"{e}"`
-- (which desugars to `++` over `show`). For the numeric tower it reuses the Binary
-- encoders; a string shows as itself; a Bool shows as its word. Same Σ-record-class +
-- instance-search pattern as Semiring/Magma.
-- ====================================================================
Show : U -> U is fn (A : U) is A -> Bytes end end
show : {A : U} -> {d : Show A} -> A -> Bytes is fn {A : U} {d : Show A} (x : A) is d x end end

instance showWhole : Show Whole is encodeWhole end
instance showInt   : Show Int   is encodeInt end
instance showBytes : Show Bytes is fn (s : Bytes) is s end end
instance showBool  : Show Bool  is fn (b : Bool) is case b of | true -> "true" | false -> "false" end end end

-- ====================================================================
-- SLICING: take/drop the first n bytes (Swift Substring / Rust slice, at the byte level).
-- Fuel-bounded by byte length; `strTake`/`strDrop` partition a string at a byte offset.
-- ====================================================================
strTakeGo : Whole -> Bytes -> Bytes is
  fn (n : Whole) is
    WholeElim (fn (k : Whole) is Bytes -> Bytes end)
      (fn (s : Bytes) is bytes 1 end)
      (fn (k : Whole) (ih : Bytes -> Bytes) is
        fn (s : Bytes) is
          case strNull s of
          | true  -> bytes 1
          | false -> strCons (strHead s) (ih (strTail s))
          end
        end
      end)
      n
  end
end
-- the first n bytes (or the whole string if shorter).
strTake : Whole -> Bytes -> Bytes is fn (n : Whole) (s : Bytes) is strTakeGo n s end end

strDropGo : Whole -> Bytes -> Bytes is
  fn (n : Whole) is
    WholeElim (fn (k : Whole) is Bytes -> Bytes end)
      (fn (s : Bytes) is s end)
      (fn (k : Whole) (ih : Bytes -> Bytes) is
        fn (s : Bytes) is
          case strNull s of
          | true  -> s
          | false -> ih (strTail s)
          end
        end
      end)
      n
  end
end
-- all but the first n bytes (or the empty string if shorter).
strDrop : Whole -> Bytes -> Bytes is fn (n : Whole) (s : Bytes) is strDropGo n s end end

-- ====================================================================
-- Option: a standard maybe type. Constructor order matches the primName
-- encoding: tag 0 = none (1 arg, the erased type A), tag 1 = some (2 args,
-- type A + value). This order is load-bearing for parseFloat/Option Float.
-- ====================================================================
data Option : U -> U is
  none : (A : U) -> Option A
| some : (A : U) -> A -> Option A
end

-- ====================================================================
-- Std.Float: machine-float (f64) IO and arithmetic. Names declared as
-- foreign inside the module so primName (last segment) resolves to the
-- same ioPrims keys as bare foreign declarations.
-- fromNat accepts Whole (the builtin-nat type) so numeric literals like 2
-- elaborate to Whole and fromNat 2 type-checks without a cast.
-- parseFloat accepts a packed-string Nat (same encoding as Bytes/codeOf).
-- ====================================================================
module Std.Float is
  foreign Float : U end
  foreign fromNat : Whole -> Float end
  foreign fadd : Float -> Float -> Float end
  foreign fsub : Float -> Float -> Float end
  foreign fmul : Float -> Float -> Float end
  foreign fdiv : Float -> Float -> Float end
  foreign parseFloat : Whole -> Option Float end
  foreign getFloat : IO Float end
  foreign printFloat : Float -> IO Float end
end
