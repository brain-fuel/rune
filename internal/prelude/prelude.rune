-- The REPL prelude: enough arithmetic for `1 + 1` to mean 2 at the prompt.
-- Everything here is ordinary surface rune — the same definitions as the
-- ch11 listing, no special status in the core. `rune repl --no-prelude`
-- starts a bare session (the book's discipline: nothing you didn't write).
--
-- The numeric tower. `Whole` is the FOUNDATION — the initial algebra {0,1,2,…}
-- with `zero`/`succ`, the type induction bottoms out on and the one bare
-- numerals bind to (so `0` has a type). `Nat` is the COUNTING numbers {1,2,3,…}
-- sitting one rung up (no zero), injected into `Whole` by `wholeOf`. `Int` and
-- `Rat` are the quotient libraries above (see the int/rational listings). The
-- calculator (`+ - * // %`, gcd) lives at `Whole`.

data Whole : U is
  zero : Whole
| succ : Whole -> Whole
end

builtin nat Whole zero succ

-- The Whole-level arithmetic kernels. These are NAMED (addW/mulW/subW) so the
-- operators `+`/`-`/`*` below can be OVERLOADED across the tower (Whole and the
-- signed fractions) by typeclass dispatch — `1 + 1` is Whole addition, `1/3 + 2/3`
-- is fraction addition, the SAME symbol. The kernels carry the bigint acceleration.

addW : Whole -> Whole -> Whole is
  fn (m : Whole) (n : Whole) is
    case m of
    | zero -> n
    | succ k with ih -> succ ih
    end
  end
end

-- Accelerate addition on closed literals: `4000 + 4000` takes one bigint step
-- instead of building a succ-chain. Registration runs a differential gate (the
-- unfolded body must equal bigint add on a battery of pairs), so this stays
-- kernel-sound; it fires ONLY when both arguments are NatLit.
builtin natAdd addW

mulW : Whole -> Whole -> Whole is
  fn (m : Whole) (n : Whole) is
    case m of
    | zero -> 0
    | succ k with ih -> addW ih n
    end
  end
end

-- Accelerate multiplication likewise — what makes `4000 * 4000` instant instead
-- of materialising 16 million succ nodes (and overflowing the stack at readback).
builtin natMul mulW

pred : Whole -> Whole is
  fn (n : Whole) is
    case n of
    | zero -> 0
    | succ k -> k
    end
  end
end

-- Truncated subtraction: m - n stops at zero (Whole has nothing below it).
subW : Whole -> Whole -> Whole is
  fn (m : Whole) (n : Whole) is
    case n of
    | zero -> m
    | succ k with ih -> pred ih
    end
  end
end

-- Accelerate truncated subtraction (saturating monus) on closed literals.
builtin natMonus subW

data Bool : U is
  true : Bool
| false : Bool
end

-- ====================================================================
-- THE ALGEBRAIC OPS LADDER (v4). Three Σ-record classes carrying OPERATIONS
-- ONLY: Semiring {add, zero, mul, one} -> Ring {+neg} -> DivRing {+recip}.
-- Laws live in SEPARATE records (SemiringLaws and friends, below), so a type
-- that can compute but not prove (IEEE754, later) still gets ops instances.
-- Superclass access is projection: a Ring contains its Semiring as .1.
-- POSITIONAL DISCIPLINE (the Num lesson): a class is identified by its
-- STRUCTURE, so two classes with identical field-type sequences collide.
-- Shapes here: Semiring A = Sig (A->A->A) (Sig A (Sig (A->A->A) A));
-- Ring A = Sig (Semiring A) (A->A); DivRing A = Sig (Ring A) (A->A) - all
-- pairwise distinct, gated by TestTowerClassHashesDistinct.
-- `recip` is TOTAL with the junk value recip zero = zero (Mathlib's move);
-- the true inverse law is guarded by a nonzero hypothesis laws-side.
-- ====================================================================
Semiring : U -> U is
  fn (A : U) is
    Sig (A -> A -> A) (fn (_add : A -> A -> A) is
      Sig A (fn (_zero : A) is
        Sig (A -> A -> A) (fn (_mul : A -> A -> A) is A end)
      end)
    end)
  end
end
mkSemiring : (A : U) -> (A -> A -> A) -> A -> (A -> A -> A) -> A -> Semiring A is
  fn (A : U) (a : A -> A -> A) (z : A) (m : A -> A -> A) (o : A) is
    Pair (A -> A -> A) (fn (_add : A -> A -> A) is
        Sig A (fn (_zero : A) is
          Sig (A -> A -> A) (fn (_mul : A -> A -> A) is A end)
        end)
      end)
      a
      (Pair A (fn (_zero : A) is
          Sig (A -> A -> A) (fn (_mul : A -> A -> A) is A end)
        end)
        z
        (Pair (A -> A -> A) (fn (_mul : A -> A -> A) is A end) m o))
  end
end

Ring : U -> U is
  fn (A : U) is Sig (Semiring A) (fn (_s : Semiring A) is A -> A end) end
end
mkRing : (A : U) -> Semiring A -> (A -> A) -> Ring A is
  fn (A : U) (s : Semiring A) (n : A -> A) is
    Pair (Semiring A) (fn (_s : Semiring A) is A -> A end) s n
  end
end

DivRing : U -> U is
  fn (A : U) is Sig (Ring A) (fn (_r : Ring A) is A -> A end) end
end
mkDivRing : (A : U) -> Ring A -> (A -> A) -> DivRing A is
  fn (A : U) (r : Ring A) (rc : A -> A) is
    Pair (Ring A) (fn (_r : Ring A) is A -> A end) r rc
  end
end

-- ====================================================================
-- ARITHMETIC DISPATCH. `+` and `*` are Semiring-constrained: the elaborator
-- resolves the dictionary from the argument TYPE (class = type family,
-- instance = registered value; see the ops-ladder banner above). Whole,
-- Int, and Frac each register a Semiring instance below at their rungs.
-- Subtraction is NOT here: ℕ is not closed under it (2 − 5 has no whole
-- answer), so `-` PROMOTES (Whole → Int) via the result-typed `SubR` class
-- below; `/` likewise promotes to Frac; `// %` are integer ops at Whole.
-- ====================================================================
instance semiringWhole : Semiring Whole is mkSemiring Whole addW zero mulW (succ zero) end

+ : {A : U} -> {d : Semiring A} -> A -> A -> A is
  fn {A : U} {d : Semiring A} (x : A) (y : A) is (d.1) x y end
end
* : {A : U} -> {d : Semiring A} -> A -> A -> A is
  fn {A : U} {d : Semiring A} (x : A) (y : A) is (d.2.2.1) x y end
end

-- ====================================================================
-- MAGMA / MONOID - the overloaded append `++` (and `mempty`), built on the SAME
-- Σ-record-class + instance-search pattern as `Semiring`/`+`. `++` is DISTINCT from the
-- numeric `+` (Raku's lesson: keep `+` arithmetic) and resolves to whatever instance
-- the argument type carries: String (packed `Bytes`, below) and List (in the listings).
-- `++` dispatches over `Magma` (a bare binary operation; a semigroup is a magma whose
-- op is PROVEN associative - the lawful record a later task adds below); a Monoid
-- adds an identity (`mempty`). `++` is right-associative and looser than `+`
-- (Haskell's `++`); GRAMMAR §3.
-- ====================================================================
Magma : U -> U is fn (A : U) is A -> A -> A end end
Monoid    : U -> U is fn (A : U) is Sig (A -> A -> A) (fn (_p : A -> A -> A) is A end) end end
mkMonoid : (A : U) -> (A -> A -> A) -> A -> Monoid A is
  fn (A : U) (a : A -> A -> A) (e : A) is
    Pair (A -> A -> A) (fn (_p : A -> A -> A) is A end) a e
  end
end

++ : {A : U} -> {d : Magma A} -> A -> A -> A is
  fn {A : U} {d : Magma A} (x : A) (y : A) is d x y end
end
mempty : {A : U} -> {d : Monoid A} -> A is fn {A : U} {d : Monoid A} is d.2 end end

-- Group: a monoid with an inverse operation. Nests Monoid the way Ring
-- nests Semiring (projection g.1 monoid, g.2 inv); structurally distinct
-- from Ring because the first component differs (Monoid A vs Semiring A).
-- Abelian-ness is a LAW (AbGroupLaws below), never ops-side.
Group : U -> U is
  fn (A : U) is Sig (Monoid A) (fn (_m : Monoid A) is A -> A end) end
end
mkGroup : (A : U) -> Monoid A -> (A -> A) -> Group A is
  fn (A : U) (m : Monoid A) (i : A -> A) is
    Pair (Monoid A) (fn (_m : Monoid A) is A -> A end) m i
  end
end

-- leb m n decides m <= n; recursion on m produces the comparison FUNCTION,
-- so the induction hypothesis is "compare against k" awaiting its argument.
leb : Whole -> Whole -> Bool is
  fn (m : Whole) is
    case m of
    | zero -> fn (n : Whole) is true end
    | succ k with ih -> fn (n : Whole) is
        case n of
        | zero -> false
        | succ j -> ih j
        end
      end
    end
  end
end

-- Equality plumbing built from `subst` (the sole Leibniz primitive; there is no
-- ambient `ap`/`cong`/`sym`/`trans`). These let the lemmas below rewrite under a
-- context and chain steps.
symEq : (A : U) -> (x : A) -> (y : A) -> Eq A x y -> Eq A y x is
  fn (A : U) (x : A) (y : A) (p : Eq A x y) is
    subst A x y p (fn (z : A) is Eq A z x end) (refl x)
  end
end
transEq : (A : U) -> (x : A) -> (y : A) -> (z : A) -> Eq A x y -> Eq A y z -> Eq A x z is
  fn (A : U) (x : A) (y : A) (z : A) (p : Eq A x y) (q : Eq A y z) is
    subst A y z q (fn (w : A) is Eq A x w end) p
  end
end

-- `isZero` is the depth-1 zero-test (compiles to an O(1) constructor dispatch, no
-- eliminator loop), complementary to `isPos`.
isZero : Whole -> Bool is
  fn (n : Whole) is case n of | zero -> true | succ k -> false end end
end

-- subW order lemmas (by induction; `subW` recurses on its SECOND arg).
-- subWZeroL: 0 - b truncates to 0.
subWZeroL : (b : Whole) -> Eq Whole (subW zero b) zero is
  fn (b : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (subW zero x) zero end)
      (refl zero)
      (fn (k : Whole) (ih : Eq Whole (subW zero k) zero) is
         subst Whole (subW zero k) zero ih
           (fn (z : Whole) is Eq Whole (subW zero (succ k)) (pred z) end)
           (refl (subW zero (succ k)))
       end)
      b
  end
end
-- subWSucc: cancelling one from both sides leaves the subtraction unchanged.
subWSucc : (a : Whole) -> (b : Whole) -> Eq Whole (subW (succ a) (succ b)) (subW a b) is
  fn (a : Whole) (b : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (subW (succ a) (succ x)) (subW a x) end)
      (refl a)
      (fn (k : Whole) (ih : Eq Whole (subW (succ a) (succ k)) (subW a k)) is
         subst Whole (subW (succ a) (succ k)) (subW a k) ih
           (fn (z : Whole) is Eq Whole (subW (succ a) (succ (succ k))) (pred z) end)
           (refl (subW (succ a) (succ (succ k))))
       end)
      b
  end
end

-- leW: the accel-friendly `<=`. `subW` is the kernel-accelerated native subtract
-- (O(1) on bignums) and `isZero` is depth-1, so `leW a b` is O(1) in COMPILED code
-- where `leb a b` is O(a) — `leb` recurses into a comparison FUNCTION the eager
-- NatElim codegen fully unrolls (catastrophic on packed-bignum-sized Wholes; fine
-- in the lazy kernel). Prefer `leW` for comparisons on values that deploy.
leW : Whole -> Whole -> Bool is
  fn (a : Whole) (b : Whole) is isZero (subW a b) end
end
-- ...and the certificate that the refactor is sound: leW agrees with leb pointwise
-- (double induction; leb recurses on the first arg, subW on the second).
lebEquiv : (a : Whole) -> (b : Whole) -> Eq Bool (leb a b) (leW a b) is
  fn (a : Whole) is
    WholeElim (fn (x : Whole) is (b : Whole) -> Eq Bool (leb x b) (isZero (subW x b)) end)
      (fn (b : Whole) is
         symEq Bool (isZero (subW zero b)) true
           (subst Whole zero (subW zero b) (symEq Whole (subW zero b) zero (subWZeroL b))
              (fn (z : Whole) is Eq Bool (isZero z) true end)
              (refl true))
       end)
      (fn (k : Whole) (ih : (b : Whole) -> Eq Bool (leb k b) (isZero (subW k b))) is
         fn (b : Whole) is
           WholeElim (fn (x : Whole) is Eq Bool (leb (succ k) x) (isZero (subW (succ k) x)) end)
             (refl false)
             (fn (j : Whole) (ihb : Eq Bool (leb (succ k) j) (isZero (subW (succ k) j))) is
                transEq Bool (leb k j) (isZero (subW k j)) (isZero (subW (succ k) (succ j)))
                  (ih j)
                  (symEq Bool (isZero (subW (succ k) (succ j))) (isZero (subW k j))
                     (subst Whole (subW (succ k) (succ j)) (subW k j) (subWSucc k j)
                        (fn (z : Whole) is Eq Bool (isZero (subW (succ k) (succ j))) (isZero z) end)
                        (refl (isZero (subW (succ k) (succ j))))))
              end)
             b
         end
       end)
      a
  end
end

-- Division and modulus by repeated subtraction, with the dividend as fuel:
-- each step removes at least one from the dividend, so the budget suffices
-- exactly. The flooring quotient of anything by zero is 0; n % 0 is n,
-- keeping DIV-LAW (a = (a // b) * b + a % b) true at b = 0 too
-- (ref_docs/rune-numeric-tower.md). `/` is exact division and lives at Rat.

divF : Whole -> Whole -> Whole -> Whole is
  fn (fuel : Whole) is
    case fuel of
    | zero -> fn (a : Whole) (b : Whole) is 0 end
    | succ f with ih -> fn (a : Whole) (b : Whole) is
        case b of
        | zero -> 0
        | succ k ->
            case leb b a of
            | true -> succ (ih (subW a b) b)
            | false -> 0
            end
        end
      end
    end
  end
end

modF : Whole -> Whole -> Whole -> Whole is
  fn (fuel : Whole) is
    case fuel of
    | zero -> fn (a : Whole) (b : Whole) is a end
    | succ f with ih -> fn (a : Whole) (b : Whole) is
        case b of
        | zero -> a
        | succ k ->
            case leb b a of
            | true -> ih (subW a b) b
            | false -> a
            end
        end
      end
    end
  end
end

// : Whole -> Whole -> Whole is
  fn (m : Whole) (n : Whole) is divF m m n end
end

% : Whole -> Whole -> Whole is
  fn (m : Whole) (n : Whole) is modF m m n end
end

-- Kernel-accelerate `//` and `%` on literals (C7 / R-NUM Decision 1): the
-- fuel-based bodies are correct but O(quotient); the accel makes division a
-- one-bigint-step op on compressed numerals, so it scales to the large literals
-- that packed-String `uncons` (n div/mod 256) and a real calculator need. Bridge
-- to the fuel body is refl; agreement is the differential-tested registration gate.
builtin natDiv //
builtin natMod %

-- Euclid. The second argument strictly decreases (a % b < b), so its
-- successor is budget enough.
gcdF : Whole -> Whole -> Whole -> Whole is
  fn (fuel : Whole) is
    case fuel of
    | zero -> fn (a : Whole) (b : Whole) is a end
    | succ f with ih -> fn (a : Whole) (b : Whole) is
        case b of
        | zero -> a
        | succ k -> ih b (a % b)
        end
      end
    end
  end
end

gcd : Whole -> Whole -> Whole is
  fn (a : Whole) (b : Whole) is gcdF (succ b) a b end
end

-- isPos decides nonzero-ness: false on zero, true on every successor. It is the
-- predicate that carves the counting numbers out of the wholes.
isPos : Whole -> Bool is
  fn (n : Whole) is
    case n of
    | zero -> false
    | succ k -> true
    end
  end
end

-- Nat: the counting numbers {1,2,3,…} as the POSITIVE wholes — a whole paired
-- with a proof it is nonzero. A bare Peano `data Nat is one | nsucc` would be
-- HASH-IDENTICAL to Whole (same shape, and identity is structure not names), so
-- the distinct type must have distinct structure: this Σ. `zero` cannot inhabit
-- it — that would need `Eq Bool false true`, which is uninhabited — so Nat is
-- zeroless by construction. `wholeOf` is the injection Nat ↪ Whole (= .1).
Nat : U is
  Sig Whole (fn (n : Whole) is Eq Bool (isPos n) true end)
end

-- one = 1, the least counting number; the proof is refl since isPos (succ zero)
-- computes to true.
one : Nat is
  Pair Whole (fn (n : Whole) is Eq Bool (isPos n) true end) (succ zero) (refl true)
end

-- nsucc steps a counting number up; the successor of anything is positive, so
-- the nonzero proof is refl regardless of the predecessor.
nsucc : Nat -> Nat is
  fn (k : Nat) is
    Pair Whole (fn (n : Whole) is Eq Bool (isPos n) true end) (succ (k.1)) (refl true)
  end
end

-- The injection up the tower: a counting number IS its underlying whole. Nat is
-- literally a subset of Whole, so wholeOf is the first projection; its image is
-- exactly the positives {1,2,3,…}.
wholeOf : Nat -> Whole is
  fn (k : Nat) is k.1 end
end

-- ====================================================================
-- Fractions and the decimal escape hatch, at the prompt. `|>` pipes a fraction
-- into a radix conversion; the result is an exact (possibly repeating) or rounded
-- positional decimal, which the REPL prints with a radix point:
--   1/3                          -- 1/3
--   -1/3                         -- -1/3      (fractions are SIGNED; prefix - negates)
--   -1/3 |> to_radix             -- -0.{3}
--   3/4 |> to_radix              -- 0.75
--   1/3 |> to_radix              -- 0.{3}        (exact; the repetend is bracketed)
--   1/7 |> to_radix              -- 0.{142857}
--   1/6 |> to_radix              -- 0.1{6}       (a non-repeating head, then a cycle)
--   7/4 |> to_radix_sigplace 1   -- 1.8          (round to 1 decimal place)
--   7/4 |> to_radix_sigfig 2     -- 1.8          (round to 2 significant figures)
-- Every division below is LONG division (each step divides a small number), so
-- nothing hits the calculator //'s fuel wall — `1/3 |> to_radix` is exact, never
-- a blown expansion.
-- ====================================================================

-- A SIGNED fraction: (sign, |num|, |den|). The sign makes the whole tower handle
-- negatives — `Whole` has none, so an unsigned fraction would floor -1/3 to 0/3.
data Frac : U is frac : Bool -> Whole -> Whole -> Frac end
fneg : Frac -> Bool  is fn (f : Frac) is case f of | frac s a b -> s end end end
fnum : Frac -> Whole is fn (f : Frac) is case f of | frac s a b -> a end end end
fden : Frac -> Whole is fn (f : Frac) is case f of | frac s a b -> b end end end

not  : Bool -> Bool is fn (b : Bool) is case b of | true -> false | false -> true end end end
xorB : Bool -> Bool -> Bool is fn (a : Bool) (b : Bool) is case a of | true -> not b | false -> b end end end

-- A bare numeral at Frac is the positive whole-valued fraction n/1.
fracOf : Whole -> Frac is fn (n : Whole) is frac false n 1 end end
builtin rat Frac fracOf

-- Put a fraction in lowest terms (divide numerator and denominator by their gcd),
-- so EVERY fraction at the prompt reads back canonically: 2/4 is 1/2, 1/3 - 2/3 is
-- -1/3 not -3/9, a whole-valued result like 3/3 is 1. (gcd 0 d = d, so a zero
-- numerator lands at 0/1, which displays as 0.)
reduce : Frac -> Frac is
  fn (f : Frac) is
    let g : Whole = gcd (fnum f) (fden f) in
    frac (fneg f) (fnum f // g) (fden f // g)
  end
end

-- Division at Frac: (sa,a/b)/(sb,c/d) = (sa xor sb, a*d/b*c), reduced.
divF : Frac -> Frac -> Frac is
  fn (x : Frac) (y : Frac) is
    reduce (frac (xorB (fneg x) (fneg y)) (fnum x * fden y) (fden x * fnum y))
  end
end
-- Division of two wholes PROMOTES to ℚ (ℕ is not closed under division), exactly as
-- subtraction promotes to ℤ: `a / b` is the fraction a/b in lowest terms. This is why
-- `16/5` works whether the operands are bare numerals OR bound Whole values (`$3/5`).
divWF : Whole -> Whole -> Frac is
  fn (a : Whole) (b : Whole) is reduce (frac false a b) end
end

-- DIVISION, with PROMOTION.  `Div A` is the class "an A divides (by an A) to a Frac";
-- its dictionary is the operation `A -> A -> Frac`. The result is ALWAYS Frac, so —
-- unlike SubR — it is keyed by the single operand type A with the codomain fixed, a
-- DISTINCT structure from `SubR R A` (which is `A -> A -> R`), so the instances do
-- not collide. Whole / Whole and Frac / Frac both land at Frac; a bound Whole result
-- divides just like a numeral literal does (`$3 / 5` = `16/5`).
Div : U -> U is fn (A : U) is A -> A -> Frac end end
instance divWhole : Div Whole is divWF end
instance divFrac  : Div Frac  is divF end
/ : {A : U} -> {d : Div A} -> A -> A -> Frac is
  fn {A : U} {d : Div A} (x : A) (y : A) is d x y end
end

-- Negation at Frac flips the sign. 0 stays unsigned in display. This is the Frac
-- instance of the promoting `negate` (defined after the Int rung, below).
fnegate : Frac -> Frac is fn (f : Frac) is frac (not (fneg f)) (fnum f) (fden f) end end

-- Fraction arithmetic — the Frac instances of the tower's `* + -`. Multiplication
-- is componentwise with sign xor; addition puts the operands over the common
-- denominator b·d and, since fractions are SIGNED, either adds the magnitudes
-- (like signs) or subtracts the smaller from the larger and takes the larger's
-- sign (unlike signs); subtraction is addition of the negation. Every result is
-- reduced to lowest terms (`reduce`, defined with `/` above).
mulF : Frac -> Frac -> Frac is
  fn (x : Frac) (y : Frac) is
    reduce (frac (xorB (fneg x) (fneg y)) (mulW (fnum x) (fnum y)) (mulW (fden x) (fden y)))
  end
end
addF : Frac -> Frac -> Frac is
  fn (x : Frac) (y : Frac) is
    let ad : Whole = mulW (fnum x) (fden y) in
    let cb : Whole = mulW (fnum y) (fden x) in
    let bd : Whole = mulW (fden x) (fden y) in
    reduce (case xorB (fneg x) (fneg y) of
    | false -> frac (fneg x) (addW ad cb) bd
    | true ->
        case leb cb ad of
        | true  -> frac (fneg x) (subW ad cb) bd
        | false -> frac (fneg y) (subW cb ad) bd
        end
    end)
  end
end
subF : Frac -> Frac -> Frac is fn (x : Frac) (y : Frac) is addF x (fnegate y) end end

-- Frac's full rung is a DivRing: reciprocal swaps numerator and denominator
-- (keeping the sign); recip of zero is the junk value zero itself (0/1),
-- per the ops-ladder convention. A reduced fraction swaps to a reduced
-- fraction, so no re-reduce is needed.
recipF : Frac -> Frac is
  fn (f : Frac) is
    case fnum f of
    | zero -> f
    | succ k -> frac (fneg f) (fden f) (fnum f)
    end
  end
end
divRingFrac : DivRing Frac is
  mkDivRing Frac
    (mkRing Frac (mkSemiring Frac addF (frac false zero (succ zero)) mulF (frac false (succ zero) (succ zero))) fnegate)
    recipF
end
instance semiringFrac : Semiring Frac is divRingFrac.1.1 end

-- ====================================================================
-- THE INT RUNG (ℤ).  Whole is not closed under subtraction, so `-` PROMOTES into
-- the signed integers. Int is JUNK-FREE: `nonneg n` denotes n and `negsucc k`
-- denotes -(k+1), so every constructor application is a distinct integer and
-- there is no representation outside the normalized image. The prior
-- sign+magnitude encoding needed a normalizing smart constructor because
-- `int true zero` and `int false zero` were TWO values denoting the same
-- integer zero, a negative-zero junk value that sat outside the smart
-- constructor's image and poisoned any law proved by pattern-matching the
-- representation (a case split on the raw constructor had to carry an extra
-- proof obligation identifying the two zeros). `intOf` injects a whole;
-- `builtin int` lets a bare numeral check at Int (so `(2-5) + 1` works, the
-- `1` becomes an Int).
-- ====================================================================
data Int : U is
  nonneg  : Whole -> Int
| negsucc : Whole -> Int
end
intOf : Whole -> Int is fn (n : Whole) is nonneg n end end
builtin int Int intOf
isign : Int -> Bool is
  fn (i : Int) is case i of | nonneg n -> false | negsucc k -> true end end
end
imag : Int -> Whole is
  fn (i : Int) is case i of | nonneg n -> n | negsucc k -> succ k end end
end
ineg : Int -> Int is
  fn (i : Int) is
    case i of
    | nonneg n -> case n of | zero -> nonneg zero | succ k -> negsucc k end
    | negsucc k -> nonneg (succ k)
    end
  end
end
-- THE PROMOTION: whole minus whole, as a signed integer.
wsub : Whole -> Whole -> Int is
  fn (a : Whole) (b : Whole) is
    case leb b a of
    | true -> nonneg (subW a b)
    | false -> negsucc (subW b (succ a))
    end
  end
end
iadd : Int -> Int -> Int is
  fn (x : Int) (y : Int) is
    case x of
    | nonneg a ->
        case y of
        | nonneg c -> nonneg (addW a c)
        | negsucc d -> wsub a (succ d)
        end
    | negsucc b ->
        case y of
        | nonneg c -> wsub c (succ b)
        | negsucc d -> negsucc (succ (addW b d))
        end
    end
  end
end
isub : Int -> Int -> Int is fn (x : Int) (y : Int) is iadd x (ineg y) end end
imul : Int -> Int -> Int is
  fn (x : Int) (y : Int) is
    case x of
    | nonneg a ->
        case y of
        | nonneg c -> nonneg (mulW a c)
        | negsucc d -> ineg (nonneg (mulW a (succ d)))
        end
    | negsucc b ->
        case y of
        | nonneg c -> ineg (nonneg (mulW (succ b) c))
        | negsucc d -> nonneg (mulW (succ b) (succ d))
        end
    end
  end
end
-- Int's full rung is a Ring (ℤ is not closed under reciprocal; division
-- promotes to Frac via divIF below).
ringInt : Ring Int is
  mkRing Int (mkSemiring Int iadd (nonneg zero) imul (nonneg (succ zero))) ineg
end
instance semiringInt : Semiring Int is ringInt.1 end

-- Int / Int climbs to ℚ, exactly as Whole / Whole does (ℤ is not closed under
-- division). So `-1` (an Int from prefix `-`) divides: `-1/3` is the Frac -1/3.
divIF : Int -> Int -> Frac is
  fn (x : Int) (y : Int) is reduce (frac (xorB (isign x) (isign y)) (imag x) (imag y)) end
end
instance divInt : Div Int is divIF end

-- Build a signed Int from a Bool sign + Whole magnitude, normalizing away
-- negative zero: for sites below that hold a sign and a magnitude apart
-- (a demotion from Frac, a parsed sign, a Binary encoder) rather than a
-- value already committed to nonneg/negsucc.
signOfMag : Bool -> Whole -> Int is
  fn (s : Bool) (m : Whole) is
    case s of
    | false -> nonneg m
    | true -> case m of | zero -> nonneg zero | succ k -> negsucc k end
    end
  end
end

-- ====================================================================
-- NEGATION, with PROMOTION.  Negating an unsigned `Whole` has no whole answer, so
-- `negate` PROMOTES Whole -> Int, exactly as `-` does (`0 - 3` is `-3 : Int`); Int
-- and Frac are already signed and stay put. Result-indexed like `SubR` (the result
-- R is a separate parameter keyed by the operand A), so a bare `-3` lands at Int and
-- `-1/3` at Frac. Prefix `-` desugars to `negate`.
-- ====================================================================
NegR : U -> U -> U is fn (R : U) (A : U) is A -> R end end
wneg : Whole -> Int is fn (n : Whole) is ineg (nonneg n) end end
instance negWhole : NegR Int  Whole is wneg end
instance negInt   : NegR Int  Int   is ineg end
instance negFrac  : NegR Frac Frac  is fnegate end
negate : {R : U} -> {A : U} -> {d : NegR R A} -> A -> R is
  fn {R : U} {A : U} {d : NegR R A} (x : A) is d x end
end

-- ====================================================================
-- SUBTRACTION, with PROMOTION.  `SubR R A` is the RELATION "an A subtracts to an
-- R": its dictionary is just the operation `A -> A -> R`. Indexing the RESULT type
-- R as a separate parameter (keyed by A, the last argument) makes the instances
-- distinct AND lets the result type be a plain inferred type rather than a stuck
-- projection — so `(2 - 5) + 1` composes. Whole − Whole promotes to Int, Int − Int
-- stays Int, Frac − Frac stays Frac. `2 - 5` is `-3 : Int`, `5 - 2` is `3 : Int`,
-- `1/3 - 2/3` is `-1/3 : Frac`. Whole − Whole has no whole answer, so `-` will not
-- type-check at Whole — use `monus`/`minus` (below) for a whole result.
-- ====================================================================
SubR : U -> U -> U is fn (R : U) (A : U) is A -> A -> R end end
instance subWhole : SubR Int  Whole is wsub end
instance subInt   : SubR Int  Int   is isub end
instance subFrac  : SubR Frac Frac  is subF end
- : {R : U} -> {A : U} -> {d : SubR R A} -> A -> A -> R is
  fn {R : U} {A : U} {d : SubR R A} (x : A) (y : A) is d x y end
end

-- ====================================================================
-- LAW STATEMENTS (v4). Reusable propositions over raw operations; the law
-- RECORDS chain them with a non-dependent And. Laws are SEPARATE from the
-- ops classes so proof-free carriers (IEEE754, later) still get ops.
-- ====================================================================
And : U -> U -> U is fn (P : U) (Q : U) is Sig P (fn (_p : P) is Q end) end end
mkAnd : (P : U) -> (Q : U) -> P -> Q -> And P Q is
  fn (P : U) (Q : U) (p : P) (q : Q) is Pair P (fn (_p : P) is Q end) p q end
end

AssocT : (A : U) -> (A -> A -> A) -> U is
  fn (A : U) (f : A -> A -> A) is (a : A) -> (b : A) -> (c : A) -> Eq A (f (f a b) c) (f a (f b c)) end
end
CommT : (A : U) -> (A -> A -> A) -> U is
  fn (A : U) (f : A -> A -> A) is (a : A) -> (b : A) -> Eq A (f a b) (f b a) end
end
IdLT : (A : U) -> (A -> A -> A) -> A -> U is
  fn (A : U) (f : A -> A -> A) (e : A) is (a : A) -> Eq A (f e a) a end
end
IdRT : (A : U) -> (A -> A -> A) -> A -> U is
  fn (A : U) (f : A -> A -> A) (e : A) is (a : A) -> Eq A (f a e) a end
end
DistribLT : (A : U) -> (A -> A -> A) -> (A -> A -> A) -> U is
  fn (A : U) (add : A -> A -> A) (mul : A -> A -> A) is
    (a : A) -> (b : A) -> (c : A) -> Eq A (mul a (add b c)) (add (mul a b) (mul a c))
  end
end
DistribRT : (A : U) -> (A -> A -> A) -> (A -> A -> A) -> U is
  fn (A : U) (add : A -> A -> A) (mul : A -> A -> A) is
    (a : A) -> (b : A) -> (c : A) -> Eq A (mul (add a b) c) (add (mul a c) (mul b c))
  end
end
AnnihLT : (A : U) -> (A -> A -> A) -> A -> U is
  fn (A : U) (mul : A -> A -> A) (z : A) is (a : A) -> Eq A (mul z a) z end
end
AnnihRT : (A : U) -> (A -> A -> A) -> A -> U is
  fn (A : U) (mul : A -> A -> A) (z : A) is (a : A) -> Eq A (mul a z) z end
end

-- The semiring laws over an ops instance: additive commutative monoid,
-- multiplicative monoid, distributivity both sides, zero annihilates.
SemiringLaws : (A : U) -> Semiring A -> U is
  fn (A : U) (s : Semiring A) is
    And (AssocT A (s.1))
    (And (CommT A (s.1))
    (And (IdLT A (s.1) (s.2.1))
    (And (IdRT A (s.1) (s.2.1))
    (And (AssocT A (s.2.2.1))
    (And (IdLT A (s.2.2.1) (s.2.2.2))
    (And (IdRT A (s.2.2.1) (s.2.2.2))
    (And (DistribLT A (s.1) (s.2.2.1))
    (And (DistribRT A (s.1) (s.2.2.1))
    (And (AnnihLT A (s.2.2.1) (s.2.1))
         (AnnihRT A (s.2.2.1) (s.2.1)))))))))))
  end
end

-- ====================================================================
-- WHOLE'S SEMIRING LAWS, machine-checked. Proven over the raw kernels addW/mulW
-- (which semiringWhole's projections compute to definitionally), by WholeElim
-- induction with subst/symEq/transEq plumbing, mirroring the subWZeroL/subWSucc
-- proofs above and ch107's Nat semiring. addW recurses on its FIRST argument;
-- mulW steps by `addW ih n` (ih FIRST; the operand order differs from ch107's
-- `add n ih`, so the mul proofs are adapted, not transcribed).
-- ====================================================================

-- Local congruence (there is no ambient cong): rewrite under a Whole context.
congW : (f : Whole -> Whole) -> (x : Whole) -> (y : Whole) -> Eq Whole x y -> Eq Whole (f x) (f y) is
  fn (f : Whole -> Whole) (x : Whole) (y : Whole) (p : Eq Whole x y) is
    subst Whole x y p (fn (z : Whole) is Eq Whole (f x) (f z) end) (refl (f x))
  end
end

-- addW is associative (induction on the first argument).
addWAssoc : AssocT Whole addW is
  fn (a : Whole) (b : Whole) (c : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (addW (addW x b) c) (addW x (addW b c)) end)
      (refl (addW b c))
      (fn (k : Whole) (ih : Eq Whole (addW (addW k b) c) (addW k (addW b c))) is
         subst Whole (addW (addW k b) c) (addW k (addW b c)) ih
           (fn (z : Whole) is Eq Whole (succ (addW (addW k b) c)) (succ z) end)
           (refl (succ (addW (addW k b) c)))
       end)
      a
  end
end

-- addW zero a = a definitionally (addW recurses on its first argument).
addWZeroL : IdLT Whole addW zero is fn (a : Whole) is refl a end end

-- addW a zero = a (induction on a; the recursion is stuck on a neutral first arg).
addWZeroR : IdRT Whole addW zero is
  fn (a : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (addW x zero) x end)
      (refl zero)
      (fn (k : Whole) (ih : Eq Whole (addW k zero) k) is
         subst Whole (addW k zero) k ih
           (fn (z : Whole) is Eq Whole (addW (succ k) zero) (succ z) end)
           (refl (addW (succ k) zero))
       end)
      a
  end
end

-- Pushing a successor out of the second argument (mirrors ch107's addSuccR).
addWSuccR : (m : Whole) -> (n : Whole) -> Eq Whole (addW m (succ n)) (succ (addW m n)) is
  fn (m : Whole) (n : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (addW x (succ n)) (succ (addW x n)) end)
      (refl (succ n))
      (fn (k : Whole) (ih : Eq Whole (addW k (succ n)) (succ (addW k n))) is
         subst Whole (addW k (succ n)) (succ (addW k n)) ih
           (fn (z : Whole) is Eq Whole (addW (succ k) (succ n)) (succ z) end)
           (refl (addW (succ k) (succ n)))
       end)
      m
  end
end

-- addW is commutative (induction on the first argument; needs addWZeroR + addWSuccR).
addWComm : CommT Whole addW is
  fn (a : Whole) (b : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (addW x b) (addW b x) end)
      (subst Whole (addW b zero) b (addWZeroR b)
         (fn (z : Whole) is Eq Whole z (addW b zero) end)
         (refl (addW b zero)))
      (fn (k : Whole) (ih : Eq Whole (addW k b) (addW b k)) is
         subst Whole (succ (addW b k)) (addW b (succ k))
           (subst Whole (addW b (succ k)) (succ (addW b k)) (addWSuccR b k)
              (fn (z : Whole) is Eq Whole z (addW b (succ k)) end)
              (refl (addW b (succ k))))
           (fn (z : Whole) is Eq Whole (succ (addW k b)) z end)
           (subst Whole (addW k b) (addW b k) ih
              (fn (z : Whole) is Eq Whole (succ (addW k b)) (succ z) end)
              (refl (succ (addW k b))))
       end)
      a
  end
end

-- A rearrangement workhorse: (x + y) + w = (x + w) + y (from assoc + comm).
addWSwapR : (x : Whole) -> (y : Whole) -> (w : Whole) -> Eq Whole (addW (addW x y) w) (addW (addW x w) y) is
  fn (x : Whole) (y : Whole) (w : Whole) is
    transEq Whole (addW (addW x y) w) (addW x (addW y w)) (addW (addW x w) y)
      (addWAssoc x y w)
      (transEq Whole (addW x (addW y w)) (addW x (addW w y)) (addW (addW x w) y)
         (congW (fn (t : Whole) is addW x t end) (addW y w) (addW w y) (addWComm y w))
         (symEq Whole (addW (addW x w) y) (addW x (addW w y)) (addWAssoc x w y)))
  end
end

-- (a + x) + succ y = (a + y) + succ x (assoc + succ-shift + comm); feeds mulWSuccR.
addWShiftSucc : (a : Whole) -> (x : Whole) -> (y : Whole)
  -> Eq Whole (addW (addW a x) (succ y)) (addW (addW a y) (succ x)) is
  fn (a : Whole) (x : Whole) (y : Whole) is
    transEq Whole (addW (addW a x) (succ y)) (addW a (addW x (succ y))) (addW (addW a y) (succ x))
      (addWAssoc a x (succ y))
      (transEq Whole (addW a (addW x (succ y))) (addW a (succ (addW y x))) (addW (addW a y) (succ x))
         (congW (fn (t : Whole) is addW a t end) (addW x (succ y)) (succ (addW y x))
            (transEq Whole (addW x (succ y)) (succ (addW x y)) (succ (addW y x))
               (addWSuccR x y)
               (congW (fn (t : Whole) is succ t end) (addW x y) (addW y x) (addWComm x y))))
         (transEq Whole (addW a (succ (addW y x))) (addW a (addW y (succ x))) (addW (addW a y) (succ x))
            (congW (fn (t : Whole) is addW a t end) (succ (addW y x)) (addW y (succ x))
               (symEq Whole (addW y (succ x)) (succ (addW y x)) (addWSuccR y x)))
            (symEq Whole (addW (addW a y) (succ x)) (addW a (addW y (succ x))) (addWAssoc a y (succ x)))))
  end
end

-- mul zero a = 0 definitionally (mulW's zero case returns 0).
mulWZeroL : AnnihLT Whole mulW zero is fn (a : Whole) is refl zero end end

-- mul a zero = 0 (induction on a; addWZeroR mops up the stuck `addW _ zero`).
mulWZeroR : AnnihRT Whole mulW zero is
  fn (a : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (mulW x zero) zero end)
      (refl zero)
      (fn (k : Whole) (ih : Eq Whole (mulW k zero) zero) is
         transEq Whole (mulW (succ k) zero) (mulW k zero) zero
           (addWZeroR (mulW k zero))
           ih
       end)
      a
  end
end

-- RIGHT distributivity: (a + b) * c = a*c + b*c (induction on a).
distribWR : DistribRT Whole addW mulW is
  fn (a : Whole) (b : Whole) (c : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (mulW (addW x b) c) (addW (mulW x c) (mulW b c)) end)
      (refl (mulW b c))
      (fn (k : Whole) (ih : Eq Whole (mulW (addW k b) c) (addW (mulW k c) (mulW b c))) is
         transEq Whole
           (addW (mulW (addW k b) c) c)
           (addW (addW (mulW k c) (mulW b c)) c)
           (addW (addW (mulW k c) c) (mulW b c))
           (congW (fn (t : Whole) is addW t c end) (mulW (addW k b) c) (addW (mulW k c) (mulW b c)) ih)
           (addWSwapR (mulW k c) (mulW b c) c)
       end)
      a
  end
end

-- Multiplicative successor-shift: mul n (succ m) = mul n m + n (induction on n).
mulWSuccR : (n : Whole) -> (m : Whole) -> Eq Whole (mulW n (succ m)) (addW (mulW n m) n) is
  fn (n : Whole) (m : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (mulW x (succ m)) (addW (mulW x m) x) end)
      (refl zero)
      (fn (k : Whole) (ih : Eq Whole (mulW k (succ m)) (addW (mulW k m) k)) is
         transEq Whole
           (addW (mulW k (succ m)) (succ m))
           (addW (addW (mulW k m) k) (succ m))
           (addW (addW (mulW k m) m) (succ k))
           (congW (fn (t : Whole) is addW t (succ m) end) (mulW k (succ m)) (addW (mulW k m) k) ih)
           (addWShiftSucc (mulW k m) k m)
       end)
      n
  end
end

-- mul is commutative (induction on the first argument; needs mulWZeroR + mulWSuccR).
-- Named for Task 4 (commLawsWhole) even though SemiringLaws omits it.
mulWComm : CommT Whole mulW is
  fn (a : Whole) (b : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (mulW x b) (mulW b x) end)
      (subst Whole (mulW b zero) zero (mulWZeroR b)
         (fn (z : Whole) is Eq Whole z (mulW b zero) end)
         (refl (mulW b zero)))
      (fn (k : Whole) (ih : Eq Whole (mulW k b) (mulW b k)) is
         transEq Whole (mulW (succ k) b) (addW (mulW b k) b) (mulW b (succ k))
           (congW (fn (t : Whole) is addW t b end) (mulW k b) (mulW b k) ih)
           (symEq Whole (mulW b (succ k)) (addW (mulW b k) b) (mulWSuccR b k))
       end)
      a
  end
end

-- mul is associative (induction on a; the step turns on distribWR + congruence).
mulWAssoc : AssocT Whole mulW is
  fn (a : Whole) (b : Whole) (c : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (mulW (mulW x b) c) (mulW x (mulW b c)) end)
      (refl zero)
      (fn (k : Whole) (ih : Eq Whole (mulW (mulW k b) c) (mulW k (mulW b c))) is
         transEq Whole
           (mulW (mulW (succ k) b) c)
           (addW (mulW (mulW k b) c) (mulW b c))
           (mulW (succ k) (mulW b c))
           (distribWR (mulW k b) b c)
           (congW (fn (t : Whole) is addW t (mulW b c) end) (mulW (mulW k b) c) (mulW k (mulW b c)) ih)
       end)
      a
  end
end

-- mul (succ zero) a = a definitionally: mul (succ zero) a = addW 0 a = a.
mulWOneL : IdLT Whole mulW (succ zero) is fn (a : Whole) is refl a end end

-- mul a (succ zero) = a (from mulWSuccR + mulWZeroR, no induction here).
mulWOneR : IdRT Whole mulW (succ zero) is
  fn (a : Whole) is
    transEq Whole (mulW a (succ zero)) (addW (mulW a zero) a) a
      (mulWSuccR a zero)
      (congW (fn (t : Whole) is addW t a end) (mulW a zero) zero (mulWZeroR a))
  end
end

-- LEFT distributivity: a * (b + c) = a*b + a*c (from mulWComm + distribWR).
distribWL : DistribLT Whole addW mulW is
  fn (a : Whole) (b : Whole) (c : Whole) is
    transEq Whole
      (mulW a (addW b c))
      (mulW (addW b c) a)
      (addW (mulW a b) (mulW a c))
      (mulWComm a (addW b c))
      (transEq Whole
         (mulW (addW b c) a)
         (addW (mulW b a) (mulW c a))
         (addW (mulW a b) (mulW a c))
         (distribWR b c a)
         (transEq Whole
            (addW (mulW b a) (mulW c a))
            (addW (mulW a b) (mulW c a))
            (addW (mulW a b) (mulW a c))
            (congW (fn (t : Whole) is addW t (mulW c a) end) (mulW b a) (mulW a b) (mulWComm b a))
            (congW (fn (t : Whole) is addW (mulW a b) t end) (mulW c a) (mulW a c) (mulWComm c a))))
  end
end

-- The assembled record. Stated over semiringWhole, whose projections compute to
-- addW/zero/mulW/(succ zero), so the raw-kernel lemmas check on the nose.
semiringLawsWhole : SemiringLaws Whole semiringWhole is
  mkAnd (AssocT Whole addW)
        (And (CommT Whole addW)
        (And (IdLT Whole addW zero)
        (And (IdRT Whole addW zero)
        (And (AssocT Whole mulW)
        (And (IdLT Whole mulW (succ zero))
        (And (IdRT Whole mulW (succ zero))
        (And (DistribLT Whole addW mulW)
        (And (DistribRT Whole addW mulW)
        (And (AnnihLT Whole mulW zero)
             (AnnihRT Whole mulW zero))))))))))
    addWAssoc
    (mkAnd (CommT Whole addW)
          (And (IdLT Whole addW zero)
          (And (IdRT Whole addW zero)
          (And (AssocT Whole mulW)
          (And (IdLT Whole mulW (succ zero))
          (And (IdRT Whole mulW (succ zero))
          (And (DistribLT Whole addW mulW)
          (And (DistribRT Whole addW mulW)
          (And (AnnihLT Whole mulW zero)
               (AnnihRT Whole mulW zero)))))))))
      addWComm
      (mkAnd (IdLT Whole addW zero)
            (And (IdRT Whole addW zero)
            (And (AssocT Whole mulW)
            (And (IdLT Whole mulW (succ zero))
            (And (IdRT Whole mulW (succ zero))
            (And (DistribLT Whole addW mulW)
            (And (DistribRT Whole addW mulW)
            (And (AnnihLT Whole mulW zero)
                 (AnnihRT Whole mulW zero))))))))
        addWZeroL
        (mkAnd (IdRT Whole addW zero)
              (And (AssocT Whole mulW)
              (And (IdLT Whole mulW (succ zero))
              (And (IdRT Whole mulW (succ zero))
              (And (DistribLT Whole addW mulW)
              (And (DistribRT Whole addW mulW)
              (And (AnnihLT Whole mulW zero)
                   (AnnihRT Whole mulW zero)))))))
          addWZeroR
          (mkAnd (AssocT Whole mulW)
                (And (IdLT Whole mulW (succ zero))
                (And (IdRT Whole mulW (succ zero))
                (And (DistribLT Whole addW mulW)
                (And (DistribRT Whole addW mulW)
                (And (AnnihLT Whole mulW zero)
                     (AnnihRT Whole mulW zero))))))
            mulWAssoc
            (mkAnd (IdLT Whole mulW (succ zero))
                  (And (IdRT Whole mulW (succ zero))
                  (And (DistribLT Whole addW mulW)
                  (And (DistribRT Whole addW mulW)
                  (And (AnnihLT Whole mulW zero)
                       (AnnihRT Whole mulW zero)))))
              mulWOneL
              (mkAnd (IdRT Whole mulW (succ zero))
                    (And (DistribLT Whole addW mulW)
                    (And (DistribRT Whole addW mulW)
                    (And (AnnihLT Whole mulW zero)
                         (AnnihRT Whole mulW zero))))
                mulWOneR
                (mkAnd (DistribLT Whole addW mulW)
                      (And (DistribRT Whole addW mulW)
                      (And (AnnihLT Whole mulW zero)
                           (AnnihRT Whole mulW zero)))
                  distribWL
                  (mkAnd (DistribRT Whole addW mulW)
                        (And (AnnihLT Whole mulW zero)
                             (AnnihRT Whole mulW zero))
                    distribWR
                    (mkAnd (AnnihLT Whole mulW zero)
                           (AnnihRT Whole mulW zero)
                      mulWZeroL
                      mulWZeroR)))))))))
end

-- ====================================================================
-- RING / DIVRING / COMM LAWS (v4, next rung). RingLaws layers additive
-- inverses onto SemiringLaws; DivRingLaws layers multiplicative inverses
-- (guarded by a nonzero PREDICATE, since the prelude has no ambient
-- negation type to state "nonzero" uniformly). Commutativity is its OWN
-- record: a commutative ring is Ring + RingLaws + CommLaws; a field is
-- DivRing + DivRingLaws + CommLaws; a Quaternion (later) is a DivRing
-- withOUT CommLaws. Whole's CommLaws instance is free from mulWComm.
-- ====================================================================
NegInvLT : (A : U) -> (A -> A -> A) -> (A -> A) -> A -> U is
  fn (A : U) (add : A -> A -> A) (neg : A -> A) (z : A) is (a : A) -> Eq A (add (neg a) a) z end
end
NegInvRT : (A : U) -> (A -> A -> A) -> (A -> A) -> A -> U is
  fn (A : U) (add : A -> A -> A) (neg : A -> A) (z : A) is (a : A) -> Eq A (add a (neg a)) z end
end
RecipInvLT : (A : U) -> (A -> A -> A) -> (A -> A) -> A -> (A -> U) -> U is
  fn (A : U) (mul : A -> A -> A) (rc : A -> A) (o : A) (nz : A -> U) is
    (x : A) -> nz x -> Eq A (mul (rc x) x) o
  end
end
RecipInvRT : (A : U) -> (A -> A -> A) -> (A -> A) -> A -> (A -> U) -> U is
  fn (A : U) (mul : A -> A -> A) (rc : A -> A) (o : A) (nz : A -> U) is
    (x : A) -> nz x -> Eq A (mul x (rc x)) o
  end
end

-- Ring laws = semiring laws over the embedded semiring + additive inverses.
RingLaws : (A : U) -> Ring A -> U is
  fn (A : U) (r : Ring A) is
    And (SemiringLaws A (r.1))
    (And (NegInvLT A (r.1.1) (r.2) (r.1.2.1))
         (NegInvRT A (r.1.1) (r.2) (r.1.2.1)))
  end
end

-- DivRing laws take a nonzero PREDICATE nz (each carrier states nonzeroness
-- its own way; the prelude has no ambient negation type). recip zero is junk
-- by convention, so the inverse laws are guarded by nz.
DivRingLaws : (A : U) -> DivRing A -> (A -> U) -> U is
  fn (A : U) (d : DivRing A) (nz : A -> U) is
    And (RingLaws A (d.1))
    (And (RecipInvLT A (d.1.1.2.2.1) (d.2) (d.1.1.2.2.2) nz)
         (RecipInvRT A (d.1.1.2.2.1) (d.2) (d.1.1.2.2.2) nz))
  end
end

-- Commutativity is its own record: a commutative ring is Ring + RingLaws +
-- CommLaws; a field is DivRing + DivRingLaws + CommLaws; Quaternion (later)
-- is a DivRing withOUT CommLaws. Whole's instance is free from mulWComm.
CommLaws : (A : U) -> Semiring A -> U is
  fn (A : U) (s : Semiring A) is CommT A (s.2.2.1) end
end
commLawsWhole : CommLaws Whole semiringWhole is mulWComm end

-- ====================================================================
-- THE LOWER LADDER (v4 full ladder). Laws for the append-family ops
-- shapes: a semigroup is a magma with associativity, a monoid adds the
-- identity laws, a commutative monoid adds commutativity. Whole sits on
-- the CommMonoid rung twice - under addition and under multiplication -
-- with every law already proven above. These are plain defs, not
-- instance-table entries: registering Magma Whole would make `++` mean
-- addition (the Raku lesson: keep `+` arithmetic, `++` append).
-- ====================================================================
-- (No witness or consumer yet: this is the lawful level the Magma rename
-- freed the name for; String's associativity candidate lives in the
-- listings over the rune-list view, not the packed carrier.)
SemigroupLaws : (A : U) -> Magma A -> U is
  fn (A : U) (m : Magma A) is AssocT A m end
end
MonoidLaws : (A : U) -> Monoid A -> U is
  fn (A : U) (d : Monoid A) is
    And (AssocT A (d.1)) (And (IdLT A (d.1) (d.2)) (IdRT A (d.1) (d.2)))
  end
end
CommMonoidLaws : (A : U) -> Monoid A -> U is
  fn (A : U) (d : Monoid A) is And (MonoidLaws A d) (CommT A (d.1)) end
end

monoidWholeAdd : Monoid Whole is mkMonoid Whole addW zero end
monoidWholeMul : Monoid Whole is mkMonoid Whole mulW (succ zero) end

commMonoidLawsWholeAdd : CommMonoidLaws Whole monoidWholeAdd is
  mkAnd (MonoidLaws Whole monoidWholeAdd) (CommT Whole addW)
    (mkAnd (AssocT Whole addW)
      (And (IdLT Whole addW zero) (IdRT Whole addW zero))
      addWAssoc
      (mkAnd (IdLT Whole addW zero) (IdRT Whole addW zero) addWZeroL addWZeroR))
    addWComm
end
commMonoidLawsWholeMul : CommMonoidLaws Whole monoidWholeMul is
  mkAnd (MonoidLaws Whole monoidWholeMul) (CommT Whole mulW)
    (mkAnd (AssocT Whole mulW)
      (And (IdLT Whole mulW (succ zero)) (IdRT Whole mulW (succ zero)))
      mulWAssoc
      (mkAnd (IdLT Whole mulW (succ zero)) (IdRT Whole mulW (succ zero)) mulWOneL mulWOneR))
    mulWComm
end

-- ====================================================================
-- THE UPPER LADDER (v4 full ladder). Group laws layer the two inverse
-- laws onto MonoidLaws; AbGroupLaws adds commutativity. The classical
-- top rungs are law bundles over the shipped ops shapes: a commutative
-- ring is Ring + RingLaws + CommLaws (over the embedded semiring), a
-- field is DivRing + DivRingLaws + CommLaws. These are plain defs, not
-- instance-table entries: this task ships no Group value.
-- ====================================================================

-- Group laws = monoid laws + the two inverse laws. NegInvLT/RT are
-- already generic in (op, inv, e), so they serve groups verbatim.
GroupLaws : (A : U) -> Group A -> U is
  fn (A : U) (g : Group A) is
    And (MonoidLaws A (g.1))
    (And (NegInvLT A (g.1.1) (g.2) (g.1.2))
         (NegInvRT A (g.1.1) (g.2) (g.1.2)))
  end
end
AbGroupLaws : (A : U) -> Group A -> U is
  fn (A : U) (g : Group A) is And (GroupLaws A g) (CommT A (g.1.1)) end
end

-- The classical top rungs as law bundles over the shipped ops shapes:
-- a commutative ring is a Ring whose multiplication commutes; a field is
-- a DivRing whose multiplication commutes.
CommRingLaws : (A : U) -> Ring A -> U is
  fn (A : U) (r : Ring A) is And (RingLaws A r) (CommLaws A (r.1)) end
end
FieldLaws : (A : U) -> DivRing A -> (A -> U) -> U is
  fn (A : U) (d : DivRing A) (nz : A -> U) is
    And (DivRingLaws A d nz) (CommLaws A (d.1.1))
  end
end

-- ====================================================================
-- THE LADDER'S EDGES. Every classical containment is a FUNCTION with a
-- proven law transport: a ring IS an abelian group under addition and a
-- monoid under multiplication. Transports are pure reassembly - project
-- the law out of the source And-chain, rebuild the target chain. When
-- Int's RingLaws land (deferred campaign), groupLawsOfRing instantly
-- yields Int's AbGroup; the bridges are written once, here.
-- ====================================================================
magmaOfMonoid : (A : U) -> Monoid A -> Magma A is
  fn (A : U) (d : Monoid A) is d.1 end
end
monoidOfGroup : (A : U) -> Group A -> Monoid A is
  fn (A : U) (g : Group A) is g.1 end
end
addMonoidOfSemiring : (A : U) -> Semiring A -> Monoid A is
  fn (A : U) (s : Semiring A) is mkMonoid A (s.1) (s.2.1) end
end
mulMonoidOfSemiring : (A : U) -> Semiring A -> Monoid A is
  fn (A : U) (s : Semiring A) is mkMonoid A (s.2.2.1) (s.2.2.2) end
end
groupOfRing : (A : U) -> Ring A -> Group A is
  fn (A : U) (r : Ring A) is mkGroup A (addMonoidOfSemiring A (r.1)) (r.2) end
end

-- Named slot extractors for the SemiringLaws And-chain (nicer than raw
-- .2.2... trails at every use site; the chain order is documented at the
-- record). Only the slots the transports need are named.
srlAddAssoc : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> AssocT A (s.1) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is l.1 end
end
srlAddComm : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> CommT A (s.1) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is l.2.1 end
end
srlAddZeroL : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> IdLT A (s.1) (s.2.1) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is l.2.2.1 end
end
srlAddZeroR : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> IdRT A (s.1) (s.2.1) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is l.2.2.2.1 end
end
srlMulAssoc : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> AssocT A (s.2.2.1) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is l.2.2.2.2.1 end
end
srlMulOneL : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> IdLT A (s.2.2.1) (s.2.2.2) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is l.2.2.2.2.2.1 end
end
srlMulOneR : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> IdRT A (s.2.2.1) (s.2.2.2) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is l.2.2.2.2.2.2.1 end
end

addCommMonoidLawsOfSemiring : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> CommMonoidLaws A (addMonoidOfSemiring A s) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is
    mkAnd (MonoidLaws A (addMonoidOfSemiring A s)) (CommT A (s.1))
      (mkAnd (AssocT A (s.1))
        (And (IdLT A (s.1) (s.2.1)) (IdRT A (s.1) (s.2.1)))
        (srlAddAssoc A s l)
        (mkAnd (IdLT A (s.1) (s.2.1)) (IdRT A (s.1) (s.2.1)) (srlAddZeroL A s l) (srlAddZeroR A s l)))
      (srlAddComm A s l)
  end
end
mulMonoidLawsOfSemiring : (A : U) -> (s : Semiring A) -> SemiringLaws A s -> MonoidLaws A (mulMonoidOfSemiring A s) is
  fn (A : U) (s : Semiring A) (l : SemiringLaws A s) is
    mkAnd (AssocT A (s.2.2.1))
      (And (IdLT A (s.2.2.1) (s.2.2.2)) (IdRT A (s.2.2.1) (s.2.2.2)))
      (srlMulAssoc A s l)
      (mkAnd (IdLT A (s.2.2.1) (s.2.2.2)) (IdRT A (s.2.2.1) (s.2.2.2)) (srlMulOneL A s l) (srlMulOneR A s l))
  end
end
groupLawsOfRing : (A : U) -> (r : Ring A) -> RingLaws A r -> GroupLaws A (groupOfRing A r) is
  fn (A : U) (r : Ring A) (l : RingLaws A r) is
    mkAnd (MonoidLaws A (addMonoidOfSemiring A (r.1)))
      (And (NegInvLT A (r.1.1) (r.2) (r.1.2.1)) (NegInvRT A (r.1.1) (r.2) (r.1.2.1)))
      (mkAnd (AssocT A (r.1.1))
        (And (IdLT A (r.1.1) (r.1.2.1)) (IdRT A (r.1.1) (r.1.2.1)))
        (srlAddAssoc A (r.1) (l.1))
        (mkAnd (IdLT A (r.1.1) (r.1.2.1)) (IdRT A (r.1.1) (r.1.2.1)) (srlAddZeroL A (r.1) (l.1)) (srlAddZeroR A (r.1) (l.1))))
      (mkAnd (NegInvLT A (r.1.1) (r.2) (r.1.2.1)) (NegInvRT A (r.1.1) (r.2) (r.1.2.1)) (l.2.1) (l.2.2))
  end
end
abGroupLawsOfRing : (A : U) -> (r : Ring A) -> RingLaws A r -> AbGroupLaws A (groupOfRing A r) is
  fn (A : U) (r : Ring A) (l : RingLaws A r) is
    mkAnd (GroupLaws A (groupOfRing A r)) (CommT A (r.1.1))
      (groupLawsOfRing A r l)
      (srlAddComm A (r.1) (l.1))
  end
end

-- ====================================================================
-- THE MONUS / ORDER LIBRARY + wsubEq (Int ring-laws campaign, Task 2).
-- The keystone `wsubEq` proves that `wsub` (the Whole-difference into Int)
-- respects cross-equal differences: a + d = c + b implies a - b = c - d as
-- signed integers. It is the transport lemma the Int ring laws stand on.
-- Everything here is machine-checked by WholeElim induction over the raw
-- kernels (leb recurses on its first arg, subW on its second, addW on its
-- first), with the shipped subst/symEq/transEq/congW plumbing.
-- ====================================================================

-- succ is injective: cancel a successor by congruence on `pred`
-- (pred (succ a) = a definitionally, so the congW result IS Eq Whole a b).
succInj : (a : Whole) -> (b : Whole) -> Eq Whole (succ a) (succ b) -> Eq Whole a b is
  fn (a : Whole) (b : Whole) (p : Eq Whole (succ a) (succ b)) is
    congW pred (succ a) (succ b) p
  end
end

-- EX-FALSO from a Bool absurdity (the idiom later tasks reuse). Given a proof
-- that `true = false`, ANY goal G follows: subst along the discriminant with a
-- Bool-CASE motive whose true-arm is trivially inhabited (Eq Bool true true,
-- by refl) and whose false-arm is G. `subst … (refl true)` transports the
-- true-arm witness to the false-arm, i.e. to G. This discharges impossible
-- case branches WITHOUT an Empty type.
boolDiscTF : (G : U) -> Eq Bool true false -> G is
  fn (G : U) (h : Eq Bool true false) is
    subst Bool true false h
      (fn (z : Bool) is
         case z of
         | true -> Eq Bool true true
         | false -> G
         end
       end)
      (refl true)
  end
end

-- Case on a Bool while RETAINING the discriminant equation. Ordinary BoolElim
-- forgets that the bound tag equals the scrutinee; here the motive is
-- `Eq Bool g x -> P x`, so applying the eliminated result to `refl g` hands
-- each arm a proof that the guard equals its tag. The order-transfer proofs
-- below need those equations to reduce `wsub` and to invoke `subWAddCancel`.
boolCaseEq : (g : Bool) -> (P : Bool -> U)
  -> (Eq Bool g true -> P true) -> (Eq Bool g false -> P false) -> P g is
  fn (g : Bool) (P : Bool -> U)
     (ht : Eq Bool g true -> P true) (hf : Eq Bool g false -> P false) is
    BoolElim (fn (x : Bool) is Eq Bool g x -> P x end) ht hf g (refl g)
  end
end

-- Congruence from Whole into Int through the two Int constructors (there is no
-- ambient cong across types; these lift a Whole equality onto nonneg/negsucc).
congNonneg : (x : Whole) -> (y : Whole) -> Eq Whole x y -> Eq Int (nonneg x) (nonneg y) is
  fn (x : Whole) (y : Whole) (p : Eq Whole x y) is
    subst Whole x y p (fn (z : Whole) is Eq Int (nonneg x) (nonneg z) end) (refl (nonneg x))
  end
end
congNegsucc : (x : Whole) -> (y : Whole) -> Eq Whole x y -> Eq Int (negsucc x) (negsucc y) is
  fn (x : Whole) (y : Whole) (p : Eq Whole x y) is
    subst Whole x y p (fn (z : Whole) is Eq Int (negsucc x) (negsucc z) end) (refl (negsucc x))
  end
end

-- COMPLETENESS of the decidable order: leb is total, so `leb a b = false`
-- forces `leb b a = true`. Double induction (leb recurses on the first arg);
-- the zero-vs-zero corner is impossible and discharged by boolDiscTF.
lebComplete : (a : Whole) -> (b : Whole) -> Eq Bool (leb a b) false -> Eq Bool (leb b a) true is
  fn (a : Whole) is
    WholeElim (fn (x : Whole) is (b : Whole) -> Eq Bool (leb x b) false -> Eq Bool (leb b x) true end)
      (fn (b : Whole) (h : Eq Bool (leb zero b) false) is
         boolDiscTF (Eq Bool (leb b zero) true) h end)
      (fn (k : Whole) (ih : (b : Whole) -> Eq Bool (leb k b) false -> Eq Bool (leb b k) true) is
         fn (b : Whole) is
           WholeElim (fn (y : Whole) is Eq Bool (leb (succ k) y) false -> Eq Bool (leb y (succ k)) true end)
             (fn (h : Eq Bool (leb (succ k) zero) false) is refl true end)
             (fn (j : Whole) (ihb : Eq Bool (leb (succ k) j) false -> Eq Bool (leb j (succ k)) true) is
                fn (h : Eq Bool (leb (succ k) (succ j)) false) is ih j h end end)
             b
         end end)
      a
  end
end

-- The monus cancellation lemma: when `b <= a`, adding `b` back to `a - b`
-- recovers `a`. Induction on the recursed variable `b` (subW steps on it,
-- addW steps on it); the a=zero-under-succ corner is impossible (b <= 0 with
-- b a successor) and is discharged by boolDiscTF. subWSucc peels the matched
-- successors so the induction hypothesis applies.
subWAddCancel : (a : Whole) -> (b : Whole) -> Eq Bool (leb b a) true -> Eq Whole (addW b (subW a b)) a is
  fn (a : Whole) (b : Whole) is
    WholeElim (fn (x : Whole) is (m : Whole) -> Eq Bool (leb x m) true -> Eq Whole (addW x (subW m x)) m end)
      (fn (m : Whole) (h : Eq Bool (leb zero m) true) is refl m end)
      (fn (k : Whole) (ih : (m : Whole) -> Eq Bool (leb k m) true -> Eq Whole (addW k (subW m k)) m) is
         fn (m : Whole) is
           WholeElim (fn (y : Whole) is Eq Bool (leb (succ k) y) true -> Eq Whole (addW (succ k) (subW y (succ k))) y end)
             (fn (h : Eq Bool (leb (succ k) zero) true) is
                boolDiscTF (Eq Whole (addW (succ k) (subW zero (succ k))) zero)
                  (symEq Bool (leb (succ k) zero) true h) end)
             (fn (j : Whole) (ihb : Eq Bool (leb (succ k) j) true -> Eq Whole (addW (succ k) (subW j (succ k))) j) is
                fn (h : Eq Bool (leb (succ k) (succ j)) true) is
                  congW (fn (t : Whole) is succ t end) (addW k (subW (succ j) (succ k))) j
                    (transEq Whole (addW k (subW (succ j) (succ k))) (addW k (subW j k)) j
                       (congW (fn (t : Whole) is addW k t end) (subW (succ j) (succ k)) (subW j k) (subWSucc j k))
                       (ih j h))
                end end)
             m
         end end)
      b
      a
  end
end

-- LEFT cancellation of addW: `k + a = k + b` implies `a = b`. Induction on the
-- prefix `k` (addW recurses on its first arg); each step strips one successor
-- with succInj and defers to the hypothesis.
addWCancelL : (k : Whole) -> (a : Whole) -> (b : Whole) -> Eq Whole (addW k a) (addW k b) -> Eq Whole a b is
  fn (k : Whole) (a : Whole) (b : Whole) is
    WholeElim (fn (x : Whole) is Eq Whole (addW x a) (addW x b) -> Eq Whole a b end)
      (fn (h : Eq Whole (addW zero a) (addW zero b)) is h end)
      (fn (n : Whole) (ih : Eq Whole (addW n a) (addW n b) -> Eq Whole a b) is
         fn (h : Eq Whole (addW (succ n) a) (addW (succ n) b)) is
           ih (succInj (addW n a) (addW n b) h)
         end end)
      k
  end
end

-- Order reflexivity through addition: m <= m + n, always. Induction on m (both
-- leb and addW recurse on their first arg, so the successor case reduces the
-- goal straight onto the hypothesis).
lebSelfAddR : (m : Whole) -> (n : Whole) -> Eq Bool (leb m (addW m n)) true is
  fn (m : Whole) (n : Whole) is
    WholeElim (fn (x : Whole) is Eq Bool (leb x (addW x n)) true end)
      (refl true)
      (fn (k : Whole) (ih : Eq Bool (leb k (addW k n)) true) is ih end)
      m
  end
end

-- STRICT completeness: `leb b a = false` (i.e. a < b) gives `leb (succ a) b`
-- = true (a + 1 <= b). Double induction mirroring lebComplete; the recursive
-- call sits in exactly one arm, the corners are refl / boolDiscTF.
lebComplStrict : (a : Whole) -> (b : Whole) -> Eq Bool (leb b a) false -> Eq Bool (leb (succ a) b) true is
  fn (a : Whole) (b : Whole) is
    WholeElim (fn (y : Whole) is (w : Whole) -> Eq Bool (leb y w) false -> Eq Bool (leb (succ w) y) true end)
      (fn (w : Whole) (h : Eq Bool (leb zero w) false) is
         boolDiscTF (Eq Bool (leb (succ w) zero) true) h end)
      (fn (j : Whole) (ih : (w : Whole) -> Eq Bool (leb j w) false -> Eq Bool (leb (succ w) j) true) is
         fn (w : Whole) is
           WholeElim (fn (x : Whole) is Eq Bool (leb (succ j) x) false -> Eq Bool (leb (succ x) (succ j)) true end)
             (fn (h : Eq Bool (leb (succ j) zero) false) is refl true end)
             (fn (i : Whole) (ihx : Eq Bool (leb (succ j) i) false -> Eq Bool (leb (succ i) (succ j)) true) is
                fn (h : Eq Bool (leb (succ j) (succ i)) false) is ih i h end end)
             w
         end end)
      b
      a
  end
end

-- ORDER TRANSFER (the mixed-branch discharger): from the cross-equality
-- a + d = c + b and `b <= a`, derive `d <= c`. Substituting a = b + (a - b)
-- and cancelling b turns the cross-equality into (a - b) + d = c, and
-- lebSelfAddR reads off d <= d + (a - b) = c.
orderTransfer : (a : Whole) -> (b : Whole) -> (c : Whole) -> (d : Whole)
  -> Eq Whole (addW a d) (addW c b) -> Eq Bool (leb b a) true -> Eq Bool (leb d c) true is
  fn (a : Whole) (b : Whole) (c : Whole) (d : Whole)
     (H : Eq Whole (addW a d) (addW c b)) (e1 : Eq Bool (leb b a) true) is
    let ba : Eq Whole (addW b (subW a b)) a = subWAddCancel a b e1 in
    let Hsub : Eq Whole (addW (addW b (subW a b)) d) (addW c b) =
      subst Whole a (addW b (subW a b)) (symEq Whole (addW b (subW a b)) a ba)
        (fn (z : Whole) is Eq Whole (addW z d) (addW c b) end) H in
    let step : Eq Whole (addW b (addW (subW a b) d)) (addW b c) =
      transEq Whole (addW b (addW (subW a b) d)) (addW (addW b (subW a b)) d) (addW b c)
        (symEq Whole (addW (addW b (subW a b)) d) (addW b (addW (subW a b) d)) (addWAssoc b (subW a b) d))
        (transEq Whole (addW (addW b (subW a b)) d) (addW c b) (addW b c) Hsub (addWComm c b)) in
    let rdc : Eq Whole (addW (subW a b) d) c = addWCancelL b (addW (subW a b) d) c step in
    let drc : Eq Whole (addW d (subW a b)) c =
      transEq Whole (addW d (subW a b)) (addW (subW a b) d) c (addWComm d (subW a b)) rdc in
    subst Whole (addW d (subW a b)) c drc (fn (z : Whole) is Eq Bool (leb d z) true end) (lebSelfAddR d (subW a b))
  end
end

-- The SAME-BRANCH compatibility cores. Both same-sign branches of wsubEq reduce
-- to a Whole equality of the two truncated differences; these package the addW
-- shuffle + subWAddCancel + addWCancelL argument once each.

-- Nonneg branch: b <= a and d <= c give (a - b) = (c - d).
subWCrossTrue : (a : Whole) -> (b : Whole) -> (c : Whole) -> (d : Whole)
  -> Eq Whole (addW a d) (addW c b)
  -> Eq Bool (leb b a) true -> Eq Bool (leb d c) true
  -> Eq Whole (subW a b) (subW c d) is
  fn (a : Whole) (b : Whole) (c : Whole) (d : Whole)
     (H : Eq Whole (addW a d) (addW c b))
     (e1 : Eq Bool (leb b a) true) (e2 : Eq Bool (leb d c) true) is
    let sac1 : Eq Whole (addW b (subW a b)) a = subWAddCancel a b e1 in
    let sac2 : Eq Whole (addW d (subW c d)) c = subWAddCancel c d e2 in
    let L1 : Eq Whole (addW (addW b d) (subW a b)) (addW a d) =
      transEq Whole (addW (addW b d) (subW a b)) (addW (addW b (subW a b)) d) (addW a d)
        (symEq Whole (addW (addW b (subW a b)) d) (addW (addW b d) (subW a b))
           (addWSwapR b (subW a b) d))
        (congW (fn (t : Whole) is addW t d end) (addW b (subW a b)) a sac1) in
    let R1 : Eq Whole (addW (addW b d) (subW c d)) (addW c b) =
      transEq Whole (addW (addW b d) (subW c d)) (addW (addW d b) (subW c d)) (addW c b)
        (congW (fn (t : Whole) is addW t (subW c d) end) (addW b d) (addW d b) (addWComm b d))
        (transEq Whole (addW (addW d b) (subW c d)) (addW (addW d (subW c d)) b) (addW c b)
           (symEq Whole (addW (addW d (subW c d)) b) (addW (addW d b) (subW c d))
              (addWSwapR d (subW c d) b))
           (congW (fn (t : Whole) is addW t b end) (addW d (subW c d)) c sac2)) in
    let E : Eq Whole (addW (addW b d) (subW a b)) (addW (addW b d) (subW c d)) =
      transEq Whole (addW (addW b d) (subW a b)) (addW a d) (addW (addW b d) (subW c d))
        L1
        (transEq Whole (addW a d) (addW c b) (addW (addW b d) (subW c d))
           H
           (symEq Whole (addW (addW b d) (subW c d)) (addW c b) R1)) in
    addWCancelL (addW b d) (subW a b) (subW c d) E
  end
end

-- Negsucc branch: leb b a = false and leb d c = false give
-- (b - succ a) = (d - succ c). subWAddCancel now fires at the shifted bound
-- (succ a <= b via lebComplStrict); one succInj strips the shared successor.
subWCrossFalse : (a : Whole) -> (b : Whole) -> (c : Whole) -> (d : Whole)
  -> Eq Whole (addW a d) (addW c b)
  -> Eq Bool (leb b a) false -> Eq Bool (leb d c) false
  -> Eq Whole (subW b (succ a)) (subW d (succ c)) is
  fn (a : Whole) (b : Whole) (c : Whole) (d : Whole)
     (H : Eq Whole (addW a d) (addW c b))
     (e1 : Eq Bool (leb b a) false) (e2 : Eq Bool (leb d c) false) is
    let sac1 : Eq Whole (addW (succ a) (subW b (succ a))) b =
      subWAddCancel b (succ a) (lebComplStrict a b e1) in
    let sac2 : Eq Whole (addW (succ c) (subW d (succ c))) d =
      subWAddCancel d (succ c) (lebComplStrict c d e2) in
    let H1 : Eq Whole (addW a (addW (succ c) (subW d (succ c)))) (addW c b) =
      subst Whole d (addW (succ c) (subW d (succ c)))
        (symEq Whole (addW (succ c) (subW d (succ c))) d sac2)
        (fn (z : Whole) is Eq Whole (addW a z) (addW c b) end) H in
    let Hb : Eq Whole (addW a (addW (succ c) (subW d (succ c)))) (addW c (addW (succ a) (subW b (succ a)))) =
      subst Whole b (addW (succ a) (subW b (succ a)))
        (symEq Whole (addW (succ a) (subW b (succ a))) b sac1)
        (fn (z : Whole) is Eq Whole (addW a (addW (succ c) (subW d (succ c)))) (addW c z) end) H1 in
    let Llhs : Eq Whole (addW a (addW (succ c) (subW d (succ c)))) (succ (addW (addW a c) (subW d (succ c)))) =
      transEq Whole (addW a (addW (succ c) (subW d (succ c)))) (succ (addW a (addW c (subW d (succ c))))) (succ (addW (addW a c) (subW d (succ c))))
        (addWSuccR a (addW c (subW d (succ c))))
        (congW (fn (t : Whole) is succ t end) (addW a (addW c (subW d (succ c)))) (addW (addW a c) (subW d (succ c)))
           (symEq Whole (addW (addW a c) (subW d (succ c))) (addW a (addW c (subW d (succ c))))
              (addWAssoc a c (subW d (succ c))))) in
    let Rrhs : Eq Whole (addW c (addW (succ a) (subW b (succ a)))) (succ (addW (addW a c) (subW b (succ a)))) =
      transEq Whole (addW c (addW (succ a) (subW b (succ a)))) (succ (addW c (addW a (subW b (succ a))))) (succ (addW (addW a c) (subW b (succ a))))
        (addWSuccR c (addW a (subW b (succ a))))
        (congW (fn (t : Whole) is succ t end) (addW c (addW a (subW b (succ a)))) (addW (addW a c) (subW b (succ a)))
           (transEq Whole (addW c (addW a (subW b (succ a)))) (addW (addW c a) (subW b (succ a))) (addW (addW a c) (subW b (succ a)))
              (symEq Whole (addW (addW c a) (subW b (succ a))) (addW c (addW a (subW b (succ a))))
                 (addWAssoc c a (subW b (succ a))))
              (congW (fn (t : Whole) is addW t (subW b (succ a)) end) (addW c a) (addW a c) (addWComm c a)))) in
    let succEq : Eq Whole (succ (addW (addW a c) (subW d (succ c)))) (succ (addW (addW a c) (subW b (succ a)))) =
      transEq Whole (succ (addW (addW a c) (subW d (succ c)))) (addW a (addW (succ c) (subW d (succ c)))) (succ (addW (addW a c) (subW b (succ a))))
        (symEq Whole (addW a (addW (succ c) (subW d (succ c)))) (succ (addW (addW a c) (subW d (succ c)))) Llhs)
        (transEq Whole (addW a (addW (succ c) (subW d (succ c)))) (addW c (addW (succ a) (subW b (succ a)))) (succ (addW (addW a c) (subW b (succ a))))
           Hb Rrhs) in
    symEq Whole (subW d (succ c)) (subW b (succ a))
      (addWCancelL (addW a c) (subW d (succ c)) (subW b (succ a))
         (succInj (addW (addW a c) (subW d (succ c))) (addW (addW a c) (subW b (succ a))) succEq))
  end
end

-- The guard-explicit form of wsub (its body with the discriminant abstracted),
-- so a proof can rewrite the guard by subst. `wsubG (leb b a) a b` is wsub a b
-- definitionally; feeding `true`/`false` collapses to the two branch values.
wsubG : Bool -> Whole -> Whole -> Int is
  fn (g : Bool) (a : Whole) (b : Whole) is
    case g of
    | true -> nonneg (subW a b)
    | false -> negsucc (subW b (succ a))
    end
  end
end
-- Branch-reduction lemmas: knowing the guard, wsub collapses to one arm.
wsubTrue : (a : Whole) -> (b : Whole) -> Eq Bool (leb b a) true -> Eq Int (wsub a b) (nonneg (subW a b)) is
  fn (a : Whole) (b : Whole) (e : Eq Bool (leb b a) true) is
    subst Bool true (leb b a) (symEq Bool (leb b a) true e)
      (fn (g : Bool) is Eq Int (wsubG g a b) (nonneg (subW a b)) end)
      (refl (nonneg (subW a b)))
  end
end
wsubFalse : (a : Whole) -> (b : Whole) -> Eq Bool (leb b a) false -> Eq Int (wsub a b) (negsucc (subW b (succ a))) is
  fn (a : Whole) (b : Whole) (e : Eq Bool (leb b a) false) is
    subst Bool false (leb b a) (symEq Bool (leb b a) false e)
      (fn (g : Bool) is Eq Int (wsubG g a b) (negsucc (subW b (succ a))) end)
      (refl (negsucc (subW b (succ a))))
  end
end

-- THE KEYSTONE. wsub respects cross-equal differences: a + d = c + b implies
-- wsub a b = wsub c d. Case-split (with the guard equations retained, via
-- boolCaseEq) on `leb b a` and `leb d c`. The two SAME-sign branches reduce to
-- a Whole equality via subWCrossTrue / subWCrossFalse and lift it onto the Int
-- constructor. The two MIXED branches are IMPOSSIBLE: orderTransfer moves one
-- branch's leb fact to the other side, collides with its assumption to make
-- `Eq Bool true false`, and boolDiscTF discharges the goal ex falso.
wsubEq : (a : Whole) -> (b : Whole) -> (c : Whole) -> (d : Whole)
  -> Eq Whole (addW a d) (addW c b) -> Eq Int (wsub a b) (wsub c d) is
  fn (a : Whole) (b : Whole) (c : Whole) (d : Whole) (H : Eq Whole (addW a d) (addW c b)) is
    boolCaseEq (leb b a)
      (fn (g1 : Bool) is Eq Int (wsub a b) (wsub c d) end)
      (fn (e1 : Eq Bool (leb b a) true) is
         boolCaseEq (leb d c)
           (fn (g2 : Bool) is Eq Int (wsub a b) (wsub c d) end)
           (fn (e2 : Eq Bool (leb d c) true) is
              transEq Int (wsub a b) (nonneg (subW a b)) (wsub c d)
                (wsubTrue a b e1)
                (transEq Int (nonneg (subW a b)) (nonneg (subW c d)) (wsub c d)
                   (congNonneg (subW a b) (subW c d) (subWCrossTrue a b c d H e1 e2))
                   (symEq Int (wsub c d) (nonneg (subW c d)) (wsubTrue c d e2)))
            end)
           (fn (e2 : Eq Bool (leb d c) false) is
              boolDiscTF (Eq Int (wsub a b) (wsub c d))
                (transEq Bool true (leb d c) false
                   (symEq Bool (leb d c) true (orderTransfer a b c d H e1)) e2)
            end)
       end)
      (fn (e1 : Eq Bool (leb b a) false) is
         boolCaseEq (leb d c)
           (fn (g2 : Bool) is Eq Int (wsub a b) (wsub c d) end)
           (fn (e2 : Eq Bool (leb d c) true) is
              boolDiscTF (Eq Int (wsub a b) (wsub c d))
                (transEq Bool true (leb b a) false
                   (symEq Bool (leb b a) true
                      (orderTransfer c d a b (symEq Whole (addW a d) (addW c b) H) e2))
                   e1)
            end)
           (fn (e2 : Eq Bool (leb d c) false) is
              transEq Int (wsub a b) (negsucc (subW b (succ a))) (wsub c d)
                (wsubFalse a b e1)
                (transEq Int (negsucc (subW b (succ a))) (negsucc (subW d (succ c))) (wsub c d)
                   (congNegsucc (subW b (succ a)) (subW d (succ c)) (subWCrossFalse a b c d H e1 e2))
                   (symEq Int (wsub c d) (negsucc (subW d (succ c))) (wsubFalse c d e2)))
            end)
       end)
  end
end

-- ====================================================================
-- THE DIFFERENCE-PAIR TRANSPORT SPECS (Int ring-laws campaign, Task 3).
-- Every Int op is rewritten as a `wsub` of Whole polynomials, so a ring law
-- reduces to Whole arithmetic under `wsubEq`. `posP`/`negP` split an Int into
-- the difference pair it denotes (x = posP x - negP x); `wsubRep` is that
-- representation, `wsubPosNeg` the cross-equality bridge, and the *Spec lemmas
-- transport each op. `iaddWsub`/`imulWsub` push a wsub through the op (chaining
-- the spec with wsubEq, cross-equality via wsubPosNeg, multiplied out over the
-- Whole semiring). Shape guide: ch107's pmulRespL/R over its own NatPair.
-- ====================================================================

-- The difference pair a junk-free Int denotes: nonneg n is n - 0, negsucc k is
-- 0 - (k+1). `posP` reads the nonneg part, `negP` the neg part.
posP : Int -> Whole is
  fn (x : Int) is case x of | nonneg n -> n | negsucc k -> zero end end
end
negP : Int -> Whole is
  fn (x : Int) is case x of | nonneg n -> zero | negsucc k -> succ k end end
end

-- Congruence into Int through both arguments of `wsub` (there is no ambient cong
-- across the Whole -> Whole -> Int shape); rewrites either or both differences.
congWsub2 : (x1 : Whole) -> (y1 : Whole) -> (x2 : Whole) -> (y2 : Whole)
  -> Eq Whole x1 y1 -> Eq Whole x2 y2 -> Eq Int (wsub x1 x2) (wsub y1 y2) is
  fn (x1 : Whole) (y1 : Whole) (x2 : Whole) (y2 : Whole)
     (p1 : Eq Whole x1 y1) (p2 : Eq Whole x2 y2) is
    subst Whole x1 y1 p1 (fn (z : Whole) is Eq Int (wsub x1 x2) (wsub z y2) end)
      (subst Whole x2 y2 p2 (fn (w : Whole) is Eq Int (wsub x1 x2) (wsub x1 w) end)
         (refl (wsub x1 x2)))
  end
end

-- The additive interchange law (x+y)+(u+v) = (x+u)+(y+v): pure associativity +
-- commutativity regrouping. The workhorse for the degree-2 cross-equalities.
addWInterchange : (x : Whole) -> (y : Whole) -> (u : Whole) -> (v : Whole)
  -> Eq Whole (addW (addW x y) (addW u v)) (addW (addW x u) (addW y v)) is
  fn (x : Whole) (y : Whole) (u : Whole) (v : Whole) is
    transEq Whole (addW (addW x y) (addW u v)) (addW x (addW y (addW u v))) (addW (addW x u) (addW y v))
      (addWAssoc x y (addW u v))
      (transEq Whole (addW x (addW y (addW u v))) (addW x (addW u (addW y v))) (addW (addW x u) (addW y v))
         (congW (fn (s : Whole) is addW x s end) (addW y (addW u v)) (addW u (addW y v))
            (transEq Whole (addW y (addW u v)) (addW (addW y u) v) (addW u (addW y v))
               (symEq Whole (addW (addW y u) v) (addW y (addW u v)) (addWAssoc y u v))
               (transEq Whole (addW (addW y u) v) (addW (addW u y) v) (addW u (addW y v))
                  (congW (fn (s : Whole) is addW s v end) (addW y u) (addW u y) (addWComm y u))
                  (addWAssoc u y v))))
         (symEq Whole (addW (addW x u) (addW y v)) (addW x (addW u (addW y v))) (addWAssoc x u (addW y v))))
  end
end

-- REPRESENTATION: wsub of an Int's own difference pair reconstructs it. Both
-- constructor cases compute (leb zero _ / subW _ zero / subW (succ k)(succ zero)).
wsubRep : (x : Int) -> Eq Int (wsub (posP x) (negP x)) x is
  fn (x : Int) is
    IntElim (fn (w : Int) is Eq Int (wsub (posP w) (negP w)) w end)
      (fn (n : Whole) is refl (nonneg n) end)
      (fn (k : Whole) is refl (negsucc k) end)
      x
  end
end

-- ineg of a nonneg is the wsub of the reversed difference (0 - m). Both branches
-- (zero / succ k) compute on the nose.
inegNonneg : (m : Whole) -> Eq Int (ineg (nonneg m)) (wsub zero m) is
  fn (m : Whole) is
    WholeElim (fn (w : Whole) is Eq Int (ineg (nonneg w)) (wsub zero w) end)
      (refl (nonneg zero))
      (fn (k : Whole) (ih : Eq Int (ineg (nonneg k)) (wsub zero k)) is refl (negsucc k) end)
      m
  end
end

-- THE CROSS-EQUALITY BRIDGE. The difference pair of `wsub p n` differs from
-- (p, n) by the wsub-choice, but the two pairs denote the same integer:
-- posP(wsub p n) + n = p + negP(wsub p n). Case on the guard `leb n p` with the
-- equation retained; subWAddCancel closes both branches (the strict shift
-- lebComplStrict feeds the false branch, addWSuccR lines up the successor).
wsubPosNeg : (p : Whole) -> (n : Whole)
  -> Eq Whole (addW (posP (wsub p n)) n) (addW p (negP (wsub p n))) is
  fn (p : Whole) (n : Whole) is
    boolCaseEq (leb n p)
      (fn (g : Bool) is Eq Whole (addW (posP (wsub p n)) n) (addW p (negP (wsub p n))) end)
      (fn (e1 : Eq Bool (leb n p) true) is
         subst Int (nonneg (subW p n)) (wsub p n)
           (symEq Int (wsub p n) (nonneg (subW p n)) (wsubTrue p n e1))
           (fn (w : Int) is Eq Whole (addW (posP w) n) (addW p (negP w)) end)
           (transEq Whole (addW (subW p n) n) (addW n (subW p n)) (addW p zero)
              (addWComm (subW p n) n)
              (transEq Whole (addW n (subW p n)) p (addW p zero)
                 (subWAddCancel p n e1)
                 (symEq Whole (addW p zero) p (addWZeroR p))))
       end)
      (fn (e2 : Eq Bool (leb n p) false) is
         subst Int (negsucc (subW n (succ p))) (wsub p n)
           (symEq Int (wsub p n) (negsucc (subW n (succ p))) (wsubFalse p n e2))
           (fn (w : Int) is Eq Whole (addW (posP w) n) (addW p (negP w)) end)
           (transEq Whole n (succ (addW p (subW n (succ p)))) (addW p (succ (subW n (succ p))))
              (symEq Whole (succ (addW p (subW n (succ p)))) n
                 (subWAddCancel n (succ p) (lebComplStrict p n e2)))
              (symEq Whole (addW p (succ (subW n (succ p)))) (succ (addW p (subW n (succ p))))
                 (addWSuccR p (subW n (succ p)))))
       end)
  end
end

-- iadd as a wsub of Whole polynomials. Four constructor cases: nonneg/nonneg is
-- refl (leb zero / subW _ zero / addW zero zero compute); the two mixed cases
-- each need one addWZeroR rewrite (the stuck addW _ zero); negsucc/negsucc uses
-- addWSuccR under a negsucc congruence.
iaddSpec : (x : Int) -> (y : Int)
  -> Eq Int (iadd x y) (wsub (addW (posP x) (posP y)) (addW (negP x) (negP y))) is
  fn (x : Int) (y : Int) is
    IntElim (fn (wx : Int) is Eq Int (iadd wx y) (wsub (addW (posP wx) (posP y)) (addW (negP wx) (negP y))) end)
      (fn (a : Whole) is
         IntElim (fn (wy : Int) is Eq Int (iadd (nonneg a) wy) (wsub (addW (posP (nonneg a)) (posP wy)) (addW (negP (nonneg a)) (negP wy))) end)
           (fn (c : Whole) is refl (nonneg (addW a c)) end)
           (fn (d : Whole) is
              congWsub2 a (addW a zero) (succ d) (succ d)
                (symEq Whole (addW a zero) a (addWZeroR a)) (refl (succ d))
            end)
           y
       end)
      (fn (b : Whole) is
         IntElim (fn (wy : Int) is Eq Int (iadd (negsucc b) wy) (wsub (addW (posP (negsucc b)) (posP wy)) (addW (negP (negsucc b)) (negP wy))) end)
           (fn (c : Whole) is
              congWsub2 c c (succ b) (addW (succ b) zero)
                (refl c)
                (congW (fn (t : Whole) is succ t end) b (addW b zero)
                   (symEq Whole (addW b zero) b (addWZeroR b)))
            end)
           (fn (d : Whole) is
              congNegsucc (succ (addW b d)) (addW b (succ d))
                (symEq Whole (addW b (succ d)) (succ (addW b d)) (addWSuccR b d))
            end)
           y
       end)
      x
  end
end

-- imul as a wsub of Whole polynomials (the signed-pair product laid out over the
-- two sign columns). Same-sign cases: rewrite the stuck addW _ zero / mulW _ zero
-- to reach nonneg. Mixed-sign cases go through inegNonneg (the product is a
-- negated nonneg, i.e. a `wsub zero _`).
imulSpec : (x : Int) -> (y : Int)
  -> Eq Int (imul x y)
       (wsub (addW (mulW (posP x) (posP y)) (mulW (negP x) (negP y)))
             (addW (mulW (posP x) (negP y)) (mulW (negP x) (posP y)))) is
  fn (x : Int) (y : Int) is
    IntElim (fn (wx : Int) is Eq Int (imul wx y)
              (wsub (addW (mulW (posP wx) (posP y)) (mulW (negP wx) (negP y)))
                    (addW (mulW (posP wx) (negP y)) (mulW (negP wx) (posP y)))) end)
      (fn (a : Whole) is
         IntElim (fn (wy : Int) is Eq Int (imul (nonneg a) wy)
                   (wsub (addW (mulW (posP (nonneg a)) (posP wy)) (mulW (negP (nonneg a)) (negP wy)))
                         (addW (mulW (posP (nonneg a)) (negP wy)) (mulW (negP (nonneg a)) (posP wy)))) end)
           (fn (c : Whole) is
              congWsub2 (mulW a c) (addW (mulW a c) zero) zero (addW (mulW a zero) zero)
                (symEq Whole (addW (mulW a c) zero) (mulW a c) (addWZeroR (mulW a c)))
                (symEq Whole (addW (mulW a zero) zero) zero
                   (transEq Whole (addW (mulW a zero) zero) (mulW a zero) zero
                      (addWZeroR (mulW a zero)) (mulWZeroR a)))
            end)
           (fn (d : Whole) is
              transEq Int (ineg (nonneg (mulW a (succ d)))) (wsub zero (mulW a (succ d)))
                (wsub (addW (mulW a zero) zero) (addW (mulW a (succ d)) zero))
                (inegNonneg (mulW a (succ d)))
                (congWsub2 zero (addW (mulW a zero) zero) (mulW a (succ d)) (addW (mulW a (succ d)) zero)
                   (symEq Whole (addW (mulW a zero) zero) zero
                      (transEq Whole (addW (mulW a zero) zero) (mulW a zero) zero
                         (addWZeroR (mulW a zero)) (mulWZeroR a)))
                   (symEq Whole (addW (mulW a (succ d)) zero) (mulW a (succ d)) (addWZeroR (mulW a (succ d)))))
            end)
           y
       end)
      (fn (b : Whole) is
         IntElim (fn (wy : Int) is Eq Int (imul (negsucc b) wy)
                   (wsub (addW (mulW (posP (negsucc b)) (posP wy)) (mulW (negP (negsucc b)) (negP wy)))
                         (addW (mulW (posP (negsucc b)) (negP wy)) (mulW (negP (negsucc b)) (posP wy)))) end)
           (fn (c : Whole) is
              transEq Int (ineg (nonneg (mulW (succ b) c))) (wsub zero (mulW (succ b) c))
                (wsub (mulW (succ b) zero) (mulW (succ b) c))
                (inegNonneg (mulW (succ b) c))
                (congWsub2 zero (mulW (succ b) zero) (mulW (succ b) c) (mulW (succ b) c)
                   (symEq Whole (mulW (succ b) zero) zero (mulWZeroR (succ b)))
                   (refl (mulW (succ b) c)))
            end)
           (fn (d : Whole) is
              congWsub2 (mulW (succ b) (succ d)) (mulW (succ b) (succ d)) zero (mulW (succ b) zero)
                (refl (mulW (succ b) (succ d)))
                (symEq Whole (mulW (succ b) zero) zero (mulWZeroR (succ b)))
            end)
           y
       end)
      x
  end
end

-- ineg as a wsub of the reversed difference. The nonneg case is exactly
-- inegNonneg; the negsucc case computes (leb zero / subW (succ k) zero).
inegSpec : (x : Int) -> Eq Int (ineg x) (wsub (negP x) (posP x)) is
  fn (x : Int) is
    IntElim (fn (w : Int) is Eq Int (ineg w) (wsub (negP w) (posP w)) end)
      (fn (n : Whole) is inegNonneg n end)
      (fn (k : Whole) is refl (nonneg (succ k)) end)
      x
  end
end

-- The degree-2 cross-equality (pmulRespL's shape over junk-free Int): given the
-- difference pairs (u,v) ~ (r,w) (u+w = r+v), the signed products by (s,t) agree
-- as differences. Both sides regroup to like-multiplier columns (distribWR) and
-- rewrite through the hypothesis; the additive shuffling is addWInterchange.
mulCrossIdent : (u : Whole) -> (v : Whole) -> (r : Whole) -> (w : Whole) -> (s : Whole) -> (t : Whole)
  -> Eq Whole (addW u w) (addW r v)
  -> Eq Whole (addW (addW (mulW u s) (mulW v t)) (addW (mulW r t) (mulW w s)))
              (addW (addW (mulW r s) (mulW w t)) (addW (mulW u t) (mulW v s))) is
  fn (u : Whole) (v : Whole) (r : Whole) (w : Whole) (s : Whole) (t : Whole)
     (hyp : Eq Whole (addW u w) (addW r v)) is
    let a1 : Whole = mulW u s in
    let a2 : Whole = mulW v t in
    let a3 : Whole = mulW r t in
    let a4 : Whole = mulW w s in
    let b1 : Whole = mulW r s in
    let b2 : Whole = mulW w t in
    let b3 : Whole = mulW u t in
    let b4 : Whole = mulW v s in
    let colPz : Eq Whole (addW a1 a4) (addW b1 b4)
      = transEq Whole (addW a1 a4) (mulW (addW u w) s) (addW b1 b4)
          (symEq Whole (mulW (addW u w) s) (addW a1 a4) (distribWR u w s))
          (transEq Whole (mulW (addW u w) s) (mulW (addW r v) s) (addW b1 b4)
             (congW (fn (zz : Whole) is mulW zz s end) (addW u w) (addW r v) hyp)
             (distribWR r v s)) in
    let vrEq : Eq Whole (addW v r) (addW w u)
      = transEq Whole (addW v r) (addW r v) (addW w u)
          (addWComm v r)
          (transEq Whole (addW r v) (addW u w) (addW w u)
             (symEq Whole (addW u w) (addW r v) hyp)
             (addWComm u w)) in
    let g2 : Eq Whole (addW a2 a3) (addW b2 b3)
      = transEq Whole (addW a2 a3) (mulW (addW v r) t) (addW b2 b3)
          (symEq Whole (mulW (addW v r) t) (addW a2 a3) (distribWR v r t))
          (transEq Whole (mulW (addW v r) t) (mulW (addW w u) t) (addW b2 b3)
             (congW (fn (zz : Whole) is mulW zz t end) (addW v r) (addW w u) vrEq)
             (distribWR w u t)) in
    let part1 : Eq Whole (addW (addW a1 a2) (addW a3 a4)) (addW (addW a1 a4) (addW a2 a3))
      = transEq Whole (addW (addW a1 a2) (addW a3 a4)) (addW (addW a1 a2) (addW a4 a3)) (addW (addW a1 a4) (addW a2 a3))
          (congW (fn (zz : Whole) is addW (addW a1 a2) zz end) (addW a3 a4) (addW a4 a3) (addWComm a3 a4))
          (addWInterchange a1 a2 a4 a3) in
    let part2 : Eq Whole (addW (addW a1 a4) (addW a2 a3)) (addW (addW b1 b4) (addW b2 b3))
      = transEq Whole (addW (addW a1 a4) (addW a2 a3)) (addW (addW b1 b4) (addW a2 a3)) (addW (addW b1 b4) (addW b2 b3))
          (congW (fn (zz : Whole) is addW zz (addW a2 a3) end) (addW a1 a4) (addW b1 b4) colPz)
          (congW (fn (zz : Whole) is addW (addW b1 b4) zz end) (addW a2 a3) (addW b2 b3) g2) in
    let part3 : Eq Whole (addW (addW b1 b4) (addW b2 b3)) (addW (addW b1 b2) (addW b3 b4))
      = transEq Whole (addW (addW b1 b4) (addW b2 b3)) (addW (addW b1 b2) (addW b4 b3)) (addW (addW b1 b2) (addW b3 b4))
          (addWInterchange b1 b4 b2 b3)
          (congW (fn (zz : Whole) is addW (addW b1 b2) zz end) (addW b4 b3) (addW b3 b4) (addWComm b4 b3)) in
    transEq Whole (addW (addW a1 a2) (addW a3 a4)) (addW (addW a1 a4) (addW a2 a3)) (addW (addW b1 b2) (addW b3 b4))
      part1
      (transEq Whole (addW (addW a1 a4) (addW a2 a3)) (addW (addW b1 b4) (addW b2 b3)) (addW (addW b1 b2) (addW b3 b4))
         part2 part3)
  end
end

-- PUSH a wsub through iadd: iadd (wsub p n) z = wsub (p + posP z) (n + negP z).
-- Chain iaddSpec at (wsub p n, z) with wsubEq; the cross-equality reduces
-- through wsubPosNeg (P0 + n = p + N0), regrouped by addWInterchange.
iaddWsub : (p : Whole) -> (n : Whole) -> (z : Int)
  -> Eq Int (iadd (wsub p n) z) (wsub (addW p (posP z)) (addW n (negP z))) is
  fn (p : Whole) (n : Whole) (z : Int) is
    let P0 : Whole = posP (wsub p n) in
    let N0 : Whole = negP (wsub p n) in
    let pz : Whole = posP z in
    let nz : Whole = negP z in
    let K : Eq Whole (addW P0 n) (addW p N0) = wsubPosNeg p n in
    let H : Eq Whole (addW (addW P0 pz) (addW n nz)) (addW (addW p pz) (addW N0 nz))
      = transEq Whole (addW (addW P0 pz) (addW n nz)) (addW (addW P0 n) (addW pz nz)) (addW (addW p pz) (addW N0 nz))
          (addWInterchange P0 pz n nz)
          (transEq Whole (addW (addW P0 n) (addW pz nz)) (addW (addW p N0) (addW pz nz)) (addW (addW p pz) (addW N0 nz))
             (congW (fn (zz : Whole) is addW zz (addW pz nz) end) (addW P0 n) (addW p N0) K)
             (symEq Whole (addW (addW p pz) (addW N0 nz)) (addW (addW p N0) (addW pz nz)) (addWInterchange p pz N0 nz))) in
    transEq Int (iadd (wsub p n) z)
      (wsub (addW P0 pz) (addW N0 nz)) (wsub (addW p pz) (addW n nz))
      (iaddSpec (wsub p n) z)
      (wsubEq (addW P0 pz) (addW N0 nz) (addW p pz) (addW n nz) H)
  end
end

-- PUSH a wsub through imul. Chain imulSpec at (wsub p n, z) with wsubEq; the
-- cross-equality is mulCrossIdent driven by wsubPosNeg (the degree-2 lift of the
-- difference-pair equality).
imulWsub : (p : Whole) -> (n : Whole) -> (z : Int)
  -> Eq Int (imul (wsub p n) z)
       (wsub (addW (mulW p (posP z)) (mulW n (negP z)))
             (addW (mulW p (negP z)) (mulW n (posP z)))) is
  fn (p : Whole) (n : Whole) (z : Int) is
    let P0 : Whole = posP (wsub p n) in
    let N0 : Whole = negP (wsub p n) in
    let pz : Whole = posP z in
    let nz : Whole = negP z in
    let K : Eq Whole (addW P0 n) (addW p N0) = wsubPosNeg p n in
    let H : Eq Whole (addW (addW (mulW P0 pz) (mulW N0 nz)) (addW (mulW p nz) (mulW n pz)))
                     (addW (addW (mulW p pz) (mulW n nz)) (addW (mulW P0 nz) (mulW N0 pz)))
      = mulCrossIdent P0 N0 p n pz nz K in
    transEq Int (imul (wsub p n) z)
      (wsub (addW (mulW P0 pz) (mulW N0 nz)) (addW (mulW P0 nz) (mulW N0 pz)))
      (wsub (addW (mulW p pz) (mulW n nz)) (addW (mulW p nz) (mulW n pz)))
      (imulSpec (wsub p n) z)
      (wsubEq (addW (mulW P0 pz) (mulW N0 nz)) (addW (mulW P0 nz) (mulW N0 pz))
              (addW (mulW p pz) (mulW n nz)) (addW (mulW p nz) (mulW n pz)) H)
  end
end

-- ====================================================================
-- THE INT RING LAWS (Int ring-laws campaign, Task 4). Each law reduces to
-- Whole arithmetic: rewrite every Int operand into `wsub` of a Whole pair
-- (via the *Spec lemmas), collapse nested ops with iaddWsub/imulWsub (and
-- the right/pair mirrors below), until each side is ONE `wsub` of a Whole
-- polynomial, then close with wsubEq (cross-equality) or congWsub2
-- (component-wise). The eight-term multiplicative-associativity shuffle is
-- packaged as `mulAssocCol` (ch107's pmulAssocFst over junk-free Int),
-- reused for both wsub columns with the e/f swap.
-- ====================================================================

-- Binary congruence on a Whole operation (there is no ambient cong2).
cong2W : (f : Whole -> Whole -> Whole) -> (x1 : Whole) -> (y1 : Whole) -> (x2 : Whole) -> (y2 : Whole)
  -> Eq Whole x1 y1 -> Eq Whole x2 y2 -> Eq Whole (f x1 x2) (f y1 y2) is
  fn (f : Whole -> Whole -> Whole) (x1 : Whole) (y1 : Whole) (x2 : Whole) (y2 : Whole)
     (p1 : Eq Whole x1 y1) (p2 : Eq Whole x2 y2) is
    transEq Whole (f x1 x2) (f y1 x2) (f y1 y2)
      (congW (fn (t : Whole) is f t x2 end) x1 y1 p1)
      (congW (fn (t : Whole) is f y1 t end) x2 y2 p2)
  end
end

-- Rewrite either operand of iadd/imul (subst under the op; no ambient cong
-- across the Int -> Int -> Int shape).
congIaddL : (x : Int) -> (x' : Int) -> (y : Int) -> Eq Int x x' -> Eq Int (iadd x y) (iadd x' y) is
  fn (x : Int) (x' : Int) (y : Int) (p : Eq Int x x') is
    subst Int x x' p (fn (z : Int) is Eq Int (iadd x y) (iadd z y) end) (refl (iadd x y))
  end
end
congIaddR : (x : Int) -> (y : Int) -> (y' : Int) -> Eq Int y y' -> Eq Int (iadd x y) (iadd x y') is
  fn (x : Int) (y : Int) (y' : Int) (p : Eq Int y y') is
    subst Int y y' p (fn (z : Int) is Eq Int (iadd x y) (iadd x z) end) (refl (iadd x y))
  end
end
congImulL : (x : Int) -> (x' : Int) -> (y : Int) -> Eq Int x x' -> Eq Int (imul x y) (imul x' y) is
  fn (x : Int) (x' : Int) (y : Int) (p : Eq Int x x') is
    subst Int x x' p (fn (z : Int) is Eq Int (imul x y) (imul z y) end) (refl (imul x y))
  end
end
congImulR : (x : Int) -> (y : Int) -> (y' : Int) -> Eq Int y y' -> Eq Int (imul x y) (imul x y') is
  fn (x : Int) (y : Int) (y' : Int) (p : Eq Int y y') is
    subst Int y y' p (fn (z : Int) is Eq Int (imul x y) (imul x z) end) (refl (imul x y))
  end
end

-- Right mirror of iaddWsub: push a wsub through the SECOND operand of iadd.
-- Same cross-equality (wsubPosNeg regrouped by addWInterchange), operands on
-- the other side.
iaddWsubR : (z : Int) -> (p : Whole) -> (n : Whole)
  -> Eq Int (iadd z (wsub p n)) (wsub (addW (posP z) p) (addW (negP z) n)) is
  fn (z : Int) (p : Whole) (n : Whole) is
    let P0 : Whole = posP (wsub p n) in
    let N0 : Whole = negP (wsub p n) in
    let pz : Whole = posP z in
    let nz : Whole = negP z in
    let K : Eq Whole (addW P0 n) (addW p N0) = wsubPosNeg p n in
    let H : Eq Whole (addW (addW pz P0) (addW nz n)) (addW (addW pz p) (addW nz N0))
      = transEq Whole (addW (addW pz P0) (addW nz n)) (addW (addW pz nz) (addW P0 n)) (addW (addW pz p) (addW nz N0))
          (addWInterchange pz P0 nz n)
          (transEq Whole (addW (addW pz nz) (addW P0 n)) (addW (addW pz nz) (addW p N0)) (addW (addW pz p) (addW nz N0))
             (congW (fn (zz : Whole) is addW (addW pz nz) zz end) (addW P0 n) (addW p N0) K)
             (symEq Whole (addW (addW pz p) (addW nz N0)) (addW (addW pz nz) (addW p N0)) (addWInterchange pz p nz N0))) in
    transEq Int (iadd z (wsub p n))
      (wsub (addW pz P0) (addW nz N0)) (wsub (addW pz p) (addW nz n))
      (iaddSpec z (wsub p n))
      (wsubEq (addW pz P0) (addW nz N0) (addW pz p) (addW nz n) H)
  end
end

-- Pair form of iaddWsub: iadd of two explicit wsubs collapses componentwise.
-- Chain iaddWsub (left literal) then resolve the right operand's posP/negP by
-- wsubPosNeg, regrouped by addWInterchange.
iaddWsub2 : (p1 : Whole) -> (n1 : Whole) -> (p2 : Whole) -> (n2 : Whole)
  -> Eq Int (iadd (wsub p1 n1) (wsub p2 n2)) (wsub (addW p1 p2) (addW n1 n2)) is
  fn (p1 : Whole) (n1 : Whole) (p2 : Whole) (n2 : Whole) is
    let Q0 : Whole = posP (wsub p2 n2) in
    let R0 : Whole = negP (wsub p2 n2) in
    let K2 : Eq Whole (addW Q0 n2) (addW p2 R0) = wsubPosNeg p2 n2 in
    let H : Eq Whole (addW (addW p1 Q0) (addW n1 n2)) (addW (addW p1 p2) (addW n1 R0))
      = transEq Whole (addW (addW p1 Q0) (addW n1 n2)) (addW (addW p1 n1) (addW Q0 n2)) (addW (addW p1 p2) (addW n1 R0))
          (addWInterchange p1 Q0 n1 n2)
          (transEq Whole (addW (addW p1 n1) (addW Q0 n2)) (addW (addW p1 n1) (addW p2 R0)) (addW (addW p1 p2) (addW n1 R0))
             (congW (fn (zz : Whole) is addW (addW p1 n1) zz end) (addW Q0 n2) (addW p2 R0) K2)
             (symEq Whole (addW (addW p1 p2) (addW n1 R0)) (addW (addW p1 n1) (addW p2 R0)) (addWInterchange p1 p2 n1 R0))) in
    transEq Int (iadd (wsub p1 n1) (wsub p2 n2))
      (wsub (addW p1 Q0) (addW n1 R0)) (wsub (addW p1 p2) (addW n1 n2))
      (iaddWsub p1 n1 (wsub p2 n2))
      (wsubEq (addW p1 Q0) (addW n1 R0) (addW p1 p2) (addW n1 n2) H)
  end
end

-- The eight-term multiplicative-associativity column (ch107's pmulAssocFst
-- shape). Both sides reduce to a1(ce+df) + b(cf+de): distribute (distribWR),
-- reassociate the triple products (mulWAssoc), interchange to a/b columns
-- (addWInterchange), contract (distribWL reversed), align the b-factor
-- (addWComm), and flip the multiplier order (mulWComm).
mulAssocCol : (a : Whole) -> (b : Whole) -> (c : Whole) -> (d : Whole) -> (e : Whole) -> (f : Whole)
  -> Eq Whole
       (addW (mulW (addW (mulW a c) (mulW b d)) e) (mulW (addW (mulW a d) (mulW b c)) f))
       (addW (mulW (addW (mulW c e) (mulW d f)) a) (mulW (addW (mulW c f) (mulW d e)) b)) is
  fn (a : Whole) (b : Whole) (c : Whole) (d : Whole) (e : Whole) (f : Whole) is
    let ace : Whole = mulW a (mulW c e) in
    let bde : Whole = mulW b (mulW d e) in
    let adf : Whole = mulW a (mulW d f) in
    let bcf : Whole = mulW b (mulW c f) in
    let canon : Whole = addW (mulW a (addW (mulW c e) (mulW d f))) (mulW b (addW (mulW c f) (mulW d e))) in
    let lhs2canon : Eq Whole
          (addW (mulW (addW (mulW a c) (mulW b d)) e) (mulW (addW (mulW a d) (mulW b c)) f))
          canon
      = transEq Whole
          (addW (mulW (addW (mulW a c) (mulW b d)) e) (mulW (addW (mulW a d) (mulW b c)) f))
          (addW (addW (mulW (mulW a c) e) (mulW (mulW b d) e)) (addW (mulW (mulW a d) f) (mulW (mulW b c) f)))
          canon
          (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
             (mulW (addW (mulW a c) (mulW b d)) e) (addW (mulW (mulW a c) e) (mulW (mulW b d) e))
             (mulW (addW (mulW a d) (mulW b c)) f) (addW (mulW (mulW a d) f) (mulW (mulW b c) f))
             (distribWR (mulW a c) (mulW b d) e)
             (distribWR (mulW a d) (mulW b c) f))
          (transEq Whole
             (addW (addW (mulW (mulW a c) e) (mulW (mulW b d) e)) (addW (mulW (mulW a d) f) (mulW (mulW b c) f)))
             (addW (addW ace bde) (addW adf bcf))
             canon
             (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
                (addW (mulW (mulW a c) e) (mulW (mulW b d) e)) (addW ace bde)
                (addW (mulW (mulW a d) f) (mulW (mulW b c) f)) (addW adf bcf)
                (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
                   (mulW (mulW a c) e) ace (mulW (mulW b d) e) bde
                   (mulWAssoc a c e) (mulWAssoc b d e))
                (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
                   (mulW (mulW a d) f) adf (mulW (mulW b c) f) bcf
                   (mulWAssoc a d f) (mulWAssoc b c f)))
             (transEq Whole
                (addW (addW ace bde) (addW adf bcf))
                (addW (addW ace adf) (addW bde bcf))
                canon
                (addWInterchange ace bde adf bcf)
                (transEq Whole
                   (addW (addW ace adf) (addW bde bcf))
                   (addW (mulW a (addW (mulW c e) (mulW d f))) (mulW b (addW (mulW d e) (mulW c f))))
                   canon
                   (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
                      (addW ace adf) (mulW a (addW (mulW c e) (mulW d f)))
                      (addW bde bcf) (mulW b (addW (mulW d e) (mulW c f)))
                      (symEq Whole (mulW a (addW (mulW c e) (mulW d f))) (addW ace adf) (distribWL a (mulW c e) (mulW d f)))
                      (symEq Whole (mulW b (addW (mulW d e) (mulW c f))) (addW bde bcf) (distribWL b (mulW d e) (mulW c f))))
                   (congW (fn (s : Whole) is addW (mulW a (addW (mulW c e) (mulW d f))) (mulW b s) end)
                      (addW (mulW d e) (mulW c f)) (addW (mulW c f) (mulW d e))
                      (addWComm (mulW d e) (mulW c f)))))) in
    transEq Whole
      (addW (mulW (addW (mulW a c) (mulW b d)) e) (mulW (addW (mulW a d) (mulW b c)) f))
      canon
      (addW (mulW (addW (mulW c e) (mulW d f)) a) (mulW (addW (mulW c f) (mulW d e)) b))
      lhs2canon
      (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
         (mulW a (addW (mulW c e) (mulW d f))) (mulW (addW (mulW c e) (mulW d f)) a)
         (mulW b (addW (mulW c f) (mulW d e))) (mulW (addW (mulW c f) (mulW d e)) b)
         (mulWComm a (addW (mulW c e) (mulW d f)))
         (mulWComm b (addW (mulW c f) (mulW d e))))
  end
end

-- THE THIRTEEN LAW LEMMAS + imulComm. Easy identities/annihilators first,
-- then commutativity, then associativity/distributivity, then the mul
-- associativity shuffle and the multiplicative identities.

-- iadd left/right zero: nonneg zero is the additive identity.
iaddZeroL : IdLT Int iadd (nonneg zero) is
  fn (a : Int) is
    transEq Int (iadd (nonneg zero) a) (wsub (posP a) (negP a)) a
      (iaddSpec (nonneg zero) a)
      (wsubRep a)
  end
end
iaddZeroR : IdRT Int iadd (nonneg zero) is
  fn (a : Int) is
    transEq Int (iadd a (nonneg zero)) (wsub (addW (posP a) zero) (addW (negP a) zero)) a
      (iaddSpec a (nonneg zero))
      (transEq Int (wsub (addW (posP a) zero) (addW (negP a) zero)) (wsub (posP a) (negP a)) a
         (congWsub2 (addW (posP a) zero) (posP a) (addW (negP a) zero) (negP a) (addWZeroR (posP a)) (addWZeroR (negP a)))
         (wsubRep a))
  end
end

-- imul left/right zero: nonneg zero annihilates.
imulZeroL : AnnihLT Int imul (nonneg zero) is
  fn (a : Int) is imulSpec (nonneg zero) a end
end
imulZeroR : AnnihRT Int imul (nonneg zero) is
  fn (a : Int) is
    transEq Int (imul a (nonneg zero))
      (wsub (addW (mulW (posP a) zero) (mulW (negP a) zero)) (addW (mulW (posP a) zero) (mulW (negP a) zero)))
      (nonneg zero)
      (imulSpec a (nonneg zero))
      (congWsub2 (addW (mulW (posP a) zero) (mulW (negP a) zero)) zero
                 (addW (mulW (posP a) zero) (mulW (negP a) zero)) zero
        (transEq Whole (addW (mulW (posP a) zero) (mulW (negP a) zero)) (mulW (negP a) zero) zero
           (congW (fn (t : Whole) is addW t (mulW (negP a) zero) end) (mulW (posP a) zero) zero (mulWZeroR (posP a)))
           (mulWZeroR (negP a)))
        (transEq Whole (addW (mulW (posP a) zero) (mulW (negP a) zero)) (mulW (negP a) zero) zero
           (congW (fn (t : Whole) is addW t (mulW (negP a) zero) end) (mulW (posP a) zero) zero (mulWZeroR (posP a)))
           (mulWZeroR (negP a))))
  end
end

-- Additive inverse: ineg a cancels a on both sides (to nonneg zero = wsub 0 0).
inegInvL : NegInvLT Int iadd ineg (nonneg zero) is
  fn (a : Int) is
    transEq Int (iadd (ineg a) a)
      (wsub (addW (negP a) (posP a)) (addW (posP a) (negP a)))
      (nonneg zero)
      (transEq Int (iadd (ineg a) a) (iadd (wsub (negP a) (posP a)) a) (wsub (addW (negP a) (posP a)) (addW (posP a) (negP a)))
         (congIaddL (ineg a) (wsub (negP a) (posP a)) a (inegSpec a))
         (iaddWsub (negP a) (posP a) a))
      (wsubEq (addW (negP a) (posP a)) (addW (posP a) (negP a)) zero zero
         (transEq Whole (addW (addW (negP a) (posP a)) zero) (addW (negP a) (posP a)) (addW (posP a) (negP a))
            (addWZeroR (addW (negP a) (posP a)))
            (addWComm (negP a) (posP a))))
  end
end
inegInvR : NegInvRT Int iadd ineg (nonneg zero) is
  fn (a : Int) is
    transEq Int (iadd a (ineg a))
      (wsub (addW (posP a) (negP a)) (addW (negP a) (posP a)))
      (nonneg zero)
      (transEq Int (iadd a (ineg a)) (iadd a (wsub (negP a) (posP a))) (wsub (addW (posP a) (negP a)) (addW (negP a) (posP a)))
         (congIaddR a (ineg a) (wsub (negP a) (posP a)) (inegSpec a))
         (iaddWsubR a (negP a) (posP a)))
      (wsubEq (addW (posP a) (negP a)) (addW (negP a) (posP a)) zero zero
         (transEq Whole (addW (addW (posP a) (negP a)) zero) (addW (posP a) (negP a)) (addW (negP a) (posP a))
            (addWZeroR (addW (posP a) (negP a)))
            (addWComm (posP a) (negP a))))
  end
end

-- iadd is commutative (component-wise addWComm on the two wsub columns).
iaddComm : CommT Int iadd is
  fn (a : Int) (b : Int) is
    transEq Int (iadd a b)
      (wsub (addW (posP a) (posP b)) (addW (negP a) (negP b)))
      (iadd b a)
      (iaddSpec a b)
      (transEq Int
         (wsub (addW (posP a) (posP b)) (addW (negP a) (negP b)))
         (wsub (addW (posP b) (posP a)) (addW (negP b) (negP a)))
         (iadd b a)
         (congWsub2 (addW (posP a) (posP b)) (addW (posP b) (posP a)) (addW (negP a) (negP b)) (addW (negP b) (negP a))
            (addWComm (posP a) (posP b)) (addWComm (negP a) (negP b)))
         (symEq Int (iadd b a) (wsub (addW (posP b) (posP a)) (addW (negP b) (negP a))) (iaddSpec b a)))
  end
end

-- imul is commutative (mulWComm on the eight products + a column swap).
imulComm : CommT Int imul is
  fn (a : Int) (b : Int) is
    transEq Int (imul a b)
      (wsub (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))))
      (imul b a)
      (imulSpec a b)
      (transEq Int
         (wsub (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))))
         (wsub (addW (mulW (posP b) (posP a)) (mulW (negP b) (negP a))) (addW (mulW (posP b) (negP a)) (mulW (negP b) (posP a))))
         (imul b a)
         (congWsub2
            (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (addW (mulW (posP b) (posP a)) (mulW (negP b) (negP a)))
            (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (addW (mulW (posP b) (negP a)) (mulW (negP b) (posP a)))
            (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
               (mulW (posP a) (posP b)) (mulW (posP b) (posP a)) (mulW (negP a) (negP b)) (mulW (negP b) (negP a))
               (mulWComm (posP a) (posP b)) (mulWComm (negP a) (negP b)))
            (transEq Whole
               (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b)))
               (addW (mulW (negP a) (posP b)) (mulW (posP a) (negP b)))
               (addW (mulW (posP b) (negP a)) (mulW (negP b) (posP a)))
               (addWComm (mulW (posP a) (negP b)) (mulW (negP a) (posP b)))
               (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
                  (mulW (negP a) (posP b)) (mulW (posP b) (negP a)) (mulW (posP a) (negP b)) (mulW (negP b) (posP a))
                  (mulWComm (negP a) (posP b)) (mulWComm (posP a) (negP b)))))
         (symEq Int (imul b a)
            (wsub (addW (mulW (posP b) (posP a)) (mulW (negP b) (negP a))) (addW (mulW (posP b) (negP a)) (mulW (negP b) (posP a))))
            (imulSpec b a)))
  end
end

-- Right mirror of imulWsub, via imulComm (avoids re-deriving mulCrossIdent on
-- the flipped multiplier column).
imulWsubR : (z : Int) -> (p : Whole) -> (n : Whole)
  -> Eq Int (imul z (wsub p n))
       (wsub (addW (mulW p (posP z)) (mulW n (negP z))) (addW (mulW p (negP z)) (mulW n (posP z)))) is
  fn (z : Int) (p : Whole) (n : Whole) is
    transEq Int (imul z (wsub p n)) (imul (wsub p n) z)
      (wsub (addW (mulW p (posP z)) (mulW n (negP z))) (addW (mulW p (negP z)) (mulW n (posP z))))
      (imulComm z (wsub p n))
      (imulWsub p n z)
  end
end

-- iadd is associative (collapse the inner op with iaddSpec, the outer with
-- iaddWsub/iaddWsubR; close with addWAssoc componentwise).
iaddAssoc : AssocT Int iadd is
  fn (a : Int) (b : Int) (c : Int) is
    transEq Int (iadd (iadd a b) c)
      (wsub (addW (addW (posP a) (posP b)) (posP c)) (addW (addW (negP a) (negP b)) (negP c)))
      (iadd a (iadd b c))
      (transEq Int (iadd (iadd a b) c)
         (iadd (wsub (addW (posP a) (posP b)) (addW (negP a) (negP b))) c)
         (wsub (addW (addW (posP a) (posP b)) (posP c)) (addW (addW (negP a) (negP b)) (negP c)))
         (congIaddL (iadd a b) (wsub (addW (posP a) (posP b)) (addW (negP a) (negP b))) c (iaddSpec a b))
         (iaddWsub (addW (posP a) (posP b)) (addW (negP a) (negP b)) c))
      (transEq Int
         (wsub (addW (addW (posP a) (posP b)) (posP c)) (addW (addW (negP a) (negP b)) (negP c)))
         (wsub (addW (posP a) (addW (posP b) (posP c))) (addW (negP a) (addW (negP b) (negP c))))
         (iadd a (iadd b c))
         (congWsub2 (addW (addW (posP a) (posP b)) (posP c)) (addW (posP a) (addW (posP b) (posP c)))
                    (addW (addW (negP a) (negP b)) (negP c)) (addW (negP a) (addW (negP b) (negP c)))
            (addWAssoc (posP a) (posP b) (posP c)) (addWAssoc (negP a) (negP b) (negP c)))
         (symEq Int (iadd a (iadd b c))
            (wsub (addW (posP a) (addW (posP b) (posP c))) (addW (negP a) (addW (negP b) (negP c))))
            (transEq Int (iadd a (iadd b c))
               (iadd a (wsub (addW (posP b) (posP c)) (addW (negP b) (negP c))))
               (wsub (addW (posP a) (addW (posP b) (posP c))) (addW (negP a) (addW (negP b) (negP c))))
               (congIaddR a (iadd b c) (wsub (addW (posP b) (posP c)) (addW (negP b) (negP c))) (iaddSpec b c))
               (iaddWsubR a (addW (posP b) (posP c)) (addW (negP b) (negP c))))))
  end
end

-- Right distributivity: (a + b) * c = a*c + b*c. Distribute each column
-- (distribWR) and interchange to the two-product columns.
idistribR : DistribRT Int iadd imul is
  fn (a : Int) (b : Int) (c : Int) is
    transEq Int (imul (iadd a b) c)
      (wsub (addW (mulW (addW (posP a) (posP b)) (posP c)) (mulW (addW (negP a) (negP b)) (negP c)))
            (addW (mulW (addW (posP a) (posP b)) (negP c)) (mulW (addW (negP a) (negP b)) (posP c))))
      (iadd (imul a c) (imul b c))
      (transEq Int (imul (iadd a b) c)
         (imul (wsub (addW (posP a) (posP b)) (addW (negP a) (negP b))) c)
         (wsub (addW (mulW (addW (posP a) (posP b)) (posP c)) (mulW (addW (negP a) (negP b)) (negP c)))
               (addW (mulW (addW (posP a) (posP b)) (negP c)) (mulW (addW (negP a) (negP b)) (posP c))))
         (congImulL (iadd a b) (wsub (addW (posP a) (posP b)) (addW (negP a) (negP b))) c (iaddSpec a b))
         (imulWsub (addW (posP a) (posP b)) (addW (negP a) (negP b)) c))
      (transEq Int
         (wsub (addW (mulW (addW (posP a) (posP b)) (posP c)) (mulW (addW (negP a) (negP b)) (negP c)))
               (addW (mulW (addW (posP a) (posP b)) (negP c)) (mulW (addW (negP a) (negP b)) (posP c))))
         (wsub (addW (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))))
               (addW (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))
         (iadd (imul a c) (imul b c))
         (congWsub2
            (addW (mulW (addW (posP a) (posP b)) (posP c)) (mulW (addW (negP a) (negP b)) (negP c)))
            (addW (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))))
            (addW (mulW (addW (posP a) (posP b)) (negP c)) (mulW (addW (negP a) (negP b)) (posP c)))
            (addW (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))))
            (transEq Whole
               (addW (mulW (addW (posP a) (posP b)) (posP c)) (mulW (addW (negP a) (negP b)) (negP c)))
               (addW (addW (mulW (posP a) (posP c)) (mulW (posP b) (posP c))) (addW (mulW (negP a) (negP c)) (mulW (negP b) (negP c))))
               (addW (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))))
               (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
                  (mulW (addW (posP a) (posP b)) (posP c)) (addW (mulW (posP a) (posP c)) (mulW (posP b) (posP c)))
                  (mulW (addW (negP a) (negP b)) (negP c)) (addW (mulW (negP a) (negP c)) (mulW (negP b) (negP c)))
                  (distribWR (posP a) (posP b) (posP c)) (distribWR (negP a) (negP b) (negP c)))
               (addWInterchange (mulW (posP a) (posP c)) (mulW (posP b) (posP c)) (mulW (negP a) (negP c)) (mulW (negP b) (negP c))))
            (transEq Whole
               (addW (mulW (addW (posP a) (posP b)) (negP c)) (mulW (addW (negP a) (negP b)) (posP c)))
               (addW (addW (mulW (posP a) (negP c)) (mulW (posP b) (negP c))) (addW (mulW (negP a) (posP c)) (mulW (negP b) (posP c))))
               (addW (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))))
               (cong2W (fn (u : Whole) (v : Whole) is addW u v end)
                  (mulW (addW (posP a) (posP b)) (negP c)) (addW (mulW (posP a) (negP c)) (mulW (posP b) (negP c)))
                  (mulW (addW (negP a) (negP b)) (posP c)) (addW (mulW (negP a) (posP c)) (mulW (negP b) (posP c)))
                  (distribWR (posP a) (posP b) (negP c)) (distribWR (negP a) (negP b) (posP c)))
               (addWInterchange (mulW (posP a) (negP c)) (mulW (posP b) (negP c)) (mulW (negP a) (posP c)) (mulW (negP b) (posP c)))))
         (symEq Int (iadd (imul a c) (imul b c))
            (wsub (addW (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))))
                  (addW (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))
            (transEq Int (iadd (imul a c) (imul b c))
               (iadd (wsub (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c)))) (imul b c))
               (wsub (addW (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))))
                     (addW (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))
               (congIaddL (imul a c) (wsub (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c)))) (imul b c) (imulSpec a c))
               (transEq Int
                  (iadd (wsub (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c)))) (imul b c))
                  (iadd (wsub (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c))))
                        (wsub (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))
                  (wsub (addW (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))))
                        (addW (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))
                  (congIaddR (wsub (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c)))) (imul b c) (wsub (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))) (imulSpec b c))
                  (iaddWsub2 (addW (mulW (posP a) (posP c)) (mulW (negP a) (negP c))) (addW (mulW (posP a) (negP c)) (mulW (negP a) (posP c)))
                             (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))))))))
  end
end

-- Left distributivity: a * (b + c) = a*b + a*c, via imulComm + idistribR.
idistribL : DistribLT Int iadd imul is
  fn (a : Int) (b : Int) (c : Int) is
    transEq Int (imul a (iadd b c)) (imul (iadd b c) a) (iadd (imul a b) (imul a c))
      (imulComm a (iadd b c))
      (transEq Int (imul (iadd b c) a) (iadd (imul b a) (imul c a)) (iadd (imul a b) (imul a c))
         (idistribR b c a)
         (transEq Int (iadd (imul b a) (imul c a)) (iadd (imul a b) (imul c a)) (iadd (imul a b) (imul a c))
            (congIaddL (imul b a) (imul a b) (imul c a) (imulComm b a))
            (congIaddR (imul a b) (imul c a) (imul a c) (imulComm c a))))
  end
end

-- imul is associative: the eight-term shuffle via mulAssocCol on each column
-- (the neg column reuses mulAssocCol with the c-factors e/f swapped + addWComm).
imulAssoc : AssocT Int imul is
  fn (a : Int) (b : Int) (c : Int) is
    transEq Int (imul (imul a b) c)
      (wsub (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (posP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (negP c)))
            (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (negP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (posP c))))
      (imul a (imul b c))
      (transEq Int (imul (imul a b) c)
         (imul (wsub (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b)))) c)
         (wsub (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (posP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (negP c)))
               (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (negP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (posP c))))
         (congImulL (imul a b) (wsub (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b)))) c (imulSpec a b))
         (imulWsub (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) c))
      (transEq Int
         (wsub (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (posP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (negP c)))
               (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (negP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (posP c))))
         (wsub (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (posP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (negP a)))
               (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a))))
         (imul a (imul b c))
         (congWsub2
            (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (posP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (negP c)))
            (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (posP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (negP a)))
            (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (negP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (posP c)))
            (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a)))
            (mulAssocCol (posP a) (negP a) (posP b) (negP b) (posP c) (negP c))
            (transEq Whole
               (addW (mulW (addW (mulW (posP a) (posP b)) (mulW (negP a) (negP b))) (negP c)) (mulW (addW (mulW (posP a) (negP b)) (mulW (negP a) (posP b))) (posP c)))
               (addW (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a)) (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)))
               (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a)))
               (mulAssocCol (posP a) (negP a) (posP b) (negP b) (negP c) (posP c))
               (addWComm (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a)) (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)))))
         (symEq Int (imul a (imul b c))
            (wsub (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (posP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (negP a)))
                  (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a))))
            (transEq Int (imul a (imul b c))
               (imul a (wsub (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))
               (wsub (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (posP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (negP a)))
                     (addW (mulW (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (negP a)) (mulW (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c))) (posP a))))
               (congImulR a (imul b c) (wsub (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))) (imulSpec b c))
               (imulWsubR a (addW (mulW (posP b) (posP c)) (mulW (negP b) (negP c))) (addW (mulW (posP b) (negP c)) (mulW (negP b) (posP c)))))))
  end
end

-- Multiplicative identities: nonneg (succ zero) is the unit on both sides.
imulOneL : IdLT Int imul (nonneg (succ zero)) is
  fn (a : Int) is
    transEq Int (imul (nonneg (succ zero)) a)
      (wsub (addW (posP a) zero) (addW (negP a) zero))
      a
      (imulSpec (nonneg (succ zero)) a)
      (transEq Int (wsub (addW (posP a) zero) (addW (negP a) zero)) (wsub (posP a) (negP a)) a
         (congWsub2 (addW (posP a) zero) (posP a) (addW (negP a) zero) (negP a) (addWZeroR (posP a)) (addWZeroR (negP a)))
         (wsubRep a))
  end
end
imulOneR : IdRT Int imul (nonneg (succ zero)) is
  fn (a : Int) is
    transEq Int (imul a (nonneg (succ zero)))
      (wsub (addW (posP a) zero) (addW (negP a) zero))
      a
      (imulWsubR a (succ zero) zero)
      (transEq Int (wsub (addW (posP a) zero) (addW (negP a) zero)) (wsub (posP a) (negP a)) a
         (congWsub2 (addW (posP a) zero) (posP a) (addW (negP a) zero) (negP a) (addWZeroR (posP a)) (addWZeroR (negP a)))
         (wsubRep a))
  end
end

-- ====================================================================
-- THE ASSEMBLED INT LAW RECORDS. semiringLawsInt is the 11-slot chain over
-- ringInt.1 (same shape as semiringLawsWhole); ringLawsInt layers the two
-- additive-inverse laws; commLawsInt is imulComm; commRingLawsInt bundles
-- them; abGroupLawsInt cashes the 1b bridge (abGroupLawsOfRing) in ONE line -
-- Int IS an abelian group under addition, for free from RingLaws.
-- ====================================================================
semiringLawsInt : SemiringLaws Int (ringInt.1) is
  mkAnd (AssocT Int iadd)
        (And (CommT Int iadd)
        (And (IdLT Int iadd (nonneg zero))
        (And (IdRT Int iadd (nonneg zero))
        (And (AssocT Int imul)
        (And (IdLT Int imul (nonneg (succ zero)))
        (And (IdRT Int imul (nonneg (succ zero)))
        (And (DistribLT Int iadd imul)
        (And (DistribRT Int iadd imul)
        (And (AnnihLT Int imul (nonneg zero))
             (AnnihRT Int imul (nonneg zero)))))))))))
    iaddAssoc
    (mkAnd (CommT Int iadd)
          (And (IdLT Int iadd (nonneg zero))
          (And (IdRT Int iadd (nonneg zero))
          (And (AssocT Int imul)
          (And (IdLT Int imul (nonneg (succ zero)))
          (And (IdRT Int imul (nonneg (succ zero)))
          (And (DistribLT Int iadd imul)
          (And (DistribRT Int iadd imul)
          (And (AnnihLT Int imul (nonneg zero))
               (AnnihRT Int imul (nonneg zero))))))))))
      iaddComm
      (mkAnd (IdLT Int iadd (nonneg zero))
            (And (IdRT Int iadd (nonneg zero))
            (And (AssocT Int imul)
            (And (IdLT Int imul (nonneg (succ zero)))
            (And (IdRT Int imul (nonneg (succ zero)))
            (And (DistribLT Int iadd imul)
            (And (DistribRT Int iadd imul)
            (And (AnnihLT Int imul (nonneg zero))
                 (AnnihRT Int imul (nonneg zero)))))))))
        iaddZeroL
        (mkAnd (IdRT Int iadd (nonneg zero))
              (And (AssocT Int imul)
              (And (IdLT Int imul (nonneg (succ zero)))
              (And (IdRT Int imul (nonneg (succ zero)))
              (And (DistribLT Int iadd imul)
              (And (DistribRT Int iadd imul)
              (And (AnnihLT Int imul (nonneg zero))
                   (AnnihRT Int imul (nonneg zero))))))))
          iaddZeroR
          (mkAnd (AssocT Int imul)
                (And (IdLT Int imul (nonneg (succ zero)))
                (And (IdRT Int imul (nonneg (succ zero)))
                (And (DistribLT Int iadd imul)
                (And (DistribRT Int iadd imul)
                (And (AnnihLT Int imul (nonneg zero))
                     (AnnihRT Int imul (nonneg zero)))))))
            imulAssoc
            (mkAnd (IdLT Int imul (nonneg (succ zero)))
                  (And (IdRT Int imul (nonneg (succ zero)))
                  (And (DistribLT Int iadd imul)
                  (And (DistribRT Int iadd imul)
                  (And (AnnihLT Int imul (nonneg zero))
                       (AnnihRT Int imul (nonneg zero))))))
              imulOneL
              (mkAnd (IdRT Int imul (nonneg (succ zero)))
                    (And (DistribLT Int iadd imul)
                    (And (DistribRT Int iadd imul)
                    (And (AnnihLT Int imul (nonneg zero))
                         (AnnihRT Int imul (nonneg zero)))))
                imulOneR
                (mkAnd (DistribLT Int iadd imul)
                      (And (DistribRT Int iadd imul)
                      (And (AnnihLT Int imul (nonneg zero))
                           (AnnihRT Int imul (nonneg zero))))
                  idistribL
                  (mkAnd (DistribRT Int iadd imul)
                        (And (AnnihLT Int imul (nonneg zero))
                             (AnnihRT Int imul (nonneg zero)))
                    idistribR
                    (mkAnd (AnnihLT Int imul (nonneg zero))
                           (AnnihRT Int imul (nonneg zero))
                      imulZeroL
                      imulZeroR)))))))))
end

ringLawsInt : RingLaws Int ringInt is
  mkAnd (SemiringLaws Int (ringInt.1))
    (And (NegInvLT Int iadd ineg (nonneg zero)) (NegInvRT Int iadd ineg (nonneg zero)))
    semiringLawsInt
    (mkAnd (NegInvLT Int iadd ineg (nonneg zero)) (NegInvRT Int iadd ineg (nonneg zero))
      inegInvL inegInvR)
end

commLawsInt : CommLaws Int semiringInt is imulComm end

commRingLawsInt : CommRingLaws Int ringInt is
  mkAnd (RingLaws Int ringInt) (CommLaws Int (ringInt.1)) ringLawsInt commLawsInt
end

abGroupLawsInt : AbGroupLaws Int (groupOfRing Int ringInt) is
  abGroupLawsOfRing Int ringInt ringLawsInt
end

-- ====================================================================
-- THE TOWER GRAPH (v4). Named injections up the tower with homomorphism
-- certificates. Edges: wholeOf (Nat -> Whole, the projection, above),
-- intOf (Whole -> Int), fracOf (Whole -> Frac), ratOfInt (Int -> Frac).
-- The intOf edge preserves + * 1, now DIRECTLY BY REFL: intOf commutes with
-- iadd/imul on the nose because iadd/imul on two `nonneg` values compute
-- straight to `nonneg` of the Whole result, no normalizing step in between.
-- (Under the old sign+magnitude Int this triangle needed a normalization
-- lemma certifying that the smart constructor's minus-zero normalization
-- was a no-op on an already-non-negative magnitude; junk-free Int has no
-- such lemma to state because it has no such junk to normalize away.) The
-- Frac edges' homomorphisms need gcd/reduce theory and ship with the Frac
-- laws campaign. The triangle ratOfInt . intOf = fracOf is DEFINITIONAL
-- (both sides are frac false n 1).
-- ====================================================================
ratOfInt : Int -> Frac is
  fn (i : Int) is frac (isign i) (imag i) 1 end
end

intOfAdd : (a : Whole) -> (b : Whole) -> Eq Int (iadd (intOf a) (intOf b)) (intOf (addW a b)) is
  fn (a : Whole) (b : Whole) is refl (nonneg (addW a b)) end
end
intOfMul : (a : Whole) -> (b : Whole) -> Eq Int (imul (intOf a) (intOf b)) (intOf (mulW a b)) is
  fn (a : Whole) (b : Whole) is refl (nonneg (mulW a b)) end
end
intOfOne : Eq Int (intOf (succ zero)) (nonneg (succ zero)) is refl (nonneg (succ zero)) end

-- The commuting triangle, by refl: ratOfInt (intOf n) = frac false n 1 = fracOf n.
ratOfIntOf : (n : Whole) -> Eq Frac (ratOfInt (intOf n)) (fracOf n) is
  fn (n : Whole) is refl (frac false n 1) end
end

-- ====================================================================
-- PROVABLY-WHOLE subtraction.  When `b <= a` is in hand, a − b stays a Whole, no
-- promotion: the proof is part of the TYPE. `monus` is the unconditional truncating
-- whole subtraction (floors at 0) for when underflow is acceptable.
-- ====================================================================
Leq : Whole -> Whole -> U is fn (a : Whole) (b : Whole) is Eq Bool (leb a b) true end end
minus : (a : Whole) -> (b : Whole) -> Leq b a -> Whole is
  fn (a : Whole) (b : Whole) (_pf : Leq b a) is subW a b end
end
monus : Whole -> Whole -> Whole is fn (a : Whole) (b : Whole) is subW a b end end

-- ====================================================================
-- DIVISION, DEFENDED.  ℕ is not closed under division either; the fraction builder
-- `/` climbs to ℚ. But x/0 is undefined at every rung, so a CHECKED division
-- returns a Result: `ok` the (reduced) quotient, or `err` on a zero divisor.
-- ====================================================================
data Result : U -> U -> U is
  ok  : (A : U) -> (E : U) -> A -> Result A E
| err : (A : U) -> (E : U) -> E -> Result A E
end

-- ArithErr — a DISCRIMINATED UNION of the ways an arithmetic operation can fail,
-- each variant CARRYING the operands that explain it (the Idris2 / Lean4 / Haskell
-- spirit: an error is structured DATA, not a string). The human-readable message is
-- the Show boundary — here the REPL's pretty-printer, which folds each variant to a
-- sentence (`divByZero 7 0` -> "cannot divide 7 by 0"), so the operands need not be
-- re-parsed out of a baked f-string. Room is left for further faults: add a
-- constructor and a renderer arm. `divByZero a b` covers the `b = (1-1)` case — the
-- zero denominator is carried, whatever expression produced it.
data ArithErr : U is
  divByZero   : Whole -> Whole -> ArithErr   -- a / 0  — carries (numerator, denominator)
| notIntegral : Frac  -> ArithErr            -- demotion of a value with denominator > 1
| negative    : Frac  -> ArithErr            -- demotion of a negative value to Whole / Nat
| notCounting : Frac  -> ArithErr            -- demotion of zero to a counting number (Nat)
end

divChecked : Whole -> Whole -> Result Frac ArithErr is
  fn (a : Whole) (b : Whole) is
    case b of
    | zero   -> err Frac ArithErr (divByZero a b)
    | succ k -> ok Frac ArithErr (reduce (frac false a b))
    end
  end
end

-- ====================================================================
-- DEMOTION, checked.  Climbing the tower (− promotes, / climbs to ℚ) is implicit;
-- coming back DOWN is not — `3/1` is `3 : Frac`, a rational that happens to be
-- whole. `toInt`/`toWhole` are the deliberate, checked descents: a fraction lands
-- in Int (resp. Whole) only when it is integral (denominator 1 in lowest terms),
-- and `toWhole` additionally only when it is non-negative; otherwise `err`. (Lisp
-- demotes implicitly because it is dynamically typed; here, where the type is a
-- static commitment, the divisibility check is made explicit and returns a Result.)
-- ====================================================================
toInt : Frac -> Result Int ArithErr is
  fn (f : Frac) is
    let r : Frac = reduce f in
    case fden r of
    | zero   -> err Int ArithErr (notIntegral f)
    | succ k ->
        case k of
        | succ j -> err Int ArithErr (notIntegral f)         -- denominator >= 2: not integral
        | zero   -> ok Int ArithErr (signOfMag (fneg r) (fnum r)) -- denominator 1: the integer
        end
    end
  end
end
toWhole : Frac -> Result Whole ArithErr is
  fn (f : Frac) is
    let r : Frac = reduce f in
    case fden r of
    | zero   -> err Whole ArithErr (notIntegral f)
    | succ k ->
        case k of
        | succ j -> err Whole ArithErr (notIntegral f)   -- denominator >= 2: not integral
        | zero   ->
            case fnum r of
            | zero   -> ok Whole ArithErr 0              -- zero is whole (any sign)
            | succ n ->
                case fneg r of
                | false -> ok Whole ArithErr (fnum r)    -- positive integer
                | true  -> err Whole ArithErr (negative f) -- negative: no whole answer
                end
            end
        end
    end
  end
end
-- toNat descends to the COUNTING numbers {1,2,3,…} (the positive-whole Σ, Nat): it
-- additionally rejects zero, since zero is not a counting number. The ok payload is
-- built from the pattern variable `succ n` (not `fnum r`), so `isPos (succ n)`
-- computes to `true` and the nonzero proof is `refl true`.
toNat : Frac -> Result Nat ArithErr is
  fn (f : Frac) is
    let r : Frac = reduce f in
    case fden r of
    | zero   -> err Nat ArithErr (notIntegral f)
    | succ k ->
        case k of
        | succ j -> err Nat ArithErr (notIntegral f)   -- denominator >= 2: not integral
        | zero   ->
            case fnum r of
            | zero   -> err Nat ArithErr (notCounting f) -- zero: integral, but not a counting number
            | succ n ->
                case fneg r of
                | true  -> err Nat ArithErr (negative f) -- negative: no counting answer
                | false -> ok Nat ArithErr
                    (Pair Whole (fn (m : Whole) is Eq Bool (isPos m) true end) (succ n) (refl true))
                end
            end
        end
    end
  end
end

powTen : Whole -> Whole is
  fn (n : Whole) is case n of | zero -> 1 | succ k with ih -> 10 * ih end end
end

data WList : U is wnil : WList | wcons : Whole -> WList -> WList end

eqW : Whole -> Whole -> Bool is
  fn (m : Whole) is
    case m of
    | zero -> fn (n : Whole) is case n of | zero -> true | succ j -> false end end
    | succ k with ih -> fn (n : Whole) is case n of | zero -> false | succ j -> ih j end end
    end
  end
end

-- The low `count` digits of v, most significant first, zero-padded (the rounded
-- fractional part). digitsOf 2 75 = [7,5]; digitsOf 2 5 = [0,5].
digitsOf : Whole -> Whole -> WList is
  fn (count : Whole) is
    case count of
    | zero -> fn (v : Whole) is wnil end
    | succ k with ih -> fn (v : Whole) is wcons ((v // powTen k) % 10) (ih v) end
    end
  end
end

-- A plain pair, the (mantissa, remainder) of a long-division run.
data P2 : U is p2 : Whole -> Whole -> P2 end
p2m : P2 -> Whole is fn (x : P2) is case x of | p2 a b -> a end end end
p2r : P2 -> Whole is fn (x : P2) is case x of | p2 a b -> b end end end

-- Long division to `count` fractional digits: (mantissa of those digits, remainder
-- after them). Each step divides rem*10 < den*10, so every // here is small.
longDiv : Whole -> Whole -> Whole -> P2 is
  fn (den : Whole) (count : Whole) is
    case count of
    | zero -> fn (rem : Whole) is p2 0 rem end
    | succ k with ih -> fn (rem : Whole) is
        let r10 : Whole = rem * 10 in
        let rest : P2 = ih (r10 % den) in
        p2 ((r10 // den) * powTen k + p2m rest) (p2r rest)
      end
    end
  end
end

-- The EXACT decimal of a fraction: sign, integer part, fractional digits, where
-- the repetend begins, and whether it terminates. `rdec false 0 [7,5] _ true` is
-- 0.75; `rdec true 0 [3] 0 false` is -0.{3}; `rdec false 0 [1,6] 1 false` is 0.1{6}.
data RDec : U is rdec : Bool -> Whole -> WList -> Whole -> Bool -> RDec end

-- Round a fraction to n decimal PLACES (round half up), as a terminating RDec:
-- n long-division digits of the magnitude, plus a carry if the next digit is >= 5,
-- carrying the fraction's sign.
roundTo : Whole -> Frac -> RDec is
  fn (n : Whole) (f : Frac) is
    let body  : P2    = longDiv (fden f) n (fnum f % fden f) in
    let nextd : Whole = (p2r body * 10) // fden f in
    let bump  : Whole = case leb 5 nextd of | true -> 1 | false -> 0 end in
    let m     : Whole = (fnum f // fden f) * powTen n + p2m body + bump in
    rdec (fneg f) (m // powTen n) (digitsOf n (m % powTen n)) 0 true
  end
end

to_radix_sigplace : Whole -> Frac -> RDec is fn (n : Whole) (f : Frac) is roundTo n f end end

-- Number of decimal digits of a whole (q < 10 has 1).
numDigits : Whole -> Whole -> Whole is
  fn (cap : Whole) is
    case cap of
    | zero -> fn (q : Whole) is 1 end
    | succ c with ih -> fn (q : Whole) is
        case leb 10 q of | false -> 1 | true -> succ (ih (q // 10)) end
      end
    end
  end
end

-- Leading zeros after the point for |f| < 1: smallest z with num*10^(z+1) >= den
-- (multiplication and comparison only — no division).
leadingZeros : Whole -> Frac -> Whole is
  fn (cap : Whole) (f : Frac) is
    (case cap of
     | zero -> fn (z : Whole) is z end
     | succ c with ih -> fn (z : Whole) is
         case leb (fden f) (fnum f * powTen (succ z)) of
         | true  -> z
         | false -> ih (succ z)
         end
       end
     end : Whole -> Whole) 0
  end
end

-- Decimal places for s SIGNIFICANT FIGURES: for |f| >= 1, s - (integer digits);
-- for |f| < 1, s + (leading zeros after the point).
sigPlaces : Whole -> Frac -> Whole is
  fn (s : Whole) (f : Frac) is
    case leb 1 (fnum f // fden f) of
    | true  -> subW s (numDigits 64 (fnum f // fden f))
    | false -> s + leadingZeros 64 f
    end
  end
end

to_radix_sigfig : Whole -> Frac -> RDec is
  fn (s : Whole) (f : Frac) is roundTo (sigPlaces s f) f end
end

-- The fractional expansion produced by cycle-detecting long division: the digits,
-- where the repetend begins, and whether it terminates (no repetend).
data FBody : U is fbody : WList -> Whole -> Bool -> FBody end
fbDigits : FBody -> WList is fn (b : FBody) is case b of | fbody d r t -> d end end end
fbRep    : FBody -> Whole is fn (b : FBody) is case b of | fbody d r t -> r end end end
fbTerm   : FBody -> Bool  is fn (b : FBody) is case b of | fbody d r t -> t end end end

-- Append at the end: the seen-remainders list grows in position order.
wsnoc : WList -> Whole -> WList is
  fn (xs : WList) (x : Whole) is
    case xs of
    | wnil -> wcons x wnil
    | wcons h t with ih -> wcons h ih
    end
  end
end
wmember : Whole -> WList -> Bool is
  fn (x : Whole) (xs : WList) is
    case xs of
    | wnil -> false
    | wcons h t with ih -> case eqW x h of | true -> true | false -> ih end
    end
  end
end
windex : Whole -> WList -> Whole is
  fn (x : Whole) (xs : WList) is
    case xs of
    | wnil -> 0
    | wcons h t with ih -> case eqW x h of | true -> 0 | false -> succ ih end
    end
  end
end

-- Long division with cycle detection. fuel bounds the loop (a cycle appears within
-- `den` steps by pigeonhole); seen records remainders in position order so a recur
-- gives the repetend's start.
expand : Whole -> Whole -> Whole -> WList -> FBody is
  fn (den : Whole) (fuel : Whole) is
    case fuel of
    | zero -> fn (rem : Whole) (seen : WList) is fbody wnil 0 true end
    | succ fl with ih -> fn (rem : Whole) (seen : WList) is
        case rem of
        | zero -> fbody wnil 0 true
        | succ rp ->
            case wmember rem seen of
            | true  -> fbody wnil (windex rem seen) false
            | false ->
                let r10  : Whole = rem * 10 in
                let rest : FBody = ih (r10 % den) (wsnoc seen rem) in
                fbody (wcons (r10 // den) (fbDigits rest)) (fbRep rest) (fbTerm rest)
            end
        end
      end
    end
  end
end

-- The exact decimal of a fraction, sign and repetend and all.
to_radix : Frac -> RDec is
  fn (f : Frac) is
    let body : FBody = expand (fden f) (succ (fden f)) (fnum f % fden f) wnil in
    rdec (fneg f) (fnum f // fden f) (fbDigits body) (fbRep body) (fbTerm body)
  end
end

-- ====================================================================
-- Packed binary strings + total numeric parsing (D1 + B4 + the goal).
-- `Bytes` is "Haskell's binary thing only better": a String is a SINGLE Whole
-- (a bignum) packing the UTF-8 bytes — NOT a [Char] cons-list. The first byte is
-- least-significant and a 0x01 SENTINEL caps the top, so the length is recoverable
-- (leading-NUL bytes survive) and `uncons` is O(1): head = code % 256, tail =
-- code // 256, and the string is exhausted when code <= 1 (sentinel only). A
-- literal `"3/4"` desugars (surface) to `bytes <packed>`, so strings COMPUTE in
-- the kernel — these parsers run in the REPL, no host needed. The `// %` accel
-- (above) keeps uncons one bigint step.
-- ====================================================================

data Bytes : U is bytes : Whole -> Bytes end
String : U is Bytes end

codeOf : Bytes -> Whole is fn (s : Bytes) is case s of | bytes n -> n end end end

-- exhausted when only the sentinel (or less) remains. Uses `leW` (not `leb`): the
-- packed `code` is a bignum, and `leb (codeOf s) 1` unrolls O(code) in compiled code
-- (see leW/lebEquiv above). `leW _ 1` is O(1) and `lebEquiv` certifies it = leb.
strNull : Bytes -> Bool  is fn (s : Bytes) is leW (codeOf s) 1 end end
-- the first byte (its UTF-8 code), or the sentinel value on an empty string.
strHead : Bytes -> Whole is fn (s : Bytes) is codeOf s % 256 end end
-- drop the first byte.
strTail : Bytes -> Bytes is fn (s : Bytes) is bytes (codeOf s // 256) end end

andB : Bool -> Bool -> Bool is fn (a : Bool) (b : Bool) is case a of | true -> b | false -> false end end end

-- prepend a byte `c` (0 <= c < 256) to a string: the new packed code is `c + 256*n`
-- (the bytes shift up one place, the sentinel rides along). O(1) via the accel ops;
-- verified against the existing accessors: strHead (c+256n) = c, strTail = bytes n,
-- and c+256n >= 256 > 1 so it is never null.
strCons : Whole -> Bytes -> Bytes is
  fn (c : Whole) (s : Bytes) is bytes (addW c (mulW 256 (codeOf s))) end
end

-- byte length and concatenation are structural recursion on FUEL (byte count), NEVER on
-- the packed code (~256^length — a code-sized recursion OOMs the eager codegen, the leb
-- lesson). The loops early-return at the sentinel, so runtime is O(length); `strFuel` is
-- only a safety bound far past any practical string.
strFuel : Whole is 1048576 end

strLenGo : Whole -> Whole -> Bytes -> Whole is
  fn (fuel : Whole) is
    WholeElim (fn (k : Whole) is Whole -> Bytes -> Whole end)
      (fn (acc : Whole) (s : Bytes) is acc end)
      (fn (f : Whole) (ih : Whole -> Bytes -> Whole) is
        fn (acc : Whole) (s : Bytes) is
          case strNull s of
          | true  -> acc
          | false -> ih (addW acc 1) (strTail s)
          end
        end
      end)
      fuel
  end
end
strLen : Bytes -> Whole is fn (s : Bytes) is strLenGo strFuel 0 s end end

strAppGo : Whole -> Bytes -> Bytes -> Bytes is
  fn (fuel : Whole) is
    WholeElim (fn (k : Whole) is Bytes -> Bytes -> Bytes end)
      (fn (s : Bytes) (t : Bytes) is t end)
      (fn (f : Whole) (ih : Bytes -> Bytes -> Bytes) is
        fn (s : Bytes) (t : Bytes) is
          case strNull s of
          | true  -> t
          | false -> strCons (strHead s) (ih (strTail s) t)
          end
        end
      end)
      fuel
  end
end
-- concatenation: cons each byte of `s` onto `t`. Fuel is exactly `strLen s` (a literal
-- for a closed string, so the loop runs exactly length-of-s times).
strApp : Bytes -> Bytes -> Bytes is fn (s : Bytes) (t : Bytes) is strAppGo (strLen s) s t end end

-- decidable string equality: the codes are equal (each <= the other). Uses subW/isZero
-- (O(1) accel), NOT leb (which is O(code) in compiled code). Sound because the sentinel
-- makes the packed encoding injective.
strEq : Bytes -> Bytes -> Bool is
  fn (a : Bytes) (b : Bytes) is
    andB (isZero (subW (codeOf a) (codeOf b))) (isZero (subW (codeOf b) (codeOf a)))
  end
end

-- String is a Magma and a Monoid under concatenation (identity = the empty string,
-- packed code 1). So `++` works on string literals. Associativity is proven in the
-- listings over the rune-list view (ch438 sappAssoc), not yet as a SemigroupLaws
-- value over this packed Bytes instance.
instance magmaBytes : Magma Bytes is strApp end
instance monoidBytes    : Monoid Bytes is mkMonoid Bytes strApp (bytes 1) end

eqW  : Whole -> Whole -> Bool is fn (a : Whole) (b : Whole) is andB (leb a b) (leb b a) end end
-- a byte is an ASCII decimal digit iff 48 ('0') <= c <= 57 ('9').
isDigitB : Whole -> Bool is fn (c : Whole) is andB (leb 48 c) (leb c 57) end end

-- the ways a parse can fail (D1: total, a value you must case on — never a crash).
data ParseErr : U is
  emptyStr  : ParseErr     -- nothing to parse
| notNumber : ParseErr     -- a byte that is not a digit / sign / slash
| badDenom  : ParseErr     -- a rational with denominator 0
| tooLong   : ParseErr     -- exceeded the parse fuel (a >256-byte token)
end

-- the digit loop: total structural recursion on FUEL (a generous fixed bound, far
-- past any real numeral), recursing into a FUNCTION type so the accumulator + the
-- remaining string thread through. Computes in the REPL (no `partial`, which would
-- stay neutral). 256 bytes of digits is astronomically more than any CLI number.
digitsGo : Whole -> Whole -> Bytes -> Result Whole ParseErr is
  fn (fuel : Whole) is
    WholeElim (fn (k : Whole) is Whole -> Bytes -> Result Whole ParseErr end)
      (fn (acc : Whole) (s : Bytes) is err Whole ParseErr tooLong end)
      (fn (f : Whole) (ih : Whole -> Bytes -> Result Whole ParseErr) is
        fn (acc : Whole) (s : Bytes) is
          case strNull s of
          | true  -> ok Whole ParseErr acc
          | false ->
              case isDigitB (strHead s) of
              | true  -> ih (addW (mulW acc 10) (subW (strHead s) 48)) (strTail s)
              | false -> err Whole ParseErr notNumber
              end
          end
        end
      end)
      fuel
  end
end

-- a Whole from the command line: a non-empty run of digits.
parseWhole : String -> Result Whole ParseErr is
  fn (s : String) is
    case strNull s of
    | true  -> err Whole ParseErr emptyStr
    | false -> digitsGo 256 0 s
    end
  end
end

resWtoI : Result Whole ParseErr -> Bool -> Result Int ParseErr is
  fn (r : Result Whole ParseErr) (sgn : Bool) is
    ResultElim Whole ParseErr (fn (x : Result Whole ParseErr) is Result Int ParseErr end)
      (fn (w : Whole) is ok Int ParseErr (signOfMag sgn w) end)
      (fn (e : ParseErr) is err Int ParseErr e end)
      r
  end
end

-- an Int: an optional leading '-' (byte 45) then a non-empty digit run.
parseInt : String -> Result Int ParseErr is
  fn (s : String) is
    case strNull s of
    | true  -> err Int ParseErr emptyStr
    | false ->
        case eqW (strHead s) 45 of
        | true  ->
            case strNull (strTail s) of
            | true  -> err Int ParseErr notNumber
            | false -> resWtoI (digitsGo 256 0 (strTail s)) true
            end
        | false -> resWtoI (digitsGo 256 0 s) false
        end
    end
  end
end

-- a Rational: [-] digits [ '/' (byte 47) digits ]. ONE pass, a state machine over
-- (sign, numerator, denominator, seen-slash, rest) recursing into a function type.
-- A bare integer "n" reads as n/1; a 0 denominator is `badDenom` (no crash).
fracGo : Whole -> Bool -> Whole -> Whole -> Bool -> Bytes -> Result Frac ParseErr is
  fn (fuel : Whole) is
    WholeElim (fn (k : Whole) is Bool -> Whole -> Whole -> Bool -> Bytes -> Result Frac ParseErr end)
      (fn (sg : Bool) (num : Whole) (den : Whole) (aft : Bool) (s : Bytes) is err Frac ParseErr tooLong end)
      (fn (f : Whole) (ih : Bool -> Whole -> Whole -> Bool -> Bytes -> Result Frac ParseErr) is
        fn (sg : Bool) (num : Whole) (den : Whole) (aft : Bool) (s : Bytes) is
          case strNull s of
          | true ->
              case aft of
              | false -> ok Frac ParseErr (reduce (frac sg num 1))
              | true  ->
                  case eqW den 0 of
                  | true  -> err Frac ParseErr badDenom
                  | false -> ok Frac ParseErr (reduce (frac sg num den))
                  end
              end
          | false ->
              case isDigitB (strHead s) of
              | true  ->
                  case aft of
                  | false -> ih sg (addW (mulW num 10) (subW (strHead s) 48)) den false (strTail s)
                  | true  -> ih sg num (addW (mulW den 10) (subW (strHead s) 48)) true (strTail s)
                  end
              | false ->
                  case eqW (strHead s) 47 of
                  | true  ->
                      case aft of
                      | true  -> err Frac ParseErr notNumber
                      | false -> ih sg num den true (strTail s)
                      end
                  | false -> err Frac ParseErr notNumber
                  end
              end
          end
        end
      end)
      fuel
  end
end

parseFrac : String -> Result Frac ParseErr is
  fn (s : String) is
    case strNull s of
    | true  -> err Frac ParseErr emptyStr
    | false ->
        case eqW (strHead s) 45 of
        | true  ->
            case strNull (strTail s) of
            | true  -> err Frac ParseErr notNumber
            | false -> fracGo 256 true 0 0 false (strTail s)
            end
        | false -> fracGo 256 false 0 0 false s
        end
    end
  end
end

-- ====================================================================
-- Binary: encode/decode between a value and its packed-Bytes rendering — the
-- "both" half of the goal (a serialization class, like Data.Binary, ONLY BETTER:
-- decode is TOTAL, returning Result, never a partial crashing `get`). The textual
-- parsers above ARE the decoders; the encoders render back to the same packed
-- Bytes, so `decode (encode x)` round-trips (computing on concretes; see the
-- rt* lemmas).
-- ====================================================================

-- prepend one byte (its UTF-8 code) onto a packed string: the new least-sig byte.
strCons : Whole -> Bytes -> Bytes is
  fn (b : Whole) (s : Bytes) is bytes (addW b (mulW 256 (codeOf s))) end
end

-- concatenate packed strings (s1's bytes, in order, then s2's). Fuel-bounded total
-- recursion on s1, recursing into the standard cons fold.
strAppGo : Whole -> Bytes -> Bytes -> Bytes is
  fn (fuel : Whole) is
    WholeElim (fn (k : Whole) is Bytes -> Bytes -> Bytes end)
      (fn (s1 : Bytes) (s2 : Bytes) is s2 end)
      (fn (f : Whole) (ih : Bytes -> Bytes -> Bytes) is
        fn (s1 : Bytes) (s2 : Bytes) is
          case strNull s1 of
          | true  -> s2
          | false -> strCons (strHead s1) (ih (strTail s1) s2)
          end
        end
      end)
      fuel
  end
end
strApp : Bytes -> Bytes -> Bytes is fn (s1 : Bytes) (s2 : Bytes) is strAppGo 256 s1 s2 end end

-- render a Whole to its decimal Bytes. Peel the least-significant digit (n % 10)
-- and PREPEND it (strCons), so the digits land most-significant-first; fuel-bounded.
encodeWholeGo : Whole -> Whole -> Bytes -> Bytes is
  fn (fuel : Whole) is
    WholeElim (fn (k : Whole) is Whole -> Bytes -> Bytes end)
      (fn (n : Whole) (acc : Bytes) is acc end)
      (fn (f : Whole) (ih : Whole -> Bytes -> Bytes) is
        fn (n : Whole) (acc : Bytes) is
          case eqW n 0 of
          | true  -> acc
          | false -> ih (n // 10) (strCons (addW 48 (n % 10)) acc)
          end
        end
      end)
      fuel
  end
end
encodeWhole : Whole -> Bytes is
  fn (n : Whole) is
    case eqW n 0 of
    | true  -> strCons 48 (bytes 1)       -- "0"
    | false -> encodeWholeGo 256 n (bytes 1)
    end
  end
end

-- render an Int: a '-' (byte 45) prefix when negative, else the magnitude.
encodeInt : Int -> Bytes is
  fn (i : Int) is
    case isign i of
    | true  -> strCons 45 (encodeWhole (imag i))
    | false -> encodeWhole (imag i)
    end
  end
end

-- render a Frac: a bare integer when the denominator is 1, else "num/den".
encodeFrac : Frac -> Bytes is
  fn (f : Frac) is
    case eqW (fden f) 1 of
    | true  -> encodeInt (signOfMag (fneg f) (fnum f))
    | false -> strApp (encodeInt (signOfMag (fneg f) (fnum f)))
                      (strApp (strCons 47 (bytes 1)) (encodeWhole (fden f)))
    end
  end
end

-- the Binary class (a Σ-record: an encoder + a TOTAL decoder), one instance per
-- tower rung. `encode`/`decode` dispatch on the resolved instance.
Binary : U -> U is
  fn (A : U) is Sig (A -> Bytes) (fn (_e : A -> Bytes) is Bytes -> Result A ParseErr end) end
end
mkBinary : (A : U) -> (A -> Bytes) -> (Bytes -> Result A ParseErr) -> Binary A is
  fn (A : U) (e : A -> Bytes) (d : Bytes -> Result A ParseErr) is
    Pair (A -> Bytes) (fn (_e : A -> Bytes) is Bytes -> Result A ParseErr end) e d
  end
end
instance binWhole : Binary Whole is mkBinary Whole encodeWhole parseWhole end
instance binInt   : Binary Int   is mkBinary Int   encodeInt   parseInt   end
instance binFrac  : Binary Frac  is mkBinary Frac  encodeFrac  parseFrac  end

encode : {A : U} -> {d : Binary A} -> A -> Bytes is
  fn {A : U} {d : Binary A} (x : A) is (d.1) x end
end
decode : {A : U} -> {d : Binary A} -> Bytes -> Result A ParseErr is
  fn {A : U} {d : Binary A} (s : Bytes) is (d.2) s end
end

-- round-trip witnesses (decode after encode): the "only better" guarantee, shown
-- COMPUTING on concrete values (the encoders/parsers reduce, so these are refl).
roundWhole : Whole -> Result Whole ParseErr is fn (n : Whole) is parseWhole (encodeWhole n) end end
roundInt   : Int   -> Result Int   ParseErr is fn (i : Int)   is parseInt   (encodeInt   i) end end
roundFrac  : Frac  -> Result Frac  ParseErr is fn (f : Frac)  is parseFrac  (encodeFrac  f) end end

-- Proof-carrying round-trips: decode-after-encode is the identity, MACHINE-CHECKED
-- by refl (it computes) — the "only better than a partial read" guarantee, on
-- concrete values; and a malformed token decodes to exactly the right error, not a
-- crash. These elaborate at prelude load, so they are a standing regression gate.
rtWhole : Eq (Result Whole ParseErr) (roundWhole 42) (ok Whole ParseErr 42) is
  refl (ok Whole ParseErr 42)
end
rtInt : Eq (Result Int ParseErr) (roundInt (negsucc 4)) (ok Int ParseErr (negsucc 4)) is
  refl (ok Int ParseErr (negsucc 4))
end
rtFrac : Eq (Result Frac ParseErr) (roundFrac (frac false 3 4)) (ok Frac ParseErr (frac false 3 4)) is
  refl (ok Frac ParseErr (frac false 3 4))
end
rtBad : Eq (Result Whole ParseErr) (parseWhole "9z") (err Whole ParseErr notNumber) is
  refl (err Whole ParseErr notNumber)
end

-- ====================================================================
-- UNICODE: explicit levels (Rust-style). The DEFAULT level is BYTES — `strLen`/
-- `strHead` above are UTF-8 bytes, matching the packed representation. This section
-- adds the RUNE (codepoint) level: `runeLen` counts Unicode scalar values by skipping
-- UTF-8 continuation bytes (0x80..0xBF), so `runeLen "é" = 1` while `strLen "é" = 2`.
-- (GRAPHEME clusters — the user-perceived-character level — need Unicode tables and are
-- future work; PARKING-LOT.) Fuel-bounded by byte length, never the packed code.
-- ====================================================================

-- a byte is a UTF-8 CONTINUATION byte iff 128 <= b <= 191 (it is not a scalar's leader).
isCont : Whole -> Bool is fn (c : Whole) is andB (leW 128 c) (leW c 191) end end

runeLenGo : Whole -> Whole -> Bytes -> Whole is
  fn (fuel : Whole) is
    WholeElim (fn (k : Whole) is Whole -> Bytes -> Whole end)
      (fn (acc : Whole) (s : Bytes) is acc end)
      (fn (f : Whole) (ih : Whole -> Bytes -> Whole) is
        fn (acc : Whole) (s : Bytes) is
          case strNull s of
          | true  -> acc
          | false ->
              case isCont (strHead s) of
              | true  -> ih acc (strTail s)
              | false -> ih (addW acc 1) (strTail s)
              end
          end
        end
      end)
      fuel
  end
end
-- codepoint length: the number of Unicode scalar values (leading bytes) in the string.
runeLen : Bytes -> Whole is fn (s : Bytes) is runeLenGo strFuel 0 s end end

-- ====================================================================
-- SHOW: render any value to a string, the basis of string interpolation `"{e}"`
-- (which desugars to `++` over `show`). For the numeric tower it reuses the Binary
-- encoders; a string shows as itself; a Bool shows as its word. Same Σ-record-class +
-- instance-search pattern as Semiring/Magma.
-- ====================================================================
Show : U -> U is fn (A : U) is A -> Bytes end end
show : {A : U} -> {d : Show A} -> A -> Bytes is fn {A : U} {d : Show A} (x : A) is d x end end

instance showWhole : Show Whole is encodeWhole end
instance showInt   : Show Int   is encodeInt end
instance showFrac  : Show Frac  is encodeFrac end
instance showBytes : Show Bytes is fn (s : Bytes) is s end end
instance showBool  : Show Bool  is fn (b : Bool) is case b of | true -> "true" | false -> "false" end end end

-- ====================================================================
-- SLICING: take/drop the first n bytes (Swift Substring / Rust slice, at the byte level).
-- Fuel-bounded by byte length; `strTake`/`strDrop` partition a string at a byte offset.
-- ====================================================================
strTakeGo : Whole -> Bytes -> Bytes is
  fn (n : Whole) is
    WholeElim (fn (k : Whole) is Bytes -> Bytes end)
      (fn (s : Bytes) is bytes 1 end)
      (fn (k : Whole) (ih : Bytes -> Bytes) is
        fn (s : Bytes) is
          case strNull s of
          | true  -> bytes 1
          | false -> strCons (strHead s) (ih (strTail s))
          end
        end
      end)
      n
  end
end
-- the first n bytes (or the whole string if shorter).
strTake : Whole -> Bytes -> Bytes is fn (n : Whole) (s : Bytes) is strTakeGo n s end end

strDropGo : Whole -> Bytes -> Bytes is
  fn (n : Whole) is
    WholeElim (fn (k : Whole) is Bytes -> Bytes end)
      (fn (s : Bytes) is s end)
      (fn (k : Whole) (ih : Bytes -> Bytes) is
        fn (s : Bytes) is
          case strNull s of
          | true  -> s
          | false -> ih (strTail s)
          end
        end
      end)
      n
  end
end
-- all but the first n bytes (or the empty string if shorter).
strDrop : Whole -> Bytes -> Bytes is fn (n : Whole) (s : Bytes) is strDropGo n s end end

-- ====================================================================
-- Option: a standard maybe type. Constructor order matches the primName
-- encoding: tag 0 = none (1 arg, the erased type A), tag 1 = some (2 args,
-- type A + value). This order is load-bearing for parseFloat/Option Float.
-- ====================================================================
data Option : U -> U is
  none : (A : U) -> Option A
| some : (A : U) -> A -> Option A
end

-- ====================================================================
-- Std.Float: machine-float (f64) IO and arithmetic. Names declared as
-- foreign inside the module so primName (last segment) resolves to the
-- same ioPrims keys as bare foreign declarations.
-- fromNat accepts Whole (the builtin-nat type) so numeric literals like 2
-- elaborate to Whole and fromNat 2 type-checks without a cast.
-- parseFloat accepts a packed-string Nat (same encoding as Bytes/codeOf).
-- ====================================================================
module Std.Float is
  foreign Float : U end
  foreign fromNat : Whole -> Float end
  foreign fadd : Float -> Float -> Float end
  foreign fsub : Float -> Float -> Float end
  foreign fmul : Float -> Float -> Float end
  foreign fdiv : Float -> Float -> Float end
  foreign parseFloat : Whole -> Option Float end
  foreign getFloat : IO Float end
  foreign printFloat : Float -> IO Float end
end
